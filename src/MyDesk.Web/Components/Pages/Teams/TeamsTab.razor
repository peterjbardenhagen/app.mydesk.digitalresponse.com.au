@page "/teams/tab"
@page "/teams/tab/configure"
@attribute [Authorize]
@inject NavigationManager Nav
@inject PlatformSettingsService PlatformSettings

@* Teams tab wrapper — renders inside the Teams iframe.
   The "page" query param controls which MyDesk section is shown.
   Configure tab: /teams/tab/configure (handled by Teams configuration page below). *@

@if (_isConfigurePage)
{
    <div style="padding:32px; font-family:system-ui,sans-serif;">
        <h2 style="margin-bottom:16px;">Configure MyDesk Tab</h2>
        <p>Choose which MyDesk module to show in this tab:</p>
        <select id="pageSelect" style="padding:8px 12px;font-size:14px;border-radius:6px;border:1px solid #ccc;margin-top:8px;">
            <option value="dashboard">Dashboard</option>
            <option value="timesheets">Timesheets</option>
            <option value="askai">Ask AI</option>
            <option value="approvals">Pending Approvals</option>
        </select>
        <br /><br />
        <button onclick="saveConfig()" style="padding:10px 20px;background:#1e40af;color:#fff;border:none;border-radius:6px;cursor:pointer;font-size:14px;">
            Save
        </button>
    </div>

    <script>
        // Register with Teams SDK to enable the "Save" button and provide config
        microsoftTeams.pages.config.registerOnSaveHandler(function(saveEvent) {
            var page = document.getElementById('pageSelect').value;
            microsoftTeams.pages.config.setConfig({
                websiteUrl: '@Nav.BaseUri'.replace(/\/$/, '') + '/' + page,
                contentUrl: '@Nav.BaseUri'.replace(/\/$/, '') + '/teams/tab?page=' + page,
                entityId: page,
                suggestedDisplayName: 'MyDesk ' + page.charAt(0).toUpperCase() + page.slice(1)
            });
            saveEvent.notifySuccess();
        });
        microsoftTeams.pages.config.setValidityState(true);
    </script>
}
else
{
    @* Redirect to the real page — inside Teams the iframe shows the full app *@
    var targetPath = _page switch
    {
        "timesheets" => "/timesheets",
        "askai"      => "/ask-ai",
        "approvals"  => "/approvals/pending",
        "legal"      => "/legal",
        _            => "/"
    };
    Nav.NavigateTo(targetPath, replace: true);
}

@code {
    [SupplyParameterFromQuery(Name = "page")]
    public string? Page { get; set; }

    private string _page = "dashboard";
    private bool _isConfigurePage;

    protected override void OnParametersSet()
    {
        _isConfigurePage = Nav.Uri.Contains("/teams/tab/configure");
        _page = Page ?? "dashboard";
    }
}
