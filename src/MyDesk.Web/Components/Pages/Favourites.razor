@page "/favourites"
@attribute [Authorize]
@inject FavouritesService FavouritesSvc
@inject NavigationManager Nav
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

<PageTitle>Favourites - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span>Favourites</span>
        </div>
        <h1>Favourites</h1>
        <p class="tl-subtitle">Your bookmarked quotes, invoices, contacts, and more.</p>
    </div>
</div>

@if (_items == null)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else if (!_items.Any())
{
    <MudPaper Class="pa-8 text-center" Elevation="0">
        <MudIcon Icon="@Icons.Material.Rounded.StarOutline" Size="Size.Large" Class="mb-4" Style="color:var(--gray-400);" />
        <MudText Typo="Typo.h6" Class="mb-2">No favourites yet</MudText>
        <MudText Class="mb-4" Style="color:var(--gray-500);">Bookmark quotes, invoices, or contacts using the star icon on those pages.</MudText>
    </MudPaper>
}
else
{
    <MudPaper Class="pa-0">
        <MudDataGrid T="FavouriteItem" Items="_items" Dense="true" Hover="true" Elevation="0" Class="tl-compact-grid">
            <Columns>
                <TemplateColumn Title="Type" CellStyle="width:60px;">
                    <CellTemplate>
                        <MudIcon Icon="@($"@Icons.Material.Rounded.{context.Item.GetIcon()}")" Size="Size.Small" Color="Color.Primary" />
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.EntityType" Title="Type" CellStyle="width:100px;" />
                <TemplateColumn Title="Name">
                    <CellTemplate>
                        <MudLink Href="@context.Item.GetRoute()" Color="Color.Primary">
                            @context.Item.EntityName
                        </MudLink>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.Notes" Title="Notes" />
                <PropertyColumn Property="x => x.CreatedAt" Title="Added" Format="yyyy-MM-dd" CellStyle="width:100px;" />
                <TemplateColumn Title="Actions" CellStyle="width:80px;" Sortable="false">
                    <CellTemplate>
                        <div class="d-flex gap-1">
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                        OnClick="@(() => RemoveFavourite(context.Item))" />
                        </div>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<FavouriteItem>? _items;
    private string _userCode = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userCode = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        _items = await FavouritesSvc.GetUserFavouritesAsync(_userCode);
    }

    private async Task RemoveFavourite(FavouriteItem item)
    {
        var parameters = new DialogParameters
        {
            { nameof(MudMessageBox.Message), $"Remove {item.EntityType} '{item.EntityName}' from favourites?" },
            { nameof(MudMessageBox.YesText), "Remove" },
            { nameof(MudMessageBox.NoText), string.Empty },
            { nameof(MudMessageBox.CancelText), "Cancel" }
        };
        var result = await Dialog.ShowAsync<MudMessageBox>("Remove Favourite", parameters);
        bool? ok = (await result.Result)?.Data as bool?;
        if (ok != true) return;

        await FavouritesSvc.RemoveFavouriteAsync(_userCode, item.EntityType, item.EntityId);
        _items = await FavouritesSvc.GetUserFavouritesAsync(_userCode);
        Snackbar.Add("Removed from favourites.", Severity.Success);
    }
}


