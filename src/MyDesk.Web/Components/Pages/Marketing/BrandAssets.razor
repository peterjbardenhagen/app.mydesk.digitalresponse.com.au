@page "/marketing/brand-assets"
@attribute [Authorize]
@inject BrandAssetService Service
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService

<PageTitle>Brand Assets - DR MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <MudLink Href="/marketing" Underline="Underline.None">Marketing</MudLink>
            <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Size="Size.Small" />
            <span>Brand Assets</span>
        </div>
        <h1 class="tl-page-title">
            <MudIcon Icon="@Icons.Material.Rounded.Business" Class="mr-2" Style="color: var(--tl-accent)" />
            Brand Assets
        </h1>
        <div class="tl-page-sub">Logos, brand guidelines, company profile, email signatures — download the full kit.</div>
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else
{
    @* Primary Brand Assets *@
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">Brand Assets</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                   StartIcon="@Icons.Material.Rounded.Add"
                   OnClick="ShowUploadDialog">Upload Asset</MudButton>
    </div>
    <div class="tl-mkt-grid mb-6">
        @foreach (var asset in _brandAssets)
        {
            <MudCard Elevation="0" Outlined="true" Class="tl-asset-card">
                <MudCardContent Class="d-flex flex-column pa-4">
                    <div class="d-flex align-center gap-3 mb-3">
                        <div class="tl-asset-icon">
                            <MudIcon Icon="@GetIconForCategory(asset.Category)" Size="Size.Large" />
                        </div>
                        <div class="flex-grow-1">
                            <MudText Typo="Typo.h6" Class="mb-1">@asset.OriginalFileName</MudText>
                            <MudText Typo="Typo.caption" Style="color: var(--gray-500);">
                                @asset.Category @(asset.FileSize > 0 ? $"• {FormatFileSize(asset.FileSize)}" : "")
                            </MudText>
                        </div>
                        <div class="d-flex gap-1">
                            <MudIconButton Icon="@Icons.Material.Rounded.Download" Size="Size.Small" 
                                          Href="@GetAssetUrl(asset)" Target="_blank" Color="Color.Primary" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" 
                                          OnClick="() => DeleteAsset(asset)" Color="Color.Error" />
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(asset.Description))
                    {
                        <MudText Typo="Typo.body2" Style="color: var(--gray-600);">
                            @asset.Description
                        </MudText>
                    }
                    <MudText Typo="Typo.caption" Style="color: var(--gray-400);" Class="mt-2">
                        Uploaded @asset.UploadedAt.ToString("g") by @asset.UploadedBy
                    </MudText>
                </MudCardContent>
            </MudCard>
        }
        @if (!_brandAssets.Any())
        {
            <MudPaper Elevation="0" Outlined="true" Class="pa-8 text-center">
                <MudIcon Icon="@Icons.Material.Rounded.CloudUpload" Size="Size.Large" Color="Color.Default" Class="mb-4" Style="opacity:0.5;" />
                <MudText Typo="Typo.h6" Class="mb-2">No Brand Assets Yet</MudText>
                <MudText Typo="Typo.body2" Style="color: var(--gray-500);" Class="mb-4">
                    Upload your first brand asset to get started.
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" 
                           StartIcon="@Icons.Material.Rounded.Add"
                           OnClick="ShowUploadDialog">Upload Asset</MudButton>
            </MudPaper>
        }
    </div>

    @* Important Files & Links Section *@
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h6">Important Links</MudText>
        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                   StartIcon="@Icons.Material.Rounded.Add"
                   OnClick="ShowAddLinkDialog">Add Link</MudButton>
    </div>
    <MudCard Elevation="0" Outlined="true">
        <MudCardContent>
            <MudGrid Spacing="3">
                @foreach (var link in _importantLinks)
                {
                    <MudItem xs="12" md="6" lg="4">
                        <div class="d-flex align-center gap-3 p-3 tl-important-link-card">
                            <MudIcon Icon="@GetIconForLink(link.Icon)" Color="link.IsExternal ? Color.Primary : Color.Default" />
                            <div class="flex-grow-1">
                                <MudText Typo="Typo.body1" Style="font-weight: 500;">@link.Title</MudText>
                                <MudText Typo="Typo.caption" Style="color: var(--gray-500);">@link.Description</MudText>
                            </div>
                            <div class="d-flex gap-1">
                                <MudIconButton Icon="@Icons.Material.Rounded.OpenInNew" Size="Size.Small" 
                                              Href="@link.Url" Target="_blank" />
                                <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" 
                                              OnClick="() => DeleteLink(link)" Color="Color.Error" />
                            </div>
                        </div>
                    </MudItem>
                }
                @if (!_importantLinks.Any())
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.body2" Style="color: var(--gray-500);" Class="text-center pa-4">
                            No important links configured. Click "Add Link" to create one.
                        </MudText>
                    </MudItem>
                }
            </MudGrid>
        </MudCardContent>
    </MudCard>

    @* Additional Resources *@
    <MudText Typo="Typo.h6" Class="mb-4 mt-6">Additional Resources</MudText>
    <div class="tl-mkt-grid">
        <MudCard Elevation="0" Outlined="true">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Primary">
                        <MudIcon Icon="@Icons.Material.Rounded.Palette" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.subtitle1">Colour Palette</MudText>
                    <MudText Typo="Typo.caption">Official brand colours</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex gap-2 flex-wrap">
                    <div class="d-flex align-center gap-2">
                        <div style="width: 24px; height: 24px; background: #ff6b35; border-radius: 4px;"></div>
                        <MudText Typo="Typo.caption">Primary #ff6b35</MudText>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <div style="width: 24px; height: 24px; background: #004e89; border-radius: 4px;"></div>
                        <MudText Typo="Typo.caption">Secondary #004e89</MudText>
                    </div>
                    <div class="d-flex align-center gap-2">
                        <div style="width: 24px; height: 24px; background: #1a1a2e; border-radius: 4px;"></div>
                        <MudText Typo="Typo.caption">Dark #1a1a2e</MudText>
                    </div>
                </div>
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="0" Outlined="true">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Secondary">
                        <MudIcon Icon="@Icons.Material.Rounded.FontDownload" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.subtitle1">Typography</MudText>
                    <MudText Typo="Typo.caption">Official brand fonts</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex flex-column gap-2">
                    <div>
                        <MudText Typo="Typo.body2" Style="font-family: 'Inter', sans-serif; font-weight: 600;">Inter</MudText>
                        <MudText Typo="Typo.caption">Headings & UI</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.body2" Style="font-family: 'Open Sans', sans-serif;">Open Sans</MudText>
                        <MudText Typo="Typo.caption">Body text</MudText>
                    </div>
                </div>
            </MudCardContent>
        </MudCard>

        <MudCard Elevation="0" Outlined="true">
            <MudCardHeader>
                <CardHeaderAvatar>
                    <MudAvatar Color="Color.Tertiary">
                        <MudIcon Icon="@Icons.Material.Rounded.ContactMail" />
                    </MudAvatar>
                </CardHeaderAvatar>
                <CardHeaderContent>
                    <MudText Typo="Typo.subtitle1">Contact Details</MudText>
                    <MudText Typo="Typo.caption">For brand enquiries</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex flex-column gap-1">
                    <MudText Typo="Typo.body2">marketing@techlight.com.au</MudText>
                    <MudText Typo="Typo.caption">1300 DR MYDESK</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </div>

<style>
    .tl-important-link-card { background: var(--gray-50); border-radius: 8px; border: 1px solid transparent; }
    body.mud-dark-mode .tl-important-link-card { background: var(--gray-100); border-color: var(--gray-300); }
</style>
}

@code {
    private bool _loading = true;
    private List<BrandAssetFile> _brandAssets = new();
    private List<ImportantLink> _importantLinks = new();
    private string? _userCode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            _userCode = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

            await LoadDataAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        _brandAssets = await Task.Run(() => Service.GetAllAssets());
        _importantLinks = await Task.Run(() => Service.GetImportantLinks());
    }

    private string GetIconForCategory(string category) => category.ToLower() switch
    {
        "logos" or "logo" => Icons.Material.Rounded.Image,
        "guidelines" => Icons.Material.Rounded.MenuBook,
        "profile" => Icons.Material.Rounded.Business,
        "signature" => Icons.Material.Rounded.AlternateEmail,
        "document" or "documents" => Icons.Material.Rounded.Description,
        "image" or "images" => Icons.Material.Rounded.PhotoLibrary,
        _ => Icons.Material.Rounded.AttachFile
    };

    private string GetIconForLink(string iconName) => iconName?.ToLower() switch
    {
        "analytics" => Icons.Material.Rounded.Analytics,
        "facebook" => Icons.Custom.Brands.Facebook,
        "language" or "web" or "website" => Icons.Material.Rounded.Public,
        "help" => Icons.Material.Rounded.Help,
        "releases" or "new" => Icons.Material.Rounded.NewReleases,
        _ => Icons.Material.Rounded.Link
    };

    private string GetAssetUrl(BrandAssetFile asset)
    {
        return $"/brand-assets/{asset.FilePath}";
    }

    private string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private async Task ShowUploadDialog()
    {
        var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<UploadAssetDialog>("Upload Brand Asset", options);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            await LoadDataAsync();
            Snackbar.Add("Asset uploaded successfully!", Severity.Success);
        }
    }

    private async Task DeleteAsset(BrandAssetFile asset)
    {
        var parameters = new DialogParameters
        {
            { nameof(MudMessageBox.Message), $"Are you sure you want to delete '{asset.OriginalFileName}'?" },
            { nameof(MudMessageBox.YesText), "Delete" },
            { nameof(MudMessageBox.NoText), string.Empty },
            { nameof(MudMessageBox.CancelText), "Cancel" }
        };
        var confirmResult = await DialogService.ShowAsync<MudMessageBox>("Confirm Delete", parameters);
        var confirm = (await confirmResult.Result)?.Data is true;

        if (confirm)
        {
            await Service.DeleteAsync(asset.Id, _userCode ?? "Unknown");
            await LoadDataAsync();
            Snackbar.Add("Asset deleted successfully!", Severity.Success);
        }
    }

    private async Task ShowAddLinkDialog()
    {
        var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<AddEditLinkDialog>("Add Link", options);
        var result = await dialog.Result;
        if (result != null && !result.Canceled)
        {
            await LoadDataAsync();
            Snackbar.Add("Link added successfully!", Severity.Success);
        }
    }

    private async Task DeleteLink(ImportantLink link)
    {
        var parameters = new DialogParameters
        {
            { nameof(MudMessageBox.Message), $"Are you sure you want to delete the link '{link.Title}'?" },
            { nameof(MudMessageBox.YesText), "Delete" },
            { nameof(MudMessageBox.NoText), string.Empty },
            { nameof(MudMessageBox.CancelText), "Cancel" }
        };
        var confirmResult = await DialogService.ShowAsync<MudMessageBox>("Confirm Delete", parameters);
        var confirm = (await confirmResult.Result)?.Data is true;

        if (confirm == true)
        {
            // Remove link from settings
            var links = Service.GetImportantLinks();
            links.RemoveAll(l => l.Id == link.Id);
            Service.SaveImportantLinks(links);
            await LoadDataAsync();
            Snackbar.Add("Link deleted successfully!", Severity.Success);
        }
    }
}


