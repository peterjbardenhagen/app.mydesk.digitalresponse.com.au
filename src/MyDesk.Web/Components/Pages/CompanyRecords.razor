@page "/company-records/{CompanyId:int}"
@attribute [Authorize]
@inject InvoiceService InvoiceService
@inject QuoteService QuoteService
@inject PurchaseOrderService PurchaseOrderService
@inject CompanyService CompanyService
@inject NavigationManager Nav

<PageTitle>Company Records</PageTitle>

@if (_company == null)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold">@_company.CompanyName</MudText>
            <MudText Typo="Typo.body2" Class="text-muted">All related MyDesk records</MudText>
        </div>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/contacts"))">
            Back to Contacts
        </MudButton>
    </div>

    <MudTabs>
        <MudTabPanel Text="@($"Invoices ({_invoices?.Count ?? 0})")" Icon="@Icons.Material.Rounded.Receipt">
            @if (_invoices?.Count > 0)
            {
                <MudTable Items="_invoices" Hover="true" Dense="true" Striped="true" Class="mt-4">
                    <HeaderContent>
                        <MudTh>Invoice No.</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Amount</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.InvoiceNum</MudTd>
                        <MudTd>@context.InvoiceDate.ToString("MMM dd, yyyy")</MudTd>
                        <MudTd>@context.NettPriceTotal.ToString("C")</MudTd>
                        <MudTd>@context.StatusName</MudTd>
                        <MudTd>
                            <MudLink Href="@($"/invoices/{context.InvoiceId}")">View</MudLink>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-4">
                    No invoices found for this company.
                </MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Quotes ({_quotes?.Count ?? 0})")" Icon="@Icons.Material.Rounded.Assignment">
            @if (_quotes?.Count > 0)
            {
                <MudTable Items="_quotes" Hover="true" Dense="true" Striped="true" Class="mt-4">
                    <HeaderContent>
                        <MudTh>Reference</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Amount</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Reference</MudTd>
                        <MudTd>@context.QuoteDate.ToString("MMM dd, yyyy")</MudTd>
                        <MudTd>@context.NettPriceTotal.ToString("C")</MudTd>
                        <MudTd>@context.QuoteStatus</MudTd>
                        <MudTd>
                            <MudLink Href="@($"/quotes/{context.Qid}")">View</MudLink>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-4">
                    No quotes found for this company.
                </MudAlert>
            }
        </MudTabPanel>

        <MudTabPanel Text="@($"Purchase Orders ({_purchaseOrders?.Count ?? 0})")" Icon="@Icons.Material.Rounded.ShoppingCart">
            @if (_purchaseOrders?.Count > 0)
            {
                <MudTable Items="_purchaseOrders" Hover="true" Dense="true" Striped="true" Class="mt-4">
                    <HeaderContent>
                        <MudTh>Project</MudTh>
                        <MudTh>Date</MudTh>
                        <MudTh>Amount</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.Project</MudTd>
                        <MudTd>@context.PODate.ToString("MMM dd, yyyy")</MudTd>
                        <MudTd>@context.PriceIncTotal.ToString("C")</MudTd>
                        <MudTd>@context.StatusName</MudTd>
                        <MudTd>
                            <MudLink Href="@($"/purchase-orders/{context.POid}")">View</MudLink>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-4">
                    No purchase orders found for this company.
                </MudAlert>
            }
        </MudTabPanel>
    </MudTabs>
}

@code {
    [Parameter] public int CompanyId { get; set; }
    private Company? _company;
    private List<Invoice>? _invoices;
    private List<Quote>? _quotes;
    private List<PurchaseOrder>? _purchaseOrders;

    protected override async Task OnInitializedAsync()
    {
        _company = await CompanyService.GetCompanyAsync(CompanyId);
        if (_company != null)
        {
            await LoadRecordsAsync();
        }
    }

    private async Task LoadRecordsAsync()
    {
        try
        {
            _invoices = await InvoiceService.GetInvoicesAsync(customer: _company!.CompanyName, limit: 500) ?? new();
            _quotes = await QuoteService.GetQuotesAsync(null, null, _company.CompanyName, null, 0, null) ?? new();
            _purchaseOrders = await PurchaseOrderService.GetPurchaseOrdersAsync(null, null, _company.CompanyName, 0, limit: 500) ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading company records: {ex.Message}");
        }
    }
}
