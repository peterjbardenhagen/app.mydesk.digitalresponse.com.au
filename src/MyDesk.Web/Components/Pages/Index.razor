@page "/"
@using MudBlazor
@attribute [Authorize]
@inject DashboardService DashboardService
@inject AuthenticationStateProvider AuthStateProvider
@inject IDialogService DialogService
@inject PlatformSettingsService PlatformSettings

<PageTitle>Dashboard - @PlatformSettings.GetBrandingName()</PageTitle>

@* ── Mobile Quick-Launch (phones only, shown above the full dashboard) ──────── *@
<div class="tl-mobile-quicklaunch d-block d-sm-none">
    <div class="tl-mql-greeting">Good @TimeOfDayGreeting(), @FirstName(_userName)</div>
    <div class="tl-mql-question">What do you want to do today?</div>
    <div class="tl-mql-grid">
        <a href="/ask-ai" class="tl-mql-tile tl-mql-ai">
            <div class="tl-mql-icon"><MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" Size="Size.Large" /></div>
            <div class="tl-mql-label">MyDesk AI</div>
            <div class="tl-mql-hint">Ask anything</div>
        </a>
        <a href="/quotes/create" class="tl-mql-tile">
            <div class="tl-mql-icon"><MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="Size.Large" /></div>
            <div class="tl-mql-label">New Quote</div>
            <div class="tl-mql-hint">Create quotation</div>
        </a>
        <a href="/invoices/create" class="tl-mql-tile">
            <div class="tl-mql-icon"><MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="Size.Large" /></div>
            <div class="tl-mql-label">New Invoice</div>
            <div class="tl-mql-hint">Bill for services</div>
        </a>
        <a href="/contacts" class="tl-mql-tile">
            <div class="tl-mql-icon"><MudIcon Icon="@Icons.Material.Rounded.People" Size="Size.Large" /></div>
            <div class="tl-mql-label">Contacts</div>
            <div class="tl-mql-hint">Customers &amp; suppliers</div>
        </a>
        <a href="/expenses" class="tl-mql-tile">
            <div class="tl-mql-icon"><MudIcon Icon="@Icons.Material.Rounded.Receipt" Size="Size.Large" /></div>
            <div class="tl-mql-label">Expenses</div>
            <div class="tl-mql-hint">Claims &amp; receipts</div>
        </a>
        <a href="/purchase-orders" class="tl-mql-tile">
            <div class="tl-mql-icon"><MudIcon Icon="@Icons.Material.Rounded.ShoppingCart" Size="Size.Large" /></div>
            <div class="tl-mql-label">Purchase Orders</div>
            <div class="tl-mql-hint">Manage POs</div>
        </a>
    </div>
</div>

@* ── Enterprise Dashboard Header ──────────────────────────────────────────── *@
<div class="tl-dashboard-header">
    <div class="tl-dashboard-header-bg">
        <div class="tl-header-swoosh"></div>
        <div class="tl-header-glow"></div>
    </div>
    <div class="tl-dashboard-header-content">
        <div class="tl-dashboard-welcome">
            <div class="tl-welcome-badge">
                <MudIcon Icon="@Icons.Material.Rounded.Dashboard" Size="Size.Small" />
                <span>Executive Dashboard</span>
            </div>
            <h1 class="tl-welcome-title">Welcome back, @FirstName(_userName)</h1>
            <p class="tl-welcome-subtitle">
                Real-time business intelligence for @PlatformSettings.GetBrandingName().
                @if (_isDirectorOrAdmin)
                {
                    <span>Accessing company analytics and team performance metrics. <strong>It's like having your own MBA in your pocket advising and coaching you towards your goals and increased profitability.</strong></span>
                }
                else
                {
                    <span>Viewing your personal performance metrics.</span>
                }
            </p>
        </div>
        <div class="tl-dashboard-actions">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Href="/quotes/create"
                       StartIcon="@Icons.Material.Rounded.Add"
                       Class="tl-action-btn">
                New Quote
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Href="/admin/setup"
                       StartIcon="@Icons.Material.Rounded.Settings"
                       Class="tl-action-btn-secondary">
                Settings
            </MudButton>
        </div>
    </div>
</div>

@if (_metrics == null)
{
    <div class="tl-loading-container">
        <div class="tl-loading-content">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-4" Style="color: var(--gray-500);">Loading business intelligence...</MudText>
        </div>
    </div>
}
else
{
    @* ── Executive KPI Cards ──────────────────────────────────────────────────── *@
    <div class="tl-kpi-section">
        <div class="tl-kpi-grid">
            @* Revenue Card *@
            <a href="@($"/invoices?filter={_chartPeriod.ToString().ToLower()}")" class="tl-kpi-card tl-kpi-revenue">
                <div class="tl-kpi-header">
                    <div class="tl-kpi-icon-wrap gold">
                        <MudIcon Icon="@Icons.Material.Rounded.AttachMoney" Size="Size.Medium" />
                    </div>
                    <div class="tl-kpi-trend @GetTrendClass(_metrics.ThisMonthVsLastMonthPercent)">
                        <MudIcon Icon="@GetTrendIcon(_metrics.ThisMonthVsLastMonthPercent)" Size="Size.Small" />
                        <span>@Math.Abs(_metrics.ThisMonthVsLastMonthPercent).ToString("N1")%</span>
                    </div>
                </div>
                <div class="tl-kpi-body">
                    <div class="tl-kpi-value">@Fmt(_metrics.ThisMonthInvoiceValue)</div>
                    <div class="tl-kpi-label">Revenue</div>
                </div>
                <div class="tl-kpi-footer">
                    <span>@_metrics.ThisMonthInvoices invoices</span>
                    <span class="tl-kpi-divider">|</span>
                    <span>YTD: @Fmt(_metrics.YtdInvoiceValue)</span>
                </div>
                <div class="tl-kpi-glow"></div>
            </a>

            @* Quotes Card *@
            <a href="@($"/quotes?filter={_chartPeriod.ToString().ToLower()}")" class="tl-kpi-card tl-kpi-quotes">
                <div class="tl-kpi-header">
                    <div class="tl-kpi-icon-wrap teal">
                        <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="Size.Medium" />
                    </div>
                    <div class="tl-kpi-trend @GetTrendClass(_metrics.ThisMonthQuotesWon - _metrics.LastMonthQuotesWon)">
                        <MudIcon Icon="@GetTrendIcon(_metrics.ThisMonthQuotesWon - _metrics.LastMonthQuotesWon)" Size="Size.Small" />
                        <span>@_metrics.ThisMonthQuotes quotes</span>
                    </div>
                </div>
                <div class="tl-kpi-body">
                    <div class="tl-kpi-value">@Fmt(_metrics.ThisMonthQuotesWon)</div>
                    <div class="tl-kpi-label">Quotes Accepted</div>
                </div>
                <div class="tl-kpi-footer">
                    <span>@_metrics.QuoteToInvoiceConversionRate.ToString("N1")% conversion</span>
                    <span class="tl-kpi-divider">|</span>
                    <span>Pipeline: @Fmt(_metrics.PipelineValue)</span>
                </div>
                <div class="tl-kpi-glow"></div>
            </a>

            @* Profit Margin Card *@
            <div class="tl-kpi-card tl-kpi-margin">
                <div class="tl-kpi-header">
                    <div class="tl-kpi-icon-wrap success">
                        <MudIcon Icon="@Icons.Material.Rounded.PieChart" Size="Size.Medium" />
                    </div>
                    <div class="tl-kpi-status @GetMarginStatusClass(_metrics.GrossProfitMargin)">
                        @GetMarginStatusText(_metrics.GrossProfitMargin)
                    </div>
                </div>
                <div class="tl-kpi-body">
                    <div class="tl-kpi-value">@_metrics.GrossProfitMargin.ToString("N1")%</div>
                    <div class="tl-kpi-label">Gross Profit Margin</div>
                </div>
                <div class="tl-kpi-footer">
                    <span>Avg Quote: @Fmt(_metrics.AverageQuoteValue)</span>
                    <span class="tl-kpi-divider">|</span>
                    <span>Avg Invoice: @Fmt(_metrics.AverageInvoiceValue)</span>
                </div>
                <div class="tl-kpi-glow"></div>
            </div>

            @* Health Score Card *@
            <div class="tl-kpi-card tl-kpi-health @GetHealthCardClass(_metrics.OverallHealthScore)" @onclick="ShowHealthRecommendations" style="cursor: pointer;">
                <div class="tl-kpi-header">
                    <div class="tl-kpi-icon-wrap @GetHealthIconClass(_metrics.OverallHealthScore)">
                        <MudIcon Icon="@Icons.Material.Rounded.HealthAndSafety" Size="Size.Medium" />
                    </div>
                    @if (HealthItemCount > 0)
                    {
                        <div class="tl-kpi-badge warning">
                            <MudIcon Icon="@Icons.Material.Rounded.Warning" Size="Size.Small" />
                            <span>@HealthItemCount</span>
                        </div>
                    }
                </div>
                <div class="tl-kpi-body">
                    <div class="tl-kpi-value">@_metrics.OverallHealthScore</div>
                    <div class="tl-kpi-label">Business Health Score</div>
                </div>
                <div class="tl-kpi-footer">
                    <span>@GetHealthStatusText(_metrics.OverallHealthScore)</span>
                    @if (HealthItemCount > 0)
                    {
                        <span class="tl-kpi-divider">|</span>
                        <span>@HealthItemCount items</span>
                    }
                </div>
                <div class="tl-kpi-glow"></div>
            </div>
        </div>
    </div>

    @* ── Dashboard Header with Time Period Selector ─────────────────────────── *@
    <div class="tl-dashboard-period-selector">
        <div class="tl-period-label">Time Period:</div>
        <MudSelect T="ChartPeriod" Variant="Variant.Outlined" Dense="true" Class="tl-period-select" Value="_chartPeriod" ValueChanged="SelectPeriodAsync">
            @foreach (var period in _periodOptions)
            {
                <MudSelectItem T="ChartPeriod" Value="@period.Key">@period.Value</MudSelectItem>
            }
        </MudSelect>
    </div>

    @* ── Dashboard Carousel (Business Intelligence) ─────────────────────────── *@
    <MudItem xs="12" Class="pa-0 mb-6">
        <DashboardCarousel Metrics="_metrics" IsDirector="_isDirectorOrAdmin" UserCode="_userCode" ChartSeries="_chartSeries" XAxisLabels="_xAxisLabels" />
    </MudItem>

    @* ── Performance View Selector ─────────────────────────────────────────────── *@
    <MudItem xs="12" Class="pa-0 mb-6">
        <div class="tl-performance-selector">
            <div class="tl-selector-label">View Performance:</div>
            <MudSelect T="PerformanceView" Variant="Variant.Outlined" Dense="true" Class="tl-performance-select" Value="_performanceView" ValueChanged="OnPerformanceViewChanged">
                <MudSelectItem T="PerformanceView" Value="PerformanceView.Personal">Your Performance</MudSelectItem>
                <MudSelectItem T="PerformanceView" Value="PerformanceView.Company">Company Performance</MudSelectItem>
                <MudSelectItem T="PerformanceView" Value="PerformanceView.CompareUsers">Compare to Users</MudSelectItem>
            </MudSelect>
            @if (_performanceView == PerformanceView.CompareUsers && _isDirectorOrAdmin)
            {
                <MudSelect T="string" Variant="Variant.Outlined" Dense="true" Placeholder="Select user" Class="tl-user-select" Value="_selectedUserCode" ValueChanged="OnUserChanged">
                    @if (_metrics?.TeamMemberKPIs != null)
                    {
                        @foreach (var kpi in _metrics.TeamMemberKPIs.OrderBy(k => k.UserName))
                        {
                            <MudSelectItem T="string" Value="@kpi.UserCode">@kpi.UserName</MudSelectItem>
                        }
                    }
                </MudSelect>
            }
        </div>
    </MudItem>

    @* ── User KPI Card (Personal Performance) ───────────────────────────────── *@
    @if ((_userKpi != null || _myKpi != null) || _performanceView == PerformanceView.Company)
    {
        <MudItem xs="12" Class="pa-0 mb-6">
            <div class="tl-user-kpi-section">
                <div class="tl-section-header">
                    <div class="tl-section-icon @(_performanceView == PerformanceView.Company ? "company" : "personal")">
                        <MudIcon Icon="@(_performanceView == PerformanceView.Company ? Icons.Material.Rounded.Business : Icons.Material.Rounded.Person)" Size="Size.Medium" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h6" Class="tl-section-title">@GetPerformanceTitle()</MudText>
                        <MudText Typo="Typo.body2" Class="tl-section-subtitle">@GetPerformanceSubtitle()</MudText>
                    </div>
                </div>
                
                <MudGrid Spacing="4">
                    @if (_performanceView == PerformanceView.CompareUsers && _myKpi != null)
                    {
                        <MudItem xs="12">
                            <MudText Typo="Typo.subtitle2" Class="mb-3">Your Performance</MudText>
                            <div class="tl-user-kpi-grid">
                                @RenderUserKpiCards(_myKpi)
                            </div>
                        </MudItem>
                        @if (_userKpi != null)
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Class="mb-3">@_userKpi.UserName's Performance</MudText>
                                <div class="tl-user-kpi-grid">
                                    @RenderUserKpiCards(_userKpi)
                                </div>
                            </MudItem>
                        }
                    }
                    else if (_userKpi != null)
                    {
                        <MudItem xs="12">
                            <div class="tl-user-kpi-grid">
                                @RenderUserKpiCards(_userKpi)
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        </MudItem>
    }

    @* ── Warnings & Recommendations ─────────────────────────────────────────── *@
    @if (_metrics.Warnings?.Any() == true || _metrics.Recommendations?.Any() == true)
    {
        <MudGrid Spacing="4" Class="mt-4">
            @if (_metrics.Warnings?.Any() == true)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="tl-alerts-panel" Elevation="0">
                        <div class="tl-alerts-header warning">
                            <MudIcon Icon="@Icons.Material.Rounded.WarningAmber" Size="Size.Medium" />
                            <span>Business Alerts</span>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">
                                @_metrics.Warnings.Count
                            </MudChip>
                        </div>
                        <div class="tl-alerts-list">
                            @foreach (var warning in _metrics.Warnings.Take(3))
                            {
                                <div class="tl-alert-item @warning.Severity">
                                    <div class="tl-alert-icon">
                                        <MudIcon Icon="@(warning.Severity == "critical" ? Icons.Material.Rounded.Error : Icons.Material.Rounded.Warning)" 
                                                 Size="Size.Small" />
                                    </div>
                                    <div class="tl-alert-content">
                                        <div class="tl-alert-title">@warning.Title</div>
                                        <div class="tl-alert-desc">@warning.Description</div>
                                        <div class="tl-alert-metric">@warning.Metric: @warning.CurrentValue (threshold: @warning.Threshold)</div>
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Rounded.ArrowForward" 
                                                   Size="Size.Small"
                                                   Href="@warning.ActionLink"
                                                   Color="Color.Primary" />
                                </div>
                            }
                        </div>
                    </MudPaper>
                </MudItem>
            }

            @if (_metrics.Recommendations?.Any() == true)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="tl-alerts-panel" Elevation="0">
                        <div class="tl-alerts-header info">
                            <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="Size.Medium" />
                            <span>Smart Recommendations</span>
                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">
                                @_metrics.Recommendations.Count
                            </MudChip>
                        </div>
                        <div class="tl-alerts-list">
                            @foreach (var rec in _metrics.Recommendations.Take(3))
                            {
                                <div class="tl-alert-item recommendation">
                                    <div class="tl-alert-icon rec">
                                        <MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" Size="Size.Small" />
                                    </div>
                                    <div class="tl-alert-content">
                                        <div class="tl-alert-title">@rec.Title</div>
                                        <div class="tl-alert-desc">@rec.Description</div>
                                        <div class="tl-alert-metric rec">Expected: @rec.ExpectedImpact</div>
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Rounded.ArrowForward" 
                                                   Size="Size.Small"
                                                   Href="@rec.ActionLink"
                                                   Color="Color.Primary" />
                                </div>
                            }
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>
    }

    @* ── Client Experience Section ─────────────────────────────────────────── *@
    <div class="tl-experience-section mt-8 pa-8 rounded-2xl mb-8">
        <MudGrid Spacing="6" Class="align-center">
            <MudItem xs="12" md="6">
                <div class="tl-experience-content">
                    <div class="tl-welcome-badge mb-4">
                        <MudIcon Icon="@Icons.Material.Rounded.Stars" Size="Size.Small" />
                        <span>Client Experience</span>
                    </div>
                    <h2 class="tl-h2 font-weight-bold mb-4">Give your clients a 5-star experience.</h2>
                    <p class="tl-body-lg mb-6" style="color: var(--gray-600);">
                        The Customer Portal allows your clients to view their own quotes, invoices, and project status in real-time. 
                        Reduce support volume and build trust through transparency.
                    </p>
                    <div class="d-flex gap-4 align-center">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Launch" 
                                   Class="rounded-xl px-6 py-3" Href="/customer-portal">
                            Explore Portal
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Rounded.People" 
                                   Class="rounded-xl px-6 py-3" Href="/contacts">
                            Contacts
                        </MudButton>
                        <MudText Typo="Typo.body2" Class="ml-2" Style="color: var(--gray-600);">Start setting up access for your contacts</MudText>
                    </div>
                </div>
            </MudItem>
            <MudItem xs="12" md="6">
                <div class="tl-mockup-container">
                    <div class="tl-mockup-screen">
                        <div class="tl-mockup-browser-bar">
                            <div class="dot red"></div><div class="dot yellow"></div><div class="dot green"></div>
                        </div>
                        <div class="tl-mockup-content">
                            @* Mockup with Light Background and Dark Foreground as requested *@
                            <div class="pa-6" style="background: white; height: 100%; border-radius: 0 0 12px 12px;">
                                <div class="d-flex align-center gap-3 mb-6">
                                    <div style="width: 40px; height: 40px; border-radius: 8px; background: var(--tl-primary-50); display: flex; align-items: center; justify-content: center;">
                                        <MudIcon Icon="@Icons.Material.Rounded.Business" Color="Color.Primary" />
                                    </div>
                                    <div>
                                        <div style="height: 14px; width: 120px; background: #111827; border-radius: 4px; margin-bottom: 4px;"></div>
                                        <div style="height: 10px; width: 80px; background: #64748b; border-radius: 4px;"></div>
                                    </div>
                                </div>

                                <div class="d-flex gap-4 mb-8">
                                    <div style="flex: 1; padding: 16px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                                        <div style="height: 8px; width: 40%; background: #94a3b8; border-radius: 4px; margin-bottom: 8px;"></div>
                                        <div style="height: 24px; width: 60%; background: #1e40af; border-radius: 4px;"></div>
                                    </div>
                                    <div style="flex: 1; padding: 16px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px;">
                                        <div style="height: 8px; width: 40%; background: #94a3b8; border-radius: 4px; margin-bottom: 8px;"></div>
                                        <div style="height: 24px; width: 60%; background: #059669; border-radius: 4px;"></div>
                                    </div>
                                </div>

                                <div style="padding: 16px; border: 1px solid #f1f5f9; border-radius: 12px; background: white;">
                                    <div class="d-flex justify-space-between mb-4">
                                        <div style="height: 12px; width: 100px; background: #e2e8f0; border-radius: 4px;"></div>
                                        <div style="height: 12px; width: 60px; background: #e2e8f0; border-radius: 4px;"></div>
                                    </div>
                                    <div style="height: 1px; width: 100%; background: #f1f5f9; margin-bottom: 12px;"></div>
                                    @for(int i=0; i<3; i++) {
                                        <div class="d-flex justify-space-between mb-3">
                                            <div style="height: 10px; width: 140px; background: #f1f5f9; border-radius: 4px;"></div>
                                            <div style="height: 10px; width: 40px; background: #f1f5f9; border-radius: 4px;"></div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="tl-mockup-shadow"></div>
                </div>
            </MudItem>
        </MudGrid>
    </div>

    @* ── Quick Actions Bar ──────────────────────────────────────────────────── *@
    <div class="tl-quick-actions-bar">
        <MudButton Href="/quotes/create" 
                   Variant="Variant.Filled" 
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Add"
                   Size="Size.Large"
                   Class="tl-quick-btn">
            <div class="tl-quick-btn-content">
                <span class="tl-quick-btn-label">New Quote</span>
                <span class="tl-quick-btn-hint">Create sales quotation</span>
            </div>
        </MudButton>
        <MudButton Href="/invoices/create" 
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Rounded.ReceiptLong"
                   Size="Size.Large"
                   Class="tl-quick-btn">
            <div class="tl-quick-btn-content">
                <span class="tl-quick-btn-label">New Invoice</span>
                <span class="tl-quick-btn-hint">Bill for services</span>
            </div>
        </MudButton>
        <MudButton Href="/purchase-orders/create" 
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Rounded.ShoppingCart"
                   Size="Size.Large"
                   Class="tl-quick-btn">
            <div class="tl-quick-btn-content">
                <span class="tl-quick-btn-label">New PO</span>
                <span class="tl-quick-btn-hint">Purchase order</span>
            </div>
        </MudButton>
        <MudButton Href="/contacts" 
                   Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Rounded.People"
                   Size="Size.Large"
                   Class="tl-quick-btn">
            <div class="tl-quick-btn-content">
                <span class="tl-quick-btn-label">Contacts</span>
                <span class="tl-quick-btn-hint">Manage customers</span>
            </div>
        </MudButton>
    </div>
}

@code {
    private RenderFragment RenderUserKpiCards(UserKPI kpi) => __builder =>
    {
        <div class="tl-user-kpi-card">
            <div class="tl-user-kpi-icon teal">
                <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="Size.Small" />
            </div>
            <div class="tl-user-kpi-value">@kpi.QuotesRaisedThisMonth</div>
            <div class="tl-user-kpi-label">Quotes Raised</div>
            <div class="tl-user-kpi-sub">@kpi.QuotesWonThisMonth accepted (@kpi.WinRate.ToString("N0")%)</div>
        </div>
        <div class="tl-user-kpi-card">
            <div class="tl-user-kpi-icon gold">
                <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="Size.Small" />
            </div>
            <div class="tl-user-kpi-value">@kpi.InvoicesClosedThisMonth</div>
            <div class="tl-user-kpi-label">Invoices Closed</div>
            <div class="tl-user-kpi-sub">@Fmt(kpi.InvoiceValueThisMonth)</div>
        </div>
        <div class="tl-user-kpi-card">
            <div class="tl-user-kpi-icon success">
                <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" Size="Size.Small" />
            </div>
            <div class="tl-user-kpi-value">@Fmt(kpi.YtdRevenue)</div>
            <div class="tl-user-kpi-label">YTD Revenue</div>
            <div class="tl-user-kpi-sub">Rank #@kpi.Rank in team</div>
        </div>
        <div class="tl-user-kpi-card">
            <div class="tl-user-kpi-icon info">
                <MudIcon Icon="@Icons.Material.Rounded.AccessTime" Size="Size.Small" />
            </div>
            <div class="tl-user-kpi-value">@kpi.PendingQuotes</div>
            <div class="tl-user-kpi-label">Pending Quotes</div>
            <div class="tl-user-kpi-sub @(kpi.OverdueQuotes > 5 ? "warning" : "")">@kpi.OverdueQuotes overdue</div>
        </div>
    };
}

@code {
    private string _userName = "there";
    private DashboardMetrics? _metrics;
    private UserKPI? _userKpi;
    private UserKPI? _myKpi;
    private bool _isDirectorOrAdmin;
    private string? _userCode;
    private PerformanceView _performanceView = PerformanceView.Personal;
    private string? _selectedUserCode;
    private List<MudBlazor.ChartSeries> _chartSeries = new();
    private string[]          _xAxisLabels = Array.Empty<string>();
    private ChartPeriod       _chartPeriod = ChartPeriod.ThisMonth;
    private string            _chartSubtitle = "Quotes · invoices · purchase orders — value by month (all, excluding lost quotes)";

    private enum PerformanceView
    {
        Personal,
        Company,
        CompareUsers
    }

    private static readonly IReadOnlyDictionary<ChartPeriod, string> _periodOptions =
        new Dictionary<ChartPeriod, string>
        {
            [ChartPeriod.ThisMonth]      = "This Month",
            [ChartPeriod.ThisYear]       = "This Year",
            [ChartPeriod.FyToDate]       = "FY to Date",
            [ChartPeriod.LastYear]       = "Last Year",
            [ChartPeriod.SinceInception] = "Since Inception",
        };

    private readonly ChartOptions _chartOptions = new()
    {
        ChartPalette = new[] { "#00a8b0", "#cca05a", "#6941c6", "#2e90fa" },
        YAxisLines = true,
        XAxisLines = false,
        LineStrokeWidth = 3,
        YAxisFormat = "$#,##0",
    };

    private string ChartWidth => _xAxisLabels.Length > 12
        ? $"{Math.Min(_xAxisLabels.Length * 50, 1200)}px"
        : "100%";

    private static string Fmt(decimal v) => "$" + v.ToString("#,##0");

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userName = user.Identity?.Name ?? "there";
        _userCode = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        _isDirectorOrAdmin = user.IsInRole("Director") || user.IsInRole("Admin");

        _metrics = await DashboardService.GetMetricsAsync();
        
        // Find current user's KPI
        _userKpi = _metrics?.TeamMemberKPIs?.FirstOrDefault(k => k.UserCode == _userCode);
        _myKpi = _userKpi;

        // Seed chart from already-loaded metrics data
        _xAxisLabels = new[]{"Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};
        _chartSeries = new List<ChartSeries>
        {
            new() { Name = "Quotes",          Data = _metrics?.MonthlyQuotesThisYear?.Select(v => (double)v).ToArray() ?? new double[12] },
            new() { Name = "Invoices",        Data = _metrics?.MonthlyInvoicesThisYear?.Select(v => (double)v).ToArray() ?? new double[12] },
            new() { Name = "Purchase Orders", Data = _metrics?.MonthlyPOsThisYear?.Select(v => (double)v).ToArray() ?? new double[12] },
        };
    }

    private async Task SelectPeriodAsync(ChartPeriod period)
    {
        if (_chartPeriod == period) return;
        _chartPeriod  = period;
        StateHasChanged();

        // Reload metrics for the selected period
        _metrics = await DashboardService.GetMetricsAsync(period);
        
        // Update chart data for the selected period
        var data = await DashboardService.GetChartDataAsync(period);
        ApplyChartData(data);
        
        // Update user KPI if viewing personal/company performance
        if (_performanceView == PerformanceView.Personal && _metrics?.TeamMemberKPIs != null)
        {
            _userKpi = _metrics.TeamMemberKPIs.FirstOrDefault(k => k.UserCode == _userCode);
            _myKpi = _userKpi;
        }
        else if (_performanceView == PerformanceView.Company && _metrics != null)
        {
            _userKpi = new UserKPI
            {
                UserName = "All Company",
                QuotesRaisedThisMonth = GetPeriodQuotes(period, _metrics),
                QuotesWonThisMonth = GetPeriodQuotesWon(period, _metrics),
                InvoicesClosedThisMonth = GetPeriodInvoices(period, _metrics),
                InvoiceValueThisMonth = GetPeriodInvoiceValue(period, _metrics),
                YtdRevenue = _metrics.YtdInvoiceValue,
                WinRate = _metrics.QuoteToInvoiceConversionRate,
                Rank = 1,
                PendingQuotes = (int)(_metrics.PipelineValue / 5000),
                OverdueQuotes = _metrics.Warnings?.Count(w => w.Title.Contains("Overdue")) ?? 0
            };
        }
    }

    private static int GetPeriodQuotes(ChartPeriod period, DashboardMetrics m) => period switch
    {
        ChartPeriod.ThisMonth => m.ThisMonthQuotes,
        _ => m.YtdQuotesWon + (m.ThisMonthQuotes - m.ThisMonthQuotesWon) // Approximate total quotes for period
    };

    private static int GetPeriodQuotesWon(ChartPeriod period, DashboardMetrics m) => period switch
    {
        ChartPeriod.ThisMonth => m.ThisMonthQuotesWon,
        _ => m.YtdQuotesWon
    };

    private static int GetPeriodInvoices(ChartPeriod period, DashboardMetrics m) => period switch
    {
        ChartPeriod.ThisMonth => m.ThisMonthInvoices,
        _ => m.YtdInvoices
    };

    private static decimal GetPeriodInvoiceValue(ChartPeriod period, DashboardMetrics m) => period switch
    {
        ChartPeriod.ThisMonth => m.ThisMonthInvoiceValue,
        _ => m.YtdInvoiceValue
    };

    private void ApplyChartData(DashboardChartData data)
    {
        _xAxisLabels   = data.Labels;
        _chartSubtitle = _chartPeriod == ChartPeriod.SinceInception
            ? "Quotes \u00b7 invoices \u00b7 purchase orders \u2014 value by year (all, excluding lost quotes)"
            : "Quotes \u00b7 invoices \u00b7 purchase orders \u2014 value by month (all, excluding lost quotes)";
        _chartSeries = new List<ChartSeries>
        {
            new() { Name = "Quotes",          Data = data.QuotesWon.Select(v => (double)v).ToArray() },
            new() { Name = "Invoices",        Data = data.Invoices.Select(v => (double)v).ToArray() },
            new() { Name = "Purchase Orders", Data = data.POs.Select(v => (double)v).ToArray() },
        };
    }

    private static string FirstName(string? n) =>
        string.IsNullOrWhiteSpace(n) ? "there"
        : n.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "there";

    private static string TimeOfDayGreeting() => DateTime.Now.Hour switch
    {
        < 12 => "morning",
        < 17 => "afternoon",
        _    => "evening"
    };

    // Helper methods for KPI cards
    private string GetTrendClass(decimal value) => value >= 0 ? "positive" : "negative";
    private string GetTrendIcon(decimal value) => value >= 0 ? Icons.Material.Rounded.TrendingUp : Icons.Material.Rounded.TrendingDown;

    private string GetMarginStatusClass(decimal margin) => margin switch
    {
        >= 30 => "excellent",
        >= 20 => "good",
        >= 15 => "warning",
        _ => "critical"
    };

    private string GetMarginStatusText(decimal margin) => margin switch
    {
        >= 30 => "Excellent",
        >= 20 => "Good",
        >= 15 => "Fair",
        _ => "Low"
    };

    private string GetHealthCardClass(int score) => score switch
    {
        >= 90 => "excellent",
        >= 70 => "good",
        >= 50 => "warning",
        _ => "critical"
    };

    private string GetHealthIconClass(int score) => score switch
    {
        >= 90 => "success",
        >= 70 => "primary",
        >= 50 => "warning",
        _ => "error"
    };

    private string GetHealthStatusText(int score) => score switch
    {
        >= 90 => "Excellent",
        >= 70 => "Good",
        >= 50 => "Needs Attention",
        _ => "Critical"
    };

    private void OnPerformanceViewChanged(PerformanceView view)
    {
        _performanceView = view;
        _selectedUserCode = null;
        if (view == PerformanceView.Personal && _metrics?.TeamMemberKPIs != null)
        {
            _userKpi = _metrics.TeamMemberKPIs.FirstOrDefault(k => k.UserCode == _userCode);
        }
        else if (view == PerformanceView.Company && _metrics != null)
        {
            _userKpi = new UserKPI
            {
                UserName = "All Company",
                QuotesRaisedThisMonth = _metrics.ThisMonthQuotes,
                QuotesWonThisMonth = _metrics.ThisMonthQuotesWon,
                InvoicesClosedThisMonth = _metrics.ThisMonthInvoices,
                InvoiceValueThisMonth = _metrics.ThisMonthInvoiceValue,
                YtdRevenue = _metrics.YtdInvoiceValue,
                WinRate = _metrics.QuoteToInvoiceConversionRate,
                Rank = 1,
                PendingQuotes = (int)(_metrics.PipelineValue / 5000), // Approximate count
                OverdueQuotes = _metrics.Warnings?.Count(w => w.Title.Contains("Overdue")) ?? 0
            };
        }
        else
        {
            _userKpi = null;
        }
        StateHasChanged();
    }

    private void OnUserChanged(string? userCode)
    {
        _selectedUserCode = userCode;
        if (!string.IsNullOrEmpty(userCode) && _metrics?.TeamMemberKPIs != null)
        {
            _userKpi = _metrics.TeamMemberKPIs.FirstOrDefault(k => k.UserCode == userCode);
        }
        StateHasChanged();
    }

    private string GetPerformanceTitle() => _performanceView switch
    {
        PerformanceView.Personal => "Your Performance This Month",
        PerformanceView.Company => "Full Company Performance",
        PerformanceView.CompareUsers => _selectedUserCode != null ? $"{_metrics?.TeamMemberKPIs?.FirstOrDefault(k => k.UserCode == _selectedUserCode)?.UserName}'s Performance" : "Compare to Users",
        _ => "Performance"
    };

    private string GetPerformanceSubtitle() => _performanceView switch
    {
        PerformanceView.Personal => "Personal KPIs and targets",
        PerformanceView.Company => "Company-wide metrics and trends aggregated across all users",
        PerformanceView.CompareUsers => _selectedUserCode != null ? "Individual performance details" : "Select a team member to compare performance",
        _ => "Performance metrics"
    };

    private int HealthItemCount => (_metrics.Warnings?.Count ?? 0) + (_metrics.Recommendations?.Count ?? 0);

    private async Task ShowHealthRecommendations()
    {
        var parameters = new DialogParameters<HealthRecommendationsDialog>
        {
            { x => x.Warnings, _metrics.Warnings ?? new() },
            { x => x.Recommendations, _metrics.Recommendations ?? new() }
        };
        var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.Medium };
        await DialogService.ShowAsync<HealthRecommendationsDialog>("", parameters, options);
    }
}

