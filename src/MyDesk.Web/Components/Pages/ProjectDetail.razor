@code {
    [Parameter] public int ProjectId { get; set; }

    private bool _loading = true;
    private int _activeTab;
    private Project? _project;
    private ProjectHealthSnapshot? _health;
    private List<TaskItem> _tasks = new();
    private List<ProjectMember> _members = new();
    private List<ProjectMilestone> _milestones = new();
    private List<ProjectCostEntry> _costEntries = new();
    private List<ChangeRequest> _changeRequests = new();
    private List<RiskIssue> _risksIssues = new();
    private decimal _costTotal;
    private string _taskFilter = "All";
    private string _filterPriority = "all";
    private string _taskView = "grid";
    private string _groupBy = "none";
    private string _userCode = "";
    private string _userName = "";

    // Kanban drag-drop
    private TaskItem? _draggingTask;
    private string _dropTarget = "";

    // Team view presets
    private record TeamPreset(string Name, string Icon, string Description, string View, string GroupBy, string Priority);
    private static readonly TeamPreset[] _teamPresets =
    [
        new("Marketing",   Icons.Material.Rounded.Campaign,  "Gallery · grouped by milestone",    "gallery", "milestone", "all"),
        new("Operations",  Icons.Material.Rounded.Build,      "Kanban · all tasks",                "kanban",  "none",      "all"),
        new("Executive",   Icons.Material.Rounded.BarChart,   "Grid · high priority items",        "grid",    "priority",  "High"),
        new("Engineering", Icons.Material.Rounded.Code,       "Gantt · timeline view",             "gantt",   "milestone", "all"),
    ];

    // Dialog state
    private bool _addTaskOpen, _addMemberOpen, _addMilestoneOpen, _addCostOpen, _addCrOpen, _addRiOpen;

    // New item buffers
    private TaskItem _newTask = new() { Priority = "Medium", Status = "Backlog", PercentComplete = 0 };
    private ProjectMember _newMember = new() { Role = "TeamMember" };
    private ProjectMilestone _newMs = new();
    private DateTime? _newMsDate;
    private ProjectCostEntry _newCost = new() { EntryType = "Labour", Quantity = 1, IsBillable = true };
    private DateTime? _newCostDate = DateTime.Today;
    private ChangeRequest _newCr = new();
    private RiskIssue _newRi = new() { ItemType = "Risk", Likelihood = "Medium", Impact = "Medium" };
    private DateTime? _newRiDate;

    private static readonly string[] _taskStatuses = { "Backlog", "ToDo", "InProgress", "InReview", "Done" };

    private readonly record struct KanbanColumn(string Status, string Label, string Icon, Color Color);
    private readonly KanbanColumn[] _kanbanColumns =
    {
        new("Backlog",    "Backlog",     Icons.Material.Rounded.Inbox,           Color.Default),
        new("ToDo",       "To Do",       Icons.Material.Rounded.RadioButtonUnchecked, Color.Info),
        new("InProgress", "In Progress", Icons.Material.Rounded.PlayCircle,       Color.Primary),
        new("InReview",   "In Review",   Icons.Material.Rounded.Visibility,       Color.Warning),
        new("Done",       "Done",        Icons.Material.Rounded.CheckCircle,      Color.Success),
    };

    private IEnumerable<TaskItem> FilteredTasks =>
        _tasks
            .Where(t => _taskFilter == "All" || t.Status == _taskFilter)
            .Where(t => _filterPriority == "all" || t.Priority.Equals(_filterPriority, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _userCode = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        _userName = auth.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? _userCode;

        await LoadAllAsync();
        _loading = false;
    }

    private async Task LoadAllAsync()
    {
        _project = await ProjectSvc.GetProjectAsync(ProjectId);
        if (_project is null) return;

        var results = await Task.WhenAll(
            ProjectSvc.GetTasksAsync(projectId: ProjectId),
            ProjectSvc.GetMembersAsync(ProjectId),
            ProjectSvc.GetMilestonesAsync(ProjectId),
            ProjectSvc.GetCostEntriesAsync(ProjectId),
            ProjectSvc.GetChangeRequestsAsync(ProjectId),
            ProjectSvc.GetRisksIssuesAsync(ProjectId));

        _tasks          = (List<TaskItem>)results[0];
        _members        = (List<ProjectMember>)results[1];
        _milestones     = (List<ProjectMilestone>)results[2];
        _costEntries    = (List<ProjectCostEntry>)results[3];
        _changeRequests = (List<ChangeRequest>)results[4];
        _risksIssues    = (List<RiskIssue>)results[5];
        _costTotal      = _costEntries.Sum(e => e.Amount);

        _health = await ProjectSvc.GetProjectHealthAsync(ProjectId);
    }

    private async Task UpdatePercent(TaskItem task, int value)
    {
        task.PercentComplete = value;
        await ProjectSvc.UpdateTaskPercentAsync(task.TaskId, value);
        _health = await ProjectSvc.GetProjectHealthAsync(ProjectId);
    }

    private async Task UpdateTaskStatus(TaskItem task, string status)
    {
        task.Status = status;
        if (status == "Done") task.PercentComplete = 100;
        await ProjectSvc.UpdateTaskStatusAsync(task.TaskId, status);
        if (status == "Done") await ProjectSvc.UpdateTaskPercentAsync(task.TaskId, 100);
        _health = await ProjectSvc.GetProjectHealthAsync(ProjectId);
    }

    private async Task MoveTask(TaskItem task, string newStatus)
    {
        await UpdateTaskStatus(task, newStatus);
    }

    private void OpenTaskEdit(TaskItem task)
    {
        _newTask = task;
        _addTaskOpen = true;
    }

    private async Task SaveTask()
    {
        if (string.IsNullOrWhiteSpace(_newTask.Title)) return;
        _newTask.ProjectId = ProjectId;
        if (_newTask.MilestoneId.HasValue)
        {
            var ms = _milestones.FirstOrDefault(m => m.MilestoneId == _newTask.MilestoneId);
            _newTask.MilestoneName = ms?.Title;
        }
        if (_newTask.TaskId == 0)
            await ProjectSvc.CreateTaskAsync(_newTask);
        else
            await ProjectSvc.UpdateTaskAsync(_newTask);

        _addTaskOpen = false;
        _newTask = new() { Priority = "Medium", Status = "Backlog" };
        _tasks = await ProjectSvc.GetTasksAsync(projectId: ProjectId);
        Snackbar.Add("Task saved", Severity.Success);
    }

    private async Task DeleteTask(int taskId)
    {
        await ProjectSvc.DeleteTaskAsync(taskId);
        _tasks = await ProjectSvc.GetTasksAsync(projectId: ProjectId);
        Snackbar.Add("Task deleted", Severity.Info);
    }

    private async Task SaveMember()
    {
        if (string.IsNullOrWhiteSpace(_newMember.Name)) return;
        _newMember.ProjectId = ProjectId;
        await ProjectSvc.AddMemberAsync(_newMember);
        _members = await ProjectSvc.GetMembersAsync(ProjectId);
        _addMemberOpen = false;
        _newMember = new() { Role = "TeamMember" };
        Snackbar.Add("Member added", Severity.Success);
    }

    private async Task RemoveMember(int memberId)
    {
        await ProjectSvc.RemoveMemberAsync(memberId);
        _members = await ProjectSvc.GetMembersAsync(ProjectId);
    }

    private async Task SaveMilestone()
    {
        if (string.IsNullOrWhiteSpace(_newMs.Title)) return;
        _newMs.ProjectId = ProjectId;
        _newMs.DueDate = _newMsDate ?? DateTime.Today.AddDays(14);
        await ProjectSvc.AddMilestoneAsync(_newMs);
        _milestones = await ProjectSvc.GetMilestonesAsync(ProjectId);
        _addMilestoneOpen = false;
        _newMs = new();
        _newMsDate = null;
        Snackbar.Add("Milestone added", Severity.Success);
    }

    private async Task SignOffMilestone(ProjectMilestone ms)
    {
        await ProjectSvc.SignOffMilestoneAsync(ms.MilestoneId, _userName);
        _milestones = await ProjectSvc.GetMilestonesAsync(ProjectId);
        Snackbar.Add("Milestone signed off", Severity.Success);
    }

    private async Task SaveCostEntry()
    {
        if (string.IsNullOrWhiteSpace(_newCost.Description)) return;
        _newCost.ProjectId  = ProjectId;
        _newCost.EntryDate  = _newCostDate ?? DateTime.Today;
        _newCost.Amount     = _newCost.Quantity * _newCost.UnitRate;
        _newCost.EnteredBy  = _userName;
        _newCost.UserCode   = _userCode;
        await ProjectSvc.AddCostEntryAsync(_newCost);
        _costEntries = await ProjectSvc.GetCostEntriesAsync(ProjectId);
        _costTotal   = _costEntries.Sum(e => e.Amount);
        _addCostOpen = false;
        _newCost = new() { EntryType = "Labour", Quantity = 1, IsBillable = true };
        _newCostDate = DateTime.Today;
        await ProjectSvc.RefreshProjectStatsAsync(ProjectId);
        _health = await ProjectSvc.GetProjectHealthAsync(ProjectId);
        Snackbar.Add("Cost entry logged", Severity.Success);
    }

    private async Task DeleteCostEntry(int id)
    {
        await ProjectSvc.DeleteCostEntryAsync(id);
        _costEntries = await ProjectSvc.GetCostEntriesAsync(ProjectId);
        _costTotal = _costEntries.Sum(e => e.Amount);
        await ProjectSvc.RefreshProjectStatsAsync(ProjectId);
    }

    private void AddRiskIssue(string type)
    {
        _newRi = new() { ItemType = type, Likelihood = "Medium", Impact = "Medium" };
        _newRiDate = null;
        _addRiOpen = true;
    }

    private async Task SaveRiskIssue()
    {
        if (string.IsNullOrWhiteSpace(_newRi.Title)) return;
        _newRi.ProjectId = ProjectId;
        _newRi.DueDate   = _newRiDate;
        _newRi.Priority  = ComputePriority(_newRi.Likelihood, _newRi.Impact);
        await ProjectSvc.AddRiskIssueAsync(_newRi);
        _risksIssues = await ProjectSvc.GetRisksIssuesAsync(ProjectId);
        _addRiOpen = false;
        Snackbar.Add($"{_newRi.ItemType} added", Severity.Success);
    }

    private async Task CloseRiskIssue(int id)
    {
        var item = _risksIssues.FirstOrDefault(r => r.RiskIssueId == id);
        if (item is null) return;
        item.Status = "Closed";
        await ProjectSvc.UpdateRiskIssueAsync(item);
        _risksIssues = await ProjectSvc.GetRisksIssuesAsync(ProjectId);
    }

    private async Task DeleteRiskIssue(int id)
    {
        await ProjectSvc.DeleteRiskIssueAsync(id);
        _risksIssues = await ProjectSvc.GetRisksIssuesAsync(ProjectId);
    }

    private async Task SaveCr(bool submit)
    {
        if (string.IsNullOrWhiteSpace(_newCr.Title) || string.IsNullOrWhiteSpace(_newCr.Description)) return;
        _newCr.ProjectId  = ProjectId;
        _newCr.RaisedBy   = _userName;
        _newCr.RaisedByCode = _userCode;
        _newCr.RaisedAt   = DateTime.Now;
        _newCr.Status     = submit ? "PendingApproval" : "Draft";
        _newCr.ChangeNumber = $"CR-{(_changeRequests.Count + 1):D3}";
        await ProjectSvc.CreateChangeRequestAsync(_newCr);
        _changeRequests = await ProjectSvc.GetChangeRequestsAsync(ProjectId);
        _addCrOpen = false;
        _newCr = new();
        Snackbar.Add(submit ? "Change request submitted for approval" : "Draft saved", Severity.Success);
    }

    private async Task ApproveCr(int id)
    {
        await ProjectSvc.UpdateChangeRequestStatusAsync(id, "Approved", _userName);
        _changeRequests = await ProjectSvc.GetChangeRequestsAsync(ProjectId);
        Snackbar.Add("Change request approved", Severity.Success);
    }

    private async Task RejectCr(int id)
    {
        await ProjectSvc.UpdateChangeRequestStatusAsync(id, "Rejected", _userName);
        _changeRequests = await ProjectSvc.GetChangeRequestsAsync(ProjectId);
        Snackbar.Add("Change request rejected", Severity.Warning);
    }

    private async Task SubmitCr(int id)
    {
        await ProjectSvc.UpdateChangeRequestStatusAsync(id, "PendingApproval");
        _changeRequests = await ProjectSvc.GetChangeRequestsAsync(ProjectId);
    }

    private void EditProject() => Nav.NavigateTo($"/project-management/{ProjectId}/edit");

    private async Task GeneratePortalLink()
    {
        if (_project is null) return;
        var token = await ProjectSvc.EnsurePortalTokenAsync(ProjectId);
        _project.PortalToken = token;
        Snackbar.Add("Portal link generated", Severity.Success);
    }

    private async Task CopyPortalLink()
    {
        // JS interop would copy to clipboard; here we just notify
        Snackbar.Add("Link copied to clipboard", Severity.Info);
    }

    // ── Helper colours / computed ──

    private static Color GetStatusColor(string status) => status switch
    {
        "Active"    => Color.Primary,
        "Complete"  => Color.Success,
        "OnHold"    => Color.Warning,
        "Cancelled" => Color.Error,
        _           => Color.Default,
    };

    private static Color GetPriorityColor(string p) => p switch
    {
        "Critical" => Color.Error,
        "High"     => Color.Warning,
        "Medium"   => Color.Info,
        _          => Color.Default,
    };

    private static Color HealthColor(string health) => health switch
    {
        "OnTrack"    => Color.Success,
        "AtRisk"     => Color.Warning,
        "Delayed"    or "OverBudget" => Color.Error,
        _            => Color.Default,
    };

    private static Color RoleColor(string role) => role switch
    {
        "ProjectManager" => Color.Primary,
        "Client"         => Color.Success,
        "Supplier"       => Color.Warning,
        "Stakeholder"    => Color.Info,
        _                => Color.Default,
    };

    private static Color ImpactColor(string level) => level switch
    {
        "High"   => Color.Error,
        "Medium" => Color.Warning,
        _        => Color.Success,
    };

    private static Color CrStatusColor(string s) => s switch
    {
        "Approved"       => Color.Success,
        "Rejected"       => Color.Error,
        "PendingApproval"=> Color.Warning,
        "Invoiced"       => Color.Info,
        _                => Color.Default,
    };

    private async Task OnDropAsync(string newStatus)
    {
        _dropTarget = string.Empty;
        if (_draggingTask is null || _draggingTask.Status == newStatus) { _draggingTask = null; return; }
        await UpdateTaskStatus(_draggingTask, newStatus);
        _draggingTask = null;
    }

    private void ApplyPreset(TeamPreset preset)
    {
        _taskView = preset.View;
        _groupBy = preset.GroupBy;
        _filterPriority = preset.Priority;
        _taskFilter = "All";
    }

    private static string PriorityHex(string p) => p switch
    {
        "Critical" => "#d32f2f",
        "High"     => "#f57c00",
        "Medium"   => "#1976d2",
        _          => "#9e9e9e",
    };

    private static Color GetTaskStatusColor(string s) => s switch
    {
        "Done"       => Color.Success,
        "InProgress" => Color.Primary,
        "InReview"   => Color.Warning,
        "ToDo"       => Color.Info,
        _            => Color.Default,
    };

    private static string ComputePriority(string likelihood, string impact) =>
        (likelihood, impact) switch
        {
            ("High",   "High")   => "Critical",
            ("High",   "Medium") or ("Medium","High") => "High",
            ("Low",    "High")   or ("High","Low")    => "Medium",
            _                                          => "Low",
        };
}
