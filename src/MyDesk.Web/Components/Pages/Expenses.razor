@page "/expenses"
@attribute [Authorize]
@using MyDesk.Shared.Models
@using MyDesk.Shared.Services
@using MyDesk.Web.Services
@using MudBlazor
@inject ExpenseService ExpenseService
@inject UserService UserService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Expense Claims - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb"><a href="/">MyDesk</a><span class="sep">/</span><span>Expense Claims</span></div>
        <h1>Expense Claims</h1>
        <p class="tl-subtitle">Submit and manage expense claims for approval and reimbursement.</p>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="NewClaim" Class="ml-auto mr-0">
        New Claim
    </MudButton>
</div>

@* Stats strip *@
<MudGrid Class="mb-4">
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5">@_allClaims.Count</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Total Claims</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Warning">@_allClaims.Count(c => c.Status == "Submitted")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Awaiting Approval</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Success">@_allClaims.Count(c => c.Status == "Approved")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Approved</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Primary">@_allClaims.Where(c => c.Status == "Approved" || c.Status == "Finalised").Sum(c => c.TotalAmount).ToString("C")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Total Approved</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@* Status tabs *@
<MudTabs @bind-ActivePanelIndex="_tabIndex" Rounded="true" Border="true" PanelClass="pa-0">
    <MudTabPanel Text="All" />
    <MudTabPanel Text="Draft" />
    <MudTabPanel Text="Submitted" />
    <MudTabPanel Text="Approved" />
    <MudTabPanel Text="Rejected" />
    <MudTabPanel Text="Finalised" />
</MudTabs>

<MudPaper Elevation="1" Class="mt-2">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!_filteredClaims.Any())
    {
        <div class="tl-empty-state pa-8">
            <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.h6" Class="mt-4">No @(_currentStatusFilter ?? "") claims</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-2">
                @if (_tabIndex == 0) { <span>Click <strong>New Claim</strong> to create your first expense claim.</span> }
                else { <span>No claims with status "@_currentStatusFilter".</span> }
            </MudText>
        </div>
    }
    else
    {
        <MudDataGrid T="ExpenseClaim" Items="_filteredClaims" Dense="true" Hover="true" Bordered="false"
                     Striped="true" Class="tl-data-grid" RowClick="@(e => Nav.NavigateTo($"/expenses/claim/{e.Item.ClaimId}"))">
            <ToolBarContent>
                <MudText Typo="Typo.h6">@(_currentStatusFilter == null ? "All Claims" : _currentStatusFilter + " Claims")</MudText>
                <MudSpacer />
                @if (_isManagerOrAccounts)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">Showing all team claims</MudChip>
                }
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.ClaimRef" Title="Claim Ref" />
                <PropertyColumn Property="x => x.ClaimPeriod" Title="Period" />
                <PropertyColumn Property="x => x.TotalAmount" Title="Total" Format="C" />
                <TemplateColumn Title="Status">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Color="@StatusColour(context.Item.Status)" Variant="Variant.Text">
                            @context.Item.Status
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <PropertyColumn Property="x => x.SubmittedBy" Title="Submitted By" />
                <PropertyColumn Property="x => x.ApproverName" Title="Approver" />
                <TemplateColumn Title="Date">
                    <CellTemplate>
                        <MudText Typo="Typo.body2">@context.Item.CreatedAt.ToString("dd MMM yyyy")</MudText>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="" Sortable="false" CellStyle="width:60px;">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Rounded.ChevronRight" Size="Size.Small"
                                       Href="@($"/expenses/claim/{context.Item.ClaimId}")" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="ExpenseClaim" />
            </PagerContent>
        </MudDataGrid>
    }
</MudPaper>

@code {
    private List<ExpenseClaim> _allClaims = new();
    private bool _loading = true;
    private int _tabIndex = 0;
    private bool _isManagerOrAccounts = false;
    private string? _currentUserName;

    private static readonly string?[] TabStatuses = { null, "Draft", "Submitted", "Approved", "Rejected", "Finalised" };

    private string? _currentStatusFilter => TabStatuses[_tabIndex];

    private List<ExpenseClaim> _filteredClaims => _currentStatusFilter == null
        ? _allClaims
        : _allClaims.Where(c => c.Status == _currentStatusFilter).ToList();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserName = auth.User.Identity?.Name ?? auth.User.FindFirst("name")?.Value;
        _isManagerOrAccounts =
            auth.User.IsInRole("Director") ||
            auth.User.IsInRole("Administrator") ||
            auth.User.IsInRole("Accounts") ||
            auth.User.FindFirst("IsAdmin")?.Value == "True" ||
            auth.User.FindFirst("IsAccounts")?.Value == "True";

        await LoadClaimsAsync();
    }

    private async Task LoadClaimsAsync()
    {
        _loading = true;
        try
        {
            // Managers/Accounts see all claims; regular users see only their own.
            _allClaims = _isManagerOrAccounts
                ? await ExpenseService.GetClaimsAsync()
                : await ExpenseService.GetClaimsAsync(submittedBy: _currentUserName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading claims: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }

    private async Task NewClaim()
    {
        var claim = new ExpenseClaim
        {
            SubmittedBy = _currentUserName ?? "",
            ClaimPeriod = DateTime.Today.ToString("MMMM yyyy"),
        };
        try
        {
            var id = await ExpenseService.SaveClaimAsync(claim);
            Nav.NavigateTo($"/expenses/claim/{id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating claim: {ex.Message}", Severity.Error);
        }
    }

    private Color StatusColour(string status) => status switch
    {
        "Approved"  => Color.Success,
        "Submitted" => Color.Warning,
        "Rejected"  => Color.Error,
        "Finalised" => Color.Info,
        "Draft"     => Color.Default,
        _           => Color.Default
    };
}
