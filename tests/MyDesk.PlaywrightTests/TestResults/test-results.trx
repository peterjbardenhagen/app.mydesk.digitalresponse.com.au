&lt;!--!--&gt;&lt;style&gt;&#xD;
    .tl-login-page {&#xD;
        min-height: 100vh;&#xD;
        display: flex;&#xD;
        align-items: center;&#xD;
        justify-content: center;&#xD;
        background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #f0fdf4 100%);&#xD;
        padding: 20px;&#xD;
    }&#xD;
&#xD;
    .tl-login-container {&#xD;
        width: 100%;&#xD;
        max-width: 400px;&#xD;
        display: flex;&#xD;
        flex-direction: column;&#xD;
        align-items: center;&#xD;
    }&#xD;
&#xD;
    .tl-login-branding {&#xD;
        text-align: center;&#xD;
        margin-bottom: 32px;&#xD;
    }&#xD;
&#xD;
    .tl-login-logo {&#xD;
        width: 64px;&#xD;
        height: 64px;&#xD;
        margin: 0 auto 16px;&#xD;
        background: white;&#xD;
        border-radius: 16px;&#xD;
        display: flex;&#xD;
        align-items: center;&#xD;
        justify-content: center;&#xD;
        box-shadow: 0 4px 20px rgba(0, 200, 200, 0.15);&#xD;
    }&#xD;
&#xD;
    .tl-logo-mark {&#xD;
        width: 40px;&#xD;
        height: 40px;&#xD;
    }&#xD;
&#xD;
    .tl-login-title {&#xD;
        font-size: 32px;&#xD;
        font-weight: 700;&#xD;
        color: var(--gray-900);&#xD;
        margin: 0 0 4px 0;&#xD;
        letter-spacing: -0.5px;&#xD;
    }&#xD;
&#xD;
    .tl-login-subtitle {&#xD;
        font-size: 14px;&#xD;
        color: var(--gray-500);&#xD;
        margin: 0;&#xD;
    }&#xD;
&#xD;
    .tl-login-card {&#xD;
        width: 100%;&#xD;
        padding: 32px;&#xD;
        border-radius: 16px;&#xD;
        background: white;&#xD;
    }&#xD;
&#xD;
    .tl-login-form {&#xD;
        display: flex;&#xD;
        flex-direction: column;&#xD;
        gap: 20px;&#xD;
    }&#xD;
&#xD;
    .tl-login-field ::deep .mud-input-outlined-border {&#xD;
        border-radius: 10px;&#xD;
    }&#xD;
&#xD;
    .tl-login-options {&#xD;
        display: flex;&#xD;
        align-items: center;&#xD;
        justify-content: space-between;&#xD;
        flex-wrap: wrap;&#xD;
        gap: 8px;&#xD;
    }&#xD;
&#xD;
    .tl-save-credentials {&#xD;
        margin: 0;&#xD;
    }&#xD;
&#xD;
    .tl-save-text {&#xD;
        font-size: 13px;&#xD;
        color: var(--gray-600);&#xD;
    }&#xD;
&#xD;
    .tl-forgot-link {&#xD;
        font-size: 13px;&#xD;
        font-weight: 500;&#xD;
    }&#xD;
&#xD;
    .tl-login-button {&#xD;
        border-radius: 10px;&#xD;
        height: 48px;&#xD;
        font-size: 15px;&#xD;
        font-weight: 600;&#xD;
        text-transform: none;&#xD;
        background: linear-gradient(135deg, #00a8b0 0%, #008a8a 100%);&#xD;
        box-shadow: 0 4px 14px rgba(0, 168, 176, 0.3);&#xD;
        transition: all 200ms ease;&#xD;
    }&#xD;
&#xD;
    .tl-login-button:hover:not(:disabled) {&#xD;
        transform: translateY(-1px);&#xD;
        box-shadow: 0 6px 20px rgba(0, 168, 176, 0.4);&#xD;
    }&#xD;
&#xD;
    .tl-login-button:disabled {&#xD;
        opacity: 0.7;&#xD;
    }&#xD;
&#xD;
    .tl-login-footer {&#xD;
        margin-top: 24px;&#xD;
        font-size: 12px;&#xD;
        color: var(--gray-400);&#xD;
        text-align: center;&#xD;
    }&#xD;
&#xD;
    /* Styled inputs to match MudBlazor design */&#xD;
    .tl-login-field {&#xD;
        width: 100%;&#xD;
    }&#xD;
&#xD;
    .tl-input {&#xD;
        width: 100%;&#xD;
        height: 48px;&#xD;
        padding: 12px 16px;&#xD;
        font-size: 15px;&#xD;
        border: 1px solid var(--gray-300);&#xD;
        border-radius: 10px;&#xD;
        background: white;&#xD;
        transition: all 200ms ease;&#xD;
        outline: none;&#xD;
        color: var(--gray-900);&#xD;
    }&#xD;
&#xD;
    .tl-input:focus {&#xD;
        border-color: var(--tl-primary-500);&#xD;
        box-shadow: 0 0 0 3px rgba(0, 168, 176, 0.1);&#xD;
    }&#xD;
&#xD;
    .tl-input::placeholder {&#xD;
        color: var(--gray-400);&#xD;
    }&#xD;
&#xD;
    .tl-password-toggle {&#xD;
        position: absolute;&#xD;
        right: 8px;&#xD;
        top: 50%;&#xD;
        transform: translateY(-50%);&#xD;
        width: 32px;&#xD;
        height: 32px;&#xD;
    }&#xD;
&lt;/style&gt;&lt;!--!--&gt;&#xD;
