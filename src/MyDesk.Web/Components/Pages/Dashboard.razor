@page "/dashboard"
@inject NavigationManager Navigation

<PageTitle>Dashboard - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span>Dashboard</span>
        </div>
        <h1>Dashboard</h1>
