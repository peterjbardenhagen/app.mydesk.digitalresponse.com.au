@page "/admin/divisions"
@attribute [Authorize]
@inject SystemService Svc
@inject ISnackbar Snackbar

<PageTitle>Divisions - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/admin/setup">Admin</a><span class="sep">/</span>
            <span style="color:var(--gray-700); font-weight:500;">Divisions</span>
        </div>
        <h1>Divisions</h1>
        <p class="tl-subtitle">Business units / departments.</p>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="AddNew">Add division</MudButton>
</div>

@if (_items == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-0">
        <MudDataGrid T="Division" Items="_items" Dense="true" Hover="true" Elevation="0">
            <Columns>
                <PropertyColumn Property="x => x.DivisionId" Title="#" CellStyle="width:80px;" />
                <TemplateColumn Title="Name">
                    <CellTemplate>
                        @if (_editingId == context.Item.DivisionId)
                        {
                            <MudTextField @bind-Value="_editingName" Immediate="true" Margin="Margin.Dense"
                                          Variant="Variant.Outlined" AutoFocus="true" />
                        }
                        else
                        {
                            @context.Item.DivisionName
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" CellStyle="width:160px;">
                    <CellTemplate>
                        @if (_editingId == context.Item.DivisionId)
                        {
                            <MudIconButton Icon="@Icons.Material.Rounded.Check" Color="Color.Success" Size="Size.Small"
                                           OnClick="@(() => Save(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Close" Size="Size.Small" OnClick="Cancel" />
                        }
                        else
                        {
                            <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => BeginEdit(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => Delete(context.Item))" />
                        }
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<Division>? _items;
    private int? _editingId;
    private string _editingName = "";

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Svc.GetDivisionsAsync();

    private void BeginEdit(Division d) { _editingId = d.DivisionId; _editingName = d.DivisionName; }
    private void Cancel() { _editingId = null; _editingName = ""; }

    private async Task Save(Division d)
    {
        try
        {
            d.DivisionName = _editingName;
            await Svc.SaveDivisionAsync(d);
            Snackbar.Add("Saved", Severity.Success);
            Cancel();
            await Reload();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private async Task AddNew()
    {
        try
        {
            await Svc.SaveDivisionAsync(new Division { DivisionName = "New division" });
            await Reload();
            var newest = _items!.OrderByDescending(d => d.DivisionId).First();
            BeginEdit(newest);
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private async Task Delete(Division d)
    {
        try
        {
            await Svc.DeleteDivisionAsync(d.DivisionId);
            Snackbar.Add("Deleted", Severity.Success);
            await Reload();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }
}



