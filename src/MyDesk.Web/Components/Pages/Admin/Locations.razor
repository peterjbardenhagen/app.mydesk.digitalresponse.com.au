@page "/admin/locations"
@attribute [Authorize]
@inject SystemService Svc
@inject ISnackbar Snackbar

<PageTitle>Locations - Techlight MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/admin/setup">Admin</a><span class="sep">/</span>
            <span style="color:var(--gray-700); font-weight:500;">Locations</span>
        </div>
        <h1>Locations</h1>
        <p class="tl-subtitle">Office / warehouse locations.</p>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="AddNew">Add location</MudButton>
</div>

@if (_items == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-0">
        <MudDataGrid T="Location" Items="_items" Dense="true" Hover="true" Elevation="0">
            <Columns>
                <PropertyColumn Property="x => x.LocationId" Title="#" CellStyle="width:80px;" />
                <TemplateColumn Title="Name">
                    <CellTemplate>
                        @if (_editingId == context.Item.LocationId)
                        {
                            <MudTextField @bind-Value="_editingName" Immediate="true" Margin="Margin.Dense"
                                          Variant="Variant.Outlined" AutoFocus="true" />
                        }
                        else { @context.Item.LocationName }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" CellStyle="width:160px;">
                    <CellTemplate>
                        @if (_editingId == context.Item.LocationId)
                        {
                            <MudIconButton Icon="@Icons.Material.Rounded.Check" Color="Color.Success" Size="Size.Small"
                                           OnClick="@(() => Save(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Close" Size="Size.Small" OnClick="Cancel" />
                        }
                        else
                        {
                            <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => BeginEdit(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => Delete(context.Item))" />
                        }
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<Location>? _items;
    private int? _editingId;
    private string _editingName = "";

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Svc.GetLocationsAsync();

    private void BeginEdit(Location l) { _editingId = l.LocationId; _editingName = l.LocationName; }
    private void Cancel() { _editingId = null; _editingName = ""; }

    private async Task Save(Location l)
    {
        try { l.LocationName = _editingName; await Svc.SaveLocationAsync(l); Snackbar.Add("Saved", Severity.Success); Cancel(); await Reload(); }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private async Task AddNew()
    {
        await Svc.SaveLocationAsync(new Location { LocationName = "New location" });
        await Reload();
        BeginEdit(_items!.OrderByDescending(l => l.LocationId).First());
    }

    private async Task Delete(Location l)
    {
        try { await Svc.DeleteLocationAsync(l.LocationId); Snackbar.Add("Deleted", Severity.Success); await Reload(); }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }
}

