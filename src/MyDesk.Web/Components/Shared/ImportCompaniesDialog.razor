@inject CompanyService CompanyService
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.subtitle1" Class="mb-2">
            Import customers from existing invoice data. Select the companies you want to import.
        </MudText>
        
        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Class="my-4" />
        }
        else if (_importItems.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="my-4">
                No new companies found in invoice data. All invoice customers already exist in the database.
            </MudAlert>
        }
        else
        {
            <div class="d-flex gap-2 mb-3">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="SelectAll">Select All</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="SelectNew">Select New Only</MudButton>
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="DeselectAll">Deselect All</MudButton>
            </div>
            
            <MudSimpleTable Dense="true" Hover="true" Style="max-height:400px;overflow-y:auto;">
                <thead>
                    <tr>
                        <th style="width:40px;">Import</th>
                        <th>Company Name</th>
                        <th>Invoice Address</th>
                        <th>Invoices</th>
                        <th>Total Value</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in _importItems)
                    {
                        <tr>
                            <td>
                                <MudCheckBox @bind-Value="item.Selected" Disabled="item.IsDuplicate" />
                            </td>
                            <td>@item.CompanyName</td>
                            <td style="font-size:0.8rem;max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @(item.InvAddress ?? "-")
                            </td>
                            <td style="text-align:right;">@item.InvoiceCount</td>
                            <td style="text-align:right;">$@item.TotalValue.ToString("N0")</td>
                            <td>
                                @if (item.IsDuplicate)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">Exists</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success">New</MudChip>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </MudSimpleTable>
            
            <MudText Typo="Typo.caption" Class="mt-2">
                @_importItems.Count(i => i.Selected && !i.IsDuplicate) new companies, 
                @_importItems.Count(i => i.Selected && i.IsDuplicate) existing companies will be updated.
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" 
                   OnClick="ImportAsync" Disabled="@_disableImport">
            @(_importing ? "Importing..." : "Import Selected")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private MudDialogInstance? MudDialog { get; set; }

    private List<CompanyImportItem> _importItems = new();
    private bool _loading = true;
    private bool _importing;
    private bool _disableImport => _importing || !_importItems.Any(i => i.Selected);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _importItems = await CompanyService.GetCompaniesFromInvoicesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load invoice data: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void SelectAll()
    {
        foreach (var item in _importItems)
            item.Selected = true;
    }

    private void SelectNew()
    {
        foreach (var item in _importItems)
            item.Selected = !item.IsDuplicate;
    }

    private void DeselectAll()
    {
        foreach (var item in _importItems)
            item.Selected = false;
    }

    private async Task ImportAsync()
    {
        _importing = true;
        var selected = _importItems.Where(i => i.Selected).ToList();
        
        try
        {
            foreach (var item in selected)
            {
                if (item.IsDuplicate && item.ExistingCompanyId.HasValue)
                {
                    await CompanyService.UpdateCompanyFromInvoiceAsync(item.ExistingCompanyId.Value, item);
                }
                else if (!item.IsDuplicate)
                {
                    await CompanyService.ImportCompanyFromInvoiceAsync(item);
                }
            }
            
            Snackbar.Add($"Successfully imported {selected.Count} companies", Severity.Success);
            MudDialog?.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private void Cancel() => MudDialog?.Cancel();
}