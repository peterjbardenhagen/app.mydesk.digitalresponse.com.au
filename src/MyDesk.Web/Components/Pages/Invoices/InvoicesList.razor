@page "/invoices"
@attribute [Authorize]
@inject InvoiceService InvoiceService
@inject LookupService LookupService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JsRuntime
@using System.Security.Claims
@using Microsoft.JSInterop

<PageTitle>Invoices - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span>Invoices</span>
        </div>
        <h1>Invoices</h1>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="@(() => Nav.NavigateTo("/invoices/create"))">New Invoice</MudButton>
</div>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="4">
            <MudTextField @bind-Value="_search" Label="Customer / Company" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                          Clearable="true" Immediate="false" />
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudDatePicker @bind-Date="_dateFrom" Label="From" Variant="Variant.Outlined" Clearable="true" />
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudDatePicker @bind-Date="_dateTo" Label="To" Variant="Variant.Outlined" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudSelect T="int" @bind-Value="_statusId" Label="Status" Variant="Variant.Outlined" Clearable="false">
                <MudSelectItem T="int" Value="0">All Statuses</MudSelectItem>
                @foreach (var s in _statuses)
                {
                    <MudSelectItem T="int" Value="@s.InvoiceStatusId">@s.StatusName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudSelect T="string" @bind-Value="_userCode" Label="Invoiced By" Variant="Variant.Outlined" Clearable="false">
                <MudSelectItem T="string" Value="@("")">All Users</MudSelectItem>
                @foreach (var u in _users)
                {
                    <MudSelectItem T="string" Value="@u.Code">@u.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
    <div class="d-flex gap-2 mt-3 flex-wrap">
        <MudButton OnClick="LoadAsync" Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Rounded.FilterList">Apply</MudButton>
        <MudButton OnClick="ResetFilter" Variant="Variant.Outlined">Reset</MudButton>
        <MudButton OnClick="@(() => Nav.NavigateTo("/invoices/myob-export"))"
                   Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Rounded.Output">MYOB Export</MudButton>
        <MudButton OnClick="ExportCsv" Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Rounded.Download">Export CSV</MudButton>
        <MudButton OnClick="ShowBulkEmailDialog" Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Email">Bulk Email</MudButton>
        <MudButton OnClick="ShowBulkStatusDialog" Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Rounded.Update">Bulk Status</MudButton>
    </div>
</MudPaper>

<MudDataGrid T="Invoice" Items="@_invoices" Loading="@_loading" Dense="true" Hover="true"
             SortMode="@SortMode.Multiple" Virtualize="true" FixedHeader="true" Height="600px" Class="tl-compact-grid">
    <Columns>
        <PropertyColumn Property="x => x.InvoiceId"   Title="#"         InitialDirection="SortDirection.Descending" />
        <PropertyColumn Property="x => x.InvoiceNum"  Title="Invoice #" />
        <PropertyColumn Property="x => x.CCompany"    Title="Customer" />
        <PropertyColumn Property="x => x.DivisionName" Title="Division" />
        <PropertyColumn Property="x => x.InvoiceDate" Title="Date"      Format="yyyy-MM-dd" />
        <PropertyColumn Property="x => x.NettPriceTotal" Title="Ex GST"  Format="C2" />
        <PropertyColumn Property="x => x.TotalIncGST"   Title="Inc GST"  Format="C2" />
        <PropertyColumn Property="x => x.InvoicedBy"  Title="By" />
        <TemplateColumn Title="Status" Sortable="false">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="@StatusColour(context.Item.StatusName)">
                    @context.Item.StatusName
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="" Sortable="false" CellStyle="width:180px;">
            <CellTemplate>
                <div class="d-flex gap-1">
                    <MudIconButton Icon="@Icons.Material.Rounded.Visibility" Size="Size.Small" Color="Color.Info"
                                   Href="@($"/invoices/{context.Item.InvoiceId}")" title="View" />
                    <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                   Href="@($"/invoices/{context.Item.InvoiceId}/edit")" title="Edit" />
                    <MudIconButton Icon="@Icons.Material.Rounded.PictureAsPdf" Size="Size.Small" Color="Color.Secondary"
                                   Href="@($"/api/pdf/invoice/{context.Item.InvoiceId}")" target="_blank" title="Print PDF" />
                    <MudIconButton Icon="@Icons.Material.Rounded.Email" Size="Size.Small" Color="Color.Default"
                                   Href="@($"/invoices/{context.Item.InvoiceId}")" title="Email" />
                    @if (_isAdmin)
                    {
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(context.Item))" title="Delete" />
                    }
                </div>
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent><MudDataGridPager T="Invoice" /></PagerContent>
</MudDataGrid>

@code {
    private List<Invoice>       _invoices = new();
    private List<InvoiceStatus> _statuses = new();
    private List<UserLookup>    _users    = new();
    [Parameter, SupplyParameterFromQuery(Name = "filter")]
    public string? Filter { get; set; }

    private bool    _loading  = true;
    private bool    _isAdmin;
    private string? _search;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private int     _statusId = 0;
    private string  _userCode = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin  = auth.User.IsInRole("Admin") ||
                    auth.User.FindFirst("IsAdmin")?.Value == "True";

        (_statuses, _users) = (
            await LookupService.GetInvoiceStatusesAsync(),
            await LookupService.GetUsersAsync());

        if (Filter == "thismonth")
        {
            var today = DateTime.Today;
            _dateFrom = new DateTime(today.Year, today.Month, 1);
            _dateTo   = today;
        }
        else if (Filter == "overdue")
        {
            _dateFrom = DateTime.Today.AddDays(-90);
            _dateTo   = DateTime.Today.AddDays(-30);
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _invoices = await InvoiceService.GetInvoicesAsync(
                _dateFrom, _dateTo, _search, _statusId,
                string.IsNullOrEmpty(_userCode) ? null : _userCode);
        }
        finally { _loading = false; }
    }

    private async Task ResetFilter()
    {
        _search = null; _dateFrom = null; _dateTo = null; _statusId = 0; _userCode = "";
        await LoadAsync();
    }

    private async Task DeleteAsync(Invoice inv)
    {
        bool? ok = await Dialog.ShowMessageBox("Delete Invoice",
            $"Delete invoice {inv.InvoiceNum} for {inv.CCompany}? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (ok != true) return;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var code = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
            await InvoiceService.DeleteAsync(inv.InvoiceId, code);
            _invoices.Remove(inv);
            Snackbar.Add("Invoice deleted.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private static Color StatusColour(string s) => s switch
    {
        "Draft"    => Color.Default,
        "Issued"   => Color.Success,
        "Paid"     => Color.Info,
        "Overdue"  => Color.Error,
        "Credited" => Color.Warning,
        _          => Color.Default,
    };

    private async Task ExportCsv()
    {
        if (!_invoices.Any())
        {
            Snackbar.Add("No data to export", Severity.Warning);
            return;
        }

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Invoice #,Customer,Division,Date,Ex GST,Inc GST,Status,By");

        foreach (var inv in _invoices)
        {
            sb.AppendLine($"\"{inv.InvoiceNum}\",\"{inv.CCompany}\",\"{inv.DivisionName}\",\"{inv.InvoiceDate:yyyy-MM-dd}\",{inv.NettPriceTotal.ToString("N2")},{inv.TotalIncGST.ToString("N2")},\"{inv.StatusName}\",\"{inv.InvoicedBy}\"");
        }

        var csv = sb.ToString();
        var fileName = $"Invoices_Export_{DateTime.Now:yyyyMMdd}.csv";

        await DownloadFile(fileName, csv);
        Snackbar.Add($"Exported {_invoices.Count} invoices", Severity.Success);
    }

    private void ShowBulkEmailDialog()
    {
        Snackbar.Add("Bulk email feature coming soon.", Severity.Info);
    }

    private void ShowBulkStatusDialog()
    {
        Snackbar.Add("Bulk status update feature coming soon.", Severity.Info);
    }

    private async Task DownloadFile(string fileName, string content)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:text/csv;base64,{base64}";
        await JsRuntime.InvokeVoidAsync("window.open", url, "_blank");
    }
}

