@page "/invoices/{Id:int}/despatch"
@attribute [Authorize]
@inject InvoiceService InvoiceService
@inject LookupService LookupService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

<PageTitle>Despatch Invoice @Id - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <a href="/invoices">Invoices</a><span class="sep">/</span>
            <a href="@($"/invoices/{Id}")">Invoice @Id</a><span class="sep">/</span>
            <span>Despatch</span>
        </div>
        <h1>Enter Despatch Details</h1>
    </div>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.ArrowBack"
               Href="@($"/invoices/{Id}")">Cancel</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else
{
    <div style="max-width:640px;">
        <MudPaper Class="pa-6" Elevation="1">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_date" Label="Despatch Date *" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect @bind-Value="_d.Carrier" Label="Carrier / Method" Variant="Variant.Outlined">
                        @foreach (var c in _carriers)
                        {
                            <MudSelectItem Value="@c">@c</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_d.CarrierRef" Label="Tracking / Carrier Ref" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_d.PackageDetails" Label="Package Details" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_d.InternalNotes" Label="Internal Notes" Variant="Variant.Outlined" Lines="3" />
                </MudItem>
            </MudGrid>

            <div class="d-flex gap-2 justify-end mt-4">
                <MudButton Variant="Variant.Outlined" Href="@($"/invoices/{Id}")">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Rounded.LocalShipping"
                           OnClick="SaveAsync" Disabled="@_saving">
                    @(_saving ? "Saving…" : "Save Despatch")
                </MudButton>
            </div>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private DespatchDetail _d       = new();
    private DateTime?      _date    = DateTime.Today;
    private bool           _loading = true;
    private bool           _saving;
    private string         _userCode = "";
    private List<string>   _carriers = new();

    protected override async Task OnInitializedAsync()
    {
        var auth  = await AuthStateProvider.GetAuthenticationStateAsync();
        _userCode = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        _carriers = LookupService.GetCarriers();

        var existing = await InvoiceService.GetDespatchAsync(Id);
        if (existing != null)
        {
            _d    = existing;
            _date = existing.DespatchDate;
            
            if (!string.IsNullOrEmpty(_d.Carrier) && !_carriers.Contains(_d.Carrier))
                _carriers.Add(_d.Carrier);
        }
        else
        {
            _d.InvoiceId = Id;
            _d.Carrier = _carriers.FirstOrDefault() ?? "";
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _d.InvoiceId    = Id;
        _d.DespatchDate = _date ?? DateTime.Today;
        _saving = true;
        try
        {
            await InvoiceService.SaveDespatchAsync(_d, _userCode);
            Snackbar.Add("Despatch details saved.", Severity.Success);
            Nav.NavigateTo($"/invoices/{Id}");
        }
        catch (Exception ex) { Snackbar.Add($"Save failed: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }
}

