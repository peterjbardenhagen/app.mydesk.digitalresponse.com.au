@inject CookieConsentService CookieSvc
@inject IJSRuntime JS

<div class="@(_class)" style="@_style">
    <MudPaper Elevation="8" Class="pa-4 cookie-banner" Style="position:fixed; bottom:0; left:0; right:0; z-index:9999;">
        <div class="d-flex align-center justify-space-between flex-wrap gap-3">
            <div class="flex:1;">
                <MudText Typo="Typo.body1" Class="mb-1">
                    <MudIcon Icon="@Icons.Material.Rounded.Cookie" Class="mr-2" />
                    Cookie Settings
                </MudText>
                <MudText Typo="Typo.body2" Style="color:var(--gray-600);">
                    We use cookies to enhance your experience. By continuing to visit this site you agree to our use of cookies. 
                    <MudLink Href="https://mydesk.digitalresponse.com.au/privacy.html" Target="_blank" Color="Color.Primary">
                        Privacy Policy
                    </MudLink>
                </MudText>
            </div>
            <div class="d-flex gap-2">
                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="RejectCookies">
                    Reject All
                </MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AcceptCookies">
                    Accept All
                </MudButton>
            </div>
        </div>
    </MudPaper>
</div>

<style>
    .cookie-banner {
        border-radius: 0;
        border-top: 1px solid var(--gray-200);
        background: var(--mud-palette-background) !important;
    }
</style>

@code {
    private string _class = "cookie-consent-show";
    private string _style = "";

    protected override void OnInitialized()
    {
        if (CookieSvc.IsConsentGiven())
        {
            _class = "cookie-consent-hidden";
        }
    }

    private void AcceptCookies()
    {
        CookieSvc.GiveConsent();
        _class = "cookie-consent-hidden";
        StateHasChanged();
    }

    private void RejectCookies()
    {
        CookieSvc.RevokeConsent();
        _class = "cookie-consent-hidden";
        StateHasChanged();
    }
}
