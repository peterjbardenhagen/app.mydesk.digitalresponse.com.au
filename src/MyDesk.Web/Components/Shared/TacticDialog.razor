@using MyDesk.Shared.Models

<MudDialog Options="new DialogOptions { CloseButton = true, CloseOnEscapeKey = true }">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">@Title</MudText>
        
        <MudTextField @bind-Value="_tactic.Title"
                     Label="Tactic Title"
                     Variant="Variant.Outlined"
                     Required="true"
                     RequiredError="Title is required"
                     Class="mb-3" />

        <MudTextField @bind-Value="_tactic.Description"
                     Label="Description"
                     Variant="Variant.Outlined"
                     Lines="3"
                     Required="true"
                     RequiredError="Description is required"
                     Class="mb-3" />

        <MudSelect @bind-Value="_tactic.Category"
                   Label="Category"
                   Variant="Variant.Outlined"
                   Required="true"
                   RequiredError="Category is required"
                   Class="mb-3">
            <MudSelectItem Value="@("Digital Marketing")">Digital Marketing</MudSelectItem>
            <MudSelectItem Value="@("Content Marketing")">Content Marketing</MudSelectItem>
            <MudSelectItem Value="@("Email Marketing")">Email Marketing</MudSelectItem>
            <MudSelectItem Value="@("Social Media")">Social Media</MudSelectItem>
            <MudSelectItem Value="@("Events")">Events</MudSelectItem>
            <MudSelectItem Value="@("Advertising")">Advertising</MudSelectItem>
            <MudSelectItem Value="@("Partnerships")">Partnerships</MudSelectItem>
        </MudSelect>

        <MudSelect @bind-Value="_tactic.Priority"
                   Label="Priority"
                   Variant="Variant.Outlined"
                   Required="true"
                   RequiredError="Priority is required"
                   Class="mb-3">
            <MudSelectItem Value="@("High")">High</MudSelectItem>
            <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
            <MudSelectItem Value="@("Low")">Low</MudSelectItem>
        </MudSelect>

        <MudNumericField @bind-Value="_tactic.Budget"
                        Label="Budget ($)"
                        Variant="Variant.Outlined"
                        Min="0"
                        Class="mb-3" />

        <MudDatePicker @bind-Date="_tactic.DueDate"
                      Label="Due Date"
                      PickerVariant="PickerVariant.Dialog"
                      Required="true"
                      RequiredError="Due date is required" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string Title { get; set; } = "Tactic";
    [Parameter] public MarketingTactic Tactic { get; set; } = new();

    private MarketingTactic _tactic = new();

    protected override void OnInitialized()
    {
        _tactic = Tactic;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_tactic.Title))
        {
            return;
        }

        MudDialog.Close(DialogResult.Ok(_tactic));
    }
}
