@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<MudLayout>
    <MudAppBar Elevation="0" Fixed="true" Dense="true">
        <MudIconButton Icon="@Icons.Material.Rounded.Menu" Color="Color.Default" Edge="Edge.Start" OnClick="DrawerToggle" />

        <a href="/" class="tl-logo-wrap ml-2" style="text-decoration:none;">
            <img src="/images/techlight-mark.svg" alt="Techlight" class="tl-logo-mark" />
            <span class="tl-logo-text-stack">
                <span class="tl-logo-brand">Techlight</span>
                <span class="tl-logo-product">MyDesk</span>
            </span>
        </a>

        <MudSpacer />

        <div class="d-none d-md-flex align-center" style="flex:1; max-width:420px; margin:0 24px;">
            <MudTextField T="string" Placeholder="Search quotes, invoices, contacts…"
                          Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search"
                          Style="background: var(--gray-50); border-radius: 8px;" />
        </div>

        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="Ask Techlight AI" Arrow="true" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Rounded.AutoAwesome" Color="Color.Primary" Href="/ask-ai" />
                </MudTooltip>
                <MudTooltip Text="Notifications" Arrow="true" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Rounded.NotificationsNone" Color="Color.Default" />
                </MudTooltip>

                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Dense="true" Class="ml-2">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Text" Class="pa-1" Style="min-width:auto; text-transform:none;">
                            <div class="d-flex align-center tl-gap-sm">
                                <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-weight:600;">
                                    @Initials(context.User.Identity?.Name)
                                </MudAvatar>
                                <div class="d-none d-md-flex flex-column" style="line-height:1.1; text-align:left;">
                                    <span style="font-size:13px; font-weight:600; color:var(--gray-900);">
                                        @context.User.Identity?.Name
                                    </span>
                                    <span style="font-size:11px; color:var(--gray-500);">
                                        Signed in
                                    </span>
                                </div>
                                <MudIcon Icon="@Icons.Material.Rounded.KeyboardArrowDown" Size="Size.Small" Color="Color.Default" />
                            </div>
                        </MudButton>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Rounded.Person" Href="/profile">Profile</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Rounded.Settings" Href="/settings">Settings</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Rounded.Logout" Href="/logout">Sign out</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Docked" Variant="DrawerVariant.Mini" OpenMiniOnHover="true">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8 px-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool _drawerOpen = true;

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpper(),
            _ => (parts[0][..1] + parts[^1][..1]).ToUpper()
        };
    }
}
