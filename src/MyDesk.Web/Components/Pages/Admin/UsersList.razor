@page "/admin/users"
@attribute [Authorize]
@inject UserService UserSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Users - Techlight MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/admin/setup">Admin</a>
            <span class="sep">/</span>
            <span style="color:var(--gray-700); font-weight:500;">Users</span>
        </div>
        <h1>Users</h1>
        <p class="tl-subtitle">Manage user accounts, roles and access.</p>
    </div>
    <div class="d-flex tl-gap-sm">
        <MudSwitch @bind-Value="_includeInactive" Color="Color.Primary" Label="Show inactive" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.PersonAdd"
                   OnClick="@(() => Nav.NavigateTo("/admin/users/new"))">Add user</MudButton>
    </div>
</div>

@if (_users == null)
{
    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Class="pa-0">
        <MudDataGrid T="User" Items="_filtered" Dense="true" Hover="true" Elevation="0" SortMode="SortMode.Multiple"
                     Filterable="true" QuickFilter="@QuickFilter">
            <ToolBarContent>
                <MudTextField T="string" Placeholder="Search users..." @bind-Value="_search"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                              IconSize="Size.Small" Class="mt-0" Immediate="true"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.Code" Title="Code" />
                <PropertyColumn Property="x => x.Name" Title="Name" />
                <PropertyColumn Property="x => x.Email" Title="Email" />
                <TemplateColumn Title="Role" Sortable="true">
                    <CellTemplate>
                        @if (IsCurrentUser(context.Item))
                        {
                            <span style="color: var(--mud-palette-action-disabled);">@context.Item.Role</span>
                        }
                        else
                        {
                            @context.Item.Role
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Status" Sortable="false">
                    <CellTemplate>
                        @if (IsActive(context.Item))
                        {
                            <span class="tl-badge success">Active</span>
                        }
                        else
                        {
                            <span class="tl-badge">Inactive</span>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" Sortable="false">
                    <CellTemplate>
                        <div class="d-flex tl-gap-sm">
                            <MudIconButton Icon="@Icons.Material.Rounded.Insights" Size="Size.Small" Color="Color.Secondary"
                                           Href="@($"/admin/users/{context.Item.UserId}/profile")" title="Performance Profile" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                           Href="@($"/admin/users/{context.Item.UserId}/edit")" title="Edit" />
                            <MudIconButton Icon="@(IsActive(context.Item) ? Icons.Material.Rounded.PersonOff : Icons.Material.Rounded.PersonAddAlt)"
                                           Size="Size.Small" Color="Color.Default"
                                           OnClick="@(() => ToggleActive(context.Item))"
                                           title="@(IsActive(context.Item) ? "Deactivate" : "Activate")" />
                        </div>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent>
                <MudDataGridPager T="User" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<User>? _users;
    private string _search = "";
    private bool _includeInactive = false;
    private int? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext?.User?.Identity?.IsAuthenticated == true)
        {
            var userIdClaim = httpContext.User.FindFirst("UserId")?.Value;
            if (int.TryParse(userIdClaim, out var uid))
                _currentUserId = uid;
        }
        await Load();
    }

    private async Task Load()
    {
        _users = await UserSvc.GetAllAsync(includeInactive: true);
    }

    private IEnumerable<User> _filtered =>
        (_users ?? Enumerable.Empty<User>())
        .Where(u => _includeInactive || u.Active);

    private Func<User, bool> QuickFilter => u =>
        string.IsNullOrWhiteSpace(_search) ||
        (u.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (u.Code?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (u.Email?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);

    private static bool IsActive(User u) => u.Active;

    private bool IsCurrentUser(User u) => u.UserId == _currentUserId;

    private async Task ToggleActive(User u)
    {
        try
        {
            await UserSvc.SetActiveAsync(u.UserId, false);
            Snackbar.Add($"Updated {u.Name}", Severity.Success);
            await Load();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
    }
}

