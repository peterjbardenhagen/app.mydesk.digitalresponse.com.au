@page "/forgot-password"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject PlatformSettingsService PlatformSettings

<PageTitle>Forgot Password - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="tl-login-root">
    <!-- LEFT: Brand Hero -->
    <aside class="tl-login-hero">
        <div class="tl-login-hero-inner">
            <div class="tl-login-hero-brand">
                <img src="/images/techlight-logo.svg" alt="@PlatformSettings.GetBrandingName()" class="hero-logo" />
            </div>

            <div class="tl-login-quote-wrap">
                <div class="tl-quote-icon">
                    <MudIcon Icon="@Icons.Material.Rounded.LockReset" Size="Size.Large" Color="Color.Inherit" />
                </div>
                <h2 class="tl-login-quote-text">
                    Reset your password securely.
                </h2>
                <div class="tl-login-quote-author">
                    <span>@PlatformSettings.GetBrandingName() &middot; <span class="accent-text">Password Recovery</span></span>
                </div>
            </div>

            <div class="tl-login-hero-footer">
                <div class="legal-links-white">
                    <MudLink Href="/privacy-policy" Typo="Typo.caption">Privacy Policy</MudLink>
                    <span class="mx-2 opacity-30">|</span>
                    <MudLink Href="/terms-and-conditions" Typo="Typo.caption">Terms & Conditions</MudLink>
                </div>
                <div class="copyright-text">
                    &copy; @DateTime.Now.Year Digital Response. All rights reserved.
                </div>
            </div>
        </div>
        
        <!-- Decorative Elements -->
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
        <div class="hero-grid-pattern"></div>
    </aside>

    <!-- RIGHT: Forgot Password Form -->
    <section class="tl-login-form-area">
        <div class="tl-login-form-container">
            <div class="tl-form-card">
                <div class="tl-form-header">
                    <div class="tl-mark-container">
                        <img src="/images/techlight-mark.svg" alt="" class="tl-form-mark" />
                    </div>
                    <h1>Forgot your password?</h1>
                    <p class="sub-text">Enter your email address and we'll send you a link to reset your password.</p>
                </div>

                @if (ShowSuccess)
                {
                    <MudAlert Severity="Severity.Success" Dense="true" Class="mb-6 rounded-lg" Variant="Variant.Filled">
                        If an account exists with that email, a password reset link has been sent. Please check your inbox.
                    </MudAlert>
                }

                @if (!ShowSuccess)
                {
                    <form method="post" action="/api/auth/forgot-password" class="login-auth-form">
                        <AntiforgeryToken />
                        <div class="field-wrap">
                            <label>Email address</label>
                            <MudTextField @bind-Value="Email" name="email"
                                          Placeholder="you@company.com"
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Normal"
                                          Required="true" FullWidth="true"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Rounded.Email"
                                          AdornmentColor="Color.Primary" />
                        </div>

                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                                   Size="Size.Large" FullWidth="true" Class="py-3 rounded-xl submit-btn">
                            Send Reset Link
                        </MudButton>
                    </form>
                }

                <div class="tl-form-footer">
                    <p>Remember your password? <MudLink Href="/login" Color="Color.Primary" Underline="Underline.Hover">Back to login</MudLink></p>
                </div>
            </div>
        </div>
    </section>
</div>

<style>
    /* Google Fonts Import */
    @@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap');

    /* Theme Variables */
    :root {
        --tl-primary: @PlatformSettings.Current.LoginPrimaryColor;
        --tl-accent: @PlatformSettings.Current.LoginAccentColor;
        --tl-login-bg: @PlatformSettings.Current.LoginBackgroundColor;
    }

    .tl-login-root {
        display: grid;
        grid-template-columns: 1fr;
        min-height: 100vh;
        background: #f8fafc;
        font-family: 'Outfit', 'Inter', sans-serif;
    }

    @@media (min-width: 1024px) {
        .tl-login-root { grid-template-columns: 1.1fr 0.9fr; }
    }

    /* Hero Section */
    .tl-login-hero {
        display: none;
        position: relative;
        background-color: var(--tl-login-bg);
        background-image: 
            radial-gradient(at 0% 0%, var(--tl-primary)22 0, transparent 50%), 
            radial-gradient(at 100% 100%, var(--tl-accent)1a 0, transparent 50%);
        color: white;
        padding: 64px;
        overflow: hidden;
    }

    @@media (min-width: 1024px) { 
        .tl-login-hero { display: flex; flex-direction: column; } 
    }

    .tl-login-hero-inner {
        position: relative;
        z-index: 10;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .hero-logo { height: 48px; width: auto; }

    .tl-login-quote-wrap { max-width: 520px; margin-top: -60px; }
    .tl-quote-icon { margin-bottom: 24px; color: var(--tl-primary); opacity: 0.8; }
    .tl-login-quote-text { 
        font-size: 38px; 
        font-weight: 700; 
        line-height: 1.2; 
        letter-spacing: -0.02em; 
        margin-bottom: 24px;
        background: linear-gradient(to bottom right, #fff 10%, #cbd5e1 90%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    .tl-login-quote-author { font-size: 16px; color: #94a3b8; font-weight: 500; }
    .accent-text { color: var(--tl-primary); font-weight: 600; }

    .legal-links-white .mud-link { color: #64748b !important; font-weight: 500; }
    .legal-links-white .mud-link:hover { color: white !important; }
    .copyright-text { margin-top: 12px; font-size: 12px; color: #475569; }

    /* Decorative Blobs */
    .hero-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        z-index: 1;
        opacity: 0.4;
    }
    .blob-1 { top: -10%; left: -10%; width: 400px; height: 400px; background: var(--tl-primary); }
    .blob-2 { bottom: -5%; right: -5%; width: 350px; height: 350px; background: var(--tl-accent); opacity: 0.2; }
    .hero-grid-pattern {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(rgba(255,255,255,0.05) 1px, transparent 1px);
        background-size: 32px 32px;
        mask-image: radial-gradient(ellipse at center, black, transparent 80%);
        opacity: 0.5;
    }

    /* Form Section */
    .tl-login-form-area {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
    }

    .tl-login-form-container { width: 100%; max-width: 440px; }
    
    .tl-form-card {
        background: white;
        padding: 40px;
        border-radius: 24px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
        border: 1px solid #f1f5f9;
        transition: all 0.3s ease;
    }

    .tl-mark-container { margin-bottom: 32px; }
    .tl-form-mark { height: 56px; }

    .tl-form-header h1 { font-size: 32px; font-weight: 700; color: #0f172a; margin-bottom: 8px; letter-spacing: -0.01em; }
    .sub-text { font-size: 16px; color: #64748b; margin-bottom: 32px; }

    .field-wrap label { font-size: 14px; font-weight: 600; color: #334155; margin-bottom: 4px; display: block; }
    
    .submit-btn { 
        font-weight: 700 !important; 
        letter-spacing: 0.02em !important;
        box-shadow: 0 10px 15px -3px rgba(0, 200, 200, 0.25) !important;
        transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) !important;
    }
    .submit-btn:hover { transform: translateY(-2px); }
    .submit-btn:active { transform: translateY(0); }

    .tl-form-footer { margin-top: 32px; text-align: center; font-size: 14px; color: #64748b; border-top: 1px solid #f1f5f9; padding-top: 24px; }

    /* Custom Transitions */
    .tl-form-card {
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* MudBlazor Adjustment */
    .mud-input-outlined-border { border-width: 1.5px !important; }
    .mud-input-control { margin-top: 0 !important; margin-bottom: 0 !important; }
</style>

@code {
    [SupplyParameterFromQuery]
    public string? Success { get; set; }

    private bool ShowSuccess => Success == "1";
    private string? Email { get; set; }
}


