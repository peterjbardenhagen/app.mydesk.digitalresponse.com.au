@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_uploadStep == UploadStep.SelectFile)
        {
            <MudText Typo="Typo.h6" Class="mb-4">Upload Receipt</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">
                Take a photo or upload a receipt image. AI will automatically extract the details for you.
            </MudText>
            
            <MudFileUpload T="IBrowserFile" OnFilesChanged="HandleFileSelected" Accept=".jpg,.jpeg,.png">
                <ButtonTemplate>
                    <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.PhotoCamera" FullWidth="true">
                        Choose Receipt Photo
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload>

            @if (!string.IsNullOrEmpty(_previewUrl))
            {
                <div class="mt-4">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Preview</MudText>
                    <img src="@_previewUrl" alt="Preview" style="max-width: 100%; max-height: 300px;" />
                </div>
            }
        }
        else if (_uploadStep == UploadStep.Uploading)
        {
            <div class="text-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mt-4">Uploading and extracting receipt details...</MudText>
            </div>
        }
        else if (_uploadStep == UploadStep.Review)
        {
            <MudText Typo="Typo.h6" Class="mb-4">Review Extracted Data</MudText>
            
            @if (_extraction != null)
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                    Confidence: @($"{_extraction.Confidence:P0}")
                    @if (_extraction.RequiresManualReview)
                    {
                        <span> - <strong>Please review and correct fields below</strong></span>
                    }
                </MudAlert>

                <MudStack Spacing="3">
                    <MudTextField T="string" Label="Supplier" @bind-Value="_correctedSupplier" Variant="Variant.Outlined" FullWidth="true" />
                    <MudTextField T="decimal?" Label="Amount" @bind-Value="_correctedAmount" Variant="Variant.Outlined" FullWidth="true" />
                    <MudDatePicker Label="Date" @bind-Date="_correctedDate" Variant="Variant.Outlined" />
                    <MudTextField T="string" Label="Description" @bind-Value="_correctedDescription" Variant="Variant.Outlined" Lines="3" FullWidth="true" />
                </MudStack>
            }
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="CancelAsync">Cancel</MudButton>
        
        @if (_uploadStep == UploadStep.SelectFile)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="UploadReceiptAsync" Disabled="string.IsNullOrEmpty(_previewUrl)">
                Upload & Extract
            </MudButton>
        }
        else if (_uploadStep == UploadStep.Review)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ConfirmAsync">
                Confirm & Save
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance? MudDialog { get; set; }
    [Parameter] public int ExpenseId { get; set; }

    private enum UploadStep { SelectFile, Uploading, Review }
    private UploadStep _uploadStep = UploadStep.SelectFile;
    private string? _previewUrl;
    private IBrowserFile? _selectedFile;

    private ExtractionResult? _extraction;
    private string? _correctedSupplier;
    private decimal? _correctedAmount;
    private DateTime? _correctedDate;
    private string? _correctedDescription;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;

        try
        {
            var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10485760);
            var bytes = new byte[_selectedFile.Size];
            await stream.ReadAsync(bytes);
            
            _previewUrl = $"data:{_selectedFile.ContentType};base64,{Convert.ToBase64String(bytes)}";
            await stream.DisposeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading file: {ex.Message}", Severity.Error);
            _selectedFile = null;
            _previewUrl = null;
        }
    }

    private async Task UploadReceiptAsync()
    {
        if (_selectedFile == null)
        {
            Snackbar.Add("Please select a receipt photo", Severity.Warning);
            return;
        }

        _uploadStep = UploadStep.Uploading;

        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 10485760);
            using var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(_selectedFile.ContentType);
            content.Add(streamContent, "receipt", _selectedFile.Name);

            var response = await Http.PostAsync($"/api/expenses/{ExpenseId}/receipt/upload", content);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                var result = System.Text.Json.JsonSerializer.Deserialize<UploadResponse>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (result?.Extraction != null)
                {
                    _extraction = result.Extraction;
                    _correctedSupplier = _extraction.SupplierName;
                    _correctedAmount = _extraction.Amount;
                    _correctedDate = _extraction.Date;
                    _uploadStep = UploadStep.Review;
                }
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Upload failed: {error}", Severity.Error);
                _uploadStep = UploadStep.SelectFile;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error uploading receipt: {ex.Message}", Severity.Error);
            _uploadStep = UploadStep.SelectFile;
        }
    }

    private void ConfirmAsync()
    {
        MudDialog?.Close(DialogResult.Ok(new
        {
            ReceiptId = _extraction?.ReceiptId,
            CorrectedSupplier = _correctedSupplier,
            CorrectedAmount = _correctedAmount,
            CorrectedDate = _correctedDate,
            CorrectedDescription = _correctedDescription
        }));
    }

    private void CancelAsync()
    {
        MudDialog?.Cancel();
    }

    public class UploadResponse
    {
        public int ReceiptId { get; set; }
        public ExtractionResult? Extraction { get; set; }
    }

    public class ExtractionResult
    {
        public int ReceiptId { get; set; }
        public string? SupplierName { get; set; }
        public DateTime? Date { get; set; }
        public decimal Amount { get; set; }
        public decimal GstAmount { get; set; }
        public double Confidence { get; set; }
        public bool AuditPassed { get; set; }
        public string? Strategy { get; set; }
        public bool RequiresManualReview { get; set; }
    }
}

