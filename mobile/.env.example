# API Configuration
EXPO_PUBLIC_API_BASE_URL=https://api-staging.mydesk.com.au
EXPO_PUBLIC_API_TIMEOUT=10000

# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=mydesk-firebase.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=mydesk-firebase
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=mydesk-firebase.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# App Configuration
EXPO_PUBLIC_LOG_LEVEL=info
EXPO_PUBLIC_ENABLE_OFFLINE_MODE=true

# Development
DEBUG=*
NODE_ENV=development
