@using MyDesk.Shared.Models
@using MyDesk.Shared.Services
@inject ContactService ContactService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">Import Contacts & Companies from Invoices</MudText>
        <MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--gray-600);">
            This will scan existing invoices and extract unique companies and contacts that are not already in the system.
        </MudText>
        
        @if (_loading)
        {
            <div class="d-flex justify-center my-4">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else
        {
            <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background:var(--gray-50);">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Found:</MudText>
                <div class="d-flex gap-4">
                    <div>
                        <MudText Typo="Typo.h4" Style="color:var(--tl-primary);">@_newCompanies</MudText>
                        <MudText Typo="Typo.caption">New Companies</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.h4" Style="color:var(--tl-primary);">@_newContacts</MudText>
                        <MudText Typo="Typo.caption">New Contacts</MudText>
                    </div>
                </div>
            </MudPaper>
        }
        
        @if (_error != null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-2">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" 
                   OnClick="ImportAsync" Disabled="@(_loading || (_newCompanies == 0 && _newContacts == 0))">
            @if (_importing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Import Data
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    
    private int _newCompanies = 0;
    private int _newContacts = 0;
    private bool _loading = true;
    private bool _importing = false;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadPreviewAsync();
    }

    private async Task LoadPreviewAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var result = await ContactService.PreviewImportFromInvoicesAsync();
            _newCompanies = result.NewCompanies;
            _newContacts = result.NewContacts;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ImportAsync()
    {
        _importing = true;
        _error = null;
        try
        {
            var result = await ContactService.ImportFromInvoicesAsync();
            Snackbar.Add($"Imported {result.CompaniesImported} companies and {result.ContactsImported} contacts", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importing = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
