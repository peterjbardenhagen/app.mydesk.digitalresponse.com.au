@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject PlatformSettingsService PlatformSettings

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudDialogProvider CloseButton="true" BackdropClick="true" CloseOnEscapeKey="true" FullWidth="true" MaxWidth="MaxWidth.Small" Position="DialogPosition.Center" />
<MudSnackbarProvider />

@* Global keyboard shortcut listener *@
<div @onkeydown="OnGlobalKeyDown" tabindex="-1" style="outline:none;">

<MudLayout id="main-content" role="main">
    <MudAppBar Elevation="0" Dense="true" Style="position:relative; overflow:visible;" role="banner" aria-label="Main navigation">
        <!-- Brand Swoosh -->
        <div class="tl-brand-swoosh d-none d-sm-block">
            <div class="tl-swoosh-accent-line"></div>
            <div class="tl-swoosh-gold-dot tl-swoosh-gold-dot-1"></div>
            <div class="tl-swoosh-gold-dot tl-swoosh-gold-dot-2"></div>
            <div class="tl-swoosh-gold-dot tl-swoosh-gold-dot-3"></div>
        </div>

        <MudIconButton Icon="@Icons.Material.Rounded.Menu" Color="Color.Default" Edge="Edge.Start" OnClick="DrawerToggle" aria-label="Toggle navigation menu" />

        <MudLink Href="/" Underline="Underline.None" Class="d-flex align-center ml-2">
            <div class="tl-logo-wrap">
                <img src="/images/mydesk-logo-color.svg" class="tl-logo-mark" alt="MyDesk" style="width: auto; height: 32px; max-width: 150px;" />
            </div>
        </MudLink>

        <MudSpacer />

        <div class="d-none d-lg-flex align-center" style="flex:1; max-width:420px; margin:0 24px;" role="search">
            <MudTextField T="string" @bind-Value="_searchQuery"
                          Placeholder="Search quotes, invoices, POs, contacts…"
                          Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Rounded.Search"
                          @onkeydown="OnSearchKeyDown" 
                          @onfocus="@(async () => await OnSearchFocus())"
                          Immediate="true"
                          aria-label="Search"
                          Style="background: var(--gray-50); border-radius: 8px;" />
            @if (_showSearchHistory && _searchHistory.Any())
            {
                <div class="search-history-dropdown">
                    <MudText Typo="Typo.caption" Class="px-3 py-2 mud-text-secondary">Recent Searches</MudText>
                    @foreach (var search in _searchHistory.Take(5))
                    {
                        <div class="search-history-item" @onclick="() => SelectSearchHistory(search)">
                            <MudIcon Icon="@Icons.Material.Rounded.History" Size="Size.Small" Class="mr-2" />
                            <MudText Typo="Typo.body2">@search</MudText>
                        </div>
                    }
                </div>
            }
        </div>

        <AuthorizeView Context="authContext">
            <Authorized Context="authContext">
                <MudTooltip Text="@_aiTooltipText" Arrow="true" Placement="Placement.Bottom">
                    <MudIconButton Icon="@Icons.Material.Rounded.AutoAwesome" Color="Color.Primary" Href="/ask-ai" aria-label="Ask AI" />
                </MudTooltip>
...
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Dense="true" Class="ml-1" aria-label="Notifications" Context="notifContext">
                    <ActivatorContent>
                        <div style="position:relative; display:inline-flex; align-items:center; justify-content:center;">
                            <MudTooltip Text="Notifications" Arrow="true" Placement="Placement.Bottom">
                                <MudIconButton Icon="@Icons.Material.Rounded.Notifications" Color="Color.Default" aria-label="Notifications" />
                            </MudTooltip>
                            @if (_notificationCount > 0)
                            {
                                <span class="notification-badge">@_notificationCount</span>
                            }
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        ...
                    </ChildContent>
                </MudMenu>

                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Dense="true" Class="ml-1" aria-label="Notifications" Context="notifContext">
                    <ActivatorContent>
                        <div style="position:relative; display:inline-flex; align-items:center; justify-content:center;">
                            <MudTooltip Text="Notifications" Arrow="true" Placement="Placement.Bottom">
                                <MudIconButton Icon="@Icons.Material.Rounded.Notifications" Color="Color.Default" aria-label="Notifications" />
                            </MudTooltip>
                            @if (_notificationCount > 0)
                            {
                                <span class="notification-badge">@_notificationCount</span>
                            }
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <div style="min-width: 350px; max-height: 400px; overflow-y: auto;">
                            <div class="pa-3 d-flex align-center justify-space-between" style="border-bottom: 1px solid var(--mud-palette-divider);">
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">Notifications</MudText>
                                @if (_notifications.Any())
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" OnClick="ClearNotifications">Clear All</MudButton>
                                }
                            </div>
                            @if (_notifications.Any())
                            {
                                @foreach (var notification in _notifications)
                                {
                                    <div class="notification-item pa-3 cursor-pointer hover-bg-light" 
                                         style="border-bottom: 1px solid var(--mud-palette-divider); position:relative;"
                                         @onclick="() => NavigateToNotification(notification)">
                                        <div class="d-flex gap-2 pr-6">
                                            <MudIcon Icon="@GetNotificationIcon(notification.Type)" Color="@GetNotificationColor(notification.Type)" Size="Size.Small" />
                                            <div style="flex:1;">
                                                <MudText Typo="Typo.body2" Style="font-weight:600;">@notification.Title</MudText>
                                                <MudText Typo="Typo.caption" Style="color: var(--gray-600); display:block;">@notification.Message</MudText>
                                                <MudText Typo="Typo.caption" Style="color: var(--gray-400); font-size:10px;">@notification.Time</MudText>
                                            </div>
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Rounded.Close" Size="Size.Small" 
                                                       Style="position:absolute; top:8px; right:8px;"
                                                       StopPropagation="true"
                                                       OnClick="@(() => RemoveNotification(notification))" />
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="pa-10 text-center">
                                    <MudIcon Icon="@Icons.Material.Rounded.NotificationsNone" Style="font-size:3rem; color: var(--gray-200);" />
                                    <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--gray-500);">All caught up!</MudText>
                                </div>
                            }
                        </div>
                    </ChildContent>
                </MudMenu>

                <MudTooltip Text="Keyboard shortcuts" Arrow="true" Placement="Placement.Bottom" Class="ml-2 d-none d-sm-inline-flex">
                    <MudIconButton Icon="@Icons.Material.Rounded.Keyboard" Color="Color.Default" OnClick="OpenKeyboardShortcuts" aria-label="Keyboard shortcuts" />
                </MudTooltip>

                <MudTooltip Text="Toggle dark mode" Arrow="true" Placement="Placement.Bottom" Class="ml-2 d-none d-sm-inline-flex">
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)"
                                  Color="Color.Default"
                                  OnClick="ToggleDarkMode"
                                  aria-label="Toggle dark mode" />
                </MudTooltip>

                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight"
                         Dense="true" Class="ml-2" aria-label="User menu">
                    <ActivatorContent>
                        <div class="d-flex align-center tl-gap-sm cursor-pointer pa-1 rounded hover-bg-light" style="user-select:none;">
                            <MudAvatar Color="Color.Primary" Size="Size.Small" Style="font-weight:600;" aria-hidden="true">
                                @Initials(authContext.User.Identity?.Name)
                            </MudAvatar>
                            <div class="d-none d-md-flex flex-column" style="line-height:1.1; text-align:left;">
                                <span style="font-size:13px; font-weight:600; color:var(--gray-900);">
                                    @authContext.User.Identity?.Name
                                </span>
                                <span style="font-size:11px; color:var(--gray-500);">
                                    Signed in
                                </span>
                            </div>
                            <MudIcon Icon="@Icons.Material.Rounded.KeyboardArrowDown" Size="Size.Small" Color="Color.Default" aria-hidden="true" />
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <MudMenuItem Icon="@Icons.Material.Rounded.Person" Href="/profile">Profile</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Rounded.Settings" Href="/settings">Settings</MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Rounded.Logout" Href="/logout">Sign out</MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/login">Login</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Docked" 
               Variant="DrawerVariant.Mini" OpenMiniOnHover="true" 
               Width="280px" MiniWidth="72px"
               Class="tl-nav-drawer" role="navigation" aria-label="Main navigation">
        <NavMenu />
    </MudDrawer>

    <MudMainContent role="main" aria-live="polite">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-8 px-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>
</div>

@code {
    private MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1e40af",
            AppbarBackground = "#ffffff",
            Background = "#f8fafc",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            ActionDefault = "#64748b",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#60a5fa",
            AppbarBackground = "#0f172a",
            Background = "#020617",
            Surface = "#0f172a",
            DrawerBackground = "#0f172a",
            TextPrimary = "#f8fafc",
            TextSecondary = "#94a3b8",
            ActionDefault = "#94a3b8",
            Divider = "rgba(255, 255, 255, 0.08)",
            TableLines = "rgba(255, 255, 255, 0.08)",
            LinesDefault = "rgba(255, 255, 255, 0.08)",
        }
    };

    bool _drawerOpen = true;
    private bool _isDarkMode;
    private string _searchQuery = "";
    private string _moduleSearchQuery = "";
    private bool _moduleSwitcherOpen;
    private List<string> _searchHistory = new();
    private bool _showSearchHistory = false;
    
    private record ModuleLink(string Title, string Href);
    private List<ModuleLink> GetAllModules() => new()
    {
        new("Dashboard", "/"),
        new("Latest Activity", "/activity"),
        new("Favourites", "/favourites"),
        new("Files Library", "/files"),
        new("Contacts", "/contacts"),
        new("Companies", "/companies"),
        new("Quotes", "/quotes"),
        new("Invoices", "/invoices"),
        new("Despatch", "/despatch"),
        new("Purchase Orders", "/purchase-orders"),
        new("Expenses", "/expenses"),
        new("Job Orders", "/job-orders"),
        new("Products", "/products"),
        new("Reports", "/reports"),
        new("Noticeboard", "/noticeboard"),
        new("Marketing Hub", "/marketing"),
        new("Setup", "/admin/setup"),
        new("Users", "/admin/users"),
        new("Integrations", "/integrations"),
        new("Settings", "/settings"),
        new("Ask AI", "/ask-ai"),
        new("Profile", "/profile"),
    };
    
    private int _notificationCount => _notifications.Count;
    private List<NotificationItem> _notifications = new();
    private string _aiTooltipText => $"Ask {PlatformSettings.GetBrandingName()} AI";
    
    private bool IsSpecialPage => NavigationManager.Uri.Contains("/help/roadmap") || NavigationManager.Uri.Contains("/pricing");


    [Inject] IJSRuntime JS { get; set; } = null!;
    [Inject] IDialogService DialogService { get; set; } = null!;

    public class NotificationItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Type { get; set; } = "";
        public string Time { get; set; } = "";
        public string? Url { get; set; }
    }

    void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await JS.InvokeVoidAsync("localStorage.setItem", "darkMode", _isDarkMode);
        ApplyDarkMode();
    }

    private void ApplyDarkMode()
    {
        // MudThemeProvider handles the primary dark mode switching for MudBlazor components
        // We also toggle the class on body for our custom CSS variables
        JS.InvokeVoidAsync("eval", _isDarkMode 
            ? "document.body.classList.add('mud-dark-mode')" 
            : "document.body.classList.remove('mud-dark-mode')");
    }

    private void OnGlobalKeyDown(KeyboardEventArgs e)
    {
        // Support ALT key shortcuts as requested
        if (e.AltKey)
        {
            switch (e.Key.ToLower())
            {
                case "k": 
                    // Open search
                    NavigationManager.NavigateTo("/search");
                    break;
                case "h": 
                    NavigationManager.NavigateTo("/");
                    break;
                case "b": 
                    DrawerToggle();
                    break;
            }
        }
        else if (e.Key == "?")
        {
            OpenKeyboardShortcuts();
        }
    }

    protected override async Task OnInitializedAsync()
    {
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSearchHistory();
        }
    }

    private async Task LoadSearchHistory()
    {
        try
        {
            var historyJson = await JS.InvokeAsync<string>("localStorage.getItem", "searchHistory");
            if (!string.IsNullOrWhiteSpace(historyJson))
            {
                _searchHistory = System.Text.Json.JsonSerializer.Deserialize<List<string>>(historyJson) ?? new();
            }
        }
        catch
        {
            // JS interop not available during prerendering
        }
    }

    private async Task SaveSearchHistory()
    {
        var historyJson = System.Text.Json.JsonSerializer.Serialize(_searchHistory);
        await JS.InvokeVoidAsync("localStorage.setItem", "searchHistory", historyJson);
    }

    private async Task OnSearchFocus()
    {
        _showSearchHistory = _searchHistory.Any();
    }

    private void SelectSearchHistory(string search)
    {
        _searchQuery = search;
        _showSearchHistory = false;
        NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(search)}");
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _showSearchHistory = false;
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                // Save to search history
                _searchHistory.Remove(_searchQuery);
                _searchHistory.Insert(0, _searchQuery);
                if (_searchHistory.Count > 10) _searchHistory.RemoveAt(_searchHistory.Count - 1);
                await SaveSearchHistory();
                
                NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery)}");
            }
        }
        else if (e.Key == "Escape")
        {
            _showSearchHistory = false;
        }
    }

    static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpper(),
            _ => (parts[0][..1] + parts[^1][..1]).ToUpper()
        };
    }


    private void ClearNotifications()
    {
        _notifications.Clear();
    }

    private void RemoveNotification(NotificationItem item)
    {
        _notifications.Remove(item);
    }

    private void NavigateToNotification(NotificationItem item)
    {
        if (!string.IsNullOrEmpty(item.Url))
        {
            NavigationManager.NavigateTo(item.Url);
        }
    }

    private string GetNotificationIcon(string type) => type.ToLower() switch
    {
        "info" => Icons.Material.Rounded.Info,
        "success" => Icons.Material.Rounded.CheckCircle,
        "warning" => Icons.Material.Rounded.Warning,
        "error" => Icons.Material.Rounded.Error,
        _ => Icons.Material.Rounded.Notifications
    };

    private Color GetNotificationColor(string type) => type.ToLower() switch
    {
        "info" => Color.Info,
        "success" => Color.Success,
        "warning" => Color.Warning,
        "error" => Color.Error,
        _ => Color.Default
    };

    private async Task OpenKeyboardShortcuts()
    {
        var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<KeyboardShortcutsDialog>("Keyboard Shortcuts", options);
    }
}

<style>
    :root {
        --blue-600: #1e40af;
        --gray-50: #f8fafc;
        --gray-100: #f1f5f9;
        --gray-200: #e2e8f0;
        --gray-300: #cbd5e1;
        --gray-400: #94a3b8;
        --gray-500: #64748b;
        --gray-600: #475569;
        --gray-700: #334155;
        --gray-800: #1e293b;
        --gray-900: #0f172a;
    }

    .notification-badge {
        position: absolute;
        top: 6px;
        right: 6px;
        background: #ef4444;
        color: white;
        font-size: 10px;
        font-weight: 700;
        min-width: 16px;
        height: 16px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 4px;
        border: 2px solid var(--mud-palette-appbar-background);
        pointer-events: none;
        z-index: 10;
        transform: translate(25%, -25%);
    }

    /* Fix Sidebar Mini clipping */
    .mud-drawer-mini .mud-nav-link {
        padding-left: 0 !important;
        padding-right: 0 !important;
        justify-content: center !important;
    }
    .mud-drawer-mini .mud-nav-link-icon {
        margin-right: 0 !important;
    }
    .mud-drawer-mini .mud-nav-menu {
        overflow-x: hidden;
    }

    /* Mobile Header Adjustments */
    @@media (max-width: 600px) {
        .mud-appbar-dense .mud-toolbar-appbar {
            padding-left: 8px !important;
            padding-right: 8px !important;
        }
        .tl-logo-mark { height: 26px !important; }
        .mud-main-content { padding-top: 56px !important; }
    }

    /* Global Dark Mode fixes */
    .mud-dark-mode {
        --gray-50: #020617;
        --gray-100: #0f172a;
        --gray-200: #1e293b;
        --gray-900: #f8fafc;
    }
    .mud-dark-mode .mud-table { background-color: var(--gray-50) !important; }
    .mud-dark-mode .tl-nav-drawer { 
        background: linear-gradient(180deg, #0f172a 0%, #020617 100%) !important;
        border-right: 1px solid rgba(255,255,255,0.05) !important;
    }
    .mud-dark-mode .mud-drawer { background-color: var(--gray-100) !important; }
    .mud-dark-mode .mud-appbar { 
        background-color: var(--gray-100) !important;
        border-bottom: 1px solid rgba(255,255,255,0.05) !important; 
    }
    .mud-dark-mode .tl-logo-brand { color: #fff !important; }
    .mud-dark-mode .tl-logo-product { color: #94a3b8 !important; }
    .mud-dark-mode .tl-logo-mark { content: url('/images/mydesk-logo-white-text.svg'); }
    
    /* Light mode nav drawer styling */
    .tl-nav-drawer {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border-right: 1px solid rgba(0,0,0,0.05);
    }
    
    /* Ensure MudDialogs are clickable-out */
    .mud-dialog-container {
        cursor: pointer;
    }
    .mud-dialog {
        cursor: default;
    }
</style>




