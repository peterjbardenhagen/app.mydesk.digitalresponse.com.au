        new("Admin", "Part Codes", "/admin/part-codes"),
        new("Admin", "Platform Admin", "/admin/platform"),
        new("Admin", "PO Status", "/admin/po-status"),
        new("Admin", "Quote Status", "/admin/quote-status"),
        new("Admin", "Settings", "/settings"),
        new("Admin", "Setup Home", "/admin/setup"),
        new("Admin", "Setup Menu", "/admin/setup-menu"),
        new("Admin", "Tenant Settings", "/admin/tenants"),
        new("Admin", "User Roles", "/admin/user-roles"),
        new("Admin", "Users", "/admin/users"),

        // ── AI ──
        new("AI", "AI Audit Log", "/admin/ai-audit"),
        new("AI", "AI User Guide", "/help/ai-guide"),
        new("AI", "Ask AI", "/ask-ai"),
        new("AI", "Marketing AI", "/marketing/ai"),

        // ── CRM ──
        new("CRM", "Call Reports", "/call-reports"),
        new("CRM", "Companies", "/companies"),
        new("CRM", "Contacts", "/contacts"),
        new("CRM", "Customer Portal", "/customer-portal"),
        new("CRM", "Sales Projects", "/sales-projects"),

        // ── Marketing ──
        new("Marketing", "Brand Assets", "/marketing/brand-assets"),
        new("Marketing", "Customer Data", "/marketing/customers"),
        new("Marketing", "Email Campaigns", "/marketing/campaigns"),
        new("Marketing", "Marketing Assets", "/marketing/assets"),
