{
  "expo": {
    "name": "MyDesk Mobile",
    "slug": "mydesk-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "au.com.digitalresponse.mydesk",
      "usesNonExemptEncryption": false,
      "infoPlist": {
        "NSCameraUsageDescription": "MyDesk needs access to your camera to capture expense receipts.",
        "NSPhotoLibraryUsageDescription": "MyDesk needs access to your photo library to attach receipts.",
        "NSLocationWhenInUseUsageDescription": "MyDesk may request your location for context (optional)."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "au.com.digitalresponse.mydesk",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MyDesk to access your camera to capture receipts."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow MyDesk to access your photos.",
          "savePhotosPermission": "Allow MyDesk to save photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "scheme": "mydesk",
    "extra": {
      "apiBaseUrl": "https://api.mydesk.com.au",
      "eas": {
        "projectId": "mydesk-mobile"
      }
    }
  }
}
