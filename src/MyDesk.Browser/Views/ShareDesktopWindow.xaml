<Window x:Class="MyDesk.Browser.Views.ShareDesktopWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MyDesk.Browser.ViewModels"
        Title="MyDesk Browser — Share My Desktop"
        Height="600"
        Width="650"
        MinHeight="500"
        MinWidth="550"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="/Assets/icon.ico">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🖥️ " FontSize="22" Margin="0,0,8,0" />
                <TextBlock Text="Share My Desktop"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
            <TextBlock Text="Create secure, time-limited share links with encrypted tokens"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" MinWidth="220" />
            </Grid.ColumnDefinitions>

            <!-- Share Form -->
            <Border Grid.Column="0"
                    Background="{DynamicResource UrlBarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Create Share Link"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,12" />

                    <TextBlock Text="Current Page URL"
                               Style="{DynamicResource SettingLabelStyle}" />
                    <TextBox Style="{DynamicResource ModernTextBoxStyle}"
                             Text="{Binding CurrentUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"
                             Margin="0,4,0,12" />

                    <TextBlock Text="Share Method"
                               Style="{DynamicResource SettingLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <RadioButton Content="📧 Email"
                                     IsChecked="{Binding ShareMethod, Converter={StaticResource RadioBoolConverter}, ConverterParameter=email}"
                                     GroupName="ShareMethod"
                                     Style="{DynamicResource ModernCheckBoxStyle}"
                                     Margin="0,0,20,0" />
                        <RadioButton Content="📋 Clipboard"
                                     IsChecked="{Binding ShareMethod, Converter={StaticResource RadioBoolConverter}, ConverterParameter=clipboard}"
                                     GroupName="ShareMethod"
                                     Style="{DynamicResource ModernCheckBoxStyle}" />
                    </StackPanel>

                    <!-- Email field (only shown for email method) -->
                    <StackPanel Visibility="{Binding ShareMethod, Converter={StaticResource StringEqualsVisibilityConverter}, ConverterParameter=email}">
                        <TextBlock Text="Recipient Email"
                                   Style="{DynamicResource SettingLabelStyle}" />
                        <TextBox Style="{DynamicResource ModernTextBoxStyle}"
                                 Text="{Binding RecipientEmail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,12"
                                 ToolTip="Enter the recipient's email address" />
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Expires In"
                                       Style="{DynamicResource SettingLabelStyle}" />
                            <ComboBox ItemsSource="{Binding ExpiryOptions}"
                                      SelectedItem="{Binding ExpiryHours, Mode=TwoWay}"
                                      Style="{DynamicResource ModernComboBoxStyle}"
                                      Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Bind to MAC?"
                                       Style="{DynamicResource SettingLabelStyle}" />
                            <CheckBox Content="Device-binding (one-time)"
                                      IsChecked="{Binding IsMacBound, Mode=TwoWay}"
                                      Style="{DynamicResource ModernCheckBoxStyle}"
                                      Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>

                    <Button Content="🔗 Create &amp; Share"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding ShareCommand}"
                            IsEnabled="{Binding IsCreating, Converter={StaticResource InvertedBoolConverter}}"
                            Height="38"
                            HorizontalAlignment="Left"
                            Padding="24,0" />

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Separator -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          Margin="0"
                          Background="Transparent"
                          HorizontalAlignment="Center"
                          ResizeBehavior="PreviousAndNext"
                          Visibility="Collapsed" />

            <!-- Recent Shares -->
            <Border Grid.Column="2"
                    Background="{DynamicResource UrlBarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Previous Shares"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,4" />

                    <Button Grid.Row="1"
                            Content="🔄 Refresh"
                            Style="{DynamicResource SecondaryButtonStyle}"
                            Command="{Binding RefreshSharesCommand}"
                            Height="28"
                            Margin="0,0,0,8" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Shares}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,4"
                                        CornerRadius="4"
                                        Margin="0,2"
                                        Background="{DynamicResource UrlBarBackgroundBrush}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding StatusIcon}" FontSize="11" Margin="0,0,4,0" />
                                            <TextBlock Text="{Binding Id}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Text=" · "
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding ShortDate}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="Expires: "
                                                       FontSize="9"
                                                       Foreground="{DynamicResource TextDisabledBrush}" />
                                            <TextBlock Text="{Binding ExpiryDate}"
                                                       FontSize="9"
                                                       Foreground="{DynamicResource TextDisabledBrush}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="📋 Copy"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.CopyToClipboardCommand}"
                                                    CommandParameter="{Binding}"
                                                    Height="22"
                                                    FontSize="10"
                                                    Padding="8,0"
                                                    Margin="0,0,4,0" />
                                            <Button Content="🔒 Revoke"
                                                    Style="{DynamicResource SecondaryButtonStyle}"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.RevokeShareCommand}"
                                                    CommandParameter="{Binding}"
                                                    Height="22"
                                                    FontSize="10"
                                                    Padding="8,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Close"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="BtnClose_Click"
                    Width="100" />
        </StackPanel>
    </Grid>
</Window>
