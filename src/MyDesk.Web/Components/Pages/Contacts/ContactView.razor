@page "/contacts/{Id:int}"
@attribute [Authorize]
@inject ContactService ContactService
@inject NavigationManager Nav
@inject IJSRuntime JsRuntime
@inject PlatformSettingsService PlatformSettings

<PageTitle>Contact - @PlatformSettings.GetBrandingName()</PageTitle>

@if (_contact == null)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4" Class="font-weight-bold">@_contact.FullName</MudText>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/contacts"))">Back</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContactPage" OnClick="DownloadVcf" Color="Color.Info">
                Export VCF
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Href="@($"/contacts/{_contact.ContactId}/edit")">Edit</MudButton>
        </div>
    </div>

    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid>
            <MudItem xs="6"><strong>Company:</strong> @_contact.CompanyName</MudItem>
            <MudItem xs="6"><strong>Position:</strong> @(_contact.Position ?? "-")</MudItem>
            <MudItem xs="6"><strong>Email:</strong> <MudLink Href="@($"mailto:{_contact.Email}")">@_contact.Email</MudLink></MudItem>
            <MudItem xs="6"><strong>Phone:</strong> @(_contact.Phone ?? "-")</MudItem>
            <MudItem xs="6"><strong>Mobile:</strong> @(_contact.Mobile ?? "-")</MudItem>
            <MudItem xs="6"><strong>Fax:</strong> @(_contact.Fax ?? "-")</MudItem>
            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <strong>Address</strong>
            </MudItem>
            <MudItem xs="6">@_contact.Address1</MudItem>
            <MudItem xs="6">@_contact.Address2</MudItem>
            <MudItem xs="6"><strong>Suburb:</strong> @_contact.Suburb</MudItem>
            <MudItem xs="6"><strong>PostCode:</strong> @_contact.PostCode</MudItem>
            <MudItem xs="12">
                <MudDivider Class="my-2" />
            </MudItem>
            <MudItem xs="6"><strong>Customer Code:</strong> @(_contact.CustomerCode ?? "-")</MudItem>
            <MudItem xs="6"><strong>Supplier Code:</strong> @(_contact.SupplierCode ?? "-")</MudItem>
        </MudGrid>
    </MudPaper>
}

@code {
    [Parameter] public int Id { get; set; }
    private Contact? _contact;

    protected override async Task OnInitializedAsync()
        => _contact = await ContactService.GetContactAsync(Id);

    private async Task DownloadVcf()
    {
        if (_contact == null) return;

        var vcf = GenerateVcf(_contact);
        var bytes = System.Text.Encoding.UTF8.GetBytes(vcf);
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"{_contact.FullName.Replace(" ", "_")}.vcf";
        
        await JsRuntime.InvokeVoidAsync("downloadBase64File", base64, "text/vcard", fileName);
    }

    private static string GenerateVcf(Contact c)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("BEGIN:VCARD");
        sb.AppendLine("VERSION:3.0");
        sb.AppendLine($"N:{c.Surname};{c.FirstName};;;");
        sb.AppendLine($"FN:{c.FullName}");
        
        if (!string.IsNullOrWhiteSpace(c.CompanyName))
            sb.AppendLine($"ORG:{c.CompanyName}");
        
        if (!string.IsNullOrWhiteSpace(c.Position))
            sb.AppendLine($"TITLE:{c.Position}");
        
        if (!string.IsNullOrWhiteSpace(c.Phone))
            sb.AppendLine($"TEL;TYPE=WORK,VOICE:{c.Phone}");
        
        if (!string.IsNullOrWhiteSpace(c.Mobile))
            sb.AppendLine($"TEL;TYPE=CELL,VOICE:{c.Mobile}");
        
        if (!string.IsNullOrWhiteSpace(c.Fax))
            sb.AppendLine($"TEL;TYPE=WORK,FAX:{c.Fax}");
        
        if (!string.IsNullOrWhiteSpace(c.Email))
            sb.AppendLine($"EMAIL;TYPE=WORK:{c.Email}");
        
        var address = "";
        if (!string.IsNullOrWhiteSpace(c.Address1))
            address += c.Address1 + ";";
        
        if (!string.IsNullOrWhiteSpace(address.TrimEnd(';')))
            sb.AppendLine($"ADR;TYPE=WORK:;;{address.TrimEnd(';')}");
        
        sb.AppendLine("END:VCARD");
        return sb.ToString();
    }
}