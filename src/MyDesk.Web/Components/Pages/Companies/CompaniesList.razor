@page "/companies"
@attribute [Authorize]
@inject CompanyService CompanyService
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@using Microsoft.JSInterop
@inject FavouritesService FavouritesSvc
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

<PageTitle>Companies - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span style="color:var(--gray-700);font-weight:500;">Companies</span>
        </div>
        <h1>Companies</h1>
         <p class="tl-subtitle">Customer and supplier organisations. <a href="/contacts" class="tl-link">View Contacts →</a></p>
    </div>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Add" Href="/companies/new">
            Add Company
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Download" OnClick="ShowImportDialog">
            Import from Invoices
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Rounded.Merge" OnClick="NormaliseAndDedupe">
            Normalise & Dedupe
        </MudButton>
    </div>
</div>

<MudPaper Class="pa-4 mb-3" Elevation="1" Style="max-width:480px;">
    <div class="d-flex gap-2">
        <MudTextField @bind-Value="_search" Label="Search companies" Variant="Variant.Outlined"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                      Clearable="true" Margin="Margin.Dense" Style="flex:1;" />
        <MudButton OnClick="LoadAsync" Color="Color.Primary" Variant="Variant.Filled"
                   Size="Size.Small">Search</MudButton>
    </div>
    <div class="d-flex gap-2 mt-2">
        <MudButton OnClick="ExportCsv" Variant="Variant.Outlined" Color="Color.Default"
                   Size="Size.Small" StartIcon="@Icons.Material.Rounded.Download">Export CSV</MudButton>
    </div>
</MudPaper>

<MudPaper Class="pa-0" Elevation="1" Style="margin-bottom: 40px;">
     <MudDataGrid T="Company" Items="@_companies" Loading="@_loading" Dense="true" Hover="true"
                  FixedHeader="true" Height="calc(100vh - 365px)" Elevation="0">
        <Columns>
            <PropertyColumn Property="x => x.CompanyId" Title="#" CellStyle="width:70px;" />
            <TemplateColumn Title="Company">
                <CellTemplate>
                    <MudLink Href="@($"/companies/{context.Item.CompanyId}/edit")" Style="font-weight:500;">
                        @context.Item.CompanyName
                    </MudLink>
                </CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="x => x.Phone" Title="Phone" />
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <PropertyColumn Property="x => x.Suburb" Title="Suburb" />
            <PropertyColumn Property="x => x.State" Title="State" CellStyle="width:70px;" />
            <TemplateColumn Title="" CellStyle="width:120px;">
                <CellTemplate>
                    <div class="d-flex gap-1">
                        <FavouriteButton EntityType="Company" EntityId="@context.Item.CompanyId" EntityName="@context.Item.CompanyName" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                       Href="@($"/companies/{context.Item.CompanyId}/edit")" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(context.Item))" />
                    </div>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
</MudPaper>

@code {
    private List<Company> _companies = new();
    private bool _loading = true;
    private string? _search;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try { _companies = await CompanyService.GetCompaniesAsync(_search); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task DeleteAsync(Company c)
    {
        try
        {
            await CompanyService.DeleteCompanyAsync(c.CompanyId);
            Snackbar.Add($"'{c.CompanyName}' deleted.", Severity.Info);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private async Task ExportCsv()
    {
        if (!_companies.Any())
        {
            Snackbar.Add("No data to export", Severity.Warning);
            return;
        }

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("ID,Company,Phone,Email,Suburb,State,ABN,Terms");

        foreach (var c in _companies)
        {
            sb.AppendLine($"{c.CompanyId},\"{c.CompanyName}\",\"{c.Phone}\",\"{c.Email}\",\"{c.Suburb}\",\"{c.State}\",\"{c.ABN}\",\"{c.PaymentTerms}\"");
        }

        var csv = sb.ToString();
        var fileName = $"Companies_Export_{DateTime.Now:yyyyMMdd}.csv";

        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:text/csv;base64,{base64}";
        await JSRuntime.InvokeVoidAsync("window.open", url, "_blank");
        
        Snackbar.Add($"Exported {_companies.Count} companies", Severity.Success);
    }

    private async Task ShowImportDialog()
    {
        await Dialog.ShowAsync<ImportFromInvoicesDialog>("Import Companies from Invoices");
    }

    private async Task NormaliseAndDedupe()
    {
        var result = await Dialog.ShowMessageBox("Normalise & Dedupe", 
            "This will normalise company names and merge duplicates. Continue?", 
            yesText: "Yes", cancelText: "Cancel");
        
        if (result != true) return;

        try
        {
            _loading = true;
            await CompanyService.NormaliseAndDedupeAsync();
            Snackbar.Add("Companies normalised and deduped successfully", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Operation failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}



