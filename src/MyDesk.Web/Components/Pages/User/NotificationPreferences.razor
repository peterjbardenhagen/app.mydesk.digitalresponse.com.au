@page "/user/notification-preferences"
@using MyDesk.Web.Services
@using System.Data
@inject DatabaseService DatabaseService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Notification Preferences</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-8">
    <MudStack Spacing="4">
        <MudStack Row="true" AlignItems="AlignItems.Center">
            <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Large" />
            <MudText Typo="Typo.h4" Class="font-bold">Notification Preferences</MudText>
        </MudStack>

        <MudText Typo="Typo.body1" Color="Color.TextSecondary">
            Choose how and when you receive notifications about budgets, approvals, and system activities.
        </MudText>

        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <MudPaper Class="pa-6">
                <MudStack Spacing="4">
                    <!-- Email Notifications -->
                    <MudStack Spacing="2">
                        <MudCheckBox @bind-Value="enableEmailNotifications"
                            Label="Email Notifications"
                            Color="Color.Primary" />
                        <MudText Typo="Typo.caption" Class="ml-6">
                            Receive email notifications for budgets, approvals, and other important events
                        </MudText>
                    </MudStack>

                    <!-- In-App Notifications -->
                    <MudStack Spacing="2">
                        <MudCheckBox @bind-Value="enableInAppNotifications"
                            Label="In-App Notifications"
                            Color="Color.Primary" />
                        <MudText Typo="Typo.caption" Class="ml-6">
                            Show notifications in the notification center when you're using MyDesk
                        </MudText>
                    </MudStack>

                    <MudDivider Class="my-3" />

                    <!-- Budget Alert Settings -->
                    <MudText Typo="Typo.h6" Class="font-bold">Budget Alerts</MudText>

                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2">
                            How often to receive budget threshold alerts:
                        </MudText>
                        <MudSelect @bind-Value="budgetAlertFrequency"
                            Label="Budget Alert Frequency"
                            Variant="Variant.Outlined">
                            <MudSelectItem Value="@("Immediate")">Immediately when threshold reached</MudSelectItem>
                            <MudSelectItem Value="@("Daily")">Daily digest at 8:00 AM</MudSelectItem>
                            <MudSelectItem Value="@("Weekly")">Weekly digest on Mondays</MudSelectItem>
                        </MudSelect>
                    </MudStack>

                    <MudDivider Class="my-3" />

                    <!-- Approval Notification Settings -->
                    <MudText Typo="Typo.h6" Class="font-bold">Approval Notifications</MudText>

                    <MudStack Spacing="2">
                        <MudText Typo="Typo.subtitle2">
                            How often to receive approval notifications:
                        </MudText>
                        <MudSelect @bind-Value="approvalAlertFrequency"
                            Label="Approval Alert Frequency"
                            Variant="Variant.Outlined">
                            <MudSelectItem Value="@("Immediate")">Immediately when approval needed</MudSelectItem>
                            <MudSelectItem Value="@("Daily")">Daily digest at 8:00 AM</MudSelectItem>
                            <MudSelectItem Value="@("Weekly")">Weekly digest on Mondays</MudSelectItem>
                        </MudSelect>
                    </MudStack>

                    <MudStack Spacing="2" Class="mt-4">
                        <MudCheckBox @bind-Value="enableDigest"
                            Label="Combine notifications into daily digest"
                            Color="Color.Primary" />
                        <MudText Typo="Typo.caption" Class="ml-6">
                            When enabled, all notifications are sent as a single email each morning
                        </MudText>
                    </MudStack>

                    <MudDivider Class="my-3" />

                    <!-- Action Buttons -->
                    <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                        <MudButton Variant="Variant.Outlined" OnClick="Cancel">
                            Cancel
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePreferences">
                            Save Preferences
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <!-- Notification Center Link -->
            <MudPaper Class="pa-4" Elevation="0" Style="background-color: var(--mud-palette-background-grey);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Info" Color="Color.Info" />
                    <MudText Typo="Typo.body2">
                        View your notification history in the <MudLink Href="/notifications">Notification Center</MudLink>
                    </MudText>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

