@page "/quotes/{Id:int}/history"
@attribute [Authorize]
@inject AuditService AuditService
@inject NavigationManager Nav

<PageTitle>Quote #@Id History - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <a href="/quotes">Quotes</a><span class="sep">/</span>
            <a href="@($"/quotes/{Id}")">Quote #@Id</a><span class="sep">/</span>
            <span style="color:var(--gray-700);font-weight:500;">History</span>
        </div>
        <h1>Quote #@Id — Audit History</h1>
    </div>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.ArrowBack"
               Href="@($"/quotes/{Id}")">Back to Quote</MudButton>
</div>

@if (_entries == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_entries.Count == 0)
{
    <MudPaper Class="pa-8 text-center" Elevation="0">
        <MudIcon Icon="@Icons.Material.Rounded.History" Style="font-size:3rem;opacity:.3;" />
        <MudText Typo="Typo.body1" Class="mt-3" Style="color:var(--gray-500);">No audit entries for this quote.</MudText>
    </MudPaper>
}
else
{
    <MudPaper Elevation="1" Class="pa-0">
        <MudSimpleTable Dense="true" Hover="true">
            <thead>
                <tr>
                    <th>Date / Time</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Details</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _entries)
                {
                    <tr>
                        <td style="white-space:nowrap;color:var(--gray-500);font-size:0.85rem;">
                            @e.Timestamp.ToString("dd/MM/yyyy HH:mm")
                        </td>
                        <td style="font-weight:500;">@e.UserName</td>
                        <td>@e.Action</td>
                        <td><span style="color:var(--gray-500);font-size:0.85rem;">@e.Details</span></td>
                    </tr>
                }
            </tbody>
        </MudSimpleTable>
    </MudPaper>
}

@code {
    [Parameter] public int Id { get; set; }
    private List<AuditEntry>? _entries;

    protected override async Task OnInitializedAsync()
    {
        _entries = await AuditService.GetAuditTrailAsync("Quote", Id);
    }
}

