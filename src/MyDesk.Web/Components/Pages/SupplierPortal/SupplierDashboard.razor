@page "/supplier-portal"
@layout SupplierPortalLayout
@attribute [Authorize]
@inject SupplierService SupplierService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@using MyDesk.Shared.Models

<PageTitle>Dashboard - Techlight Supplier Portal</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">Welcome, @_supplier?.SupplierName!</MudText>
<MudText Typo="Typo.body1" Color="Color.Default" Class="mb-6">Here's your supplier overview</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 cursor-pointer" Elevation="2" OnClick="GoToQuotes">
            <div class="d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="Size.Large" Color="Color.Primary" />
                <div>
                    <MudText Typo="Typo.h4">@_quoteCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">RFQs / Quotes</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 cursor-pointer" Elevation="2" OnClick="GoToOrders">
            <div class="d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Rounded.ShoppingCart" Size="Size.Large" Color="Color.Success" />
                <div>
                    <MudText Typo="Typo.h4">@_poCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Purchase Orders</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4 cursor-pointer" Elevation="2" OnClick="GoToInvoices">
            <div class="d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Rounded.Receipt" Size="Size.Large" Color="Color.Warning" />
                <div>
                    <MudText Typo="Typo.h4">@_invoiceCount</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Invoices</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" sm="6" md="3">
        <MudPaper Class="pa-4" Elevation="2">
            <div class="d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Rounded.Star" Size="Size.Large" Color="Color.Info" />
                <div>
                    <MudText Typo="Typo.h5">@_supplier?.Tier</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">Supplier Tier</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-6">
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Supplier Score</MudText>
            @if (_supplier != null)
            {
                <div class="d-flex align-center gap-3 mb-2">
                    <MudProgressLinear Value="@_supplier.Score" Color="Color.Primary" Style="flex:1;height:12px;border-radius:6px;" />
                    <MudText Typo="Typo.body1">@_supplier.Score%</MudText>
                </div>
                <MudText Typo="Typo.caption" Color="Color.Default">
                    Based on quality, delivery, and responsiveness
                </MudText>
            }
        </MudPaper>
    </MudItem>
    
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Purchase Order Stats</MudText>
            <div class="d-flex flex-column gap-2">
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">Total Orders</MudText>
                    <MudText Typo="Typo.body2" FontWeight="FontWeight.Bold">@_supplier?.OrderCount</MudText>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">Total Spend</MudText>
                    <MudText Typo="Typo.body2" FontWeight="FontWeight.Bold">$@_supplier?.TotalSpend.ToString("N0")</MudText>
                </div>
                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.body2">On-Time %</MudText>
                    <MudText Typo="Typo.body2" FontWeight="FontWeight.Bold">@_supplier?.OnTimePercent%</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-2">
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-4">Quick Actions</MudText>
            <div class="d-flex gap-2 flex-wrap">
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.RequestQuote" OnClick="GoToQuotes">Quotes</MudButton>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.ShoppingCart" OnClick="GoToOrders">Orders</MudButton>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.Receipt" OnClick="GoToInvoices">Invoices</MudButton>
                <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.Email" OnClick="ContactUs">Contact Us</MudButton>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private Supplier? _supplier;
    private int _quoteCount;
    private int _poCount;
    private int _invoiceCount;

    private void GoToQuotes() => Nav.NavigateTo("/supplier-portal/quotes");
    private void GoToOrders() => Nav.NavigateTo("/supplier-portal/orders");
    private void GoToInvoices() => Nav.NavigateTo("/supplier-portal/invoices");

    protected override async Task OnInitializedAsync()
    {
        _supplier = await SupplierService.GetCurrentPortalSupplierAsync();
        if (_supplier == null)
        {
            Nav.NavigateTo("/supplier-login");
            return;
        }

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        if (_supplier == null) return;
        _quoteCount = 0;
        _poCount = _supplier.OrderCount;
        _invoiceCount = 0;
    }

    private async Task ContactUs()
    {
        Snackbar.Add("Contact your account manager at info@techlight.com.au", Severity.Info);
    }

    private static Color GetStatusColor(string? status) => status switch
    {
        "Approved" => Color.Success,
        "Pending" => Color.Warning,
        "Issued" => Color.Info,
        "Declined" => Color.Error,
        _ => Color.Default
    };
}