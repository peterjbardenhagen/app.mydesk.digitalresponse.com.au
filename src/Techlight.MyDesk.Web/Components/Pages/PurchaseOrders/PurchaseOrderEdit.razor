@page "/purchase-orders/create"
@page "/purchase-orders/{Id:int}/edit"
@attribute [Authorize]
@inject PurchaseOrderService POService
@inject LookupService LookupService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(IsNew ? "New" : "Edit") PO - Techlight MyDesk</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Class="font-weight-bold">@(IsNew ? "New Purchase Order" : $"Edit PO #{_po.PurchaseOrderId}")</MudText>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo(IsNew ? "/purchase-orders" : $"/purchase-orders/{Id}"))">Cancel</MudButton>
</div>

<MudPaper Elevation="2" Class="pa-6">
    <MudForm @ref="_form" Model="_po" @bind-IsValid="_isValid">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_po.PurchaseOrderNumber" Label="PO Number" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" @bind-Value="_po.ContactId" Label="Supplier" Variant="Variant.Outlined" Required="true">
                    @foreach (var c in _contacts)
                    {
                        <MudSelectItem T="int" Value="@c.ContactId">@c.CompanyName - @c.FullName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_poDate" Label="PO Date" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_deliveryDate" Label="Expected Delivery" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" @bind-Value="_po.POStatusId" Label="Status" Variant="Variant.Outlined">
                    @foreach (var s in _statuses)
                    {
                        <MudSelectItem T="int" Value="@s.POStatusId">@s.StatusName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_po.Reference" Label="Reference" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_po.AmountExGST" Label="Amount ex GST" Format="N2" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudNumericField @bind-Value="_po.Amount" Label="Total Amount" Format="N2" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <div class="d-flex justify-end gap-2 mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo(IsNew ? "/purchase-orders" : $"/purchase-orders/{Id}"))">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_saving" StartIcon="@Icons.Material.Filled.Save">
                @(_saving ? "Saving..." : "Save")
            </MudButton>
        </div>
    </MudForm>
</MudPaper>

@code {
    [Parameter] public int? Id { get; set; }
    private bool IsNew => !Id.HasValue || Id == 0;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;

    private PurchaseOrder _po = new() { PODate = DateTime.Today, POStatusId = 1 };
    private DateTime? _poDate = DateTime.Today;
    private DateTime? _deliveryDate;
    private List<Contact> _contacts = new();
    private List<POStatus> _statuses = new();

    protected override async Task OnInitializedAsync()
    {
        _contacts = await LookupService.GetContactLookupsAsync();
        _statuses = await LookupService.GetPoStatusesAsync();

        if (!IsNew)
        {
            var existing = await POService.GetPurchaseOrderAsync(Id!.Value);
            if (existing != null)
            {
                _po = existing;
                _poDate = existing.PODate;
                _deliveryDate = existing.ExpectedDelivery;
            }
        }
    }

    private async Task SaveAsync()
    {
        await _form.Validate();
        if (!_isValid) return;
        _saving = true;
        try
        {
            _po.PODate = _poDate ?? DateTime.Today;
            _po.ExpectedDelivery = _deliveryDate;

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var code = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

            if (IsNew)
            {
                var newId = await POService.CreatePurchaseOrderAsync(_po, code);
                Snackbar.Add($"PO #{newId} created", Severity.Success);
                Nav.NavigateTo($"/purchase-orders/{newId}");
            }
            else
            {
                await POService.UpdatePurchaseOrderAsync(_po);
                Snackbar.Add("PO updated", Severity.Success);
                Nav.NavigateTo($"/purchase-orders/{_po.PurchaseOrderId}");
            }
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _saving = false; }
    }
}
