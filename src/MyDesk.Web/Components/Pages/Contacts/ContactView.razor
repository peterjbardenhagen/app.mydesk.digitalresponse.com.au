@page "/contacts/{Id:int}"
@attribute [Authorize]
@inject ContactService ContactService
@inject CompanyService CompanyService
@inject InvoiceService InvoiceService
@inject QuoteService QuoteService
@inject PurchaseOrderService PurchaseOrderService
@inject NavigationManager Nav
@inject IJSRuntime JsRuntime
@inject PlatformSettingsService PlatformSettings

<PageTitle>Contact - @PlatformSettings.GetBrandingName()</PageTitle>

@if (_contact == null)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4" Class="font-weight-bold">@_contact.FullName</MudText>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo("/contacts"))">Back</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ContactPage" OnClick="DownloadVcf" Color="Color.Info">
                Export VCF
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit" Href="@($"/contacts/{_contact.ContactId}/edit")">Edit</MudButton>
        </div>
    </div>

    <MudPaper Elevation="2" Class="pa-6">
        <MudGrid>
            <MudItem xs="6"><strong>Company:</strong> @_contact.CompanyName</MudItem>
            <MudItem xs="6"><strong>Position:</strong> @(_contact.Position ?? "-")</MudItem>
            <MudItem xs="6"><strong>Email:</strong> <MudLink Href="@($"mailto:{_contact.Email}")">@_contact.Email</MudLink></MudItem>
            <MudItem xs="6"><strong>Phone:</strong> @(_contact.Phone ?? "-")</MudItem>
            <MudItem xs="6"><strong>Mobile:</strong> @(_contact.Mobile ?? "-")</MudItem>
            <MudItem xs="6"><strong>Fax:</strong> @(_contact.Fax ?? "-")</MudItem>
            <MudItem xs="12">
                <MudDivider Class="my-2" />
                <strong>Company Addresses</strong> - <MudLink Href="@($"/companies/{_contact.CompanyId}/edit")" Color="Color.Primary">Edit</MudLink>
            </MudItem>
            @if (_company != null)
            {
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Style="color:var(--gray-500);">INVOICE ADDRESS</MudText>
                    <MudText Typo="Typo.body2">@(_company.InvoiceAddress ?? "Not specified")</MudText>
                </MudItem>
                <MudItem xs="6">
                    <MudText Typo="Typo.caption" Style="color:var(--gray-500);">DELIVERY ADDRESS</MudText>
                    <MudText Typo="Typo.body2">@(_company.DeliveryAddress ?? "Not specified")</MudText>
                </MudItem>
            }
            <MudItem xs="12">
                <MudDivider Class="my-2" />
            </MudItem>
            <MudItem xs="6"><strong>Customer Code:</strong> @(_contact.CustomerCode ?? "-")</MudItem>
            <MudItem xs="6"><strong>Supplier Code:</strong> @(_contact.SupplierCode ?? "-")</MudItem>
        </MudGrid>
    </MudPaper>

    @* Related MyDesk Records Section *@
    @if (!string.IsNullOrWhiteSpace(_contact.CompanyName) && _contact.CompanyId > 0)
    {
        <div class="mt-6">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h5" Class="font-weight-bold">Related Records</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Rounded.ViewWeek" 
                           Href="@($"/company-records/{_contact.CompanyId}")">
                    View All for @_contact.CompanyName
                </MudButton>
            </div>

            @if (_loadingRelated)
            {
                <div class="d-flex justify-center pa-4">
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else
            {
                <MudGrid>
                    @if (_invoices?.Count > 0)
                    {
                        <MudItem xs="12" md="4">
                            <MudPaper Elevation="1" Class="pa-4">
                                <MudText Typo="Typo.h6" Class="mb-3">
                                    <MudIcon Icon="@Icons.Material.Rounded.Receipt" Size="Size.Small" Class="mr-2" />
                                    Invoices
                                </MudText>
                                <MudText Typo="Typo.body2" Class="text-muted mb-3">@_invoices.Count recent invoices</MudText>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var inv in _invoices.Take(5))
                                    {
                                        <MudLink Href="@($"/invoices/{inv.InvoiceId}")">
                                            <MudText Typo="Typo.body2" Class="text-truncate">@inv.InvoiceNum (@inv.InvoiceDate.ToString("MMM dd, yyyy"))</MudText>
                                        </MudLink>
                                    }
                                    @if (_invoices.Count > 5)
                                    {
                                        <MudLink Href="@($"/invoices?company={Uri.EscapeDataString(_contact.CompanyName)}")">
                                            <MudText Typo="Typo.body2" Class="text-muted">+@(_invoices.Count - 5) more</MudText>
                                        </MudLink>
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>
                    }

                    @if (_quotes?.Count > 0)
                    {
                        <MudItem xs="12" md="4">
                            <MudPaper Elevation="1" Class="pa-4">
                                <MudText Typo="Typo.h6" Class="mb-3">
                                    <MudIcon Icon="@Icons.Material.Rounded.Assignment" Size="Size.Small" Class="mr-2" />
                                    Quotes
                                </MudText>
                                <MudText Typo="Typo.body2" Class="text-muted mb-3">@_quotes.Count recent quotes</MudText>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var quote in _quotes.Take(5))
                                    {
                                        <MudLink Href="@($"/quotes/{quote.Qid}")">
                                            <MudText Typo="Typo.body2" Class="text-truncate">@quote.Reference (@quote.QuoteDate.ToString("MMM dd, yyyy"))</MudText>
                                        </MudLink>
                                    }
                                    @if (_quotes.Count > 5)
                                    {
                                        <MudLink Href="@($"/quotes?customer={Uri.EscapeDataString(_contact.CompanyName)}")">
                                            <MudText Typo="Typo.body2" Class="text-muted">+@(_quotes.Count - 5) more</MudText>
                                        </MudLink>
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>
                    }

                    @if (_purchaseOrders?.Count > 0)
                    {
                        <MudItem xs="12" md="4">
                            <MudPaper Elevation="1" Class="pa-4">
                                <MudText Typo="Typo.h6" Class="mb-3">
                                    <MudIcon Icon="@Icons.Material.Rounded.ShoppingCart" Size="Size.Small" Class="mr-2" />
                                    Purchase Orders
                                </MudText>
                                <MudText Typo="Typo.body2" Class="text-muted mb-3">@_purchaseOrders.Count recent POs</MudText>
                                <div class="d-flex flex-column gap-2">
                                    @foreach (var po in _purchaseOrders.Take(5))
                                    {
                                        <MudLink Href="@($"/purchase-orders/{po.POid}")">
                                            <MudText Typo="Typo.body2" Class="text-truncate">@po.Project (@po.PODate.ToString("MMM dd, yyyy"))</MudText>
                                        </MudLink>
                                    }
                                    @if (_purchaseOrders.Count > 5)
                                    {
                                        <MudLink Href="@($"/purchase-orders?supplier={Uri.EscapeDataString(_contact.CompanyName)}")">
                                            <MudText Typo="Typo.body2" Class="text-muted">+@(_purchaseOrders.Count - 5) more</MudText>
                                        </MudLink>
                                    }
                                </div>
                            </MudPaper>
                        </MudItem>
                    }

                    @if ((_invoices?.Count ?? 0) == 0 && (_quotes?.Count ?? 0) == 0 && (_purchaseOrders?.Count ?? 0) == 0)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                No invoices, quotes, or purchase orders found for @_contact.CompanyName.
                            </MudAlert>
                        </MudItem>
                    }
                </MudGrid>
            }
        </div>
    }
}

@code {
    [Parameter] public int Id { get; set; }
    private Contact? _contact;
    private Company? _company;
    private List<Invoice>? _invoices;
    private List<Quote>? _quotes;
    private List<PurchaseOrder>? _purchaseOrders;
    private bool _loadingRelated = false;

    protected override async Task OnInitializedAsync()
    {
        _contact = await ContactService.GetContactAsync(Id);
        if (_contact?.CompanyId > 0)
        {
            _company = await CompanyService.GetCompanyAsync(_contact.CompanyId);
        }
        if (_contact?.CompanyId > 0 && !string.IsNullOrWhiteSpace(_contact.CompanyName))
        {
            await LoadRelatedRecordsAsync();
        }
    }

    private async Task LoadRelatedRecordsAsync()
    {
        _loadingRelated = true;
        try
        {
            // Load invoices, quotes, and purchase orders for the contact's company
            _invoices = await InvoiceService.GetInvoicesAsync(customer: _contact!.CompanyName, limit: 50) ?? new();
            _quotes = await QuoteService.GetQuotesAsync(null, null, _contact.CompanyName, null, 0, null) ?? new();
            _purchaseOrders = await PurchaseOrderService.GetPurchaseOrdersAsync(null, null, _contact.CompanyName, 0, limit: 50) ?? new();
        }
        catch (Exception ex)
        {
            // Log error but don't fail the page
            Console.WriteLine($"Error loading related records: {ex.Message}");
        }
        finally
        {
            _loadingRelated = false;
        }
    }

    private async Task DownloadVcf()
    {
        if (_contact == null) return;

        var vcf = GenerateVcf(_contact);
        var bytes = System.Text.Encoding.UTF8.GetBytes(vcf);
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"{_contact.FullName.Replace(" ", "_")}.vcf";
        
        await JsRuntime.InvokeVoidAsync("downloadBase64File", base64, "text/vcard", fileName);
    }

    private static string GenerateVcf(Contact c)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("BEGIN:VCARD");
        sb.AppendLine("VERSION:3.0");
        sb.AppendLine($"N:{c.Surname};{c.FirstName};;;");
        sb.AppendLine($"FN:{c.FullName}");
        
        if (!string.IsNullOrWhiteSpace(c.CompanyName))
            sb.AppendLine($"ORG:{c.CompanyName}");
        
        if (!string.IsNullOrWhiteSpace(c.Position))
            sb.AppendLine($"TITLE:{c.Position}");
        
        if (!string.IsNullOrWhiteSpace(c.Phone))
            sb.AppendLine($"TEL;TYPE=WORK,VOICE:{c.Phone}");
        
        if (!string.IsNullOrWhiteSpace(c.Mobile))
            sb.AppendLine($"TEL;TYPE=CELL,VOICE:{c.Mobile}");
        
        if (!string.IsNullOrWhiteSpace(c.Fax))
            sb.AppendLine($"TEL;TYPE=WORK,FAX:{c.Fax}");
        
        if (!string.IsNullOrWhiteSpace(c.Email))
            sb.AppendLine($"EMAIL;TYPE=WORK:{c.Email}");
        
        sb.AppendLine("END:VCARD");
        return sb.ToString();
    }
}


