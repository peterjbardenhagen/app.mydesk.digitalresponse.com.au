@page "/admin/accounting-integrations"
@attribute [Authorize(Roles = "Admin,Director")]
@using MyDesk.Shared.Models
@using MyDesk.Shared.Services.Integrations
@inject PlatformSettingsService PlatformSettings
@inject XeroSyncService XeroSvc
@inject QuickBooksSyncService QboSvc
@inject MyobSyncService MyobSvc
@inject AccountingSyncManager SyncManager
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>Accounting Integrations - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Dashboard</a><span class="sep">/</span>
            <a href="/admin/setup">Admin</a><span class="sep">/</span>
            <span>Accounting Integrations</span>
        </div>
        <h1>Accounting Integrations</h1>
        <p class="tl-subtitle">Real-time two-way sync with Xero, QuickBooks Online, and MYOB</p>
    </div>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Rounded.Sync"
               OnClick="RunAllSyncs"
               Disabled="_running"
               Class="rounded-lg px-6">
        @if (_running)
        {
            <MudProgressCircular Size="Size.Small" Color="Color.Inherit" Class="mr-2" />
            <span>Syncing...</span>
        }
        else
        {
            <span>Run All Syncs</span>
        }
    </MudButton>
</div>

@* ── Health badges ── *@
<div class="d-flex gap-3 flex-wrap mb-6">
    @foreach (var s in _statuses)
    {
        <MudChip T="string"
                 Color="@(s.IsConnected ? Color.Success : s.Enabled ? Color.Warning : Color.Default)"
                 Icon="@(s.IsConnected ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Cancel)"
                 Variant="Variant.Filled"
                 Size="Size.Medium">
            @s.Provider: @s.Status
        </MudChip>
    }
</div>

@if (_saving)
{
    <MudProgressLinear Indeterminate Color="Color.Primary" Class="mb-4" />
}

@* ─── Xero Card ─── *@
<MudExpansionPanels Class="mb-4" Elevation="1">
    <MudExpansionPanel>
        <TitleContent>
            <div class="d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Rounded.AccountBalance" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Xero</MudText>
                <MudSpacer />
                <MudChip T="string"
                         Color="@(_settings.Xero.IsConnected ? Color.Success : Color.Default)"
                         Size="Size.Small"
                         Variant="Variant.Filled">
                    @(_settings.Xero.IsConnected ? "Connected" : "Not Connected")
                </MudChip>
            </div>
        </TitleContent>
        <ChildContent>
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSwitch @bind-Value="_settings.EnableXeroIntegration"
                               Label="Enable Xero Integration"
                               Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-center">
                    @if (_settings.Xero.LastSync.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Last sync: @_settings.Xero.LastSync.Value.ToLocalTime().ToString("g")
                        </MudText>
                    }
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.Xero.ClientId"
                                  Label="Client ID"
                                  Variant="Variant.Outlined"
                                  Disabled="@_settings.Xero.IsConnected" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_settings.Xero.ClientSecret"
                                  Label="Client Secret"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Disabled="@_settings.Xero.IsConnected" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSwitch @bind-Value="_settings.Xero.SyncInvoices"  Label="Sync Invoices"         Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSwitch @bind-Value="_settings.Xero.SyncContacts"  Label="Sync Contacts"         Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSwitch @bind-Value="_settings.Xero.AutoExportInvoices" Label="Auto-export Invoices" Color="Color.Primary" />
                </MudItem>
                <MudItem xs="12">
                    <div class="d-flex gap-3 flex-wrap">
                        @if (!_settings.Xero.IsConnected)
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Rounded.Link"
                                       OnClick="ConnectXero"
                                       Disabled="@(string.IsNullOrWhiteSpace(_settings.Xero.ClientId))">
                                Connect to Xero
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                       StartIcon="@Icons.Material.Rounded.LinkOff"
                                       OnClick="@(() => DisconnectProvider("Xero"))">
                                Disconnect
                            </MudButton>
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Rounded.Sync"
                                       OnClick="@(() => ManualSync("Xero"))"
                                       Disabled="_running">
                                Sync Now
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Rounded.Save"
                                   OnClick="SaveSettings">
                            Save
                        </MudButton>
                    </div>
                </MudItem>
                @if (_xeroLogs.Any())
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Recent Sync Log</MudText>
                        @RenderLogTable(_xeroLogs)
                    </MudItem>
                }
            </MudGrid>
        </ChildContent>
    </MudExpansionPanel>
</MudExpansionPanels>

