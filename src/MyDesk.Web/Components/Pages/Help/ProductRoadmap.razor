                new("Email & SMS Campaigns",                 "Open/click tracking, A/B testing, drip sequences. Twilio for Aus numbers."),
                new("WhatsApp Business Channel",             "Send quotes and invoices via WhatsApp; receive replies into the CRM thread."),
                new("Customer Health Score / Churn Risk",    "Detect customers whose order frequency is decaying and trigger nurture sequences."),
                new("NPS / Customer Satisfaction Surveys",   "Auto-send NPS after invoice paid; close-the-loop tickets for detractors."),
