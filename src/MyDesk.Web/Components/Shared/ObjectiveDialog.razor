@using MyDesk.Shared.Models

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">@Title</MudText>
        
        <MudTextField @bind-Value="_objective.Title"
                     Label="Objective Title"
                     Variant="Variant.Outlined"
                     Required="true"
                     RequiredError="Title is required"
                     Class="mb-3" />

        <MudTextField @bind-Value="_objective.Description"
                     Label="Description"
                     Variant="Variant.Outlined"
                     Lines="3"
                     Class="mb-3" />

        <MudTextField @bind-Value="_objective.TargetValue"
                     Label="Target Value"
                     Variant="Variant.Outlined"
                     Required="true"
                     RequiredError="Target value is required"
                     Class="mb-3" />

        <MudSelect @bind-Value="_objective.Category"
                   Label="Category"
                   Variant="Variant.Outlined"
                   Required="true"
                   RequiredError="Category is required"
                   Class="mb-3">
            <MudSelectItem Value="@("Revenue")">Revenue</MudSelectItem>
            <MudSelectItem Value="@("Customer Acquisition")">Customer Acquisition</MudSelectItem>
            <MudSelectItem Value="@("Brand Awareness")">Brand Awareness</MudSelectItem>
            <MudSelectItem Value="@("Market Share")">Market Share</MudSelectItem>
        </MudSelect>

        <MudDatePicker @bind-Date="_objective.TargetDate"
                      Label="Target Date"
                      PickerVariant="PickerVariant.Dialog"
                      Required="true"
                      RequiredError="Target date is required"
                      Class="mb-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string Title { get; set; } = "Objective";
    [Parameter] public StrategicObjective Objective { get; set; } = new();

    private StrategicObjective _objective = new();

    protected override void OnInitialized()
    {
        _objective = Objective;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_objective.Title))
        {
            return;
        }

        MudDialog.Close(DialogResult.Ok(_objective));
    }
}
