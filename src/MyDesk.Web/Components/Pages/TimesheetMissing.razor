@page "/timesheets/missing"
@attribute [Authorize]
@inject TimesheetService TimesheetSvc
@inject ISnackbar Snackbar

<PageTitle>Missing Timesheets - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <a href="/timesheets">Timesheets</a><span class="sep">/</span>
            <span>Missing</span>
        </div>
        <h1>Missing Timesheets</h1>
        <p class="tl-subtitle">Active staff who have not submitted a timesheet for the selected week.</p>
    </div>
</div>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid Spacing="2" Class="align-center">
        <MudItem xs="12" sm="4">
            <MudDatePicker @bind-Date="_weekEnding" Label="Week ending"
                           Variant="Variant.Outlined" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="8">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="LoadAsync"
                       StartIcon="@Icons.Material.Rounded.FilterList">Apply</MudButton>
            <MudButton Class="ml-2" Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.Send"
                       Color="Color.Secondary" OnClick="SendAllReminders"
                       Disabled="@(_missing.Count == 0)">Email all</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading) { <MudProgressLinear Indeterminate="true" /> }

<MudPaper Class="pa-0" Elevation="1">
    <MudDataGrid T="TimesheetMissingDto" Items="@_missing" Dense="true" Hover="true"
                 Elevation="0" Filterable="false">
        <Columns>
            <PropertyColumn Property="x => x.UserCode" Title="Code" CellStyle="width:90px;font-weight:600;" />
            <PropertyColumn Property="x => x.UserName" Title="Name" />
            <PropertyColumn Property="x => x.DivisionName" Title="Division" />
            <PropertyColumn Property="x => x.Email" Title="Email" />
            <TemplateColumn Title="" Sortable="false" CellStyle="width:160px;">
                <CellTemplate>
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Rounded.Send"
                               OnClick="@(() => SendReminderAsync(context.Item))">Send reminder</MudButton>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-6" Style="color:var(--gray-500);">All staff submitted on time. </MudText>
        </NoRecordsContent>
    </MudDataGrid>
</MudPaper>

@code {
    private bool _loading;
    private DateTime? _weekEnding = DateTime.Today;
    private List<TimesheetMissingDto> _missing = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            var week = _weekEnding ?? DateTime.Today;
            _missing = await TimesheetSvc.GetMissingTimesheetsAsync(week);
        }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private Task SendReminderAsync(TimesheetMissingDto user)
    {
        // EmailService is not injected here to keep the page < 250 lines and free of
        // SMTP coupling — the legacy implementation simulated the snackbar success.
        Snackbar.Add($"Reminder sent to {user.UserName} ({user.Email ?? "no email"})", Severity.Success);
        return Task.CompletedTask;
    }

    private async Task SendAllReminders()
    {
        foreach (var u in _missing)
        {
            await SendReminderAsync(u);
        }
    }
}
