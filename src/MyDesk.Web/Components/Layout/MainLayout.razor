        new("Accounts", "MYOB Export", "/invoices/myob-export"),
        new("Accounts", "MYOB Sync", "/reconciliation/sync"),
        new("Accounts", "Reconciliation", "/reconciliation"),

        // ── Admin ──
        new("Admin", "Activity Types", "/admin/activity-types"),
        new("Admin", "Brand Assets", "/admin/brand-assets"),
