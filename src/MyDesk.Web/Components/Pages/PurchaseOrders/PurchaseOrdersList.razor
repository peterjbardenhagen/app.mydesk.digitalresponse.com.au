@page "/purchase-orders"
@page "/purchaseorders"
@attribute [Authorize]
@inject PurchaseOrderService POService
@inject LookupService LookupService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IDialogService Dialog
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JsRuntime
@using System.Security.Claims
@using Microsoft.JSInterop

<PageTitle>Purchase Orders - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span>Purchase Orders</span>
        </div>
        <h1>Purchase Orders</h1>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="@(() => Nav.NavigateTo("/purchase-orders/create"))">New PO</MudButton>
</div>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="3">
            <MudTextField @bind-Value="_search" Label="Supplier" Variant="Variant.Outlined"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                          Clearable="true" Immediate="false" />
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudDatePicker @bind-Date="_dateFrom" Label="From" Variant="Variant.Outlined" Clearable="true" />
        </MudItem>
        <MudItem xs="6" sm="2">
            <MudDatePicker @bind-Date="_dateTo" Label="To" Variant="Variant.Outlined" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudSelect T="int" @bind-Value="_statusId" Label="Status" Variant="Variant.Outlined">
                <MudSelectItem T="int" Value="0">All Statuses</MudSelectItem>
                @foreach (var s in _statuses)
                {
                    <MudSelectItem T="int" Value="@s.POStatusId">@s.StatusName</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect T="string" @bind-Value="_userCode" Label="Originator" Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@("")">All Users</MudSelectItem>
                @foreach (var u in _users)
                {
                    <MudSelectItem T="string" Value="@u.Code">@u.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>
    <div class="d-flex gap-2 mt-3 flex-wrap">
        <MudButton OnClick="LoadAsync" Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Rounded.FilterList">Apply</MudButton>
        <MudButton OnClick="ResetFilter" Variant="Variant.Outlined">Reset</MudButton>
        <MudButton Variant="@(_pendingOnly ? Variant.Filled : Variant.Outlined)"
                   Color="Color.Warning"
                   StartIcon="@Icons.Material.Rounded.Pending"
                   OnClick="TogglePendingApproval">
            Pending Approval
        </MudButton>
        <MudButton OnClick="ExportCsv" Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Rounded.Download">Export CSV</MudButton>
    </div>
</MudPaper>

<MudPaper Class="pa-0" Elevation="1" Style="margin-bottom: 40px;">
    <MudDataGrid T="PurchaseOrder" Items="@_pos" Loading="@_loading" Dense="true" Hover="true"
                 SortMode="@SortMode.Multiple" Virtualize="true" FixedHeader="true" Height="calc(100vh - 365px)" Class="tl-compact-grid"
                 RowClicked="OnPORowClicked">
    <Columns>
        <PropertyColumn Property="x => x.POid"         Title="#"         InitialDirection="SortDirection.Descending" />
        <PropertyColumn Property="x => x.SupplierName" Title="Supplier" />
        <PropertyColumn Property="x => x.Project"      Title="Project" />
        <PropertyColumn Property="x => x.DivisionName" Title="Division" />
        <PropertyColumn Property="x => x.PODate"       Title="Date"      Format="yyyy-MM-dd" />
        <PropertyColumn Property="x => x.DateRequired" Title="Required"  Format="yyyy-MM-dd" />
        <PropertyColumn Property="x => x.PriceIncTotal" Title="Inc GST"  Format="C2" />
        <PropertyColumn Property="x => x.OriginatorName" Title="By" />
        <TemplateColumn Title="Status" Sortable="false">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small" Color="@StatusColour(context.Item.StatusName)">
                    @context.Item.StatusName
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <TemplateColumn Title="" Sortable="false" CellStyle="width:180px;">
            <CellTemplate>
                <div class="d-flex gap-1">
                    <MudIconButton Icon="@Icons.Material.Rounded.Visibility" Size="Size.Small" Color="Color.Info"
                                   Href="@($"/purchase-orders/{context.Item.POid}")" title="View" />
                    <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                   Href="@($"/purchase-orders/{context.Item.POid}/edit")" title="Edit" />
                    <MudIconButton Icon="@Icons.Material.Rounded.PictureAsPdf" Size="Size.Small" Color="Color.Secondary"
                                   Href="@($"/api/pdf/purchase-order/{context.Item.POid}")" target="_blank" title="Print PDF" />
                    <MudIconButton Icon="@Icons.Material.Rounded.Email" Size="Size.Small" Color="Color.Default"
                                   Href="@($"/purchase-orders/{context.Item.POid}")" title="Email" />
                    @if (_isAdmin)
                    {
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(context.Item))" title="Delete" />
                    }
                </div>
            </CellTemplate>
        </TemplateColumn>
     </Columns>
     <PagerContent><MudDataGridPager T="PurchaseOrder" /></PagerContent>
    </MudDataGrid>
</MudPaper>

@code {
    private List<PurchaseOrder> _pos      = new();
    private List<POStatus>      _statuses = new();
    private List<UserLookup>    _users    = new();
    private bool    _loading     = true;
    [Parameter, SupplyParameterFromQuery(Name = "filter")]
    public string? Filter { get; set; }

    private bool    _isAdmin;
    private bool    _pendingOnly = false;
    private string? _search;
    private DateTime? _dateFrom;
    private DateTime? _dateTo;
    private int     _statusId = 0;
    private string  _userCode = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = auth.User.IsInRole("Admin") || auth.User.FindFirst("IsAdmin")?.Value == "True";

        (_statuses, _users) = (
            await LookupService.GetPoStatusesAsync(),
            await LookupService.GetUsersAsync());

        // Debug: log if statuses are empty
        if (_statuses.Count == 0)
        {
            Snackbar.Add("Warning: No PO statuses loaded. Check PurchaseOrderStatus table.", Severity.Warning);
        }

        if (Filter == "thismonth")
        {
            var today = DateTime.Today;
            _dateFrom = new DateTime(today.Year, today.Month, 1);
            _dateTo   = today;
        }
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _pos = await POService.GetPurchaseOrdersAsync(
                _dateFrom, _dateTo, _search, _pendingOnly ? 0 : _statusId,
                string.IsNullOrEmpty(_userCode) ? null : _userCode,
                pendingApprovalOnly: _pendingOnly);
        }
        finally { _loading = false; }
    }

    private async Task ResetFilter()
    {
        _search = null; _dateFrom = null; _dateTo = null;
        _statusId = 0; _userCode = ""; _pendingOnly = false;
        await LoadAsync();
    }

    private async Task TogglePendingApproval()
    {
        _pendingOnly = !_pendingOnly;
        await LoadAsync();
    }

    private async Task DeleteAsync(PurchaseOrder po)
    {
        var parameters = new DialogParameters
        {
            { nameof(MudMessageBox.Message), $"Delete PO for {po.SupplierName} ({po.Project})? This cannot be undone." },
            { nameof(MudMessageBox.YesText), "Delete" },
            { nameof(MudMessageBox.NoText), string.Empty },
            { nameof(MudMessageBox.CancelText), "Cancel" }
        };
        var result = await Dialog.ShowAsync<MudMessageBox>("Delete PO", parameters);
        bool? ok = (await result.Result)?.Data as bool?;
        if (ok != true) return;
        try
        {
            await POService.DeleteAsync(po.POid);
            _pos.Remove(po);
            Snackbar.Add("PO deleted.", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private static Color StatusColour(string s) => s switch
    {
        "Draft"              => Color.Default,
        "Pending Approval"   => Color.Warning,
        "Approved"           => Color.Success,
        "Issued"             => Color.Info,
        "Declined"           => Color.Error,
        "Cancelled"          => Color.Dark,
        _                    => Color.Default,
    };

    private async Task ExportCsv()
    {
        if (!_pos.Any())
        {
            Snackbar.Add("No data to export", Severity.Warning);
            return;
        }

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("PO #,Supplier,Project,Division,Date,Required,Inc GST,Status,By");

        foreach (var po in _pos)
        {
            sb.AppendLine($"\"{po.POid}\",\"{po.SupplierName}\",\"{po.Project}\",\"{po.DivisionName}\",\"{po.PODate:yyyy-MM-dd}\",\"{po.DateRequired:yyyy-MM-dd}\",{po.PriceIncTotal.ToString("N2")},\"{po.StatusName}\",\"{po.OriginatorName}\"");
        }

        var csv = sb.ToString();
        var fileName = $"PurchaseOrders_Export_{DateTime.Now:yyyyMMdd}.csv";

        await DownloadFile(fileName, csv);
        Snackbar.Add($"Exported {_pos.Count} purchase orders", Severity.Success);
    }

    private async Task DownloadFile(string fileName, string content)
    {
        var bytes = System.Text.Encoding.UTF8.GetBytes(content);
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:text/csv;base64,{base64}";
        await JsRuntime.InvokeVoidAsync("window.open", url, "_blank");
    }

    private void OnPORowClicked(DataGridRowClickEventArgs<PurchaseOrder> args)
    {
        Nav.NavigateTo($"/purchase-orders/{args.Item.POid}");
    }
}



