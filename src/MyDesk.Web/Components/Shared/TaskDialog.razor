@using MyDesk.Shared.Models
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(_task.TaskId == 0 ? "Create Task" : "Edit Task")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField T="string" Label="Title" @bind-Value="_task.Title" Required="true" />
        <MudTextField T="string" Label="Description" @bind-Value="_task.Description" Lines="2" Class="mt-3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int ProjectId { get; set; }
    [Parameter] public TaskItem? Task { get; set; }

    private TaskItem _task = new();

    protected override void OnInitialized()
    {
        _task = Task ?? new TaskItem();
        if (ProjectId > 0) _task.ProjectId = ProjectId;
    }

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(_task);
}
