@using Microsoft.AspNetCore.Components

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Rounded.Verified" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="html-preview-wrap">
            @((MarkupString)HtmlContent)
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Variant="Variant.Filled" Color="Color.Primary">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .html-preview-wrap {
        max-height: 70vh;
        overflow: auto;
        padding: 4px;
    }
</style>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Title { get; set; } = "Preview";
    [Parameter] public string HtmlContent { get; set; } = string.Empty;

    private void Close() => MudDialog.Close(DialogResult.Ok(true));
}
