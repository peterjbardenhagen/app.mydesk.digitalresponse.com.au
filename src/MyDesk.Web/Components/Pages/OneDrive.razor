@page "/onedrive"
@attribute [Authorize]
@inject PlatformSettingsService PlatformSettings
@inject OneDriveService OneDriveSvc
@inject AuthenticationStateProvider AuthStateProvider
@using MyDesk.Web.Services

<PageTitle>OneDrive - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Dashboard</a><span class="sep">/</span>
            <span>OneDrive</span>
        </div>
        <h1>OneDrive Files</h1>
        <p class="tl-subtitle">Browse your OneDrive documents directly from MyDesk.</p>
    </div>
    @if (_snapshot?.IsConnected == true)
    {
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.Refresh"
                   OnClick="RefreshAsync" Disabled="@_loading">Refresh</MudButton>
    }
</div>

@if (_loading)
{
    <div class="d-flex justify-center pa-12">
        <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
    </div>
}
else if (_snapshot is null || !_snapshot.IsConnected)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-4">
        OneDrive is not connected. Connect via
        <MudLink Href="/integrations">Settings → Integrations → My Outlook</MudLink>
        and enable <strong>Sync OneDrive</strong>.
    </MudAlert>
}
else if (!string.IsNullOrWhiteSpace(_snapshot.ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mt-4">
        @_snapshot.ErrorMessage
    </MudAlert>
}
else if (_snapshot.Items.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Class="mt-4">
        No files found in your OneDrive root folder.
    </MudAlert>
}
else
{
    <MudPaper Elevation="1" Class="mt-4">
        <MudTable Items="_snapshot.Items" Hover="true" Dense="true" Striped="true"
                  Filter="FilterFunc" @ref="_table">
            <ToolBarContent>
                <MudText Typo="Typo.h6">@_snapshot.Items.Count file(s)</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Search files…"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium" Class="mt-0" Immediate="true" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Type</MudTh>
                <MudTh>Size</MudTh>
                <MudTh>Modified</MudTh>
                <MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div class="d-flex align-center gap-2">
                        <MudIcon Icon="@GetFileIcon(context)" Size="Size.Small"
                                 Color="@(context.IsFolder ? Color.Warning : Color.Default)" />
                        @context.Name
                    </div>
                </MudTd>
                <MudTd>@(context.IsFolder ? "Folder" : GetFileType(context.Name))</MudTd>
                <MudTd>@(context.IsFolder ? "—" : FormatSize(context.Size))</MudTd>
                <MudTd>@context.ModifiedTime?.ToString("dd MMM yyyy HH:mm")</MudTd>
                <MudTd>
                    @if (!string.IsNullOrWhiteSpace(context.WebUrl))
                    {
                        <MudIconButton Icon="@Icons.Material.Rounded.OpenInNew"
                                       Size="Size.Small" Target="_blank"
                                       Href="@context.WebUrl" Title="Open in OneDrive" />
                    }
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    <MudText Typo="Typo.caption" Class="mt-3 text-muted">
        Showing OneDrive root folder · <MudLink Href="/integrations">Manage integration</MudLink>
    </MudText>
}

@code {
    private OneDriveSnapshot? _snapshot;
    private bool _loading = true;
    private string _search = "";
    private MudTable<OneDriveItem>? _table;

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            _snapshot = await OneDriveSvc.GetRootFilesAsync(PlatformSettings.Current);
        }
        finally
        {
            _loading = false;
        }
    }

    private bool FilterFunc(OneDriveItem item) =>
        string.IsNullOrWhiteSpace(_search) ||
        item.Name.Contains(_search, StringComparison.OrdinalIgnoreCase);

    private static string GetFileIcon(OneDriveItem item)
    {
        if (item.IsFolder) return Icons.Material.Rounded.Folder;
        var ext = Path.GetExtension(item.Name).ToLowerInvariant();
        return ext switch
        {
            ".pdf"                              => Icons.Material.Rounded.PictureAsPdf,
            ".doc" or ".docx" or ".txt"         => Icons.Material.Rounded.Description,
            ".xls" or ".xlsx" or ".csv"         => Icons.Material.Rounded.TableChart,
            ".ppt" or ".pptx"                   => Icons.Material.Rounded.Slideshow,
            ".jpg" or ".jpeg" or ".png" or ".gif" or ".bmp" or ".webp"
                                                => Icons.Material.Rounded.Image,
            ".zip" or ".rar" or ".7z"           => Icons.Material.Rounded.FolderZip,
            ".mp4" or ".avi" or ".mov" or ".mkv"=> Icons.Material.Rounded.VideoLibrary,
            ".mp3" or ".wav" or ".flac"         => Icons.Material.Rounded.AudioFile,
            _                                   => Icons.Material.Rounded.InsertDriveFile,
        };
    }

    private static string GetFileType(string name)
    {
        var ext = Path.GetExtension(name).TrimStart('.').ToUpperInvariant();
        return string.IsNullOrEmpty(ext) ? "File" : ext;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1_048_576) return $"{bytes / 1024.0:0.#} KB";
        if (bytes < 1_073_741_824) return $"{bytes / 1_048_576.0:0.#} MB";
        return $"{bytes / 1_073_741_824.0:0.##} GB";
    }
}
