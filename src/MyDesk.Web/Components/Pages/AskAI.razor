@page "/ask-ai"
@attribute [Authorize]
@inject AzureAIService AI
@inject McpIntegrationService McpSvc
@inject AiAuditService AuditSvc
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JsRuntime
@inject AIFunctionExecutor FuncExecutor
@inject MyDesk.Web.AI.AskAiAgentService Agent
@using MyDesk.Web.Services
@using MyDesk.Web.AI
@using MyDesk.Shared.Services
@using System.Security.Claims
@using Microsoft.JSInterop
@using System.Text.Json
@inject FileLibraryService FileLibrarySvc

<PageTitle>Ask AI - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span style="color:var(--gray-700);font-weight:500;">Ask AI</span>
        </div>
        <h1 style="display:flex;align-items:center;gap:10px;">
            <MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" Style="color:var(--tl-primary);" />
            Ask Techlight AI
        </h1>
        <p class="tl-subtitle">Ask questions about your business data.</p>
    </div>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.Clear"
               OnClick="Clear" Disabled="@(!_history.Any())">Clear</MudButton>
</div>

@if (!AI.IsConfigured)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        Azure OpenAI is not configured. Set <code>Azure:OpenAIEndpoint</code>, <code>Azure:OpenAIModel</code>,
        <code>Azure:OpenAIApiVersion</code>, and <code>Azure:OpenAIApiKey</code> in appsettings.json.
    </MudAlert>
}

<div class="tl-askai-shell">
<MudPaper Elevation="1" Class="pa-4 mb-3 tl-chat-container"
          @ref="_chatBox">
    <div class="tl-chat-messages">
    @if (!_history.Any())
    {
        <div class="tl-chat-empty-state">
            <MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" Style="font-size:3rem;" />
            <MudText Typo="Typo.body1" Class="mt-3">Ask anything about your quotes, invoices, customers, or sales data.</MudText>
            <MudText Typo="Typo.caption">Press Enter to send</MudText>
        </div>
    }
    @foreach (var msg in _history)
    {
        <div class="@(msg.IsUser ? "d-flex justify-end" : "d-flex justify-start") mb-3">
            <div class="@(msg.IsUser ? "tl-chat-bubble-user" : "tl-chat-bubble-ai")" style="max-width:80%;padding:12px 16px;border-radius:12px;font-size:.875rem;white-space:pre-wrap;
                        background:@(msg.IsUser ? "var(--tl-primary)" : "var(--mud-palette-surface)");
                        color:@(msg.IsUser ? "#fff" : "inherit");
                        border:@(msg.IsUser ? "none" : "1px solid var(--gray-200)");">
                @msg.Content
            </div>
        </div>
        @if (!msg.IsUser && msg.Renderables.Count > 0)
        {
            <div class="d-flex justify-start mb-3" style="margin-left:0;max-width:90%;">
                <div style="flex:1;">
                    @foreach (var r in msg.Renderables)
                    {
                        <MyDesk.Web.Components.Shared.AiRenderableView Item="@r" />
                    }
                </div>
            </div>
        }
        @if (!msg.IsUser && msg.ToolTrace.Count > 0)
        {
            <div class="d-flex justify-start mb-3">
                <MudExpansionPanels Elevation="0" Style="background:transparent;flex:1;max-width:90%;">
                    <MudExpansionPanel Text="@($"Tools used ({msg.ToolTrace.Count})")">
                        @foreach (var t in msg.ToolTrace)
                        {
                            <MudText Typo="Typo.caption" Style="font-family:monospace;display:block;opacity:.8;">
                                @(t.Success ? "✓" : "✗") <strong>@t.ToolName</strong> @t.ArgsJson
                            </MudText>
                        }
                    </MudExpansionPanel>
                </MudExpansionPanels>
            </div>
        }
    }
    @if (_thinking)
    {
        <div class="d-flex justify-start mb-3">
            <div class="tl-chat-thinking" style="padding:12px 16px;border-radius:12px;border:1px solid var(--gray-200);">
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                <span style="margin-left:8px;font-size:.875rem;color:var(--gray-500);">Thinking…</span>
            </div>
        </div>
    }
    </div>
</MudPaper>

@if (!_history.Any())
{
    <MudPaper Elevation="0" Class="pa-3 mb-3" Style="background:transparent;">
        <MudText Typo="Typo.caption" Class="mb-2" Style="color:var(--gray-500);">Try asking:</MudText>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var prompt in _suggestedPrompts)
            {
                <MudChip T="string" OnClick="@(() => UseSuggested(prompt))"
                         Color="Color.Default" Variant="Variant.Outlined" Size="Size.Small">
                    @prompt
                </MudChip>
            }
        </div>
    </MudPaper>
}

<MudPaper Elevation="1" Class="tl-chat-input-wrap pa-3">
    <div class="d-flex align-center gap-2 mb-2">
        <MudText Typo="Typo.caption" Style="color:var(--gray-500);">Add to context:</MudText>
        <MudCheckBox @bind-Value="_includeMyDeskData" Size="Size.Small" Label="MyDesk Data" Color="Color.Primary" Dense="true" />
        <MudCheckBox @bind-Value="_includeFilesLibrary" Size="Size.Small" Label="Files Library" Color="Color.Primary" Dense="true" />
        <MudCheckBox @bind-Value="_includeIntegrations" Size="Size.Small" Label="Integrations" Color="Color.Primary" Dense="true" />
    </div>
    <div class="d-flex gap-2 align-end">
        <MudTextField @bind-Value="_input" Placeholder="Ask a question." Variant="Variant.Outlined"
                      Lines="2" Immediate="true" OnKeyDown="OnKeyDown" Style="flex:1;"
                      Margin="Margin.Dense" Disabled="@_thinking" />
        <MudIconButton Icon="@(_listening ? Icons.Material.Rounded.MicOff : Icons.Material.Rounded.Mic)"
                       Color="@(_listening ? Color.Error : Color.Default)"
                       OnClick="ToggleVoiceAsync" Disabled="@_thinking" Size="Size.Large"
                       title="Voice input (browser speech recognition)" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Send"
                   OnClick="SendAsync"
                   Disabled="@(_thinking || string.IsNullOrWhiteSpace(_input))">
            Send
        </MudButton>
    </div>
        <MudText Typo="Typo.caption" Class="mt-1" Style="color:var(--gray-500);">
            Enter to send · Shift+Enter for new line · 🎤 to speak · All interactions are logged for compliance
        </MudText>
</MudPaper>
</div>

@code {
    private string _input = "";
    private bool _thinking;
    private MudPaper? _chatBox;

    private record UiMessage(
        bool IsUser,
        string Content,
        IReadOnlyList<AiRenderable> Renderables,
        IReadOnlyList<AskAiToolTrace> ToolTrace)
    {
        public static UiMessage User(string content)         => new(true, content, Array.Empty<AiRenderable>(), Array.Empty<AskAiToolTrace>());
        public static UiMessage Assistant(string content,
            IReadOnlyList<AiRenderable>? r = null,
            IReadOnlyList<AskAiToolTrace>? t = null) =>
            new(false, content, r ?? Array.Empty<AiRenderable>(), t ?? Array.Empty<AskAiToolTrace>());
    }
    private readonly List<UiMessage> _history = new();

    private readonly List<AzureChatMessage> _apiMessages = new();
    private string? _userCode;
    private bool _contextLoaded;
    private bool _listening;
    private DotNetObjectReference<AskAI>? _dotNetRef;

    private readonly string[] _suggestedPrompts = new[]
    {
        "How many quotes have we won this month vs lost? Show me a chart.",
        "Show our revenue trend for the last 12 months as a line chart.",
        "What's in our open pipeline by ageing?",
        "Schedule a weekly pipeline summary email to peter@bardenhagen.xyz every Monday at 9am.",
        "Compare quotes won vs lost this quarter — pie chart.",
        "How is the pipeline trending this month?",
        "Set up a daily reminder to file timesheets at 5pm.",
        "What's our cash position?",
        "Show me invoiced revenue YTD."
    };

    /// <summary>
    /// File inclusion toggle flags
    /// </summary>
    private bool _includeMyDeskData = true;
    private bool _includeFilesLibrary = true;
    private bool _includeIntegrations = true;
    
    [Inject] private PlatformSettingsService SettingsSvc { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        _userCode = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "unknown";
        
        var companyName = SettingsSvc.Current.CompanyName;
        var platformName = SettingsSvc.Current.PlatformName;
        
        _apiMessages.Add(AzureChatMessage.System($@"
You are a helpful AI assistant embedded in {platformName}, a business management system for {companyName}.

You have access to the following business data through function calls:
- Quotes (with status, amounts, dates)
- Invoices (with status, balances, due dates)
- Purchase Orders
- Companies/Contacts
- Expenses
- Aged receivables

IMPORTANT: When users ask about business data, use the appropriate function to fetch real data.
Available functions:
- get_quotes: Get quotes with optional status/minAmount/limit filters
- get_invoices: Get invoices with optional status/minAmount/limit filters  
- get_purchase_orders: Get purchase orders with optional status/limit filters
- get_companies: Get companies with optional search/limit filters
- get_expenses: Get expenses with optional status/limit filters
- get_aged_receivables: Get outstanding invoices and total owed
- get_dashboard_stats: Get summary statistics
- execute_query: Execute a custom SELECT query (read-only)

Always use functions to get real data rather than saying data is unavailable.
Be concise, practical, and focus on actionable business insights."));
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey) { await SendAsync(); }
    }

    private async Task SendAsync()
    {
        var question = _input.Trim();
        if (string.IsNullOrEmpty(question) || _thinking) return;

        _history.Add(UiMessage.User(question));
        _input = "";
        _thinking = true;
        StateHasChanged();

        var startTime = DateTime.Now;
        var success = true;
        var replyContent = "";

        try
        {
            if (!AI.IsConfigured)
            {
                throw new InvalidOperationException("Azure OpenAI is not configured. Please set Azure:OpenAIEndpoint, Azure:OpenAIModel, Azure:OpenAIApiVersion, and Azure:OpenAIApiKey in appsettings.json");
            }

            // Use the AskAiAgentService — it has access to typed tools (quotes / invoices /
            // pipeline summaries with chart specs, schedule_recurring_task, etc.) and runs
            // a multi-turn tool-calling loop. Tools execute inside this request scope so
            // tenant isolation (RLS + EF filter) applies automatically.
            var reply = await Agent.AskAsync(question);
            replyContent = reply.Text;
            _history.Add(UiMessage.Assistant(reply.Text, reply.Renderables, reply.Trace));
        }
        catch (Exception ex)
        {
            success = false;
            replyContent = $"Error: {ex.Message}";
            _history.Add(UiMessage.Assistant(replyContent));
        }
        finally
        {
            var duration = (int)(DateTime.Now - startTime).TotalMilliseconds;
            _ = Task.Run(() => AuditSvc.LogAsync(_userCode!, "web", question, replyContent,
                success: success, durationMs: duration));
        }

        _thinking = false;
        StateHasChanged();
    }

    private async Task<object?> TryExecuteFunctionAsync(string question)
    {
        var lowerQuestion = question.ToLowerInvariant();
        
        // Check for quotes-related queries
        if (lowerQuestion.Contains("quote"))
        {
            decimal? minAmount = null;
            if (lowerQuestion.Contains("$10,000") || lowerQuestion.Contains("10000"))
                minAmount = 10000;
            else if (lowerQuestion.Contains("$5,000") || lowerQuestion.Contains("5000"))
                minAmount = 5000;
                
            return await FuncExecutor.GetQuotesAsync(
                lowerQuestion.Contains("pending") ? "Pending" : null,
                minAmount,
                20);
        }
        
        // Check for invoices-related queries
        if (lowerQuestion.Contains("invoice") || lowerQuestion.Contains("owe") || lowerQuestion.Contains("outstanding"))
        {
            return await FuncExecutor.GetInvoicesAsync(null, null, 20);
        }
        
        // Check for purchase orders
        if (lowerQuestion.Contains("purchase order") || lowerQuestion.Contains("po "))
        {
            return await FuncExecutor.GetPurchaseOrdersAsync(null, 20);
        }
        
        // Check for companies
        if (lowerQuestion.Contains("compan") || lowerQuestion.Contains("customer"))
        {
            return await FuncExecutor.GetCompaniesAsync(null, 20);
        }
        
        // Check for expenses
        if (lowerQuestion.Contains("expense"))
        {
            return await FuncExecutor.GetExpensesAsync(null, 20);
        }
        
        // Check for aged receivables
        if (lowerQuestion.Contains("aged") || lowerQuestion.Contains("receivable") || lowerQuestion.Contains("overdue"))
        {
            return await FuncExecutor.GetAgedReceivablesAsync();
        }
        
        // Check for dashboard/stats
        // Check for queries about summary or stats
        if (lowerQuestion.Contains("summary") || lowerQuestion.Contains("stats") || lowerQuestion.Contains("brief me") || lowerQuestion.Contains("cash position") || lowerQuestion.Contains("how many"))
        {
            return await FuncExecutor.GetDashboardStatsAsync();
        }

        return null;
    }

    private void UseSuggested(string prompt)
    {
        _input = prompt;
    }

    private void Clear()
    {
        _history.Clear();
        // Keep the system priming message (index 0) — used only by the legacy chat path.
        if (_apiMessages.Count > 1) _apiMessages.RemoveRange(1, _apiMessages.Count - 1);
        _input = "";
    }

    private async Task ToggleVoiceAsync()
    {
        try
        {
            if (_dotNetRef == null)
                _dotNetRef = DotNetObjectReference.Create(this);

            if (!_listening)
            {
                await JsRuntime.InvokeVoidAsync("startSpeechRecognition", _dotNetRef);
                _listening = true;
            }
            else
            {
                await JsRuntime.InvokeVoidAsync("stopSpeechRecognition");
                _listening = false;
            }
        }
        catch (Exception ex)
        {
            _listening = false;
            _history.Add(UiMessage.Assistant($"Voice input not available: {ex.Message}"));
        }
    }

    [JSInvokable]
    public void OnSpeechResult(string transcript)
    {
        _input = transcript;
        _listening = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnSpeechEnd()
    {
        _listening = false;
        InvokeAsync(StateHasChanged);
    }

}

<style>
    /* Shell that fits the visible viewport — chat scrolls internally,
        suggestions + input bar stay pinned at the bottom regardless of how
        many suggestion chips wrap onto extra rows.
        The header above us in MainLayout is ~64px and the page-header inside
        AskAI is ~120px, so we subtract those plus some breathing room. */
    .tl-askai-shell {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 220px);
        min-height: 480px;
    }
    
    /* Ensure input bar is always visible and sticky at bottom */
    .tl-askai-shell > .tl-chat-input-wrap {
        position: sticky;
        bottom: 0;
        background: var(--surface);
        z-index: 10;
        margin-top: auto;
    }
    body.mud-dark-mode .tl-askai-shell > .tl-chat-input-wrap {
        background: var(--gray-100) !important;
        border-top: 1px solid var(--gray-300);
    }
    .tl-chat-container {
        flex: 1 1 auto;
        min-height: 0;          /* allow children to shrink so flex scrolling works */
        display: flex;
        flex-direction: column;
        overflow: hidden;
        background: var(--mud-palette-background);
    }
    .tl-chat-messages {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 4px;
    }
    .tl-chat-empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100%;
        min-height: 200px;
        opacity: 0.45;
    }
    /* Suggestions + input pinned at bottom of the shell */
    .tl-askai-shell > .tl-chat-input-wrap {
        flex: 0 0 auto;
    }

    body.mud-dark-mode .tl-chat-bubble-ai { background: var(--gray-200) !important; border-color: var(--gray-400) !important; color: var(--gray-900) !important; }
    body.mud-dark-mode .tl-chat-bubble-user { background: var(--tl-primary-400) !important; color: #000 !important; }
    body.mud-dark-mode .tl-chat-thinking { border-color: var(--gray-400) !important; background: var(--gray-100); }
    body.mud-dark-mode .tl-chat-input-wrap { background: var(--gray-100) !important; border-color: var(--gray-300) !important; }
    body.mud-dark-mode .tl-chat-container { background: var(--gray-50) !important; }
</style>
