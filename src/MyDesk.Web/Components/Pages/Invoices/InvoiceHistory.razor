@page "/invoices/{Id:int}/history"
@attribute [Authorize]
@inject InvoiceService InvoiceService
@inject NavigationManager Nav

<PageTitle>Invoice @Id History - Techlight MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Techlight MyDesk</a><span class="sep">/</span>
            <a href="/invoices">Invoices</a><span class="sep">/</span>
            <a href="@($"/invoices/{Id}")">Invoice @Id</a><span class="sep">/</span>
            <span>History</span>
        </div>
        <h1>Invoice History</h1>
    </div>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.ArrowBack"
               Href="@($"/invoices/{Id}")">Back to Invoice</MudButton>
</div>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else if (!_entries.Any())
{
    <MudAlert Severity="Severity.Info">No history records found for this invoice.</MudAlert>
}
else
{
    <MudPaper Elevation="1">
        <MudTable Items="@_entries" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>Date</MudTh>
                <MudTh>User</MudTh>
                <MudTh>Action</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.DateEntered.ToString("dd MMM yyyy HH:mm")</MudTd>
                <MudTd>@(context.UserName ?? context.Code)</MudTd>
                <MudTd>@context.Action</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    [Parameter] public int Id { get; set; }
    private List<InvoiceAuditEntry> _entries = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try   { _entries = await InvoiceService.GetAuditAsync(Id); }
        finally { _loading = false; }
    }
}

