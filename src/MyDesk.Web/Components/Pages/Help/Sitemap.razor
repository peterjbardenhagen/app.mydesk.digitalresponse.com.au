@page "/sitemap"
@attribute [Authorize]
@inject PlatformSettingsService PlatformSettings

<PageTitle>Site Map - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Dashboard</a><span class="sep">/</span>
            <a href="/help-center">Help Centre</a><span class="sep">/</span>
            <span>Site Map</span>
        </div>
        <h1>Site Map</h1>
        <p class="tl-subtitle">Every page in @PlatformSettings.GetBrandingName(), grouped by area. Use it as a quick reference or to confirm a feature exists.</p>
    </div>
    <div>
        <MudTextField T="string" @bind-Value="_filter" Placeholder="Filter pages…" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search" Immediate="true" Margin="Margin.Dense" Style="width: 280px;" />
    </div>
</div>

<MudGrid Spacing="3" Class="mt-2">
    @foreach (var section in _sections)
    {
        var visible = section.Pages.Where(MatchesFilter).ToList();
        if (visible.Count == 0) { continue; }

        <MudItem xs="12" md="6" lg="4">
            <MudPaper Class="pa-5 rounded-xl h-100" Elevation="0" Style="border:1px solid var(--gray-200);">
                <div class="d-flex align-center gap-2 mb-3">
                    <MudIcon Icon="@section.Icon" Color="Color.Primary" />
                    <MudText Typo="Typo.h6" Class="font-weight-bold">@section.Title</MudText>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-auto">@visible.Count</MudChip>
                </div>
                <div class="d-flex flex-column gap-1">
                    @foreach (var p in visible)
                    {
                        <MudLink Href="@p.Path" Underline="Underline.Hover" Class="d-flex align-center gap-2 sitemap-link">
                            <MudIcon Icon="@(string.IsNullOrEmpty(p.Icon) ? Icons.Material.Rounded.ChevronRight : p.Icon)" Size="Size.Small" Color="Color.Default" />
                            <span><strong>@p.Label</strong> <span class="mud-text-secondary" style="font-size:.85em;">@p.Path</span></span>
                        </MudLink>
                    }
                </div>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

<style>
    .sitemap-link { padding: 4px 6px; border-radius: 6px; }
    .sitemap-link:hover { background: var(--gray-50); }
    .h-100 { height: 100%; }
</style>

