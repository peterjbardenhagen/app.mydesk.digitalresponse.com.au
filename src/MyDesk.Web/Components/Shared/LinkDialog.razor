@using MyDesk.Shared.Models

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Title</MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField @bind-Value="Link.Title" Label="Title" Required="true" RequiredError="Title is required" Class="mb-3" />
            <MudTextField @bind-Value="Link.Url" Label="URL" Required="true" RequiredError="URL is required" Class="mb-3" />
            <MudTextField @bind-Value="Link.Description" Label="Description" Lines="2" Class="mb-3" />
            <MudTextField @bind-Value="Link.Icon" Label="Icon (Material name, e.g. Link)" Class="mb-3" />
            <MudTextField @bind-Value="Link.Category" Label="Category" Class="mb-3" />
            <MudNumericField @bind-Value="Link.DisplayOrder" Label="Display Order" Min="0" Class="mb-3" />
            <MudSwitch @bind-Value="Link.IsExternal" Label="Opens in new tab" Color="Color.Primary" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string Title { get; set; } = "Link";
    [Parameter] public ImportantLink Link { get; set; } = new();

    private MudForm? _form;

    private async Task Save()
    {
        if (_form is not null) { await _form.Validate(); if (!_form.IsValid) return; }
        if (Link.Id == Guid.Empty) Link.Id = Guid.NewGuid();
        MudDialog.Close(DialogResult.Ok(Link));
    }

    private void Cancel() => MudDialog.Cancel();
}
