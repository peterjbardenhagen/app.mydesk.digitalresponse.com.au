@using MudBlazor
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject InvoiceService InvoiceService
@inject LookupService LookupService
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-4">Bulk Update Invoice Status</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">Update status for @SelectedCount selected invoice(s).</MudText>
        <MudSelect T="int" @bind-Value="_newStatusId" Label="New Status" Variant="Variant.Outlined" FullWidth>
            @foreach (var s in _statuses)
            {
                <MudSelectItem T="int" Value="@s.InvoiceStatusId">@s.StatusName</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="UpdateStatus" Disabled="@(_newStatusId == 0)">Update Status</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public MudDialogInstance? Dialog { get; set; }
    
    [Parameter] public List<int> InvoiceIds { get; set; } = new();
    [Parameter] public int SelectedCount { get; set; }

    private int _newStatusId = 0;
    private List<InvoiceStatus> _statuses = new();
    
    protected override async Task OnInitializedAsync()
    {
        _statuses = await LookupService.GetInvoiceStatusesAsync();
    }

    private async Task UpdateStatus()
    {
        if (_newStatusId == 0 || !InvoiceIds.Any()) return;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userCode = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
            var statusName = _statuses.FirstOrDefault(s => s.InvoiceStatusId == _newStatusId)?.StatusName ?? "";

            foreach (var id in InvoiceIds)
            {
                await InvoiceService.UpdateStatusAsync(id, _newStatusId, userCode, statusName);
            }

            Snackbar.Add($"Updated {InvoiceIds.Count} invoice(s) to '{statusName}'.", Severity.Success);
            Dialog?.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Update failed: {ex.Message}", Severity.Error);
        }
    }
    
    private void Cancel() => Dialog?.Cancel();
}
