@using MyDesk.Shared.Models

<MudForm @ref="_form">
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">System Credential</MudText>
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Site Name" @bind-Value="_cred.SiteName" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Category" @bind-Value="_cred.Category" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Description" @bind-Value="_cred.Description" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Website URL" @bind-Value="_cred.Website" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Username" @bind-Value="_cred.Username" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Password" @bind-Value="_cred.EncryptedPassword" InputType="InputType.Password" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Value="_cred.IsActive" Label="Active" />
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Save</MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SystemCredential Credential { get; set; } = new();

    private MudForm _form = default!;
    private SystemCredential _cred = new();

    protected override void OnInitialized()
    {
        _cred = Credential ?? new SystemCredential();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        MudDialog.Close(_cred);
    }
}
