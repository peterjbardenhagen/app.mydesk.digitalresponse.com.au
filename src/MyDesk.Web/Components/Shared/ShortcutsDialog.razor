<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Rounded.Keyboard" Size="Size.Small" />
            <span>Keyboard Shortcuts</span>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.subtitle2" Class="mb-3">Navigation</MudText>
        <div class="shortcut-list">
            <div class="shortcut-item">
                <kbd class="shortcut-key">Ctrl</kbd> + <kbd class="shortcut-key">K</kbd>
                <span>Quick search</span>
            </div>
            <div class="shortcut-item">
                <kbd class="shortcut-key">Ctrl</kbd> + <kbd class="shortcut-key">/</kbd>
                <span>Go to Dashboard</span>
            </div>
        </div>

        <MudDivider Class="my-4" />

        <MudText Typo="Typo.subtitle2" Class="mb-3">Actions</MudText>
        <div class="shortcut-list">
            <div class="shortcut-item">
                <kbd class="shortcut-key">Ctrl</kbd> + <kbd class="shortcut-key">N</kbd>
                <span>New item</span>
            </div>
            <div class="shortcut-item">
                <kbd class="shortcut-key">Ctrl</kbd> + <kbd class="shortcut-key">S</kbd>
                <span>Save</span>
            </div>
            <div class="shortcut-item">
                <kbd class="shortcut-key">Escape</kbd>
                <span>Close dialog / cancel</span>
            </div>
        </div>

        <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true">
            More shortcuts coming soon
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .shortcut-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .shortcut-item {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .shortcut-key {
        display: inline-block;
        padding: 4px 8px;
        font-size: 12px;
        font-weight: 600;
        background: var(--gray-100);
        border: 1px solid var(--gray-300);
        border-radius: 4px;
        min-width: 24px;
        text-align: center;
    }
</style>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private void Close()
    {
        MudDialog.Cancel();
    }
}
