<MudDialog Options="new DialogOptions { CloseButton = true, CloseOnEscapeKey = true }">
    <DialogContent>
        <MudText Typo="Typo.h6" Class="mb-3">Schedule Campaign</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">Campaign: @CampaignName</MudText>
        
        <MudDatePicker @bind-Date="_scheduledDate"
                      Label="Schedule Date & Time"
                      PickerVariant="PickerVariant.Dialog"
                      OpenTo="OpenTo.Date"
                      Required="true"
                      RequiredError="Schedule date is required" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">Schedule</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int CampaignId { get; set; }
    [Parameter] public string CampaignName { get; set; } = "";

    private DateTime? _scheduledDate = DateTime.Now.AddDays(1);

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Submit()
    {
        if (!_scheduledDate.HasValue || _scheduledDate.Value < DateTime.Now)
        {
            return;
        }

        MudDialog.Close(DialogResult.Ok(_scheduledDate.Value));
    }
}
