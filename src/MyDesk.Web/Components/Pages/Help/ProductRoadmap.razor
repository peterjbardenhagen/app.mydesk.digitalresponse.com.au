@page "/help/roadmap"
@page "/roadmap"
@attribute [Authorize]
@inject PlatformSettingsService PlatformSettings

<PageTitle>Product Roadmap - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Dashboard</a><span class="sep">/</span>
            <a href="/help-center">Help Centre</a><span class="sep">/</span>
            <span>Product Roadmap</span>
        </div>
        <h1>Product Roadmap</h1>
        <p class="tl-subtitle">The strategic direction for @PlatformSettings.GetBrandingName() – built for Australian small and medium businesses.</p>
    </div>
</div>

<MudGrid Spacing="4" Class="mt-4">
    <MudItem xs="12" md="8">
        <MudPaper Class="pa-8 rounded-xl" Elevation="1">

            @* ---------------------- SHIPPED ---------------------- *@
            <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Shipped (v3.0 – v3.1)</MudText>
            <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
                Already in production and available to all customers today.
            </MudText>
            <div class="d-flex flex-column gap-2 mb-8">
                @foreach (var item in _shipped)
                {
                    <div class="status-item">
                        <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.body2"><strong>@item.Title:</strong> @item.Detail</MudText>
                    </div>
                }
            </div>

            <MudDivider Class="my-6" />

            @* ---------------------- PHASES ---------------------- *@
            @foreach (var phase in _phases)
            {
                <div class="roadmap-section mb-8">
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudIcon Icon="@phase.Icon" Color="Color.Primary" Size="Size.Medium" />
                        <MudText Typo="Typo.h6" Class="color-primary font-weight-bold">@phase.Title</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-3">@phase.Subtitle</MudText>
                    <ul class="roadmap-list">
                        @foreach (var f in phase.Features)
                        {
                            <li>
                                <strong>@f.Title.</strong> @f.Detail
                                @if (!string.IsNullOrWhiteSpace(f.Tag))
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Class="ml-2">@f.Tag</MudChip>
                                }
                            </li>
                        }
                    </ul>
                </div>
            }

            <MudDivider Class="my-6" />

            <MudText Typo="Typo.h5" Class="mb-4 font-weight-bold">Infrastructure Evolution</MudText>
            <ul class="roadmap-list">
                <li><strong>Schema-per-tenant.</strong> Database partitioning for high-security clients (government, medical, legal).</li>
                <li><strong>Self-healing data layer.</strong> AI-monitored data integrity that flags incorrect ABNs, GST mismatches and duplicate records.</li>
                <li><strong>On-premise / sovereign LLM.</strong> Locally hosted Llama 3 / Phi-3 models for clients with extreme data sovereignty requirements.</li>
                <li><strong>Australian region hosting.</strong> All data hosted in Sydney/Melbourne Azure regions; CDR-ready architecture.</li>
                <li><strong>Daily encrypted backups.</strong> 30-day point-in-time restore included for every tenant.</li>
            </ul>

        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Class="pa-6 rounded-xl sidebar-card" Elevation="0">
            <MudText Typo="Typo.h6" Class="mb-3">Strategic Vision</MudText>
            <MudText Typo="Typo.body2" Class="mb-3">
                @PlatformSettings.GetBrandingName() is evolving into a <strong>one-stop-shop AI-powered business operating system</strong> for Australian SMBs – replacing the patchwork of accounting, CRM, ops and comms tools most businesses still juggle.
            </MudText>
            <MudText Typo="Typo.body2">
                The goal is a platform you can <strong>talk to</strong>, and that <strong>talks to you</strong>.
            </MudText>
        </MudPaper>

        <MudPaper Class="pa-6 rounded-xl mt-4" Elevation="0" Style="background: #f1f5f9;">
            <MudText Typo="Typo.subtitle2" Class="mb-2 opacity-60">BY THE NUMBERS</MudText>
            <div class="d-flex flex-column gap-2">
                <div><MudText Typo="Typo.h5" Class="font-weight-bold">@_shipped.Count</MudText><MudText Typo="Typo.caption">features shipped</MudText></div>
                <div><MudText Typo="Typo.h5" Class="font-weight-bold">@_phases.Sum(p => p.Features.Count)</MudText><MudText Typo="Typo.caption">on the roadmap</MudText></div>
                <div><MudText Typo="Typo.h5" Class="font-weight-bold">@_phases.Count</MudText><MudText Typo="Typo.caption">delivery phases</MudText></div>
            </div>
        </MudPaper>

        <MudPaper Class="pa-6 rounded-xl mt-4" Elevation="0" Style="background: #fffbeb;">
            <MudText Typo="Typo.subtitle2" Class="mb-2 opacity-60">PREPARED BY</MudText>
            <MudText Typo="Typo.body1" Class="font-weight-bold">Digital Response</MudText>
            <MudText Typo="Typo.caption" Class="d-block mt-1">Last updated: @DateTime.Today.ToString("dd MMMM yyyy")</MudText>
            <MudButton Class="mt-3" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Rounded.Email" Href="@($"mailto:{PlatformSettings.Current.SupportEmail}?subject=Roadmap%20feedback")">
                Send Feedback
            </MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

<style>
    .status-item { display: flex; align-items: flex-start; gap: 12px; }
    .color-primary { color: var(--tl-primary, #00c8c8); }
    .roadmap-list { padding-left: 20px; color: var(--gray-700); }
    .roadmap-list li { margin-bottom: 10px; line-height: 1.55; }
    .sidebar-card { background: #f0fdfa !important; border: 1px solid #ccfbf1; }
</style>

@code {
