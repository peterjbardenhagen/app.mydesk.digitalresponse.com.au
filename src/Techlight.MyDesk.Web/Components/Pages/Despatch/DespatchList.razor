@page "/despatch"
@attribute [Authorize]
@inject DespatchService Svc

<PageTitle>Despatch - Techlight MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb"><a href="/">Techlight MyDesk</a><span class="sep">/</span><span style="color:var(--gray-700); font-weight:500;">Despatch</span></div>
        <h1>Despatch</h1>
        <p class="tl-subtitle">Shipment tracking linked to invoices.</p>
    </div>
</div>

@if (_items == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-0">
        <MudDataGrid T="DespatchRow" Items="_items" Dense="true" Hover="true" Elevation="0"
                     Filterable="true" QuickFilter="@QuickFilter">
            <ToolBarContent>
                <MudTextField T="string" Placeholder="Search shipments..." @bind-Value="_search" Immediate="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
                <MudSpacer />
                <MudText Typo="Typo.caption" Class="mt-2" Style="color:var(--gray-500);">
                    Showing latest 500 records
                </MudText>
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.DespatchId" Title="#" CellStyle="width:80px;" />
                <PropertyColumn Property="x => x.DespatchDate" Title="Date" Format="yyyy-MM-dd" />
                <PropertyColumn Property="x => x.CompanyName" Title="Customer" />
                <PropertyColumn Property="x => x.InvoiceNumber" Title="Invoice #" />
                <PropertyColumn Property="x => x.Carrier" Title="Carrier" />
                <PropertyColumn Property="x => x.TrackingNumber" Title="Tracking" />
            </Columns>
            <PagerContent><MudDataGridPager T="DespatchRow" /></PagerContent>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<DespatchRow>? _items;
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _items = await Svc.GetAllAsync();
    }

    private Func<DespatchRow, bool> QuickFilter => d =>
        string.IsNullOrWhiteSpace(_search) ||
        (d.CompanyName?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (d.InvoiceNumber?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
        (d.TrackingNumber?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false);
}
