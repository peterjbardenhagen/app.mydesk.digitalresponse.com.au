@page "/dashboards/executive"
@using System.Net.Http.Json
@using System.Security.Claims
@using MyDesk.Web.Services
@using MyDesk.Web.Components.Shared
@using MyDesk.Web.Components.Dialogs
@inject AnalyticsService AnalyticsService
@inject DashboardChartService ChartService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Executive Dashboard - MyDesk</PageTitle>

<MudContainer MaxWidth="MaxWidth.Lg" Class="py-8">
    <MudStack Spacing="4">
        <!-- Header -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="responsive-header">
            <MudStack>
                <MudText Typo="Typo.h4" Class="font-bold">Executive Dashboard</MudText>
                <MudText Typo="Typo.body2" Color="Color.TextSecondary">Real-time metrics for CFO oversight</MudText>
            </MudStack>
            <MudStack Row="true" Spacing="2" Class="responsive-buttons">
                <MudButton Variant="Variant.Outlined" OnClick="RefreshData" StartIcon="@Icons.Material.Filled.Refresh">
                    Refresh
                </MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="ShowExportDialog" StartIcon="@Icons.Material.Filled.FileDownload">
                    Export
                </MudButton>
            </MudStack>
        </MudStack>

        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (dashboard != null)
        {
            <!-- Key Metrics - Mobile First Grid -->
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MetricCard
                        Title="Total Expenses MTD"
                        Value="@FormatCurrency(dashboard.TotalExpensesMonthToDate)"
                        Icon="@Icons.Material.Filled.AttachMoney"
                        IconColor="Color.Primary" />
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MetricCard
                        Title="Pending Approvals"
                        Value="@dashboard.PendingApprovals.ToString()"
                        Icon="@Icons.Material.Filled.HourglassBottom"
                        IconColor="Color.Warning" />
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MetricCard
                        Title="Approved This Month"
                        Value="@dashboard.ApprovedThisMonth.ToString()"
                        Icon="@Icons.Material.Filled.CheckCircle"
                        IconColor="Color.Success" />
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MetricCard
                        Title="Avg. Approval Time"
                        Value="@FormatHours(dashboard.AverageApprovalTimeHours)"
                        Icon="@Icons.Material.Filled.Schedule"
                        IconColor="Color.Info" />
                </MudItem>
            </MudGrid>

            <!-- Expenses by Department -->
            <MudPaper Class="pa-6">
                <MudText Typo="Typo.h6" Class="font-bold mb-4">Expenses by Department</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudStack Spacing="2">
                            @foreach (var dept in dashboard.ByDepartment)
                            {
                                <MudPaper Class="pa-3" Elevation="0">
                                    <div class="d-flex justify-space-between w-100">
                                        <MudText>@dept.Department</MudText>
                                        <MudStack Row="true" Spacing="2">
                                            <MudText Class="font-semibold">@FormatCurrency(dept.Amount)</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@dept.Count items</MudChip>
                                        </MudStack>
                                    </div>
                                    <MudProgressLinear Value="@GetPercentage(dept.Amount)" Class="mt-2" />
                                </MudPaper>
                            }
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <DashboardPieChart
                            Title="Department Distribution"
                            TenantId="@tenantId"
                            DataSourceAsync="@(() => ChartService.GetDepartmentChartDataAsync(tenantId))" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Expenses by Category -->
            <MudPaper Class="pa-6">
                <MudText Typo="Typo.h6" Class="font-bold mb-4">Expenses by Category</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudStack Spacing="2">
                            @foreach (var cat in dashboard.ByCategory)
                            {
                                <MudPaper Class="pa-3" Elevation="0">
                                    <div class="d-flex justify-space-between w-100">
                                        <MudText>@cat.Category</MudText>
                                        <MudStack Row="true" Spacing="2">
                                            <MudText Class="font-semibold">@FormatCurrency(cat.Amount)</MudText>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default">@cat.Count items</MudChip>
                                        </MudStack>
                                    </div>
                                    <MudProgressLinear Value="@GetPercentage(cat.Amount)" Class="mt-2" />
                                </MudPaper>
                            }
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <DashboardPieChart
                            Title="Category Distribution"
                            TenantId="@tenantId"
                            DataSourceAsync="@(() => ChartService.GetCategoryChartDataAsync(tenantId))" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Budget vs Actual -->
            <DashboardBarChart
                Title="Budget vs Actual by Department"
                TenantId="@tenantId"
                DataSourceAsync="@(() => ChartService.GetBudgetVsActualChartDataAsync(tenantId))" />
        }
        else
        {
            <MudAlert Severity="Severity.Error">
                Failed to load dashboard data. Please try again.
            </MudAlert>
        }
    </MudStack>
</MudContainer>

@code {
    private bool isLoading = true;
    private ExecutiveDashboard? dashboard;
    private int tenantId = 1;

    protected override async Task OnInitializedAsync()
    {
        await GetAuthenticationContext();
        await LoadDashboard();
    }

    private async Task GetAuthenticationContext()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user?.Identity?.IsAuthenticated == true)
        {
            var tenantClaim = user.FindFirst("tenant_id")?.Value;
            if (int.TryParse(tenantClaim, out var tid))
            {
                tenantId = tid;
            }
        }
    }

    private async Task LoadDashboard()
    {
        try
        {
            isLoading = true;
            dashboard = await AnalyticsService.GetExecutiveDashboardAsync(tenantId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading dashboard: {ex.Message}", Severity.Error);
            dashboard = null;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshData()
    {
        await LoadDashboard();
        Snackbar.Add("Dashboard refreshed", Severity.Success);
    }

    private async Task ShowExportDialog()
    {
        var dialog = await DialogService.ShowAsync<DashboardExportDialog>(
            "Export Dashboard",
            new DialogParameters
            {
                { "DashboardType", "executive" }
            });

        var result = await dialog.Result;
        if (!result.Canceled)
        {
            Snackbar.Add("Dashboard export completed", Severity.Success);
        }
    }

    private string FormatCurrency(decimal amount) => amount.ToString("C");

    private string FormatHours(double hours) => $"{hours:F1}h";

    private int GetPercentage(decimal amount) => (int)((amount / 45250.75m) * 100);
}

<style>
.responsive-header {
    flex-wrap: wrap;
    gap: 1rem;
}

.responsive-buttons {
    gap: 0.5rem;
    flex-wrap: wrap;
}

@media (max-width: 599px) {
    .responsive-header {
        flex-direction: column;
        align-items: stretch !important;
    }

    .responsive-buttons {
        width: 100%;
        flex-direction: column;
    }

    :deep(.mud-button) {
        width: 100%;
    }
}
</style>
