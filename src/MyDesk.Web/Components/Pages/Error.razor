@page "/Error"
@layout EmptyLayout
@using System.Diagnostics
@using Microsoft.AspNetCore.Diagnostics
@inject PlatformSettingsService PlatformSettings
@inject IHttpContextAccessor HttpContextAccessor
@inject IWebHostEnvironment Environment
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime

<PageTitle>Error - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="tl-error-root">
    <div class="tl-error-container">
        <div class="tl-error-card">
            <div class="tl-error-icon">
                <MudIcon Icon="@Icons.Material.Rounded.ErrorOutline" Size="Size.Large" />
            </div>
            
            <h1>Something went wrong</h1>
            <p class="tl-error-subtitle">We're sorry, but an unexpected error occurred. Our team has been notified.</p>
            
            @if (!string.IsNullOrEmpty(RequestId))
            {
                <div class="tl-error-details">
                    <MudText Typo="Typo.caption" Class="tl-request-id">
                        <MudIcon Icon="@Icons.Material.Rounded.Fingerprint" Size="Size.Small" />
                        Request ID: <code>@RequestId</code>
                        <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Primary"
                                   OnClick="CopyRequestId" Class="ml-2" Style="min-width:auto;padding:4px 8px;">
                            <MudIcon Icon="@Icons.Material.Rounded.ContentCopy" Size="Size.Small" />
                        </MudButton>
                    </MudText>
                </div>
            }

            @if (HasExceptionDetails)
            {
                <div class="tl-error-toggle-row">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Default"
                               Size="Size.Small"
                               StartIcon="@(_showDetails ? Icons.Material.Rounded.ExpandLess : Icons.Material.Rounded.ExpandMore)"
                               OnClick="@(() => _showDetails = !_showDetails)">
                        @(_showDetails ? "Hide error details" : "View error details")
                    </MudButton>
                </div>

                <MudCollapse Expanded="_showDetails">
                    <div class="tl-error-stack">
                        @if (!string.IsNullOrWhiteSpace(_exceptionType))
                        {
                            <div class="tl-error-stack-row">
                                <span class="tl-error-stack-label">Type</span>
                                <code>@_exceptionType</code>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_exceptionPath))
                        {
                            <div class="tl-error-stack-row">
                                <span class="tl-error-stack-label">Path</span>
                                <code>@_exceptionPath</code>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_exceptionMessage))
                        {
                            <div class="tl-error-stack-row">
                                <span class="tl-error-stack-label">Message</span>
                                <code>@_exceptionMessage</code>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_innerExceptionMessage))
                        {
                            <div class="tl-error-stack-row">
                                <span class="tl-error-stack-label">Inner</span>
                                <code>@_innerExceptionMessage</code>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_stackTrace))
                        {
                            <div class="tl-error-stack-row">
                                <span class="tl-error-stack-label">Stack trace</span>
                                <pre class="tl-error-stack-trace">@_stackTrace</pre>
                            </div>
                        }
                        @if (!isDevelopment)
                        {
                            <MudText Typo="Typo.caption" Class="mt-2" Style="opacity:0.7;">
                                Production builds redact sensitive details. Full stack traces are available in
                                Admin → Setup → Error Logs.
                            </MudText>
                        }
                    </div>
                </MudCollapse>
            }

            <div class="tl-error-actions">
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="rounded-xl">
                    <MudIcon Icon="@Icons.Material.Rounded.Home" Size="Size.Small" />
                    Return to Dashboard
                </MudButton>
                <MudButton Href="mailto:support@digitalresponse.com.au" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" Class="rounded-xl">
                    <MudIcon Icon="@Icons.Material.Rounded.Support" Size="Size.Small" />
                    Contact Support
                </MudButton>
            </div>
        </div>

        <div class="tl-error-footer">
            @if (isDevelopment)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mt-6">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>Development Mode Active</strong>
                    </MudText>
                    <MudText Typo="Typo.caption">
                        Detailed error information is being logged to the database. Check the Admin > Setup > Error Logs section for details.
                    </MudText>
                </MudAlert>
            }
            
            <div class="tl-help-tips">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Helpful Tips</MudText>
                <ul>
                    <li>Try refreshing the page</li>
                    <li>Clear your browser cache and cookies</li>
                    <li>Check your internet connection</li>
                    <li>If the problem persists, contact support with the Request ID above</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .tl-error-root {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        padding: 40px 20px;
        font-family: 'Outfit', 'Inter', sans-serif;
    }

    body.mud-dark-mode .tl-error-root {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    }

    .tl-error-container {
        max-width: 600px;
        width: 100%;
    }

    .tl-error-card {
        background: white;
        border-radius: 24px;
        padding: 48px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
        text-align: center;
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    body.mud-dark-mode .tl-error-card {
        background: #1e293b;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.2);
    }

    .tl-error-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        color: #dc2626;
    }

    body.mud-dark-mode .tl-error-icon {
        background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);
    }

    .tl-error-card h1 {
        font-size: 32px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 12px;
    }

    body.mud-dark-mode .tl-error-card h1 {
        color: #f1f5f9;
    }

    .tl-error-subtitle {
        font-size: 16px;
        color: #64748b;
        margin-bottom: 24px;
    }

    body.mud-dark-mode .tl-error-subtitle {
        color: #94a3b8;
    }

    .tl-error-details {
        background: #f8fafc;
        border-radius: 12px;
        padding: 16px;
        margin: 24px 0;
    }

    body.mud-dark-mode .tl-error-details {
        background: #334155;
    }

    .tl-request-id {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: monospace;
    }

    .tl-request-id code {
        background: white;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
    }

    body.mud-dark-mode .tl-request-id code {
        background: #475569;
        color: #f1f5f9;
    }

    .tl-error-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        margin-top: 32px;
        flex-wrap: wrap;
    }

    .tl-error-footer {
        margin-top: 32px;
        text-align: center;
    }

    .tl-help-tips {
        background: white;
        border-radius: 16px;
        padding: 24px;
        margin-top: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    body.mud-dark-mode .tl-help-tips {
        background: #1e293b;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
    }

    .tl-help-tips ul {
        list-style: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }

    .tl-help-tips li {
        padding: 8px 0;
        color: #64748b;
        font-size: 14px;
        position: relative;
        padding-left: 24px;
    }

    body.mud-dark-mode .tl-help-tips li {
        color: #94a3b8;
    }

    .tl-help-tips li:before {
        content: '';
        position: absolute;
        left: 0;
        width: 6px;
        height: 6px;
        background: var(--mud-palette-primary);
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Collapsible error-details panel */
    .tl-error-toggle-row {
        margin-top: 12px;
        text-align: center;
    }
    .tl-error-stack {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 16px;
        margin-top: 12px;
        text-align: left;
        font-size: 12px;
        color: #1f2937;
    }
    .tl-error-stack-row + .tl-error-stack-row { margin-top: 10px; }
    .tl-error-stack-label {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 10px;
        font-weight: 700;
        color: #64748b;
        margin-right: 8px;
    }
    .tl-error-stack code {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 4px;
        padding: 2px 6px;
        word-break: break-word;
    }
    .tl-error-stack-trace {
        margin: 4px 0 0 0;
        padding: 12px;
        background: #0f172a;
        color: #e2e8f0;
        border-radius: 8px;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 11px;
        line-height: 1.5;
        max-height: 320px;
        overflow: auto;
        white-space: pre-wrap;
        word-break: break-word;
    }
    body.mud-dark-mode .tl-error-stack {
        background: #0f172a;
        border-color: #334155;
        color: #e2e8f0;
    }
    body.mud-dark-mode .tl-error-stack code {
        background: #1e293b;
        border-color: #334155;
        color: #f1f5f9;
    }
    body.mud-dark-mode .tl-error-stack-label { color: #94a3b8; }
    body.mud-dark-mode .tl-error-stack-trace {
        background: #020617;
        color: #cbd5e1;
    }
</style>

@code {
    [CascadingParameter]
    private HttpContext? CascadedHttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool _showDetails;

    private string? _exceptionType;
    private string? _exceptionMessage;
    private string? _innerExceptionMessage;
    private string? _stackTrace;
    private string? _exceptionPath;

    private bool isDevelopment => Environment.IsDevelopment();
    private bool HasExceptionDetails =>
        !string.IsNullOrWhiteSpace(_exceptionMessage) ||
        !string.IsNullOrWhiteSpace(_stackTrace);

    protected override void OnInitialized()
    {
        // Resolve current HttpContext from either the cascading parameter (Blazor)
        // or the IHttpContextAccessor (server-side prerender / static page).
        var ctx = CascadedHttpContext ?? HttpContextAccessor.HttpContext;
        RequestId = global::System.Diagnostics.Activity.Current?.Id ?? ctx?.TraceIdentifier;

        // The global `app.UseExceptionHandler("/Error")` middleware re-executes
        // this page with the original Exception parked on IExceptionHandlerFeature.
        // We surface the *type*, *message*, and (in development only) the stack
        // trace so power users can self-diagnose without digging through the log
        // file. Production hides the stack trace to avoid leaking internals.
        var feature = ctx?.Features.Get<IExceptionHandlerFeature>()
                   ?? ctx?.Features.Get<IExceptionHandlerPathFeature>() as IExceptionHandlerFeature;
        var pathFeature = ctx?.Features.Get<IExceptionHandlerPathFeature>();
        var ex = feature?.Error;

        if (ex != null)
        {
            _exceptionType = ex.GetType().FullName;
            _exceptionMessage = ex.Message;
            _innerExceptionMessage = ex.InnerException?.Message;
            _stackTrace = isDevelopment ? ex.ToString() : null;
        }
        _exceptionPath = pathFeature?.Path;
    }

    private async Task CopyRequestId()
    {
        if (!string.IsNullOrEmpty(RequestId))
        {
            await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", RequestId);
            Snackbar.Add("Request ID copied to clipboard", Severity.Success, options =>
            {
                options.SnackbarVariant = Variant.Filled;
                options.ShowCloseIcon = true;
            });
        }
    }
}
