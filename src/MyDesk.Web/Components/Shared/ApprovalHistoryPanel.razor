@using MyDesk.Shared.Services
@using MudBlazor
@inject WorkflowApprovalService ApprovalSvc

<MudPaper Class="pa-4" Elevation="0">
    <MudText Typo="Typo.h6" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Rounded.History" Class="mr-2" />
        Approval History
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_history.Count == 0)
    {
        <MudText Typo="Typo.body2" Color="Color.Default">
            No approval actions yet.
        </MudText>
    }
    else
    {
        <MudTimeline TimelinePosition="TimelinePosition.Start" TimelineAlign="TimelineAlign.Default">
            @foreach (var action in _history)
            {
                <MudTimelineItem Color="@GetActionColor(action.Action)" Icon="@GetActionIcon(action.Action)">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        @action.Action by @action.ApprovedBy
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">
                        Level @action.Level • @action.ActionAt
                    </MudText>
                    @if (!string.IsNullOrEmpty(action.Comments))
                    {
                        <MudText Typo="Typo.body2" Class="mt-2">
                            <em>@action.Comments</em>
                        </MudText>
                    }
                </MudTimelineItem>
            }
        </MudTimeline>
    }
</MudPaper>

@code {
    [Parameter] public int RequestId { get; set; }

    private List<WorkflowApprovalService.ApprovalHistoryDto> _history = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _loading = true;
        try
        {
            _history = await ApprovalSvc.GetHistoryAsync(RequestId);
            _history = _history.OrderBy(x => x.Level).ToList();
        }
        catch
        {
            // Silent fail - history might not be available
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetActionColor(string action)
    {
        return action switch
        {
            "Approved" => Color.Success,
            "Rejected" => Color.Error,
            "Delegated" => Color.Warning,
            _ => Color.Default
        };
    }

    private string GetActionIcon(string action)
    {
        return action switch
        {
            "Approved" => Icons.Material.Rounded.CheckCircle,
            "Rejected" => Icons.Material.Rounded.Cancel,
            "Delegated" => Icons.Material.Rounded.Person,
            _ => Icons.Material.Rounded.Info
        };
    }
}
