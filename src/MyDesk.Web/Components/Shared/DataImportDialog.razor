@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudAlert Severity="Severity.Info" Class="mb-3">Import data from CSV. Ensure columns match the target table schema.</MudAlert>
        <MudSelect T="string" @bind-Value="_target" Label="Import To" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-2">
            <MudSelectItem Value="@("Companies")">Companies</MudSelectItem>
            <MudSelectItem Value="@("Contacts")">Contacts</MudSelectItem>
            <MudSelectItem Value="@("Products")">Products</MudSelectItem>
        </MudSelect>
        <MudTextField @bind-Value="_filePath" Label="CSV File Path" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Paste file path" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="@string.IsNullOrEmpty(_filePath)">Import</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public MudDialogInstance? Dialog { get; set; }
    private string _target = "Companies";
    private string _filePath = "";
    private void Submit() => Dialog?.Close(DialogResult.Ok(new { Target = _target, FilePath = _filePath }));
    private void Cancel() => Dialog?.Cancel();
}
