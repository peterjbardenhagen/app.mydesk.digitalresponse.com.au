@page "/contacts"
@attribute [Authorize]
@inject ContactService ContactService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JsRuntime
@inject NavigationManager Nav
@inject PlatformSettingsService PlatformSettings
@using MyDesk.Shared.Models

<PageTitle>Contacts - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span>Contacts</span>
        </div>
        <h1>Contacts</h1>
         <p class="tl-subtitle">Manage company and personal contacts. <a href="/companies" class="tl-link">View Companies →</a></p>
    </div>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
                   OnClick="@(() => Nav.NavigateTo("/contacts/create"))">New Contact</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Upload"
                   OnClick="ImportFromInvoices">Import from Invoices</MudButton>
    </div>
</div>

<MudPaper Elevation="2" Class="pa-4 mb-4">
    <MudTextField @bind-Value="_search" Label="Search (name, company, email)" Variant="Variant.Outlined"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  Clearable="true" OnKeyDown="OnKey" />
    <div class="d-flex gap-2 mt-3">
        <MudButton OnClick="LoadAsync" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.FilterList">Search</MudButton>
        <MudButton OnClick="Reset" Variant="Variant.Outlined">Reset</MudButton>
        <MudButton OnClick="NormaliseAndDedupe" Variant="Variant.Outlined" Color="Color.Warning"
                   Size="Size.Small" StartIcon="@Icons.Material.Rounded.MergeType">Normalise & Dedupe</MudButton>
        <MudCheckBox @bind-Value="_showOnlyWithRecords" Label="Only contacts with records" Color="Color.Primary" Dense="true" Class="ml-2" />
    </div>
</MudPaper>

<MudPaper Class="pa-0" Elevation="1" Style="margin-bottom: 40px;">
    <MudDataGrid T="Contact" Items="@_contacts" Loading="@_loading" Dense="true" Hover="true"
                 SortMode="@SortMode.Multiple" Virtualize="true" FixedHeader="true" Height="calc(100vh - 365px)"
                 RowClicked="OnContactRowClicked">
    <Columns>
        <PropertyColumn Property="x => x.ContactId" Title="#" />
        <PropertyColumn Property="x => x.CompanyName" Title="Company" />
        <PropertyColumn Property="x => x.FullName" Title="Name" />
        <PropertyColumn Property="x => x.Position" Title="Position" />
        <PropertyColumn Property="x => x.Email" Title="Email" />
        <PropertyColumn Property="x => x.Phone" Title="Phone" />
        <TemplateColumn Title="Actions" Sortable="false" CellStyle="width:150px;">
            <CellTemplate>
                <div class="d-flex gap-1">
                    <FavouriteButton EntityType="Contact" EntityId="@context.Item.ContactId" EntityName="@context.Item.FullName" />
                    <MudIconButton Icon="@Icons.Material.Rounded.Timer" Size="Size.Small" Color="Color.Warning"
                                   OnClick="@(() => StartStopwatchForContact(context.Item))"
                                   Title="Track time for this contact" />
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" Color="Color.Info"
                                   Href="@($"/contacts/{context.Item.ContactId}")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                   Href="@($"/contacts/{context.Item.ContactId}/edit")" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => DeleteAsync(context.Item))" />
                </div>
            </CellTemplate>
        </TemplateColumn>
     </Columns>
     <PagerContent>
         <MudDataGridPager T="Contact" />
     </PagerContent>
    </MudDataGrid>
</MudPaper>

@code {
    private List<Contact> _contacts = new();
    private bool _loading = true;
    private string? _search;
    private bool _showOnlyWithRecords = false;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try { _contacts = await ContactService.GetContactsAsync(_search, onlyWithRecords: _showOnlyWithRecords); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }
    
    private async Task DeleteAsync(Contact c)
    {
        var parameters = new DialogParameters
        {
            { nameof(MudMessageBox.Message), $"Delete contact '{c.FullName}'?" },
            { nameof(MudMessageBox.YesText), "Delete" },
            { nameof(MudMessageBox.NoText), string.Empty },
            { nameof(MudMessageBox.CancelText), "Cancel" }
        };
        var result = await DialogService.ShowAsync<MudMessageBox>("Delete Contact", parameters);
        bool? ok = (await result.Result)?.Data as bool?;
        if (ok != true) return;

        try
        {
            await ContactService.DeleteContactAsync(c.ContactId);
            Snackbar.Add($"Contact '{c.FullName}' deleted.", Severity.Info);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private async Task NormaliseAndDedupe()
    {
        try
        {
            var count = await ContactService.NormaliseAndDedupeAsync();
            Snackbar.Add($"Normalised {count} contacts.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task ImportFromInvoices()
    {
        var parameters = new DialogParameters();
        var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        var dialog = await DialogService.ShowAsync<ImportContactsDialog>("Import Contacts & Companies", parameters, options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled)
        {
            await LoadAsync();
            Snackbar.Add("Import completed successfully", Severity.Success);
        }
    }

    private async Task Reset() { _search = null; await LoadAsync(); }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoadAsync();
    }

    private async Task ExportCsv()
    {
        if (!_contacts.Any())
        {
            Snackbar.Add("No data to export", Severity.Warning);
            return;
        }

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("ID,Company,Name,Position,Email,Phone,Mobile");

        foreach (var c in _contacts)
        {
            sb.AppendLine($"{c.ContactId},\"{c.CompanyName}\",\"{c.FullName}\",\"{c.Position}\",\"{c.Email}\",\"{c.Phone}\",\"{c.Mobile}\"");
        }

        var csv = sb.ToString();
        var fileName = $"Contacts_Export_{DateTime.Now:yyyyMMdd}.csv";

        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:text/csv;base64,{base64}";
        await JsRuntime.InvokeVoidAsync("window.open", url, "_blank");
        
        Snackbar.Add($"Exported {_contacts.Count} contacts", Severity.Success);
    }

    private void StartStopwatchForContact(Contact contact)
    {
        // Navigate to timesheets page with company pre-filled
        if (contact.CompanyId > 0)
        {
            Nav.NavigateTo($"/timesheets?companyId={contact.CompanyId}&companyName={Uri.EscapeDataString(contact.CompanyName ?? "")}");
        }
        else
        {
            Snackbar.Add("Contact is not associated with a company. Cannot track billable time.", Severity.Warning);
        }
    }

    private void OnContactRowClicked(DataGridRowClickEventArgs<Contact> args)
    {
        Nav.NavigateTo($"/contacts/{args.Item.ContactId}");
    }
}


