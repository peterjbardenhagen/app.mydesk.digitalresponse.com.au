@using MyDesk.Shared.Models

<MudForm @ref="_form">
    <MudDialog>
        <TitleContent>
            <MudText Typo="Typo.h6">Charge</MudText>
        </TitleContent>
        <DialogContent>
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Date" Date="_charge.ChargeDate" DateChanged="(d) => { if (d.HasValue) _charge.ChargeDate = d.Value; }" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Client Name" @bind-Value="_charge.ClientName" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Project Name" @bind-Value="_charge.ProjectName" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" Label="Category" @bind-Value="_charge.Category">
                        <MudSelectItem Value="@("General")">General</MudSelectItem>
                        <MudSelectItem Value="@("Hosting")">Hosting</MudSelectItem>
                        <MudSelectItem Value="@("Software")">Software</MudSelectItem>
                        <MudSelectItem Value="@("Travel")">Travel</MudSelectItem>
                        <MudSelectItem Value="@("Hardware")">Hardware</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Description" @bind-Value="_charge.Description" Required="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" Label="Amount" @bind-Value="_charge.Amount" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="decimal" Label="Cost" @bind-Value="_charge.Cost" Min="0" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudCheckBox T="bool" @bind-Value="_charge.IsInvoiced" Label="Invoiced" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string" Label="Notes" @bind-Value="_charge.Notes" Lines="2" />
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancel">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Save</MudButton>
        </DialogActions>
    </MudDialog>
</MudForm>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public DRMCharge Charge { get; set; } = new();

    private MudForm _form = default!;
    private DRMCharge _charge = new();

    protected override void OnInitialized()
    {
        _charge = Charge ?? new DRMCharge();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        MudDialog.Close(_charge);
    }
}
