@page "/rfq"
@attribute [Authorize]
@inject RfqService RfqSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>RFQ - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span>RFQ</span>
        </div>
        <h1>Request For Quote</h1>
        <p class="tl-subtitle">Request prices from suppliers and compare responses side by side.</p>
    </div>
    <div class="d-flex gap-2">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Rounded.Add"
                   Href="/rfq/edit">New RFQ</MudButton>
    </div>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}

<MudPaper Class="pa-0" Elevation="1">
    <MudDataGrid T="Rfq" Items="@_items" Dense="true" Hover="true" Elevation="0"
                 SortMode="SortMode.Multiple" Filterable="false">
        <Columns>
            <PropertyColumn Property="x => x.RfqNumber" Title="RFQ #" CellStyle="width:160px;font-weight:600;" />
            <PropertyColumn Property="x => x.Title" Title="Title" />
            <PropertyColumn Property="x => x.CreatedDate" Title="Created" Format="dd/MM/yyyy" CellStyle="width:110px;" />
            <PropertyColumn Property="x => x.RequiredByDate" Title="Required By" Format="dd/MM/yyyy" CellStyle="width:120px;" />
            <TemplateColumn Title="Suppliers" CellStyle="width:90px;text-align:center;">
                <CellTemplate>@context.Item.Suppliers.Count</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Responses" CellStyle="width:100px;text-align:center;">
                <CellTemplate>@context.Item.Responses.Count</CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Status" CellStyle="width:130px;">
                <CellTemplate>
                    <span class="tl-badge @StatusTone(context.Item.Status)">@context.Item.Status</span>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="" CellStyle="width:200px;" Sortable="false">
                <CellTemplate>
                    <div class="d-flex gap-1">
                        <MudIconButton Icon="@Icons.Material.Rounded.Visibility" Size="Size.Small"
                                       Color="Color.Info" Href="@($"/rfq/view/{context.Item.Id}")" title="View" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/rfq/edit/{context.Item.Id}")" title="Edit" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Compare" Size="Size.Small"
                                       Color="Color.Secondary" Href="@($"/rfq/compare/{context.Item.Id}")"
                                       Disabled="@(context.Item.Responses.Count == 0)" title="Compare quotes" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small"
                                       Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(context.Item))" title="Delete" />
                    </div>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent><MudDataGridPager T="Rfq" /></PagerContent>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Class="pa-6" Style="color:var(--gray-500);">No RFQs yet. Click <strong>New RFQ</strong> to create one.</MudText>
        </NoRecordsContent>
    </MudDataGrid>
</MudPaper>

@code {
    private List<Rfq> _items = new();
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try { _items = await RfqSvc.GetAllAsync(); }
        catch (Exception ex) { Snackbar.Add($"Load failed: {ex.Message}", Severity.Error); }
        finally { _loading = false; }
    }

    private async Task DeleteAsync(Rfq rfq)
    {
        try
        {
            await RfqSvc.DeleteAsync(rfq.Id);
            _items.Remove(rfq);
            Snackbar.Add($"RFQ {rfq.RfqNumber} deleted.", Severity.Info);
        }
        catch (Exception ex) { Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error); }
    }

    private static string StatusTone(RfqStatus s) => s switch
    {
        RfqStatus.Draft     => "info",
        RfqStatus.Sent      => "primary",
        RfqStatus.Responded => "warning",
        RfqStatus.Awarded   => "success",
        RfqStatus.Cancelled => "error",
        _                   => "info"
    };
}
