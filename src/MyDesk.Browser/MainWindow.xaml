<Window x:Class="MyDesk.Browser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyDesk.Browser"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:vm="clr-namespace:MyDesk.Browser.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle, FallbackValue='MyDesk Browser'}"
        Height="900"
        Width="1400"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Icon="/Assets/icon.ico"
        Background="{DynamicResource WindowBackgroundBrush}"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      NonClientFrameEdges="None"
                      ResizeBorderThickness="5"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />  <!-- Title Bar -->
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="*" />    <!-- WebView -->
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource TitleBarBackgroundBrush}"
                WindowChrome.IsHitTestVisibleInChrome="True">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- App Icon + User Profile + AgentsOS -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="18"
                           Height="18"
                           Margin="8,0,4,0"
                           Source="/Assets/mydesk-mark.svg"
                           VerticalAlignment="Center" />

                    <!-- User avatar/initials when authenticated -->
                    <Border x:Name="UserAvatar"
                            Background="{DynamicResource MyDeskPrimaryBrush}"
                            CornerRadius="10"
                            Width="22"
                            Height="22"
                            Margin="4,0,0,0"
                            Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}"
                            ToolTip="{Binding UserName}"
                            Cursor="Hand"
                            MouseLeftButtonDown="UserAvatar_MouseDown">
                        <TextBlock x:Name="UserInitials"
                                   Text="{Binding UserInitials, FallbackValue='U'}"
                                   Foreground="White"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <!-- AgentsOS status indicator -->
                    <Ellipse x:Name="AgentsDot"
                             Width="8"
                             Height="8"
                             Margin="6,0,0,0"
                             ToolTip="{Binding AgentsStatusText}"
                             Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{DynamicResource TextDisabledBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAgentsOnline}" Value="True">
                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                </StackPanel>

                <!-- Title / User Info -->
                <TextBlock Grid.Column="1"
                           Text="{Binding WindowTitle, FallbackValue='MyDesk Browser'}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TitleBarTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           Margin="8,0" />

                <!-- Window Controls -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Margin="0,0,8,0">
                    <Button x:Name="BtnMinimize"
                            Style="{DynamicResource WindowButtonStyle}"
                            ToolTip="Minimize"
                            Click="BtnMinimize_Click"
                            Width="46"
                            Height="32">
                        <Path Data="M0,6 H8 M0,6 L8,6"
                              Stroke="{DynamicResource TitleBarTextBrush}"
                              StrokeThickness="1.5"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Width="10"
                              Height="10" />
                    </Button>
                    <Button x:Name="BtnMaximize"
                            Style="{DynamicResource WindowButtonStyle}"
                            ToolTip="Maximize"
                            Click="BtnMaximize_Click"
                            Width="46"
                            Height="32">
                        <Path x:Name="MaximizeIcon"
                              Data="M0,0 H10 V10 H0 Z"
                              Stroke="{DynamicResource TitleBarTextBrush}"
                              StrokeThickness="1.5"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Width="10"
                              Height="10" />
                    </Button>
                    <Button x:Name="BtnClose"
                            Style="{DynamicResource WindowButtonCloseStyle}"
                            ToolTip="Close"
                            Click="BtnClose_Click"
                            Width="46"
                            Height="32">
                        <Path Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{DynamicResource TitleBarTextBrush}"
                              StrokeThickness="1.5"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Width="10"
                              Height="10" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4"
                Visibility="{Binding ShowUrlBar, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                    <Button x:Name="BtnBack"
                            Style="{DynamicResource ToolbarButtonStyle}"
                            ToolTip="Back"
                            Click="BtnBack_Click"
                            IsEnabled="{Binding CanGoBack}">
                        <Path Data="M15,18 L9,12 L15,6"
                              Stroke="{DynamicResource ToolbarIconBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="16"
                              Height="16" />
                    </Button>
                    <Button x:Name="BtnForward"
                            Style="{DynamicResource ToolbarButtonStyle}"
                            ToolTip="Forward"
                            Click="BtnForward_Click"
                            IsEnabled="{Binding CanGoForward}"
                            Margin="4,0,0,0">
                        <Path Data="M9,6 L15,12 L9,18"
                              Stroke="{DynamicResource ToolbarIconBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="16"
                              Height="16" />
                    </Button>
                    <Button x:Name="BtnRefresh"
                            Style="{DynamicResource ToolbarButtonStyle}"
                            ToolTip="Refresh"
                            Click="BtnRefresh_Click"
                            Margin="8,0,0,0">
                        <Path Data="M23,4 V4 A20,20 0 0 1 23,44 A1,1 0 0 1 22,44 A18,18 0 0 0 4,26 A1,1 0 0 1 4,25 A1,1 0 0 1 5,24 A18,18 0 0 1 23,6 V6"
                              Stroke="{DynamicResource ToolbarIconBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="16"
                              Height="16" />
                    </Button>
                    <Button x:Name="BtnHome"
                            Style="{DynamicResource ToolbarButtonStyle}"
                            ToolTip="Home"
                            Click="BtnHome_Click"
                            Margin="8,0,0,0">
                        <Path Data="M3,9 L9,3 L15,9 V21 A2,2 0 0 0 17,23 H7 A2,2 0 0 0 5,21 V9 Z M9,21 V14 H15 V21"
                              Stroke="{DynamicResource ToolbarIconBrush}"
                              StrokeThickness="1.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Width="16"
                              Height="16" />
                    </Button>
                </StackPanel>

                <!-- URL Bar -->
                <Border Grid.Column="1"
                        Background="{DynamicResource UrlBarBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="🔒"
                                   VerticalAlignment="Center"
                                   Margin="8,0"
                                   FontSize="14" />
                        <TextBox x:Name="UrlBar"
                                 Grid.Column="1"
                                 Text="{Binding CurrentUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource TextBrush}"
                                 FontSize="13"
                                 VerticalAlignment="Center"
                                 Padding="4,0"
                                 KeyDown="UrlBar_KeyDown" />
                        <Button x:Name="BtnGo"
                                Grid.Column="2"
                                Style="{DynamicResource ToolbarButtonStyle}"
                                ToolTip="Go"
                                Click="BtnGo_Click"
                                Margin="0,0,8,0"
                                Padding="8,0"
                                Content="Go"
                                FontSize="11"
                                FontWeight="SemiBold" />
                    </Grid>
                </Border>

                <!-- Menu Button -->
                <Button x:Name="BtnMenu"
                        Grid.Column="2"
                        Style="{DynamicResource ToolbarButtonStyle}"
                        ToolTip="Apps"
                        Click="BtnMenu_Click"
                        Margin="0,0,8,0"
                        Width="36"
                        Height="32">
                    <Path Data="M3,18 H21 M3,12 H21 M3,6 H21"
                          Stroke="{DynamicResource ToolbarIconBrush}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Width="18"
                          Height="18" />
                </Button>
            </Grid>
        </Border>

        <!-- WebView2 -->
        <Border Grid.Row="2"
                Background="{DynamicResource WebViewBackgroundBrush}"
                BorderThickness="0">
            <Grid x:Name="WebViewHost">
                <wv2:WebView2 x:Name="WebView"
                              Source="{Binding InitialUrl}"
                              NavigationStarting="WebView_NavigationStarting"
                              NavigationCompleted="WebView_NavigationCompleted"
                              SourceChanged="WebView_SourceChanged"
                              ContentLoading="WebView_ContentLoading"
                              WebMessageReceived="WebView_WebMessageReceived"
                              DefaultBackgroundColor="White" />
                <Border x:Name="LoadingOverlay"
                        Background="{DynamicResource LoadingOverlayBrush}"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Panel.ZIndex="10">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200"
                                     Height="4"
                                     Margin="0,0,0,16"
                                     Foreground="{DynamicResource AccentBrush}" />
                        <TextBlock Text="Loading..."
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="Medium" />
                    </StackPanel>
                </Border>
                <Border x:Name="ErrorOverlay"
                        Background="{DynamicResource ErrorOverlayBrush}"
                        Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Panel.ZIndex="20">
                    <StackPanel VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="40">
                        <TextBlock Text="⚠"
                                   FontSize="48"
                                   Foreground="{DynamicResource WarningBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16" />
                        <TextBlock x:Name="ErrorMessage"
                                   Text="{Binding ErrorMessage}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="16"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"
                                   Margin="0,0,0,24" />
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <Button Content="Retry"
                                    Style="{DynamicResource PrimaryButtonStyle}"
                                    Click="BtnRetry_Click"
                                    Width="100"
                                    Margin="0,0,12,0" />
                            <Button Content="Open in Browser"
                                    Style="{DynamicResource SecondaryButtonStyle}"
                                    Click="BtnOpenInBrowser_Click"
                                    Width="140" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>