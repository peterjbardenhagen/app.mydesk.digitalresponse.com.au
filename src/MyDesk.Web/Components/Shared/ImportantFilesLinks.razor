@* Generic Important Files & Links Component - Uses Platform Settings *@
@inject BrandAssetService BrandAssetService
@inject PlatformSettingsService PlatformSettings

<MudPaper Class="pa-5 mb-4" Elevation="1" Style="background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%); border: 1px solid var(--gray-200);">
    <div class="d-flex align-center gap-3 mb-5">
        <div style="width: 48px; height: 48px; border-radius: 12px; background: linear-gradient(135deg, var(--tl-primary-500) 0%, var(--tl-primary-600) 100%); display: flex; align-items: center; justify-content: center; color: white;">
            <MudIcon Icon="@Icons.Material.Rounded.FolderSpecial" Size="Size.Medium" />
        </div>
        <div>
            <MudText Typo="Typo.h6" Style="font-weight: 600; color: var(--gray-900);">Important Files & Links</MudText>
            <MudText Typo="Typo.body2" Style="color: var(--gray-500);">Brand assets and company resources</MudText>
        </div>
        <MudSpacer />
        <a href="@PlatformSettings.Current.CompanyWebsite" target="_blank" class="tl-brand-website-link">
            <MudIcon Icon="@Icons.Material.Rounded.Language" Size="Size.Small" Class="gold-accent" />
            <span>@PlatformSettings.GetBrandingName() Website</span>
            <MudIcon Icon="@Icons.Material.Rounded.OpenInNew" Size="Size.Small" Style="opacity: 0.7;" />
        </a>
    </div>

    <div class="tl-brand-assets-grid">
        @* Dynamic Important Links from Platform Settings *@
        @foreach (var link in _importantLinks)
        {
            <div class="tl-brand-asset-card">
                <div class="tl-brand-asset-thumbnail">
                    <div class="tl-brand-asset-icon @GetCategoryColor(link.Category)">
                        <MudIcon Icon="@GetIcon(link.Icon)" Size="Size.Large" />
                    </div>
                </div>
                <div class="tl-brand-asset-content">
                    <div class="tl-brand-asset-title">@link.Title</div>
                    <div class="tl-brand-asset-desc">@link.Description</div>
                    <div class="tl-brand-asset-actions">
                        <a href="@link.Url" target="@(link.IsExternal ? "_blank" : "_self")" class="tl-brand-asset-btn primary">
                            <MudIcon Icon="@Icons.Material.Rounded.OpenInNew" Size="Size.Small" />
                            Open
                        </a>
                    </div>
                </div>
            </div>
        }

        @* Dynamic Brand Assets from Platform Settings *@
        @foreach (var asset in _brandAssets)
        {
            <div class="tl-brand-asset-card">
                <div class="tl-brand-asset-thumbnail">
                    <div class="tl-brand-asset-icon @GetCategoryColor(asset.Category)">
                        <MudIcon Icon="@GetFileIcon(asset.ContentType)" Size="Size.Large" />
                    </div>
                </div>
                <div class="tl-brand-asset-content">
                    <div class="tl-brand-asset-title">@asset.OriginalFileName</div>
                    <div class="tl-brand-asset-desc">@(asset.Description ?? $"{asset.Category} - {asset.FormattedSize}")</div>
                    <div class="tl-brand-asset-actions">
                        <a href="/api/brand-assets/download/@asset.Id" class="tl-brand-asset-btn primary">
                            <MudIcon Icon="@Icons.Material.Rounded.Download" Size="Size.Small" />
                            Download
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!_brandAssets.Any() && !_importantLinks.Any())
    {
        <MudAlert Severity="Severity.Info" Class="mt-4">
            <div class="d-flex align-center gap-2">
                <MudIcon Icon="@Icons.Material.Rounded.Info" Size="Size.Small" />
                <span>No brand assets or links configured. Contact your administrator to add content.</span>
            </div>
        </MudAlert>
    }
</MudPaper>

@code {
    private List<BrandAssetFile> _brandAssets = new();
    private List<ImportantLink> _importantLinks = new();

    protected override void OnInitialized()
    {
        // Load from Platform Settings via BrandAssetService
        _brandAssets = BrandAssetService.GetAllAssets();
        _importantLinks = BrandAssetService.GetImportantLinks();
    }

    private string GetIcon(string iconName)
    {
        return iconName switch
        {
            "Analytics" => Icons.Material.Rounded.Analytics,
            "Facebook" => Icons.Material.Rounded.Public,
            "Language" => Icons.Material.Rounded.Language,
            "MoreHoriz" => Icons.Material.Rounded.MoreHoriz,
            "Style" => Icons.Material.Rounded.Style,
            "Business" => Icons.Material.Rounded.Business,
            "Image" => Icons.Material.Rounded.Image,
            "Description" => Icons.Material.Rounded.Description,
            "Badge" => Icons.Material.Rounded.Badge,
            "Work" => Icons.Material.Rounded.Work,
            "Email" => Icons.Material.Rounded.Email,
            "MenuBook" => Icons.Material.Rounded.MenuBook,
            _ => Icons.Material.Rounded.Link
        };
    }

    private string GetFileIcon(string contentType)
    {
        if (contentType.Contains("pdf")) return Icons.Material.Rounded.PictureAsPdf;
        if (contentType.Contains("image")) return Icons.Material.Rounded.Image;
        if (contentType.Contains("word") || contentType.Contains("document")) return Icons.Material.Rounded.Description;
        if (contentType.Contains("excel") || contentType.Contains("sheet")) return Icons.Material.Rounded.TableChart;
        if (contentType.Contains("html")) return Icons.Material.Rounded.Language;
        if (contentType.Contains("zip")) return Icons.Material.Rounded.FolderZip;
        return Icons.Material.Rounded.InsertDriveFile;
    }

    private string GetCategoryColor(string category)
    {
        return category.ToLower() switch
        {
            "analytics" => "gold",
            "social" => "primary",
            "website" => "teal",
            "logo" => "dark",
            "guidelines" => "gold",
            "profile" => "teal",
            "stationery" => "primary",
            _ => ""
        };
    }
}

