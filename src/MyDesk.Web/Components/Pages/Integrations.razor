@page "/integrations"
@attribute [Authorize]
@using MudBlazor
@inject PlatformSettingsService SettingsSvc
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IConfiguration Configuration
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Integrations - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Dashboard</a><span class="sep">/</span>
            <span>Integrations</span>
        </div>
        <h1>Integrations</h1>
        <p class="tl-subtitle">Connect and manage external services</p>
    </div>
</div>

<MudGrid Spacing="4" Class="mt-4">
    <MudItem xs="12" md="8">
        <MudText Typo="Typo.h6" Class="mb-4">Available Integrations</MudText>
        
        @foreach (var integration in _integrations)
        {
            <MudPaper Elevation="1" Class="pa-4 mb-3" Style="@(integration.Connected ? "border-left: 4px solid var(--mud-palette-success);" : "")">
                <div class="d-flex align-center justify-space-between">
                    <div class="d-flex align-center gap-4">
                        <div class="tl-integration-icon" style="background: @(integration.Color + "15"); color: @integration.Color;">
                            <MudIcon Icon="@integration.Icon" />
                        </div>
                        <div>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@integration.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@integration.Description</MudText>
                            @if (integration.Connected && integration.Settings.LastSyncTime.HasValue)
                            {
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    Last sync: @integration.Settings.LastSyncTime?.ToString("g")
                                </MudText>
                            }
                        </div>
                    </div>
                    <div class="d-flex align-center gap-3">
                        @if (integration.Connected)
                        {
                            <div class="d-flex align-center gap-2">
                                <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">Connected</MudChip>
                                <MudTooltip Text="Test Connection">
                                    <MudIconButton Icon="@Icons.Material.Rounded.Cable" Size="Size.Small" Color="Color.Primary" OnClick="() => TestConnectionAsync(integration)" />
                                </MudTooltip>
                                <MudTooltip Text="Settings">
                                    <MudIconButton Icon="@Icons.Material.Rounded.Settings" Size="Size.Small" OnClick="() => OpenSettingsDialog(integration)" />
                                </MudTooltip>
                                <MudMenu Icon="@Icons.Material.Rounded.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight">
                                    <MudMenuItem OnClick="() => OpenSettingsDialog(integration)">Configure</MudMenuItem>
                                    <MudMenuItem OnClick="() => SyncNow(integration)">Sync Now</MudMenuItem>
                                    <MudMenuItem OnClick="() => DisconnectIntegration(integration)">Disconnect</MudMenuItem>
                                </MudMenu>
                            </div>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="() => ConnectIntegration(integration)">
                                @(IsPerUserMicrosoftIntegration(integration) ? "Connect Account" : $"Connect {integration.Name}")
                            </MudButton>
                        }
                    </div>
                </div>
            </MudPaper>
        }
    </MudItem>

    <MudItem xs="12" md="4">
        <MudPaper Elevation="0" Class="pa-6 tl-status-card">
            <MudText Typo="Typo.h6" Class="mb-4">System Integration</MudText>
            
            <div class="d-flex flex-column gap-4">
                <div class="tl-status-item">
                    <div class="tl-status-dot connected"></div>
                    <div class="flex-1">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">SQL Database</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Direct Connection Active</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Rounded.CheckCircle" Color="Color.Success" Size="Size.Small" />
                </div>

                <div class="tl-status-item">
                    <div class="tl-status-dot @(SettingsSvc.Current.EnableAIAssistant ? "connected" : "")"></div>
                    <div class="flex-1">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">Azure OpenAI</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@(GetAIModel())</MudText>
                    </div>
                    <MudIcon Icon="@(SettingsSvc.Current.EnableAIAssistant ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Cancel)" 
                             Color="@(SettingsSvc.Current.EnableAIAssistant ? Color.Success : Color.Default)" Size="Size.Small" />
                </div>
                
                <div class="tl-status-item">
                    <div class="tl-status-dot @(SettingsSvc.Current.EnableAskAI ? "connected" : "")"></div>
                    <div class="flex-1">
                        <MudText Typo="Typo.body2" Style="font-weight:600;">Ask AI Assistant</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">@(SettingsSvc.Current.EnableAskAI ? "Data-augmented queries" : "Disabled")</MudText>
                    </div>
                    <MudIcon Icon="@(SettingsSvc.Current.EnableAskAI ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Cancel)" 
                             Color="@(SettingsSvc.Current.EnableAskAI ? Color.Success : Color.Default)" Size="Size.Small" />
                </div>
            </div>

            <MudDivider Class="my-6" />

            <MudText Typo="Typo.subtitle2" Class="mb-3" Style="font-weight:700;">Integration Benefits</MudText>
            <div class="d-flex flex-column gap-2">
                <div class="d-flex align-center gap-2">
                    <MudIcon Size="Size.Small" Color="Color.Primary"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.83l1.46 1.46C19.54 15.03 20 13.57 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.83L5.24 7.74C4.46 8.97 4 10.43 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"/></svg></MudIcon>
                    <MudText Typo="Typo.body2">Real-time data synchronization</MudText>
                </div>
                <div class="d-flex align-center gap-2">
                    <MudIcon Size="Size.Small" Color="Color.Primary"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M7 14c-1.66 0-3 1.34-3 3 0 1.31-1.16 2-2 2 .92 1.22 2.49 2 4 2 2.21 0 4-1.79 4-4 0-1.66-1.34-3-3-3zm13.71-9.37l-1.34-1.34a.996.996 0 00-1.41 0L9 12.25 11.75 15l8.96-8.96a.996.996 0 000-1.41z"/></svg></MudIcon>
                    <MudText Typo="Typo.body2">Automated business workflows</MudText>
                </div>
                <div class="d-flex align-center gap-2">
                    <MudIcon Size="Size.Small" Color="Color.Primary"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg></MudIcon>
                    <MudText Typo="Typo.body2">Secure OAuth2 authentication</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

<MudDialog @bind-Visible="_showSettingsDialog" MaxWidth="MaxWidth.Medium" FullWidth="true"
         Options="new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true }">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_selectedIntegration?.Name) Settings</MudText>
    </TitleContent>
    <DialogContent>
        @if (_selectedIntegration != null)
        {
            <MudGrid>
                <MudItem xs="12">
                    <MudSwitch T="bool" @bind-Value="_selectedIntegration.Connected" Label="Enabled" Color="Color.Primary" />
                </MudItem>
                
                @if (!IsPerUserMicrosoftIntegration(_selectedIntegration))
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_selectedIntegration.Settings.ClientId" Label="Client ID" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_selectedIntegration.Settings.ClientSecret" Label="Client Secret" Variant="Variant.Outlined" Margin="Margin.Dense" InputType="InputType.Password" />
                    </MudItem>
                }
                
                @if (_selectedIntegration.Key is "MYOB" or "Xero" or "QuickBooks")
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_selectedIntegration.Settings.RedirectUri" Label="Redirect URI" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                }
                
                <MudItem xs="12">
                    <MudDivider Class="my-2" />
                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">Sync Options</MudText>
                </MudItem>
                
                @if (_selectedIntegration.Key == "MYOB")
                {
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncInvoices" Label="Invoices" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncQuotes" Label="Quotes" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncContacts" Label="Contacts" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.AutoExportInvoices" Label="Auto-Export" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                }
                else if (_selectedIntegration.Key == "Xero" || _selectedIntegration.Key == "QuickBooks")
                {
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncInvoices" Label="Invoices" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncContacts" Label="Contacts" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.AutoExportInvoices" Label="Auto-Export" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                }
                else if (_selectedIntegration.Key == "Outlook" || _selectedIntegration.Key == "MyOutlook")
                {
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncCalendar" Label="Calendar" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncContacts" Label="Contacts" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncEmail" Label="Email" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudDivider Class="my-2" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight:600;">AI Assistant Settings</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox T="bool" @bind-Value="_selectedIntegration.Settings.AutoCategorise" Label="Auto-categorise emails" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox T="bool" @bind-Value="_selectedIntegration.Settings.AutoDraftReplies" Label="Prepare Draft emails automatically" Color="Color.Primary" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudCheckBox T="bool" @bind-Value="_selectedIntegration.Settings.MoveToCompanyFolder" Label="Move to Company folder if read &amp; 1 day elapsed" Color="Color.Primary" />
                    </MudItem>
                }
                else if (_selectedIntegration.Key == "MyOneDrive")
                {
                    <MudItem xs="12" sm="4">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncDrive" Label="OneDrive Files" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                }
                else if (_selectedIntegration.Key == "Google")
                {
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncDrive" Label="Drive" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6" sm="3">
                        <MudSwitch @bind-Value="_selectedIntegration.Settings.SyncGmail" Label="Gmail" Color="Color.Primary" Margin="Margin.Dense" />
                    </MudItem>
                }
                
                @if (_selectedIntegration.Settings.LastSyncTime.HasValue)
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">
                            Last sync: @_selectedIntegration.Settings.LastSyncTime?.ToString("g")
                        </MudText>
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showSettingsDialog = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveIntegrationSettings">
            Save Settings
        </MudButton>
    </DialogActions>
</MudDialog>

<style>
    .tl-page-header { margin-bottom: 24px; }
    .tl-breadcrumb { font-size: 13px; color: var(--gray-500); margin-bottom: 4px; }
    .tl-breadcrumb a { color: var(--gray-500); text-decoration: none; }
    .tl-breadcrumb .sep { margin: 0 8px; color: var(--gray-300); }
    .tl-subtitle { color: var(--gray-500); }

    .tl-integration-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .tl-status-card {
        background: var(--gray-50) !important;
        border-radius: 16px !important;
    }

    .tl-status-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        background: white;
        border-radius: 12px;
        border: 1px solid var(--gray-200);
    }

    .tl-status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--gray-300);
    }
    .tl-status-dot.connected {
        background: var(--mud-palette-success);
        box-shadow: 0 0 0 4px var(--mud-palette-success-hover);
    }
</style>

@code {
    private List<IntegrationItem> _integrations = new();
    private bool _showSettingsDialog;
    private IntegrationItem? _selectedIntegration;
    private string _currentUserCode = string.Empty;

    private string GetAIModel() => Configuration["Azure:OpenAIModel"] ?? "GPT-5";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserCode = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
        LoadIntegrations();
    }

    private void LoadIntegrations()
    {
        var s = SettingsSvc.Current;
        var myUserGraph = GetCurrentUserMicrosoftConnection(s);
        _integrations = new List<IntegrationItem>
        {
            new ("MYOB", "Business management software (AU)", Icons.Material.Rounded.Business, "#FF6600", "MYOB")
            {
                Connected = s.MYOB.Enabled,
                Settings = new IntegrationSettingsModel
                {
                    ClientId = s.MYOB.ClientId,
                    ClientSecret = s.MYOB.ClientSecret,
                    RedirectUri = s.MYOB.RedirectUri,
                    AuthEndpoint = s.MYOB.AuthEndpoint,
                    SyncInvoices = s.MYOB.SyncInvoices,
                    SyncQuotes = s.MYOB.SyncQuotes,
                    SyncContacts = s.MYOB.SyncContacts,
                    AutoExportInvoices = s.MYOB.AutoExportInvoices,
                    LastSyncTime = s.MYOB.LastSyncTime,
                    Status = s.MYOB.Status?.ToString()
                }
            },
            new ("Xero", "Accounting & invoicing (AU)", Icons.Material.Rounded.AccountBalance, "#00B5D2", "Xero")
            {
                Connected = s.Xero.Enabled,
                Settings = new IntegrationSettingsModel
                {
                    ClientId = s.Xero.ClientId,
                    ClientSecret = s.Xero.ClientSecret,
                    RedirectUri = s.Xero.RedirectUri,
                    AuthEndpoint = s.Xero.AuthEndpoint,
                    SyncInvoices = s.Xero.SyncInvoices,
                    SyncContacts = s.Xero.SyncContacts,
                    AutoExportInvoices = s.Xero.AutoExportInvoices,
                    LastSyncTime = s.Xero.LastSyncTime,
                    Status = s.Xero.Status?.ToString()
                }
            },
            new ("QuickBooks", "Financial management (AU)", Icons.Material.Rounded.Payments, "#2CA01C", "QuickBooks")
            {
                Connected = s.QuickBooks.Enabled,
                Settings = new IntegrationSettingsModel
                {
                    ClientId = s.QuickBooks.ClientId,
                    ClientSecret = s.QuickBooks.ClientSecret,
                    RedirectUri = s.QuickBooks.RedirectUri,
                    AuthEndpoint = s.QuickBooks.AuthEndpoint,
                    SyncInvoices = s.QuickBooks.SyncInvoices,
                    SyncContacts = s.QuickBooks.SyncContacts,
                    AutoExportInvoices = s.QuickBooks.AutoExportInvoices,
                    LastSyncTime = s.QuickBooks.LastSyncTime,
                    Status = s.QuickBooks.Status?.ToString()
                }
            },
            new ("Shared Outlook Mailbox", "Shared company mailbox (Microsoft 365)", Icons.Material.Rounded.Business, "#0078D4", "Outlook")
            {
                Connected = s.Outlook.Enabled,
                Settings = new IntegrationSettingsModel
                {
                    ClientId = s.Outlook.ClientId,
                    ClientSecret = s.Outlook.ClientSecret,
                    RedirectUri = s.Outlook.RedirectUri,
                    AuthEndpoint = s.Outlook.AuthEndpoint,
                    SyncCalendar = s.Outlook.SyncCalendar,
                    SyncContacts = s.Outlook.SyncContacts,
                    SyncEmail = s.Outlook.SyncEmail,
                    AutoCategorise = s.OutlookAutoCategorise,
                    AutoDraftReplies = s.OutlookAutoDraftReplies,
                    MoveToCompanyFolder = s.OutlookMoveToCompanyFolder,
                    LastSyncTime = s.Outlook.LastSyncTime,
                    Status = s.Outlook.Status?.ToString()
                }
            },
            new ("My Outlook", "Personal email & calendar (uses your profile email)", Icons.Material.Rounded.Mail, "#00B4D8", "MyOutlook")
            {
                Connected = myUserGraph.Enabled || myUserGraph.IsConnected,
                Settings = new IntegrationSettingsModel
                {
                    ClientId = s.MyOutlook.ClientId,
                    ClientSecret = s.MyOutlook.ClientSecret,
                    RedirectUri = s.MyOutlook.RedirectUri,
                    AuthEndpoint = s.MyOutlook.AuthEndpoint,
                    SyncCalendar = myUserGraph.SyncCalendar,
                    SyncContacts = myUserGraph.SyncContacts,
                    SyncEmail = myUserGraph.SyncEmail,
                    LastSyncTime = myUserGraph.LastSyncTime,
                    Status = myUserGraph.Status?.ToString()
                }
            },
            new ("My OneDrive", "Personal OneDrive files (Microsoft 365)", Icons.Material.Rounded.CloudUpload, "#2563EB", "MyOneDrive")
            {
                Connected = myUserGraph.Enabled || myUserGraph.IsConnected,
                Settings = new IntegrationSettingsModel
                {
                    ClientId = s.MyOutlook.ClientId,
                    ClientSecret = s.MyOutlook.ClientSecret,
                    RedirectUri = s.MyOutlook.RedirectUri,
                    AuthEndpoint = s.MyOutlook.AuthEndpoint,
                    SyncDrive = myUserGraph.SyncDrive,
                    LastSyncTime = myUserGraph.LastSyncTime,
                    Status = myUserGraph.Status?.ToString()
                }
            },
            new ("Google Cloud", "Drive, Gmail & Docs", Icons.Material.Rounded.Cloud, "#4285F4", "Google")
            {
                Connected = s.Google.Enabled,
                Settings = new IntegrationSettingsModel
                {
                    ClientId = s.Google.ClientId,
                    ClientSecret = s.Google.ClientSecret,
                    RedirectUri = s.Google.RedirectUri,
                    AuthEndpoint = s.Google.AuthEndpoint,
                    SyncDrive = s.Google.SyncDrive,
                    SyncGmail = s.Google.SyncGmail,
                    LastSyncTime = s.Google.LastSyncTime,
                    Status = s.Google.Status?.ToString()
                }
            },
        };
    }

    private void OpenSettingsDialog(IntegrationItem integration)
    {
        _selectedIntegration = integration;
        _showSettingsDialog = true;
    }

    private bool IsPerUserMicrosoftIntegration(IntegrationItem integration)
        => integration.Key is "MyOutlook" or "MyOneDrive";

    private void ConnectIntegration(IntegrationItem integration)
    {
        if (IsPerUserMicrosoftIntegration(integration))
        {
            Nav.NavigateTo("/integrations/microsoft/connect", forceLoad: true);
            return;
        }

        OpenSettingsDialog(integration);
    }

    private IntegrationSettings GetCurrentUserMicrosoftConnection(PlatformSettings settings)
    {
        if (!string.IsNullOrWhiteSpace(_currentUserCode)
            && settings.MyOutlookUserConnections.TryGetValue(_currentUserCode, out var existing))
        {
            return existing;
        }

        return new IntegrationSettings
        {
            SyncCalendar = settings.MyOutlook.SyncCalendar,
            SyncContacts = settings.MyOutlook.SyncContacts,
            SyncEmail = settings.MyOutlook.SyncEmail,
            SyncDrive = true,
            Status = "Not Connected"
        };
    }

    private void SaveCurrentUserMicrosoftConnection(PlatformSettings settings, IntegrationSettings value)
    {
        if (string.IsNullOrWhiteSpace(_currentUserCode)) return;
        settings.MyOutlookUserConnections[_currentUserCode] = value;
    }

    private async Task TestConnectionAsync(IntegrationItem integration)
    {
        if (string.IsNullOrEmpty(integration.Settings.ClientId) || string.IsNullOrEmpty(integration.Settings.ClientSecret))
        {
            Snackbar.Add($"Please configure {integration.Name} settings first.", Severity.Warning);
            return;
        }

        Snackbar.Add($"Testing {integration.Name} connection...", Severity.Info);
        
        integration.Settings.StatusDetails.LastTested = DateTime.UtcNow;
        integration.Settings.StatusDetails.LastTestSuccess = true;
        integration.Settings.StatusDetails.LastTestMessage = "Connection configured successfully";
        
        await SettingsSvc.SaveAsync();
        LoadIntegrations();
        
        Snackbar.Add($"{integration.Name} connection test successful.", Severity.Success);
    }

    private async Task SyncNow(IntegrationItem integration)
    {
        Snackbar.Add($"Starting sync with {integration.Name}...", Severity.Info);

        integration.Settings.LastSyncTime = DateTime.UtcNow;
        if (IsPerUserMicrosoftIntegration(integration))
        {
            var conn = GetCurrentUserMicrosoftConnection(SettingsSvc.Current);
            conn.LastSyncTime = integration.Settings.LastSyncTime;
            SaveCurrentUserMicrosoftConnection(SettingsSvc.Current, conn);
        }
        await SettingsSvc.SaveAsync();
        LoadIntegrations();
        
        Snackbar.Add($"{integration.Name} sync completed.", Severity.Success);
    }

    private async Task SaveIntegrationSettings()
    {
        if (_selectedIntegration == null) return;

        var s = SettingsSvc.Current;
        
        switch (_selectedIntegration.Key)
        {
            case "MYOB":
                s.MYOB.Enabled = _selectedIntegration.Connected;
                s.MYOB.ClientId = _selectedIntegration.Settings.ClientId;
                s.MYOB.ClientSecret = _selectedIntegration.Settings.ClientSecret;
                s.MYOB.RedirectUri = _selectedIntegration.Settings.RedirectUri;
                s.MYOB.SyncInvoices = _selectedIntegration.Settings.SyncInvoices;
                s.MYOB.SyncQuotes = _selectedIntegration.Settings.SyncQuotes;
                s.MYOB.SyncContacts = _selectedIntegration.Settings.SyncContacts;
                s.MYOB.AutoExportInvoices = _selectedIntegration.Settings.AutoExportInvoices;
                break;
            case "Xero":
                s.Xero.Enabled = _selectedIntegration.Connected;
                s.Xero.ClientId = _selectedIntegration.Settings.ClientId;
                s.Xero.ClientSecret = _selectedIntegration.Settings.ClientSecret;
                s.Xero.RedirectUri = _selectedIntegration.Settings.RedirectUri;
                s.Xero.SyncInvoices = _selectedIntegration.Settings.SyncInvoices;
                s.Xero.SyncContacts = _selectedIntegration.Settings.SyncContacts;
                s.Xero.AutoExportInvoices = _selectedIntegration.Settings.AutoExportInvoices;
                break;
            case "QuickBooks":
                s.QuickBooks.Enabled = _selectedIntegration.Connected;
                s.QuickBooks.ClientId = _selectedIntegration.Settings.ClientId;
                s.QuickBooks.ClientSecret = _selectedIntegration.Settings.ClientSecret;
                s.QuickBooks.RedirectUri = _selectedIntegration.Settings.RedirectUri;
                s.QuickBooks.SyncInvoices = _selectedIntegration.Settings.SyncInvoices;
                s.QuickBooks.SyncContacts = _selectedIntegration.Settings.SyncContacts;
                s.QuickBooks.AutoExportInvoices = _selectedIntegration.Settings.AutoExportInvoices;
                break;
            case "Outlook":
                s.Outlook.Enabled = _selectedIntegration.Connected;
                s.Outlook.ClientId = _selectedIntegration.Settings.ClientId;
                s.Outlook.ClientSecret = _selectedIntegration.Settings.ClientSecret;
                s.Outlook.RedirectUri = _selectedIntegration.Settings.RedirectUri;
                s.Outlook.SyncCalendar = _selectedIntegration.Settings.SyncCalendar;
                s.Outlook.SyncContacts = _selectedIntegration.Settings.SyncContacts;
                s.Outlook.SyncEmail = _selectedIntegration.Settings.SyncEmail;
                s.OutlookAutoCategorise = _selectedIntegration.Settings.AutoCategorise;
                s.OutlookAutoDraftReplies = _selectedIntegration.Settings.AutoDraftReplies;
                s.OutlookMoveToCompanyFolder = _selectedIntegration.Settings.MoveToCompanyFolder;
                break;
            case "MyOutlook":
                {
                    var userConn = GetCurrentUserMicrosoftConnection(s);
                    userConn.Enabled = _selectedIntegration.Connected;
                    userConn.SyncCalendar = _selectedIntegration.Settings.SyncCalendar;
                    userConn.SyncContacts = _selectedIntegration.Settings.SyncContacts;
                    userConn.SyncEmail = _selectedIntegration.Settings.SyncEmail;
                    userConn.Status = userConn.Enabled ? "Connected" : "Disabled";
                    SaveCurrentUserMicrosoftConnection(s, userConn);
                }
                break;
            case "MyOneDrive":
                {
                    var userConn = GetCurrentUserMicrosoftConnection(s);
                    userConn.Enabled = _selectedIntegration.Connected;
                    userConn.SyncDrive = _selectedIntegration.Settings.SyncDrive;
                    userConn.Status = userConn.Enabled ? "Connected" : "Disabled";
                    SaveCurrentUserMicrosoftConnection(s, userConn);
                }
                break;
            case "Google":
                s.Google.Enabled = _selectedIntegration.Connected;
                s.Google.ClientId = _selectedIntegration.Settings.ClientId;
                s.Google.ClientSecret = _selectedIntegration.Settings.ClientSecret;
                s.Google.RedirectUri = _selectedIntegration.Settings.RedirectUri;
                s.Google.SyncDrive = _selectedIntegration.Settings.SyncDrive;
                s.Google.SyncGmail = _selectedIntegration.Settings.SyncGmail;
                break;
        }
        
        await SettingsSvc.SaveAsync();
        LoadIntegrations();
        _showSettingsDialog = false;
        
        Snackbar.Add($"{_selectedIntegration.Name} settings saved.", Severity.Success);
    }

    private async Task DisconnectIntegration(IntegrationItem integration)
    {
        var s = SettingsSvc.Current;
        
        switch (integration.Key)
        {
            case "MYOB": s.MYOB.Enabled = false; break;
            case "Xero": s.Xero.Enabled = false; break;
            case "QuickBooks": s.QuickBooks.Enabled = false; break;
            case "Outlook": s.Outlook.Enabled = false; break;
            case "MyOutlook":
            case "MyOneDrive":
                if (!string.IsNullOrWhiteSpace(_currentUserCode))
                    s.MyOutlookUserConnections.Remove(_currentUserCode);
                break;
            case "Google": s.Google.Enabled = false; break;
        }
        
        await SettingsSvc.SaveAsync();
        LoadIntegrations();
        Snackbar.Add($"{integration.Name} disconnected.", Severity.Info);
    }

    public class IntegrationItem
    {
        public string Name { get; set; }
        public string Description { get; set; }
        public string Icon { get; set; }
        public string Color { get; set; }
        public string Key { get; set; }
        public bool Connected { get; set; }
        public IntegrationSettingsModel Settings { get; set; } = new();

        public IntegrationItem(string name, string description, string icon, string color, string key)
        {
            Name = name;
            Description = description;
            Icon = icon;
            Color = color;
            Key = key;
        }
    }

    public class IntegrationSettingsModel
    {
        public string? ClientId { get; set; }
        public string? ClientSecret { get; set; }
        public string? RedirectUri { get; set; }
        public string? AuthEndpoint { get; set; }
        public bool SyncInvoices { get; set; } = true;
        public bool SyncQuotes { get; set; } = true;
        public bool SyncContacts { get; set; } = true;
        public bool AutoExportInvoices { get; set; }
        public bool SyncCalendar { get; set; }
        public bool SyncEmail { get; set; }
        public bool SyncDrive { get; set; }
        public bool SyncGmail { get; set; }
        public bool AutoCategorise { get; set; } = true;
        public bool AutoDraftReplies { get; set; }
        public bool MoveToCompanyFolder { get; set; } = true;
        public DateTime? LastSyncTime { get; set; }
        public string? Status { get; set; }
public IntegrationStatusModel StatusDetails { get; set; } = new();
    }

    public class IntegrationStatusModel
    {
        public DateTime? LastTested { get; set; }
        public bool LastTestSuccess { get; set; }
        public string? LastTestMessage { get; set; }
    }
