@page "/reset-password"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject PlatformSettingsService PlatformSettings
@inject IJSRuntime JS
@inject HttpClient HttpClient

<PageTitle>Reset Password - @PlatformSettings.GetBrandingName()</PageTitle>

@code {
    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private string? NewPassword { get; set; }
    private string? ConfirmPassword { get; set; }
    private string? SuccessMessage { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsLoading { get; set; }
    private bool HasResetSuccessfully { get; set; }
    private bool _isDarkMode;
    private int PasswordStrength { get; set; }
    private string PasswordStrengthText { get; set; } = "";
    private string PasswordStrengthColor { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            ErrorMessage = "Invalid reset link. Please request a new password reset.";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var darkPref = await JS.InvokeAsync<string?>("localStorage.getItem", "mydesk_dark_mode");
                _isDarkMode = darkPref == "1";
                if (_isDarkMode)
                {
                    await JS.InvokeVoidAsync("eval", "document.body.classList.add('mud-dark-mode');");
                    StateHasChanged();
                }

                // Check if app is open
                var isAppOpen = await JS.InvokeAsync<bool>("eval", "typeof window.MyDeskAndroid !== 'undefined' || typeof window.webkit !== 'undefined'");
                if (isAppOpen)
                {
                    // Notify app to show reset password screen
                    await JS.InvokeVoidAsync("eval", "window.MyDeskAndroid?.onResetPasswordToken ? window.MyDeskAndroid.onResetPasswordToken('" + Token + "') : window.webkit?.messageHandlers?.onResetPasswordToken?.postMessage('" + Token + "')");
                }
            }
            catch { }
        }
    }

    private void UpdatePasswordStrength()
    {
        if (string.IsNullOrWhiteSpace(NewPassword))
        {
            PasswordStrength = 0;
            PasswordStrengthText = "";
            return;
        }

        var strength = 0;
        var pwd = NewPassword;

        // Length score
        if (pwd.Length >= 8) strength++;
        if (pwd.Length >= 12) strength++;
        if (pwd.Length >= 16) strength++;

        // Complexity score
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, "[a-z]")) strength++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, "[A-Z]")) strength++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, "[0-9]")) strength++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pwd, "[!@#$%^&*()_+=\\[\\]{};':\",./<>?]")) strength++;

        PasswordStrength = Math.Min(strength, 10);
        (PasswordStrengthText, PasswordStrengthColor) = PasswordStrength switch
        {
            <= 2 => ("Weak", "linear-gradient(90deg, #ef4444 0%, #ef4444 100%)"),
            <= 4 => ("Fair", "linear-gradient(90deg, #f97316 0%, #f97316 100%)"),
            <= 6 => ("Good", "linear-gradient(90deg, #eab308 0%, #eab308 100%)"),
            <= 8 => ("Strong", "linear-gradient(90deg, #84cc16 0%, #84cc16 100%)"),
            _ => ("Very Strong", "linear-gradient(90deg, #22c55e 0%, #22c55e 100%)")
        };
    }

    private async Task SubmitAsync()
    {
        ErrorMessage = null;
        SuccessMessage = null;

        // Validation
        if (string.IsNullOrWhiteSpace(NewPassword))
        {
            ErrorMessage = "Please enter a password";
            return;
        }

        if (NewPassword.Length < 8)
        {
            ErrorMessage = "Password must be at least 8 characters";
            return;
        }

        if (NewPassword != ConfirmPassword)
        {
            ErrorMessage = "Passwords do not match";
            return;
        }

        if (PasswordStrength < 4)
        {
            ErrorMessage = "Password is too weak. Please use at least 8 characters with uppercase, lowercase, and numbers.";
            return;
        }

        IsLoading = true;

        try
        {
            var response = await HttpClient.PostAsJsonAsync("/api/auth/reset-password", new
            {
                token = Token,
                newPassword = NewPassword
            });

            if (response.IsSuccessStatusCode)
            {
                HasResetSuccessfully = true;
                SuccessMessage = "Your password has been reset successfully!";
            }
            else
            {
                var errorContent = await response.Content.ReadAsAsync<dynamic>();
                ErrorMessage = errorContent?.error ?? "Failed to reset password. The reset link may have expired.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An error occurred. Please try again later.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void BackToLogin()
    {
        _ = JS.InvokeVoidAsync("window.location.href", "/login");
    }
}

<div class="tl-login-root @(_isDarkMode ? "dark-mode" : "")">
    <div class="tl-login-container">
        <div class="tl-login-card">
            <div class="tl-login-logo">
                <img src="@PlatformSettings.Current.LoginLogoUrl" alt="@PlatformSettings.Current.PlatformName" onerror="this.onerror=null;this.src='/images/mydesk-logo-white-text.svg';" />
            </div>

            @if (string.IsNullOrWhiteSpace(Token))
            {
                <h1>Invalid Reset Link</h1>
                <p style="color: var(--text-secondary); margin-bottom: 24px;">The password reset link is invalid or has expired.</p>
                <div style="text-align: center;">
                    <button @onclick="@(() => JS.InvokeVoidAsync("window.location.href", "/forgot-password"))" class="tl-login-button">
                        Request New Reset Link
                    </button>
                    <button @onclick="BackToLogin" class="tl-back-button">Back to Login</button>
                </div>
            }
            else if (!HasResetSuccessfully)
            {
                <h1>Reset Your Password</h1>
                <p style="color: var(--text-secondary); margin-bottom: 24px;">Enter a new password for your account.</p>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div style="background: rgba(239,68,68,0.1); border: 1px solid #ef4444; color: #ef4444; padding: 12px; border-radius: 8px; margin-bottom: 16px;">
                        @ErrorMessage
                    </div>
                }

                <form @onsubmit="SubmitAsync">
                    <div class="tl-login-group">
                        <label for="newPassword">New Password</label>
                        <input
                            type="password"
                            id="newPassword"
                            @bind="NewPassword"
                            @oninput="@((ChangeEventArgs e) => { NewPassword = e.Value?.ToString(); UpdatePasswordStrength(); })"
                            placeholder="Enter new password"
                            disabled="@IsLoading"
                            autocomplete="new-password"
                        />

                        @if (!string.IsNullOrEmpty(NewPassword))
                        {
                            <div style="margin-top: 12px;">
                                <div style="font-size: 12px; color: var(--text-secondary); margin-bottom: 4px;">
                                    Password Strength: <strong style="color: @(PasswordStrengthColor.Contains("ef4444") ? "#ef4444" : PasswordStrengthColor.Contains("f97316") ? "#f97316" : PasswordStrengthColor.Contains("eab308") ? "#eab308" : PasswordStrengthColor.Contains("84cc16") ? "#84cc16" : "#22c55e")">@PasswordStrengthText</strong>
                                </div>
                                <div style="height: 4px; background: var(--bg-secondary); border-radius: 2px; overflow: hidden;">
                                    <div style="height: 100%; width: @(PasswordStrength * 10)%; background: @PasswordStrengthColor; transition: width 0.2s;"></div>
                                </div>
                                <div style="font-size: 11px; color: var(--text-tertiary); margin-top: 8px;">
                                    <ul style="margin: 0; padding-left: 20px;">
                                        <li style="color: @(NewPassword.Length >= 8 ? "#22c55e" : "#a0a0c0")">At least 8 characters</li>
                                        <li style="color: @(System.Text.RegularExpressions.Regex.IsMatch(NewPassword, "[A-Z]") ? "#22c55e" : "#a0a0c0")">Uppercase letter (A-Z)</li>
                                        <li style="color: @(System.Text.RegularExpressions.Regex.IsMatch(NewPassword, "[a-z]") ? "#22c55e" : "#a0a0c0")">Lowercase letter (a-z)</li>
                                        <li style="color: @(System.Text.RegularExpressions.Regex.IsMatch(NewPassword, "[0-9]") ? "#22c55e" : "#a0a0c0")">Number (0-9)</li>
                                        <li style="color: @(System.Text.RegularExpressions.Regex.IsMatch(NewPassword, "[!@#$%^&*()_+=\\[\\]{};':\",./<>?]") ? "#22c55e" : "#a0a0c0")">Special character (!@#$%)</li>
                                    </ul>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="tl-login-group">
                        <label for="confirmPassword">Confirm Password</label>
                        <input
                            type="password"
                            id="confirmPassword"
                            @bind="ConfirmPassword"
                            placeholder="Confirm password"
                            disabled="@IsLoading"
                            autocomplete="new-password"
                        />
                    </div>

                    <button type="submit" disabled="@(IsLoading || PasswordStrength < 4)" class="tl-login-button" style="opacity: @(PasswordStrength < 4 ? "0.5" : "1"); cursor: @(PasswordStrength < 4 ? "not-allowed" : "pointer");">
                        @if (IsLoading)
                        {
                            <span>Resetting...</span>
                        }
                        else
                        {
                            <span>Reset Password</span>
                        }
                    </button>
                </form>

                <div style="text-align: center; margin-top: 16px;">
                    <button @onclick="BackToLogin" class="tl-back-button">Back to Login</button>
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 32px 0;">
                    <div style="font-size: 48px; margin-bottom: 16px;">✓</div>
                    <h2>Password Reset Successfully!</h2>
                    <p style="color: var(--text-secondary); margin: 16px 0;">Your password has been reset. You can now log in with your new password.</p>

                    <button @onclick="BackToLogin" class="tl-login-button">Go to Login</button>
                </div>
            }
        </div>
    </div>
</div>

<style>
.tl-back-button {
    background: transparent;
    color: var(--primary-color);
    border: 1px solid var(--primary-color);
    padding: 10px 24px;
    border-radius: 6px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s;
    margin-top: 8px;
}

.tl-back-button:hover {
    background: var(--primary-color);
    color: white;
}

.tl-login-group {
    margin-bottom: 20px;
}

.tl-login-group label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    color: var(--text-primary);
}

.tl-login-group input {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--border-color);
    border-radius: 6px;
    background: var(--input-bg);
    color: var(--text-primary);
    font-family: inherit;
    font-size: 14px;
    transition: border-color 0.2s;
}

.tl-login-group input:focus {
    border-color: var(--primary-color);
}

.tl-login-button {
    width: 100%;
    padding: 12px;
    background: var(--primary-color);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    font-size: 14px;
    transition: background 0.2s;
}

.tl-login-button:hover:not(:disabled) {
    opacity: 0.9;
}

.tl-login-button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}
</style>
