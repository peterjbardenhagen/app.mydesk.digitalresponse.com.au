<style>
    .sync-log-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .sync-log-table th, .sync-log-table td { padding: 4px 10px; text-align: left; border-bottom: 1px solid rgba(0,0,0,0.08); }
    .sync-log-table th { font-weight: 700; color: #64748b; }
    .status-success { color: #16a34a; font-weight: 600; }
    .status-failed  { color: #dc2626; font-weight: 600; }
    .status-running { color: #d97706; font-weight: 600; }
</style>

@code {
    private PlatformSettings _settings = new();
    private List<AccountingSyncStatus> _statuses = new();
    private List<SyncLogEntry> _xeroLogs = new();
    private List<SyncLogEntry> _qboLogs  = new();
    private List<SyncLogEntry> _myobLogs = new();
    private bool _saving  = false;
    private bool _running = false;

    protected override async Task OnInitializedAsync()
    {
        _settings = PlatformSettings.Current;

        // Handle OAuth callback query params
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var connected = query["connected"];
        var err = query["error"];

        if (!string.IsNullOrWhiteSpace(connected))
            Snackbar.Add($"Successfully connected to {connected}!", Severity.Success);
        if (!string.IsNullOrWhiteSpace(err))
            Snackbar.Add($"Connection error: {err}", Severity.Error);

        await LoadStatusAsync();
    }

    private async Task LoadStatusAsync()
    {
        try
        {
            _statuses = await SyncManager.GetSyncStatusAsync();
            _xeroLogs = _statuses.FirstOrDefault(s => s.Provider == "Xero")?.RecentLogs ?? new();
            _qboLogs  = _statuses.FirstOrDefault(s => s.Provider == "QuickBooks")?.RecentLogs ?? new();
            _myobLogs = _statuses.FirstOrDefault(s => s.Provider == "MYOB")?.RecentLogs ?? new();
        }
        catch
        {
            _statuses = new();
        }
    }

    private async Task SaveSettings()
    {
        _saving = true;
        try
        {
            await PlatformSettings.SaveAsync(_settings);
            Snackbar.Add("Settings saved", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ConnectXero()
    {
        await PlatformSettings.SaveAsync(_settings);
        var redirectUri = $"{Nav.BaseUri.TrimEnd('/')}/oauth/accounting/callback";
        var url = await XeroSvc.GetAuthUrlAsync(redirectUri);
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task ConnectQuickBooks()
    {
        await PlatformSettings.SaveAsync(_settings);
        var redirectUri = $"{Nav.BaseUri.TrimEnd('/')}/oauth/accounting/callback";
        var url = await QboSvc.GetAuthUrlAsync(redirectUri);
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task ConnectMyob()
    {
        await PlatformSettings.SaveAsync(_settings);
        var redirectUri = $"{Nav.BaseUri.TrimEnd('/')}/oauth/accounting/callback";
        var url = await MyobSvc.GetAuthUrlAsync(redirectUri);
        Nav.NavigateTo(url, forceLoad: true);
    }

    private async Task DisconnectProvider(string provider)
    {
        var cfg = provider switch
        {
            "Xero"       => _settings.Xero,
            "QuickBooks" => _settings.QuickBooks,
            "MYOB"       => _settings.MYOB,
            _            => null
        };
        if (cfg is null) return;

        cfg.IsConnected  = false;
        cfg.AccessToken  = null;
        cfg.RefreshToken = null;
        cfg.TokenExpiry  = null;
        cfg.Status       = "Disconnected";

        await PlatformSettings.SaveAsync(_settings);
        Snackbar.Add($"Disconnected from {provider}", Severity.Info);
        await LoadStatusAsync();
    }

    private async Task ManualSync(string provider)
    {
        _running = true;
        try
        {
            switch (provider)
            {
                case "Xero":       await XeroSvc.RunFullSyncAsync(); break;
                case "QuickBooks": await QboSvc.RunFullSyncAsync();  break;
                case "MYOB":       await MyobSvc.RunFullSyncAsync(); break;
            }
            Snackbar.Add($"{provider} sync complete", Severity.Success);
            _settings = PlatformSettings.Current;
            await LoadStatusAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{provider} sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _running = false;
        }
    }

    private async Task RunAllSyncs()
    {
        _running = true;
        try
        {
            await SyncManager.RunScheduledSyncAsync();
            Snackbar.Add("All syncs complete", Severity.Success);
            _settings = PlatformSettings.Current;
            await LoadStatusAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Sync failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _running = false;
        }
    }

    private RenderFragment RenderLogTable(List<SyncLogEntry> logs) => __builder =>
    {
        __builder.OpenElement(0, "table");
        __builder.AddAttribute(1, "class", "sync-log-table");
        __builder.OpenElement(2, "thead");
        __builder.OpenElement(3, "tr");
        foreach (var h in new[] { "Entity", "Direction", "Count", "Status", "Started", "Completed", "Error" })
        {
            __builder.OpenElement(4, "th");
            __builder.AddContent(5, h);
            __builder.CloseElement();
        }
        __builder.CloseElement();
        __builder.CloseElement();
        __builder.OpenElement(6, "tbody");
        foreach (var log in logs)
        {
            __builder.OpenElement(7, "tr");
            __builder.OpenElement(8, "td"); __builder.AddContent(9, log.EntityType);  __builder.CloseElement();
            __builder.OpenElement(10, "td"); __builder.AddContent(11, log.Direction); __builder.CloseElement();
            __builder.OpenElement(12, "td"); __builder.AddContent(13, log.Count);     __builder.CloseElement();
            __builder.OpenElement(14, "td");
            __builder.AddAttribute(15, "class", log.Status == "Success" ? "status-success" : log.Status == "Failed" ? "status-failed" : "status-running");
            __builder.AddContent(16, log.Status);
            __builder.CloseElement();
            __builder.OpenElement(17, "td"); __builder.AddContent(18, log.StartedAt.ToLocalTime().ToString("g")); __builder.CloseElement();
            __builder.OpenElement(19, "td"); __builder.AddContent(20, log.CompletedAt?.ToLocalTime().ToString("g") ?? "-"); __builder.CloseElement();
            __builder.OpenElement(21, "td"); __builder.AddContent(22, log.ErrorMessage ?? ""); __builder.CloseElement();
            __builder.CloseElement();
        }
        __builder.CloseElement();
        __builder.CloseElement();
    };
}
