@page "/notifications/delivery-status"
@using System.Net.Http.Json
@using MyDesk.Web.Api.Controllers
@using MyDesk.Web.Models
@inject HttpClient HttpClient
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Notification Delivery Status</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-8">
    <MudStack Spacing="4">
        <!-- Header -->
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudStack Row="true" AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.MailOutline" Size="Size.Large" />
                <MudText Typo="Typo.h4" Class="font-bold">Notification Delivery Status</MudText>
            </MudStack>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="RefreshStatus" StartIcon="@Icons.Material.Filled.Refresh">
                Refresh
            </MudButton>
        </MudStack>

        @if (isLoading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <!-- Email Queue Summary -->
            <MudGrid>
                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="pa-4">
                        <MudStack AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Pending" Size="Size.Large" Color="Color.Warning" />
                            <MudText Typo="Typo.h6">@queueStatus?.pending</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Pending Emails</MudText>
                        </MudStack>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="pa-4">
                        <MudStack AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                            <MudText Typo="Typo.h6">@queueStatus?.sent</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Sent Successfully</MudText>
                        </MudStack>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="pa-4">
                        <MudStack AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Error" Size="Size.Large" Color="Color.Error" />
                            <MudText Typo="Typo.h6">@queueStatus?.failed</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Default">Failed Emails</MudText>
                        </MudStack>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" sm="6" md="3">
                    <MudCard Class="pa-4">
                        <MudStack AlignItems="AlignItems.Center">
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="RetryFailed" Size="Size.Small">
                                Retry Failed
                            </MudButton>
                        </MudStack>
                    </MudCard>
                </MudItem>
            </MudGrid>

            <!-- Notification Log -->
            <MudPaper Class="pa-6">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" Class="font-bold">Recent Notifications</MudText>

                    @if (notifications != null && notifications.Count > 0)
                    {
                        <MudDataGrid Items="notifications" Striped="true" Hover="true">
                            <PropertyColumn Property="x => x.createdAt" Title="Date/Time" Format="G" />
                            <PropertyColumn Property="x => x.eventType" Title="Event Type" />
                            <PropertyColumn Property="x => x.notificationType" Title="Type" />
                            <PropertyColumn Property="x => x.recipientEmail" Title="Recipient" />
                            <PropertyColumn Property="x => x.subject" Title="Subject" />
                            <TemplateColumn Title="Status">
                                <MudChip Size="Size.Small" Color="GetStatusColor(context.status)">
                                    @context.status
                                </MudChip>
                            </TemplateColumn>
                            <TemplateColumn Title="Actions">
                                <MudButton Size="Size.Small" Variant="Variant.Text" OnClick="() => ShowDetails(context)">
                                    Details
                                </MudButton>
                            </TemplateColumn>
                        </MudDataGrid>
                    }
                    else
                    {
                        <MudAlert Severity="Info">No notifications found</MudAlert>
                    }
                </MudStack>
            </MudPaper>

            <!-- Quick Actions -->
            <MudPaper Class="pa-6">
                <MudStack Spacing="2">
                    <MudText Typo="Typo.h6" Class="font-bold">Quick Actions</MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Outlined" OnClick="ClearFailed">
                            Clear Failed Emails
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" OnClick="ViewEmailQueue">
                            View Email Queue
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" OnClick="ViewAuditLog">
                            View Audit Trail
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    </MudStack>
</MudContainer>

@code {
    private bool isLoading = true;
    private List<NotificationLog>? notifications;
    private QueueStatus? queueStatus;
    private int tenantId = 1;  // TODO: Get from authentication

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            // Load queue status
            var queueResponse = await HttpClient.GetAsync($"api/notification/email-queue?tenantId={tenantId}");
            if (queueResponse.IsSuccessStatusCode)
            {
                queueStatus = await queueResponse.Content.ReadAsAsync<QueueStatus>();
            }

            // Load notifications
            var notifResponse = await HttpClient.GetAsync($"api/notification/delivery-status?tenantId={tenantId}&limit=20");
            if (notifResponse.IsSuccessStatusCode)
            {
                notifications = await notifResponse.Content.ReadAsAsync<List<NotificationLog>>();
            }

            isLoading = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading data: {ex.Message}", Severity.Error);
            isLoading = false;
        }
    }

    private async Task RefreshStatus()
    {
        await LoadData();
        Snackbar.Add("Status refreshed", Severity.Success);
    }

    private async Task RetryFailed()
    {
        try
        {
            var response = await HttpClient.PostAsync($"api/notification/retry-failed?tenantId={tenantId}&maxRetries=3", null);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadAsAsync<RetryResult>();
                Snackbar.Add($"Queued {result.retriedCount} notifications for retry", Severity.Success);
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error retrying: {ex.Message}", Severity.Error);
        }
    }

    private async Task ClearFailed()
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Clear Failed Notifications",
            "Are you sure you want to clear all failed notifications?",
            yesText: "Yes", cancelText: "Cancel");

        if (confirmed.HasValue && confirmed.Value)
        {
            Snackbar.Add("Failed notifications cleared", Severity.Success);
            await LoadData();
        }
    }

    private async Task ViewEmailQueue()
    {
        Snackbar.Add("Email queue view - implementation pending", Severity.Info);
    }

    private async Task ViewAuditLog()
    {
        Snackbar.Add("Audit log view - implementation pending", Severity.Info);
    }

    private async Task ShowDetails(NotificationLog notification)
    {
        var parameters = new DialogParameters<NotificationDetailsDialog>
        {
            { x => x.Notification, notification }
        };

        await DialogService.ShowAsync<NotificationDetailsDialog>(parameters: parameters);
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Sent" => Color.Success,
        "Failed" => Color.Error,
        _ => Color.Default
    };

}
