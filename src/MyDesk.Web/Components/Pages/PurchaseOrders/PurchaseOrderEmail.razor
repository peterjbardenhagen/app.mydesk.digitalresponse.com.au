@page "/purchase-orders/{Id:int}/email"
@attribute [Authorize]
@inject PurchaseOrderService POService
@inject PdfService PdfService
@inject EmailService EmailService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@using System.Security.Claims

<PageTitle>Email PO @Id - MyDesk</PageTitle>

@if (_po == null)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else
{
    <div class="tl-page-header">
        <div>
            <div class="tl-breadcrumb">
                <a href="/">MyDesk</a><span class="sep">/</span>
                <a href="/purchase-orders">Purchase Orders</a><span class="sep">/</span>
                <a href="@($"/purchase-orders/{Id}")">PO @Id</a><span class="sep">/</span>
                <span>Email</span>
            </div>
            <h1>Email Purchase Order</h1>
        </div>
        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.ArrowBack"
                   Href="@($"/purchase-orders/{Id}")">Cancel</MudButton>
    </div>

    <MudGrid Spacing="3">
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-6" Elevation="1">
                <MudTextField @bind-Value="_toEmail" Label="To Email *" Required="true"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
                <MudTextField @bind-Value="_ccEmail" Label="CC"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
                <MudTextField @bind-Value="_attention" Label="Attention"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
                <MudTextField @bind-Value="_subject" Label="Subject"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" />
                <MudTextField @bind-Value="_notes" Label="Notes / Message"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Lines="6" Class="mb-3" />

                <div class="d-flex gap-2 mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Rounded.Send"
                               OnClick="SendAsync" Disabled="@_sending">
                        @(_sending ? "Sending..." : "Send Email")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Href="@($"/purchase-orders/{Id}")">Cancel</MudButton>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-5" Elevation="1">
                <MudText Typo="Typo.subtitle2" Class="mb-3"
                         Style="color:var(--gray-500);text-transform:uppercase;">PO Details</MudText>
                <MudText Typo="Typo.body2"><strong>PO #:</strong> @_po.POid</MudText>
                <MudText Typo="Typo.body2"><strong>Supplier:</strong> @_po.SupplierName</MudText>
                <MudText Typo="Typo.body2"><strong>Project:</strong> @_po.Project</MudText>
                <MudText Typo="Typo.body2"><strong>Total:</strong> @_po.PriceIncTotal.ToString("C")</MudText>
                <MudText Typo="Typo.body2"><strong>Status:</strong> @_po.StatusName</MudText>
                <MudDivider Class="my-3" />
                <MudAlert Severity="Severity.Info" Class="mb-0">
                    PDF will be attached automatically.
                </MudAlert>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public int Id { get; set; }
    private PurchaseOrder? _po;
    private string _toEmail = "";
    private string _ccEmail = "";
    private string _attention = "";
    private string _subject = "";
    private string _notes = "";
    private bool   _sending;
    private string _userCode = "";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userCode = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

        _po = await POService.GetPurchaseOrderAsync(Id);
        if (_po != null)
        {
            _attention = _po.SupplierName ?? "";
            _subject = $"Purchase Order #{_po.POid} - {_po.Project}";
            _notes = $"Please find attached Purchase Order #{_po.POid} for project: {_po.Project}.\n\nPlease confirm receipt and expected delivery date.";
        }
    }

    private async Task SendAsync()
    {
        if (_po == null || string.IsNullOrWhiteSpace(_toEmail))
        {
            Snackbar.Add("Please enter a recipient email.", Severity.Warning);
            return;
        }

        _sending = true;
        try
        {
            var pdfBytes = await PdfService.GeneratePurchaseOrderPdfAsync(Id);
            
            var sent = await EmailService.EmailPurchaseOrderAsync(
                poId: Id,
                toEmail: _toEmail,
                subject: _subject,
                message: _notes,
                senderCode: _userCode,
                pdfBytes: pdfBytes);

            if (!sent) throw new Exception("Email send returned false");

            // Promote status to Issued (4) if < 4
            if (_po.POStatusId < 4)
            {
                await POService.UpdateStatusAsync(Id, 4, _userCode, "Issued");
            }

            Snackbar.Add($"Email sent to {_toEmail}.", Severity.Success);
            Nav.NavigateTo($"/purchase-orders/{Id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Email failed: {ex.Message}", Severity.Error);
        }
        finally { _sending = false; }
    }
}



