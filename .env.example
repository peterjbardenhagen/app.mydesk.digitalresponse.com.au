# Environment Variables Template
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.

# --- App ---
# APP_ENV=development

# --- Database ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=myapp
# DB_USER=postgres
# DB_PASSWORD=

# --- Auth ---
# JWT_SECRET=
# JWT_EXPIRES_IN=3600

# --- External Services ---
# API_KEY=
# API_URL=https://api.example.com

# --- Deployment ---
# DEPLOY_TARGET=production
