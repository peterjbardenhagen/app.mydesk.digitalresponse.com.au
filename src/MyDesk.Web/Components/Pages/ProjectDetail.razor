<!-- Add Task Dialog -->
<MudDialog @bind-Visible="_addTaskOpen" Options="@(new DialogOptions{MaxWidth=MaxWidth.Small,FullWidth=true})">
    <TitleContent><MudText Typo="Typo.h6">Add Task</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newTask.Title" Label="Title" Variant="Variant.Outlined" Class="mb-3" Required="true" />
        <MudTextField @bind-Value="_newTask.Description" Label="Description" Variant="Variant.Outlined" Lines="3" Class="mb-3" />
        <MudSelect @bind-Value="_newTask.AssigneeName" Label="Assignee" Variant="Variant.Outlined" Class="mb-3">
            @foreach (var m in _members.Where(m => m.Role != "Client" && m.Role != "Supplier"))
            {
                <MudSelectItem Value="@m.Name">@m.Name</MudSelectItem>
            }
        </MudSelect>
        <MudSelect @bind-Value="_newTask.Priority" Label="Priority" Variant="Variant.Outlined" Class="mb-3">
            <MudSelectItem Value="@("Low")">Low</MudSelectItem>
            <MudSelectItem Value="@("Medium")">Medium</MudSelectItem>
            <MudSelectItem Value="@("High")">High</MudSelectItem>
            <MudSelectItem Value="@("Critical")">Critical</MudSelectItem>
        </MudSelect>
        <MudGrid Spacing="2">
            <MudItem xs="6"><MudDatePicker @bind-Date="_newTask.TaskStartDate" Label="Start Date" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="6"><MudDatePicker @bind-Date="_newTask.TaskEndDate" Label="End Date" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="6"><MudDatePicker @bind-Date="_newTask.DueDate" Label="Due Date" Variant="Variant.Outlined" /></MudItem>
            <MudItem xs="6"><MudNumericField @bind-Value="_newTask.EstimatedHours" Label="Est. Hours" Variant="Variant.Outlined" /></MudItem>
        </MudGrid>
        <MudSelect @bind-Value="_newTask.MilestoneId" Label="Milestone" Variant="Variant.Outlined" Class="mt-3" Clearable="true">
            @foreach (var ms in _milestones)
            {
                <MudSelectItem Value="@((int?)ms.MilestoneId)">@ms.Title</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _addTaskOpen = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveTask">Save Task</MudButton>
    </DialogActions>
</MudDialog>

