@page "/favorites"
@attribute [Authorize]
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Favorites - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Dashboard</a><span class="sep">/</span>
            <span>Favorites</span>
        </div>
        <h1>Favorites</h1>
        <p class="tl-subtitle">Your bookmarked items from across MyDesk</p>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex justify-center align-center" style="height: 300px;">
        <MudProgressCircular Size="Size.Large" Indeterminate="true" />
    </div>
}
else
{
    <MudGrid Spacing="4">
        @if (_bookmarkedCampaigns.Any())
        {
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="1">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Rounded.Campaign" Color="Color.Primary" />
                            <MudText Typo="Typo.h6">Email Campaigns (@_bookmarkedCampaigns.Count)</MudText>
                        </div>
                        <MudButton Variant="Variant.Text" 
                                  Color="Color.Primary" 
                                  Href="/marketing/campaigns">
                            View All
                        </MudButton>
                    </div>
                    <MudTable Items="_bookmarkedCampaigns" Dense="true" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Campaign Name</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Sent</MudTh>
                            <MudTh>Open Rate</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <div style="font-weight: 500;">@context.Name</div>
                            </MudTd>
                            <MudTd>
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Value="@context.Status">@context.Status</MudChip>
                            </MudTd>
                            <MudTd Style="text-align: right;">@context.RecipientCount.ToString("N0")</MudTd>
                            <MudTd Style="text-align: right;">
                                @if (context.OpenRate > 0)
                                {
                                    <span>@context.OpenRate.ToString("F1")%</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        }

        @if (_bookmarkedCustomers.Any())
        {
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="1">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Rounded.People" Color="Color.Success" />
                            <MudText Typo="Typo.h6">Customers (@_bookmarkedCustomers.Count)</MudText>
                        </div>
                        <MudButton Variant="Variant.Text" 
                                  Color="Color.Primary" 
                                  Href="/marketing/customers">
                            View All
                        </MudButton>
                    </div>
                    <MudTable Items="_bookmarkedCustomers" Dense="true" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Customer</MudTh>
                            <MudTh>Revenue YTD</MudTh>
                            <MudTh>Quotes</MudTh>
                            <MudTh>Score</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <div class="d-flex align-center gap-2">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary">@GetInitials(context.CompanyName)</MudAvatar>
                                    <span style="font-weight: 500;">@context.CompanyName</span>
                                </div>
                            </MudTd>
                            <MudTd Style="text-align: right;">-</MudTd>
                            <MudTd Style="text-align: right;">-</MudTd>
                            <MudTd Style="text-align: center;">-</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        }

        @if (_bookmarkedSuppliers.Any())
        {
            <MudItem xs="12">
                <MudPaper Class="pa-4" Elevation="1">
                    <div class="d-flex align-center justify-space-between mb-4">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Rounded.LocalShipping" Color="Color.Warning" />
                            <MudText Typo="Typo.h6">Suppliers (@_bookmarkedSuppliers.Count)</MudText>
                        </div>
                        <MudButton Variant="Variant.Text" 
                                  Color="Color.Primary" 
                                  Href="/marketing/suppliers">
                            View All
                        </MudButton>
                    </div>
                    <MudTable Items="_bookmarkedSuppliers" Dense="true" Hover="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Supplier</MudTh>
                            <MudTh>Spend YTD</MudTh>
                            <MudTh>Orders</MudTh>
                            <MudTh>On-Time %</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <div class="d-flex align-center gap-2">
                                    <MudAvatar Size="Size.Small" Color="Color.Default">@GetInitials(context.CompanyName)</MudAvatar>
                                    <span style="font-weight: 500;">@context.CompanyName</span>
                                </div>
                            </MudTd>
                            <MudTd Style="text-align: right;">-</MudTd>
                            <MudTd Style="text-align: right;">-</MudTd>
                            <MudTd Style="text-align: right;">-</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudPaper>
            </MudItem>
        }

        @if (!_bookmarkedCampaigns.Any() && !_bookmarkedCustomers.Any() && !_bookmarkedSuppliers.Any())
        {
            <MudItem xs="12">
                <MudPaper Class="pa-8 text-center" Elevation="1">
                    <div class="tl-empty-state-icon">
                        <MudIcon Icon="@Icons.Material.Rounded.StarBorder" 
                                Size="Size.Large" 
                                Color="Color.Default" />
                    </div>
                    <MudText Typo="Typo.h6" Class="mt-4" Style="color: var(--gray-600);">No favorites yet</MudText>
                    <MudText Typo="Typo.body2" Class="mt-2" Style="color: var(--gray-400);">
                        Bookmark items across MyDesk to see them here
                    </MudText>
                    <MudButton Variant="Variant.Filled" 
                              Color="Color.Primary" 
                              Class="mt-4"
                              Href="/marketing/campaigns">
                        Browse Campaigns
                    </MudButton>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

<style>
    .tl-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }
    .tl-breadcrumb {
        font-size: 13px;
        color: var(--gray-500);
    }
    .tl-breadcrumb a {
        color: var(--gray-500);
        text-decoration: none;
    }
    .tl-breadcrumb a:hover {
        color: var(--tl-primary-500);
    }
    .tl-breadcrumb .sep {
        margin: 0 8px;
        color: var(--gray-300);
    }
    .tl-subtitle {
        color: var(--gray-500);
        margin-top: 4px;
    }
    .tl-empty-state-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--gray-100);
        border-radius: 50%;
        color: var(--gray-400);
        animation: fadeIn 0.5s ease;
    }

    .tl-fade-in {
        animation: fadeIn 0.3s ease-in-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: scale(0.9); }
        to { opacity: 1; transform: scale(1); }
    }
</style>

@code {
    private bool _loading = true;
    private List<EmailCampaign> _bookmarkedCampaigns = new();
    private List<CustomerScoreCard> _bookmarkedCustomers = new();
    private List<SupplierScoreCard> _bookmarkedSuppliers = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadBookmarks();
            StateHasChanged();
        }
    }

    private async Task LoadBookmarks()
    {
        await Task.WhenAll(
            LoadCampaignBookmarks(),
            LoadCustomerBookmarks(),
            LoadSupplierBookmarks()
        );
        _loading = false;
    }

    private async Task LoadCampaignBookmarks()
    {
        var bookmarksJson = await JS.InvokeAsync<string>("localStorage.getItem", "bookmarkedCampaigns");
        if (!string.IsNullOrWhiteSpace(bookmarksJson))
        {
            _bookmarkedCampaigns = System.Text.Json.JsonSerializer.Deserialize<List<EmailCampaign>>(bookmarksJson) ?? new();
        }
    }

    private async Task LoadCustomerBookmarks()
    {
        var bookmarksJson = await JS.InvokeAsync<string>("localStorage.getItem", "bookmarkedCustomers");
        if (!string.IsNullOrWhiteSpace(bookmarksJson))
        {
            _bookmarkedCustomers = System.Text.Json.JsonSerializer.Deserialize<List<CustomerScoreCard>>(bookmarksJson) ?? new();
        }
    }

    private async Task LoadSupplierBookmarks()
    {
        var bookmarksJson = await JS.InvokeAsync<string>("localStorage.getItem", "bookmarkedSuppliers");
        if (!string.IsNullOrWhiteSpace(bookmarksJson))
        {
            _bookmarkedSuppliers = System.Text.Json.JsonSerializer.Deserialize<List<SupplierScoreCard>>(bookmarksJson) ?? new();
        }
    }

    private Color GetStatusColor(string status) => status.ToLower() switch
    {
        "draft" => Color.Default,
        "scheduled" => Color.Info,
        "sending" => Color.Warning,
        "sent" => Color.Success,
        _ => Color.Default
    };

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpper(),
            _ => $"{parts[0][..1].ToUpper()}{parts[^1][..1].ToUpper()}"
        };
    }
}
