<?xml version="1.0" encoding="utf-8"?>
<!--
  Techlight MyDesk - IIS Production Configuration
  
  Security Hardening:
  - Remove IIS version headers
  - Disable directory browsing
  - Enable dynamic/static compression
  - Security headers (X-Frame-Options, X-Content-Type-Options, etc.)
  - Request limits (max URL length, query string)
  
  Place this file in the root of the published application.
-->
<configuration>
  <system.webServer>
    <!-- Remove IIS version from HTTP headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" />
        <!-- Prevent search engine indexing -->
        <add name="X-Robots-Tag" value="noindex, nofollow, noarchive, nosnippet, noimageindex" />
      </customHeaders>
    </httpProtocol>

    <!-- Security: Disable directory browsing -->
    <directoryBrowse enabled="false" />

    <!-- Enable compression -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
    <httpCompression>
      <dynamicTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="message/*" enabled="true" />
        <add mimeType="application/x-javascript" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/json" enabled="true" />
        <add mimeType="application/xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </dynamicTypes>
      <staticTypes>
        <add mimeType="text/*" enabled="true" />
        <add mimeType="message/*" enabled="true" />
        <add mimeType="application/javascript" enabled="true" />
        <add mimeType="application/atom+xml" enabled="true" />
        <add mimeType="application/xaml+xml" enabled="true" />
        <add mimeType="*/*" enabled="false" />
      </staticTypes>
    </httpCompression>

    <!-- Request limits (prevent abuse) -->
    <security>
      <requestFiltering>
        <requestLimits maxUrl="4096" maxQueryString="2048" maxAllowedContentLength="104857600" />
        <verbs>
          <add verb="TRACE" allowed="false" />
          <add verb="HEAD" allowed="false" />
        </verbs>
        <hiddenSegments>
          <add segment="Logs" />
          <add segment="appsettings.json" />
          <add segment="appsettings.Production.json" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- ASP.NET Core hosting -->
    <handlers>
      <remove name="WebServiceHandler" />
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    
    <!-- Authentication settings for IIS - allow anonymous for login -->
    <security>
      <authentication>
        <anonymousAuthentication enabled="true" />
        <windowsAuthentication enabled="false" />
      </authentication>
    </security>
    
    <!-- IIS rewrite rule to ensure login works -->
    <rewrite>
      <rules>
        <!-- Allow anonymous access to login page and API auth -->
        <rule name="Allow Login and API Auth" stopProcessing="true">
          <match url="^login$|^api/auth|^forgot-password" />
          <conditions>
            <add input="{AUTHENTICATED_USER}" matchType="Pattern" pattern=".+" negate="true" />
          </conditions>
          <action type="None" />
        </rule>
      </rules>
    </rewrite>

    <!-- Logging -->
    <aspNetCore processPath="dotnet" arguments=".\MyDesk.Web.dll" stdoutLogEnabled="false" hostingModel="inprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        <environmentVariable name="DOTNET_gcServer" value="1" />
      </environmentVariables>
    </aspNetCore>

    <!-- Static file caching -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <!-- Rewrite rules -->
    <rewrite>
      <rules>
        <!-- Force HTTPS -->
        <rule name="Force HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>
        
        <!-- Remove trailing slashes -->
        <rule name="Remove trailing slash" stopProcessing="true">
          <match url="(.+)/$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Redirect" redirectType="Permanent" url="{R:1}" />
        </rule>

        <!-- Block access to sensitive files -->
        <rule name="Block sensitive files" stopProcessing="true">
          <match url="^(.*\.(?:config|log|md|yml|yaml|sql|env|sh|ps1))$" />
          <action type="AbortRequest" />
        </rule>

        <!-- Block search engine crawlers and AI bots by User-Agent -->
        <rule name="Block Search Crawlers" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{HTTP_USER_AGENT}" pattern="(Googlebot|Googlebot-Image|Googlebot-Mobile|Bingbot|Slurp|DuckDuckBot|Baiduspider|YandexBot|GPTBot|ChatGPT-User|ClaudeBot|anthropic-ai|CCBot|PerplexityBot|AhrefsBot|SemrushBot|MJ12bot|DotBot|DataForSeoBot)" />
          </conditions>
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Access denied - indexing prohibited" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>

  <!-- ASP.NET settings -->
  <system.web>
    <httpRuntime maxUrlLength="4096" maxQueryStringLength="2048" requestValidationMode="4.5" />
    <customErrors mode="RemoteOnly" defaultRedirect="/error">
      <error statusCode="404" redirect="/404" />
      <error statusCode="500" redirect="/500" />
    </customErrors>
    <sessionState mode="InProc" cookieless="UseCookies" timeout="480" />
    <machineKey validation="AES" decryption="AES" />
  </system.web>

    <!-- Connection strings (optional - can also be in appsettings) -->
    <connectionStrings>
      <!-- IIS uses SQL authentication to connect to LocalDB -->
      <add name="TechlightDb" 
           connectionString="Server=(localdb)\MSSQLLocalDB;Database=Techlight_MyDesk;User Id=mydesk;Password=Omnfxop09!;Encrypt=false;TrustServerCertificate=true;" 
           providerName="System.Data.SqlClient" />
    </connectionStrings>
</configuration>
