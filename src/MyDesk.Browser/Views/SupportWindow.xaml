<Window x:Class="MyDesk.Browser.Views.SupportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MyDesk.Browser.ViewModels"
        Title="MyDesk Browser — IT Support"
        Height="650"
        Width="700"
        MinHeight="500"
        MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="/Assets/icon.ico">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="IT Support"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />
            <TextBlock Text="Submit a support request or view previous tickets"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="200" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Recent Tickets List -->
            <Border Grid.Column="0"
                    Background="{DynamicResource UrlBarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recent Tickets"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,4" />

                    <Button Grid.Row="1"
                            Content="✨ New Ticket"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding NewTicketCommand}"
                            Height="32"
                            Margin="0,0,0,8" />

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Tickets}"
                             SelectedItem="{Binding SelectedTicket}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6,4"
                                        CornerRadius="4"
                                        Margin="0,2"
                                        Background="{DynamicResource UrlBarBackgroundBrush}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding PriorityIcon}" FontSize="12" Margin="0,0,4,0" />
                                            <TextBlock Text="{Binding Subject}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="160" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding StatusIcon}" FontSize="10" Margin="0,0,2,0" />
                                            <TextBlock Text="{Binding Status}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Text=" · "
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                            <TextBlock Text="{Binding ShortDate}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Separator -->
            <GridSplitter Grid.Column="1"
                          Width="3"
                          Margin="4,0"
                          Background="Transparent"
                          HorizontalAlignment="Center"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Ticket Form / Detail View -->
            <Border Grid.Column="2"
                    Background="{DynamicResource UrlBarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>

                    <!-- New Ticket Form -->
                    <StackPanel Visibility="{Binding ShowNewTicket, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="New Support Request"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,12" />

                        <TextBlock Text="Subject *"
                                   Style="{DynamicResource SettingLabelStyle}" />
                        <TextBox Style="{DynamicResource ModernTextBoxStyle}"
                                 Text="{Binding Subject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,4,0,12" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Category"
                                           Style="{DynamicResource SettingLabelStyle}" />
                                <ComboBox ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                          Style="{DynamicResource ModernComboBoxStyle}"
                                          Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Priority"
                                           Style="{DynamicResource SettingLabelStyle}" />
                                <ComboBox ItemsSource="{Binding Priorities}"
                                          SelectedItem="{Binding SelectedPriority, Mode=TwoWay}"
                                          Style="{DynamicResource ModernComboBoxStyle}"
                                          Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Description *"
                                   Style="{DynamicResource SettingLabelStyle}" />
                        <TextBox Style="{DynamicResource ModernTextBoxStyle}"
                                 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="140"
                                 VerticalScrollBarVisibility="Auto"
                                 Margin="0,4,0,12" />

                        <Button Content="📤 Submit Support Request"
                                Style="{DynamicResource PrimaryButtonStyle}"
                                Command="{Binding SubmitCommand}"
                                IsEnabled="{Binding IsSubmitting, Converter={StaticResource InvertedBoolConverter}}"
                                Height="38"
                                HorizontalAlignment="Left"
                                Padding="20,0" />

                        <TextBlock Text="{Binding StatusMessage}"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="11"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Ticket Detail View -->
                    <StackPanel Visibility="{Binding ShowNewTicket, Converter={StaticResource InvertedBoolConverter}}">
                        <StackPanel DataContext="{Binding SelectedTicket}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="{Binding PriorityIcon}" FontSize="16" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding Subject}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock Text="Ticket #{Binding Id}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,12" />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Status"
                                               Style="{DynamicResource SettingLabelStyle}" />
                                    <TextBlock Text="{Binding StatusIcon}"
                                               FontSize="14" />
                                    <TextBlock Text="{Binding Status}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Category"
                                               Style="{DynamicResource SettingLabelStyle}" />
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Submitted"
                                               Style="{DynamicResource SettingLabelStyle}" />
                                    <TextBlock Text="{Binding ShortDate}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </StackPanel>
                            </Grid>

                            <Separator Margin="0,0,0,12" />

                            <TextBlock Text="Description"
                                       Style="{DynamicResource SettingLabelStyle}"
                                       Margin="0,0,0,4" />
                            <Border Background="{DynamicResource WindowBackgroundBrush}"
                                    CornerRadius="4"
                                    Padding="12"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding Description}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Close"
                    Style="{DynamicResource SecondaryButtonStyle}"
                    Click="BtnClose_Click"
                    Width="100" />
        </StackPanel>
    </Grid>
</Window>
