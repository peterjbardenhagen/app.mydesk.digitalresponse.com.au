        "/admin/users"         => Icons.Material.Rounded.PeopleAlt,
        "/integrations"        => Icons.Material.Rounded.Hub,
        "/settings"            => Icons.Material.Rounded.Tune,
        "/ask-ai"              => Icons.Material.Rounded.AutoAwesome,
        "/profile"             => Icons.Material.Rounded.AccountCircle,
        _                      => Icons.Material.Rounded.ArrowForward
    };

    /// <summary>Persist side-nav drawer state so user pref survives reloads.</summary>
    private async Task PersistDrawerState()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "mydesk_col2_open",   _col2Open ? "1" : "0");
        }
        catch { /* JS interop unavailable during prerender */ }
    }

    private async Task RestoreDarkModeAsync()
    {
        try
        {
            var darkPref = await JS.InvokeAsync<string?>("localStorage.getItem", "mydesk_dark_mode");
            if (darkPref == "1")
            {
                _isDarkMode = true;
                ApplyDarkMode();
                StateHasChanged();
            }
        }
        catch { }
    }

    private async Task RestoreDrawerStateAsync()
    {
        try
        {
            var open   = await JS.InvokeAsync<string?>("localStorage.getItem", "mydesk_col2_open");
            // Default to OPEN unless localStorage explicitly says "0".
            _col2Open   = open   != "0";
            StateHasChanged();
        }
        catch { /* JS interop unavailable during prerender */ }
    }
}

