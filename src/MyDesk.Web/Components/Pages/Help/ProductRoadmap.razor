        new("Copy Supplier Quote","AI-powered PDF extraction with automatic margin markup."),
        new("Customer Portal",    "Self-service portal for quotes, invoices and orders."),
        new("Supplier Portal",    "Suppliers can view POs, submit RFQ responses and ASNs."),
        new("Subscription Manager","Recurring renewals with one-click invoice raising."),
        new("MYOB Integration",   "Bidirectional invoice and payment sync."),
        new("Dashboard Weather",  "Configurable global weather widget per user."),
