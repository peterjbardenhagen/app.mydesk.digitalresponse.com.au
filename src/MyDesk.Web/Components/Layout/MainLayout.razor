    private int _notificationCount => _notifications.Count;
    private List<NotificationItem> _notifications = new();
    private string _aiTooltipText => $"Ask {PlatformSettings.GetBrandingName()} AI";
    
    private bool IsSpecialPage => NavigationManager.Uri.Contains("/help/roadmap") || NavigationManager.Uri.Contains("/pricing");


    [Inject] IJSRuntime JS { get; set; } = null!;
    [Inject] IDialogService DialogService { get; set; } = null!;

    public class NotificationItem
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string Title { get; set; } = "";
        public string Message { get; set; } = "";
        public string Type { get; set; } = "";
        public string Time { get; set; } = "";
        public string? Url { get; set; }
    }

    async Task DrawerToggle()
    {
        _col2Open = !_col2Open;
        await PersistDrawerState();
    }

    private async Task OnNavSectionSelected(string section)
    {
        _activeNavSection = section;
        // Selecting a section always reveals the drilldown.
        _col2Open = true;
        await PersistDrawerState();
        StateHasChanged();
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        if (_isDarkMode)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "mydesk_dark_mode", "1");
        }
        else
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", "mydesk_dark_mode");
        }
        ApplyDarkMode();
    }

    private void ApplyDarkMode()
    {
        // MudThemeProvider handles the primary dark mode switching for MudBlazor components
        // We also toggle the class on body for our custom CSS variables
        JS.InvokeVoidAsync("eval", _isDarkMode 
            ? "document.body.classList.add('mud-dark-mode')" 
            : "document.body.classList.remove('mud-dark-mode')");
    }

    private void OnGlobalKeyDown(KeyboardEventArgs e)
    {
        // Ctrl+K (or Cmd+K on Mac) opens the Quick Nav command palette.
        if ((e.CtrlKey || e.MetaKey) && e.Key.Equals("k", StringComparison.OrdinalIgnoreCase))
        {
            _ = InvokeAsync(OpenQuickNav);
            return;
        }

        // Alt-key shortcuts.
        if (e.AltKey)
        {
            switch (e.Key.ToLower())
            {
                case "k":
                    NavigationManager.NavigateTo("/search");
                    break;
                case "h":
                    NavigationManager.NavigateTo("/");
                    break;
                case "b":
                    _ = InvokeAsync(DrawerToggle);
                    break;
            }
        }
        else if (e.Key == "?")
        {
            _ = InvokeAsync(OpenKeyboardShortcuts);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userIdClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out var userId))
            {
                _tenantMemberships = await TenantSvc.GetUserTenantsAsync(userId);
            }
        }
        catch { }
    }

    private void SwitchWorkspace()
    {
        NavigationManager.NavigateTo("/login/select-tenant", forceLoad: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSearchHistory();
            await RestoreDrawerStateAsync();
            await RestoreDarkModeAsync();
        }
    }

    private async Task LoadSearchHistory()
    {
        try
        {
            var historyJson = await JS.InvokeAsync<string>("localStorage.getItem", "mydesk_search_history");
            if (!string.IsNullOrWhiteSpace(historyJson))
            {
                _searchHistory = System.Text.Json.JsonSerializer.Deserialize<List<string>>(historyJson) ?? new();
            }
        }
        catch
        {
        }
    }

    private async Task SaveSearchHistory()
    {
        var historyJson = System.Text.Json.JsonSerializer.Serialize(_searchHistory);
        await JS.InvokeVoidAsync("localStorage.setItem", "mydesk_search_history", historyJson);
    }

    private async Task ClearSearchHistory()
    {
        _searchHistory.Clear();
        _showSearchHistory = false;
        await JS.InvokeVoidAsync("localStorage.removeItem", "mydesk_search_history");
    }

    private async Task OnSearchFocus()
    {
        _showSearchHistory = _searchHistory.Any();
    }

    private void SelectSearchHistory(string search)
    {
        _searchQuery = search;
        _showSearchHistory = false;
        NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(search)}");
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _showSearchHistory = false;
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                // Save to search history
                _searchHistory.Remove(_searchQuery);
                _searchHistory.Insert(0, _searchQuery);
                if (_searchHistory.Count > 10) _searchHistory.RemoveAt(_searchHistory.Count - 1);
                await SaveSearchHistory();
                
                NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery)}");
            }
        }
        else if (e.Key == "Escape")
        {
            _showSearchHistory = false;
        }
    }

    static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "?",
            1 => parts[0][..1].ToUpper(),
            _ => (parts[0][..1] + parts[^1][..1]).ToUpper()
        };
    }


    private void ClearNotifications()
    {
        _notifications.Clear();
    }

    private void RemoveNotification(NotificationItem item)
    {
        _notifications.Remove(item);
    }

    private void NavigateToNotification(NotificationItem item)
    {
        if (!string.IsNullOrEmpty(item.Url))
        {
            NavigationManager.NavigateTo(item.Url);
        }
    }

    private string GetNotificationIcon(string type) => type.ToLower() switch
    {
        "info" => Icons.Material.Rounded.Info,
        "success" => Icons.Material.Rounded.CheckCircle,
        "warning" => Icons.Material.Rounded.Warning,
        "error" => Icons.Material.Rounded.Error,
        _ => Icons.Material.Rounded.Notifications
    };

    private Color GetNotificationColor(string type) => type.ToLower() switch
    {
        "info" => Color.Info,
        "success" => Color.Success,
        "warning" => Color.Warning,
        "error" => Color.Error,
        _ => Color.Default
    };

    private async Task OpenKeyboardShortcuts()
    {
        var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        await DialogService.ShowAsync<KeyboardShortcutsDialog>("Keyboard Shortcuts", options);
    }

    /// <summary>
    /// Opens the Quick Nav command palette (header icon + Ctrl+K). Items come from
    /// <see cref="GetAllModules"/> so there is one canonical list shared with the side nav.
    /// </summary>
    private async Task OpenQuickNav()
    {
        var allItems = GetAllModules()
            .Select(m => new MyDesk.Web.Components.Shared.QuickNavDialog.QuickNavItem(m.Title, m.Href, GetIconForHref(m.Href), m.Group))
            .ToList();

        var parameters = new DialogParameters<MyDesk.Web.Components.Shared.QuickNavDialog>
        {
            { x => x.AllItems, allItems }
        };

        var options = new DialogOptions
        {
            CloseButton = false,
            CloseOnEscapeKey = true,
            BackdropClick = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            NoHeader = true
        };
        await DialogService.ShowAsync<MyDesk.Web.Components.Shared.QuickNavDialog>(string.Empty, parameters, options);
    }

    private static string? GetIconForHref(string href) => href switch
    {
        "/"                    => Icons.Material.Rounded.Dashboard,
        "/activity"            => Icons.Material.Rounded.History,
        "/favourites"          => Icons.Material.Rounded.Star,
        "/files"               => Icons.Material.Rounded.Folder,
        "/emails"              => Icons.Material.Rounded.Mail,
        "/contacts"            => Icons.Material.Rounded.Person,
        "/companies"           => Icons.Material.Rounded.Business,
        "/accounts"            => Icons.Material.Rounded.AccountBalanceWallet,
        "/quotes"              => Icons.Material.Rounded.Description,
        "/quotes/copy-supplier"=> Icons.Material.Rounded.ContentCopy,
        "/invoices"            => Icons.Material.Rounded.Receipt,
        "/despatch"            => Icons.Material.Rounded.LocalShipping,
        "/purchase-orders"     => Icons.Material.Rounded.ShoppingBasket,
        "/expenses"            => Icons.Material.Rounded.Payment,
        "/banking"             => Icons.Material.Rounded.AccountBalance,
        "/banking/upload"      => Icons.Material.Rounded.UploadFile,
        "/job-orders"          => Icons.Material.Rounded.Build,
