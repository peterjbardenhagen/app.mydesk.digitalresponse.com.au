@using MyDesk.Shared.Models
@inject IDialogService DialogService

<div class="tl-dashboard-carousel">
    <div class="tl-carousel-header">
        <div class="tl-carousel-title-section">
            <div class="tl-carousel-icon">
                <MudIcon Icon="@CurrentView.Icon" Size="Size.Medium" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Class="tl-carousel-title">@CurrentView.Title</MudText>
                <MudText Typo="Typo.body2" Class="tl-carousel-subtitle">@CurrentView.Subtitle</MudText>
            </div>
        </div>
        
        <div class="tl-carousel-controls">
            <div class="tl-carousel-nav-buttons">
                <MudButton OnClick="PreviousView" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary"
                           Size="Size.Small"
                           Class="tl-nav-btn">
                    <MudIcon Icon="@Icons.Material.Rounded.ChevronLeft" Size="Size.Small" />
                </MudButton>
                <MudButton OnClick="NextView" 
                           Variant="Variant.Filled" 
                           Color="Color.Primary"
                           Size="Size.Small"
                           Class="tl-nav-btn">
                    <MudIcon Icon="@Icons.Material.Rounded.ChevronRight" Size="Size.Small" />
                </MudButton>
            </div>
            
            <div class="tl-carousel-indicators">
                @for (int i = 0; i < Views.Count; i++)
                {
                    var index = i;
                    <button class="tl-carousel-dot @(i == CurrentIndex ? "active" : "")" 
                            @onclick="() => GoToView(index)"
                            title="@Views[index].Title"></button>
                }
            </div>
        </div>
    </div>

    <div class="tl-carousel-content">
        @switch (CurrentView.Id)
        {
            case "revenue-trends":
                @RevenueTrendsView
                break;
            case "profit-analysis":
                @ProfitAnalysisView
                break;
            case "conversion-funnel":
                @ConversionFunnelView
                break;
            case "team-leaderboard":
                @TeamLeaderboardView
                break;
            case "health-score":
                @HealthScoreView
                break;
            case "comparative":
                @ComparativeView
                break;
            case "customer-supplier-intel":
                @CustomerSupplierIntelligenceView
                break;
            case "targets":
                <TargetsView />
                break;
        }
    </div>
</div>

@code {
    [Parameter] public DashboardMetrics? Metrics { get; set; }
    [Parameter] public bool IsDirector { get; set; }
    [Parameter] public string? UserCode { get; set; }

    private int CurrentIndex { get; set; } = 0;

    private List<CarouselView> Views { get; set; } = new();
    private CustomerSupplierView _customerSupplierView = CustomerSupplierView.Customers;

    private CarouselView CurrentView => Views[CurrentIndex];

    protected override void OnInitialized()
    {
        Views = new List<CarouselView>
        {
            new()
            {
                Id = "targets",
                Title = "Performance Targets",
                Subtitle = "Monthly, quarterly & yearly targets — Company, Team & Individuals",
                Icon = Icons.Material.Rounded.TrackChanges,
                DirectorOnly = true
            },
            new()
            {
                Id = "customer-supplier-intel",
                Title = "Customer & Supplier Intelligence",
                Subtitle = "Best, worst, at-risk & growing customers and suppliers",
                Icon = Icons.Material.Rounded.Analytics,
                DirectorOnly = true
            },
            new()
            {
                Id = "revenue-trends",
                Title = "Revenue Trends",
                Subtitle = "Monthly performance across quotes, invoices & POs",
                Icon = Icons.Material.Rounded.TrendingUp
            },
            new()
            {
                Id = "profit-analysis",
                Title = "Profit Analysis",
                Subtitle = "Gross margins, average values & profitability",
                Icon = Icons.Material.Rounded.Analytics
            },
            new()
            {
                Id = "conversion-funnel",
                Title = "Conversion Funnel",
                Subtitle = "Quote to invoice pipeline & win rates",
                Icon = Icons.Material.Rounded.FilterAlt
            },
            new()
            {
                Id = "team-leaderboard",
                Title = "Team Leadership Board",
                Subtitle = "Individual & team performance rankings",
                Icon = Icons.Material.Rounded.EmojiEvents
            },
            new()
            {
                Id = "health-score",
                Title = "Business Health",
                Subtitle = "Overall score, warnings & recommendations",
                Icon = Icons.Material.Rounded.HealthAndSafety
            },
            new()
            {
                Id = "comparative",
                Title = "Comparative Analysis",
                Subtitle = "Year-over-year & month-over-month insights",
                Icon = Icons.Material.Rounded.CompareArrows
            }
        };

        // Filter views based on role — Directors/Admins get extra executive views
        if (!IsDirector)
        {
            Views = Views.Where(v => !v.DirectorOnly && v.Id != "team-leaderboard").ToList();
        }
    }

    private void NextView()
    {
        CurrentIndex = (CurrentIndex + 1) % Views.Count;
        StateHasChanged();
    }

    private void PreviousView()
    {
        CurrentIndex = (CurrentIndex - 1 + Views.Count) % Views.Count;
        StateHasChanged();
    }

    private void GoToView(int index)
    {
        CurrentIndex = index;
        StateHasChanged();
    }

    private class CarouselView
    {
        public string Id { get; set; } = "";
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public string Icon { get; set; } = "";
        public bool DirectorOnly { get; set; }
    }

    private enum CustomerSupplierView
    {
        Customers,
        Suppliers
    }

    private RenderFragment RevenueTrendsView => __builder => {
        if (Metrics != null) {
    <div class="tl-view-content">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-4" Elevation="0" Style="background: var(--gray-50); border-radius: 12px;">
                    <MudChart ChartType="ChartType.Line" 
                              ChartSeries="@GetRevenueSeries()" 
                              XAxisLabels="@GetMonthLabels()"
                              Width="100%" Height="300px"
                              ChartOptions="@RevenueChartOptions" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <div class="tl-kpi-mini-grid">
                    <div class="tl-kpi-mini-card teal">
                        <div class="tl-kpi-mini-value">@Fmt(Metrics.ThisMonthQuotesValue)</div>
                        <div class="tl-kpi-mini-label">Quotes (MTD)</div>
                        <div class="tl-kpi-mini-delta @GetDeltaClass(Metrics.ThisMonthVsLastMonthPercent)">
                            @Metrics.ThisMonthVsLastMonthPercent.ToString("+#;-#;0")% vs last month
                        </div>
                    </div>
                    <div class="tl-kpi-mini-card gold">
                        <div class="tl-kpi-mini-value">@Fmt(Metrics.ThisMonthInvoiceValue)</div>
                        <div class="tl-kpi-mini-label">Invoices (MTD)</div>
                        <div class="tl-kpi-mini-delta @GetDeltaClass(Metrics.ThisMonthVsLastYearPercent)">
                            @Metrics.ThisMonthVsLastYearPercent.ToString("+#;-#;0")% vs last year
                        </div>
                    </div>
                    <div class="tl-kpi-mini-card dark">
                        <div class="tl-kpi-mini-value">@Fmt(Metrics.ProjectedMonthlyRevenue)</div>
                        <div class="tl-kpi-mini-label">Projected (EO Month)</div>
                        <div class="tl-kpi-mini-delta neutral">
                            Based on pipeline
                        </div>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    </div>
        }
    };

    private RenderFragment ProfitAnalysisView => __builder => {
        if (Metrics != null) {
    <div class="tl-view-content">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="0" Style="background: var(--gray-50); border-radius: 12px;">
                    <div class="tl-profit-ring">
                        <div class="tl-profit-ring-inner">
                            <div class="tl-profit-value">@(Metrics.GrossProfitMargin == 0 && Metrics.ThisMonthQuotesValue == 0 ? "-.-%" : $"{Metrics.GrossProfitMargin:N1}%")</div>
                            <div class="tl-profit-label">Gross Profit Margin</div>
                        </div>
                        <svg class="tl-profit-svg" viewBox="0 0 100 100">
                            <circle class="tl-profit-track" cx="50" cy="50" r="45"/>
                            <circle class="tl-profit-progress" cx="50" cy="50" r="45" 
                                    style="stroke-dasharray: @GetCircleCircumference().ToString("F2"); 
                                           stroke-dashoffset: @GetCircleOffset(Metrics?.GrossProfitMargin ?? 0).ToString("F2")"/>
                        </svg>
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <div class="tl-profit-metrics">
                    <div class="tl-profit-metric">
                        <div class="tl-profit-metric-icon teal">
                            <MudIcon Icon="@Icons.Material.Rounded.RequestQuote" Size="Size.Small" />
                        </div>
                        <div class="tl-profit-metric-info">
                            <div class="tl-profit-metric-value">@Fmt(Metrics.AverageQuoteValue)</div>
                            <div class="tl-profit-metric-label">Average Quote Value</div>
                        </div>
                    </div>
                    <div class="tl-profit-metric">
                        <div class="tl-profit-metric-icon gold">
                            <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="Size.Small" />
                        </div>
                        <div class="tl-profit-metric-info">
                            <div class="tl-profit-metric-value">@Fmt(Metrics.AverageInvoiceValue)</div>
                            <div class="tl-profit-metric-label">Average Invoice Value</div>
                        </div>
                    </div>
                    <div class="tl-profit-metric">
                        <div class="tl-profit-metric-icon success">
                            <MudIcon Icon="@Icons.Material.Rounded.Percent" Size="Size.Small" />
                        </div>
                        <div class="tl-profit-metric-info">
                            <div class="tl-profit-metric-value">@Metrics.QuoteToInvoiceConversionRate.ToString("N1")%</div>
                            <div class="tl-profit-metric-label">Quote→Invoice Conversion</div>
                        </div>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
    </div>
        }
    };

    private RenderFragment ConversionFunnelView => __builder => {
        if (Metrics != null) {
    <div class="tl-view-content">
        <div class="tl-funnel-container">
            <div class="tl-funnel-stage">
                <div class="tl-funnel-bar" style="width: 100%; background: linear-gradient(90deg, var(--tl-primary-500), var(--tl-primary-400));">
                    <span class="tl-funnel-bar-label">Open Quotes</span>
                    <span class="tl-funnel-bar-value">@Metrics.OpenQuotesCount</span>
                </div>
                <div class="tl-funnel-connector"></div>
            </div>
            <div class="tl-funnel-stage">
                <div class="tl-funnel-bar" style="width: 85%; background: linear-gradient(90deg, var(--tl-primary-400), var(--tl-primary-300));">
                    <span class="tl-funnel-bar-label">Pending Approval</span>
                    <span class="tl-funnel-bar-value">@Metrics.PendingApprovalPOs</span>
                </div>
                <div class="tl-funnel-connector"></div>
            </div>
            <div class="tl-funnel-stage">
                <div class="tl-funnel-bar" style="width: 60%; background: linear-gradient(90deg, var(--tl-accent), var(--tl-accent-light));">
                    <span class="tl-funnel-bar-label">Quotes Won (MTD)</span>
                    <span class="tl-funnel-bar-value">@Metrics.ThisMonthQuotesWon</span>
                </div>
                <div class="tl-funnel-connector"></div>
            </div>
            <div class="tl-funnel-stage">
                <div class="tl-funnel-bar" style="width: 45%; background: linear-gradient(90deg, var(--success-500), var(--success-400));">
                    <span class="tl-funnel-bar-label">Invoices Closed (MTD)</span>
                    <span class="tl-funnel-bar-value">@Metrics.ThisMonthInvoices</span>
                </div>
            </div>
        </div>
        <div class="tl-funnel-pipeline">
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Rounded.AccountBalanceWallet" Size="Size.Small" />
                    <span>Pipeline Value: <strong>@Fmt(Metrics.PipelineValue)</strong> in open quotes</span>
                </div>
            </MudAlert>
        </div>
    </div>
        }
    };

    private RenderFragment TeamLeaderboardView => __builder => {
        if (Metrics?.TeamMemberKPIs != null && IsDirector) {
    <div class="tl-view-content">
        <MudTable Items="@Metrics.TeamMemberKPIs.OrderBy(k => k.Rank).Take(5)" Dense="true" Hover="true" Elevation="0">
            <HeaderContent>
                <MudTh>Rank</MudTh>
                <MudTh>Team Member</MudTh>
                <MudTh Style="text-align: right;">Quotes</MudTh>
                <MudTh Style="text-align: right;">Invoices</MudTh>
                <MudTh Style="text-align: right;">Revenue (MTD)</MudTh>
                <MudTh>Status</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @if (context.Rank <= 3)
                    {
                        <span class="tl-rank-badge tl-rank-@context.Rank">#@context.Rank</span>
                    }
                    else
                    {
                        <span class="tl-rank-badge">#@context.Rank</span>
                    }
                </MudTd>
                <MudTd>
                    <div class="d-flex align-center gap-2">
                        <MudAvatar Size="Size.Small" Color="Color.Primary">@GetInitials(context.UserName)</MudAvatar>
                        <span>@context.UserName</span>
                        @if (context.IsDirector)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">Director</MudChip>
                        }
                    </div>
                </MudTd>
                <MudTd Style="text-align: right;">@context.QuotesRaisedThisMonth</MudTd>
                <MudTd Style="text-align: right;">@context.InvoicesClosedThisMonth</MudTd>
                <MudTd Style="text-align: right;">@Fmt(context.InvoiceValueThisMonth)</MudTd>
                <MudTd>
                    <MudIcon Icon="@GetTrendIcon(context.PerformanceTrend)" 
                             Color="@GetTrendColor(context.PerformanceTrend)" 
                             Size="Size.Small" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>
        }
    };

    private RenderFragment HealthScoreView => __builder => {
        if (Metrics != null) {
    <div class="tl-view-content">
        <MudGrid Spacing="4">
            @* Health Score Gauge *@
            <MudItem xs="12" md="5">
                <div class="tl-health-hero @GetHealthScoreClass(Metrics.OverallHealthScore)">
                    <div class="tl-health-gauge-container">
                        <svg class="tl-health-gauge" viewBox="0 0 200 120">
                            @* Background arc *@
                            <path d="M 20 100 A 80 80 0 0 1 180 100" 
                                  fill="none" 
                                  stroke="rgba(255,255,255,0.2)" 
                                  stroke-width="12" 
                                  stroke-linecap="round"/>
                            @* Progress arc *@
                            <path d="M 20 100 A 80 80 0 0 1 180 100" 
                                  fill="none" 
                                  stroke="white" 
                                  stroke-width="12" 
                                  stroke-linecap="round"
                                  stroke-dasharray="251.2"
                                  stroke-dashoffset="@GetGaugeOffset(Metrics.OverallHealthScore)"
                                  class="tl-gauge-progress"/>
                        </svg>
                        <div class="tl-health-gauge-value">
                            <span class="tl-health-score-large">@Metrics.OverallHealthScore</span>
                            <span class="tl-health-score-max">/100</span>
                        </div>
                    </div>
                    <div class="tl-health-status-badge">
                        <MudIcon Icon="@GetHealthIcon(Metrics.OverallHealthScore)" Size="Size.Small" />
                        <span>@GetHealthStatus(Metrics.OverallHealthScore)</span>
                    </div>
                    <div class="tl-health-last-updated">Last updated: @DateTime.Now.ToString("MMM dd, h:mm tt")</div>
                </div>
            </MudItem>
            
            @* Health Breakdown *@
            <MudItem xs="12" md="7">
                <div class="tl-health-breakdown">
                    <MudText Typo="Typo.subtitle2" Class="tl-breakdown-title">Health Breakdown</MudText>
                    <div class="tl-health-metrics">
                        <div class="tl-health-metric">
                            <div class="tl-metric-icon @GetHealthMetricClass(Metrics.GrossProfitMargin, 20, 30)">
                                <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" Size="Size.Small" />
                            </div>
                            <div class="tl-metric-info">
                                <div class="tl-metric-label">Profit Margin</div>
                                <div class="tl-metric-bar-container">
                                    <div class="tl-metric-bar" style="width: @Math.Min(Metrics.GrossProfitMargin, 100)%"></div>
                                </div>
                                <div class="tl-metric-value">@Metrics.GrossProfitMargin.ToString("N1")%</div>
                            </div>
                        </div>
                        <div class="tl-health-metric">
                            <div class="tl-metric-icon @GetHealthMetricClass(Metrics.QuoteToInvoiceConversionRate, 30, 40)">
                                <MudIcon Icon="@Icons.Material.Rounded.SyncAlt" Size="Size.Small" />
                            </div>
                            <div class="tl-metric-info">
                                <div class="tl-metric-label">Conversion Rate</div>
                                <div class="tl-metric-bar-container">
                                    <div class="tl-metric-bar" style="width: @Math.Min(Metrics.QuoteToInvoiceConversionRate, 100)%"></div>
                                </div>
                                <div class="tl-metric-value">@Metrics.QuoteToInvoiceConversionRate.ToString("N1")%</div>
                            </div>
                        </div>
                        <div class="tl-health-metric">
                            <div class="tl-metric-icon @GetHealthMetricClass(100 - (Metrics.InvoicesOverdue * 2), 70, 90)">
                                <MudIcon Icon="@Icons.Material.Rounded.Schedule" Size="Size.Small" />
                            </div>
                            <div class="tl-metric-info">
                                <div class="tl-metric-label">Cash Flow Health</div>
                                <div class="tl-metric-bar-container">
                                    <div class="tl-metric-bar @GetCashFlowBarClass(Metrics.InvoicesOverdue)" style="width: @Math.Min(Math.Max(100 - (Metrics.InvoicesOverdue * 2), 0), 100)%"></div>
                                </div>
                                <div class="tl-metric-value">@Metrics.InvoicesOverdue overdue</div>
                            </div>
                        </div>
                    </div>
                </div>
            </MudItem>
        </MudGrid>
        
        @* Active Warnings & Recommendations *@
        <MudGrid Spacing="3" Class="mt-2">
            <MudItem xs="12" md="6">
                <div class="tl-health-section">
                    <div class="tl-section-header">
                        <MudIcon Icon="@Icons.Material.Rounded.WarningAmber" Size="Size.Small" Color="Color.Warning" />
                        <MudText Typo="Typo.subtitle2">Active Warnings</MudText>
                        @if (Metrics.Warnings?.Any() == true)
                        {
                            <MudBadge Content="@Metrics.Warnings.Count" Color="Color.Warning" Class="ml-2" />
                        }
                    </div>
                    @if (Metrics.Warnings?.Any() == true)
                    {
                        <div class="tl-warnings-modern">
                            @foreach (var warning in Metrics.Warnings.Take(3))
                            {
                                <div class="tl-warning-card @warning.Severity">
                                    <div class="tl-warning-severity-indicator @warning.Severity"></div>
                                    <div class="tl-warning-content">
                                        <div class="tl-warning-header">
                                            <MudIcon Icon="@(warning.Severity == "critical" ? Icons.Material.Rounded.Error : Icons.Material.Rounded.Warning)" 
                                                     Size="Size.Small" 
                                                     Color="@(warning.Severity == "critical" ? Color.Error : Color.Warning)" />
                                            <span class="tl-warning-title">@warning.Title</span>
                                        </div>
                                        <div class="tl-warning-desc">@warning.Description</div>
                                        <div class="tl-warning-meta">
                                            <span class="tl-warning-category">@warning.Category</span>
                                            <MudButton Href="@warning.ActionLink" 
                                                       Size="Size.Small" 
                                                       Variant="Variant.Text"
                                                       Color="Color.Primary"
                                                       EndIcon="@Icons.Material.Rounded.ArrowForward">View</MudButton>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="tl-no-warnings-modern">
                            <div class="tl-success-ring">
                                <MudIcon Icon="@Icons.Material.Rounded.Check" Color="Color.Success" Size="Size.Medium" />
                            </div>
                            <MudText Typo="Typo.body2" Class="mt-2">No active warnings</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">All business metrics are within healthy ranges</MudText>
                        </div>
                    }
                </div>
            </MudItem>
            
            <MudItem xs="12" md="6">
                <div class="tl-health-section">
                    <div class="tl-section-header">
                        <MudIcon Icon="@Icons.Material.Rounded.Lightbulb" Size="Size.Small" Color="Color.Info" />
                        <MudText Typo="Typo.subtitle2">Smart Recommendations</MudText>
                        @if (Metrics.Recommendations?.Any() == true)
                        {
                            <MudBadge Content="@Metrics.Recommendations.Count" Color="Color.Info" Class="ml-2" />
                        }
                    </div>
                    @if (Metrics.Recommendations?.Any() == true)
                    {
                        <div class="tl-recommendations-modern">
                            @foreach (var rec in Metrics.Recommendations.Take(4))
                            {
                                <div class="tl-recommendation-card">
                                    <div class="tl-rec-priority-indicator @rec.Priority"></div>
                                    <div class="tl-rec-content">
                                        <div class="tl-rec-header">
                                            <MudIcon Icon="@GetRecommendationIcon(rec.Category)" 
                                                     Size="Size.Small" 
                                                     Color="Color.Info" />
                                            <span class="tl-rec-title">@rec.Title</span>
                                        </div>
                                        <div class="tl-rec-desc">@rec.Description</div>
                                        <div class="tl-rec-impact">
                                            <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" Size="Size.Small" />
                                            <span>@rec.ExpectedImpact</span>
                                        </div>
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Rounded.ArrowForward" 
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   Href="@rec.ActionLink" />
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="tl-no-recommendations">
                            <MudText Typo="Typo.body2">No recommendations at this time</MudText>
                        </div>
                    }
                </div>
            </MudItem>
        </MudGrid>
    </div>
        }
    };

    private RenderFragment ComparativeView => __builder => {
        if (Metrics != null) {
    <div class="tl-view-content">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-3">This Year vs Last Year</MudText>
                <MudChart ChartType="ChartType.Bar" 
                          ChartSeries="@GetComparisonSeries()" 
                          XAxisLabels="@GetMonthLabels()"
                          Width="100%" Height="250px"
                          ChartOptions="@ComparisonChartOptions" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Target vs Actual</MudText>
                <div class="tl-target-comparison">
                    @for (int i = 0; i < 12; i++)
                    {
                        var target = Metrics.TargetMonthlyRevenue[i];
                        var actual = Metrics.MonthlyInvoicesThisYear[i];
                        var percent = target > 0 ? (actual / target * 100) : 0;
                        var month = new DateTime(DateTime.Now.Year, i + 1, 1).ToString("MMM");
                        <div class="tl-target-row">
                            <div class="tl-target-month">@month</div>
                            <div class="tl-target-bar-container">
                                <div class="tl-target-bar-bg"></div>
                                <div class="tl-target-bar-fill" style="width: @Math.Min(percent, 100)%"></div>
                            </div>
                            <div class="tl-target-percent @(percent >= 100 ? "success" : percent >= 80 ? "warning" : "error")">
                                @percent.ToString("N0")%
                            </div>
                        </div>
                    }
                </div>
            </MudItem>
        </MudGrid>
    </div>
        }
    };

    private RenderFragment CustomerSupplierIntelligenceView => __builder => {
        <div class="tl-view-content">
            <div class="tl-cs-tabs">
                <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary">
                    <MudButton @onclick="@(() => _customerSupplierView = CustomerSupplierView.Customers)" 
                               Variant="@(_customerSupplierView == CustomerSupplierView.Customers ? Variant.Filled : Variant.Outlined)">
                        <MudIcon Icon="@Icons.Material.Rounded.People" Size="Size.Small" Class="mr-2" />
                        Customers
                    </MudButton>
                    <MudButton @onclick="@(() => _customerSupplierView = CustomerSupplierView.Suppliers)" 
                               Variant="@(_customerSupplierView == CustomerSupplierView.Suppliers ? Variant.Filled : Variant.Outlined)">
                        <MudIcon Icon="@Icons.Material.Rounded.LocalShipping" Size="Size.Small" Class="mr-2" />
                        Suppliers
                    </MudButton>
                </MudButtonGroup>
            </div>

            @if (_customerSupplierView == CustomerSupplierView.Customers)
            {
                <MudGrid Spacing="3" Class="mt-4">
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: linear-gradient(135deg, var(--success-50) 0%, white 100%); border-radius: 12px; border: 1px solid var(--success-200);">
                            <div class="tl-cs-header success">
                                <MudIcon Icon="@Icons.Material.Rounded.TrendingUp" Size="Size.Medium" />
                                <div>
                                    <MudText Typo="Typo.h6">Best Customers</MudText>
                                    <MudText Typo="Typo.body2">Top 5 by revenue and margin</MudText>
                                </div>
                            </div>
                            <MudTable Items="@GetBestCustomers()" Dense="true" Hover="true" Elevation="0" Class="mt-3">
                                <HeaderContent>
                                    <MudTh>Customer</MudTh>
                                    <MudTh Style="text-align: right;">Revenue</MudTh>
                                    <MudTh Style="text-align: right;">Margin</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Name</MudTd>
                                    <MudTd Style="text-align: right;">@Fmt(context.Revenue)</MudTd>
                                    <MudTd Style="text-align: right;">@context.Margin.ToString("N1")%</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: linear-gradient(135deg, var(--error-50) 0%, white 100%); border-radius: 12px; border: 1px solid var(--error-200);">
                            <div class="tl-cs-header error">
                                <MudIcon Icon="@Icons.Material.Rounded.TrendingDown" Size="Size.Medium" />
                                <div>
                                    <MudText Typo="Typo.h6">At-Risk Customers</MudText>
                                    <MudText Typo="Typo.body2">Declining revenue or low activity</MudText>
                                </div>
                            </div>
                            <MudTable Items="@GetAtRiskCustomers()" Dense="true" Hover="true" Elevation="0" Class="mt-3">
                                <HeaderContent>
                                    <MudTh>Customer</MudTh>
                                    <MudTh Style="text-align: right;">Revenue</MudTh>
                                    <MudTh Style="text-align: right;">Trend</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Name</MudTd>
                                    <MudTd Style="text-align: right;">@Fmt(context.Revenue)</MudTd>
                                    <MudTd Style="text-align: right;">
                                        <MudIcon Icon="@GetTrendIcon(context.Trend)" 
                                                 Color="@GetTrendColor(context.Trend)" 
                                                 Size="Size.Small" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
            else
            {
                <MudGrid Spacing="3" Class="mt-4">
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: linear-gradient(135deg, var(--success-50) 0%, white 100%); border-radius: 12px; border: 1px solid var(--success-200);">
                            <div class="tl-cs-header success">
                                <MudIcon Icon="@Icons.Material.Rounded.LocalShipping" Size="Size.Medium" />
                                <div>
                                    <MudText Typo="Typo.h6">Best Suppliers</MudText>
                                    <MudText Typo="Typo.body2">Top 5 by volume and reliability</MudText>
                                </div>
                            </div>
                            <MudTable Items="@GetBestSuppliers()" Dense="true" Hover="true" Elevation="0" Class="mt-3">
                                <HeaderContent>
                                    <MudTh>Supplier</MudTh>
                                    <MudTh Style="text-align: right;">Volume</MudTh>
                                    <MudTh Style="text-align: right;">On-Time</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Name</MudTd>
                                    <MudTd Style="text-align: right;">@Fmt(context.Volume)</MudTd>
                                    <MudTd Style="text-align: right;">@context.OnTimeRate.ToString("N0")%</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-4" Elevation="0" Style="background: linear-gradient(135deg, var(--error-50) 0%, white 100%); border-radius: 12px; border: 1px solid var(--error-200);">
                            <div class="tl-cs-header error">
                                <MudIcon Icon="@Icons.Material.Rounded.Warning" Size="Size.Medium" />
                                <div>
                                    <MudText Typo="Typo.h6">Problem Suppliers</MudText>
                                    <MudText Typo="Typo.body2">Late deliveries or quality issues</MudText>
                                </div>
                            </div>
                            <MudTable Items="@GetProblemSuppliers()" Dense="true" Hover="true" Elevation="0" Class="mt-3">
                                <HeaderContent>
                                    <MudTh>Supplier</MudTh>
                                    <MudTh Style="text-align: right;">Issues</MudTh>
                                    <MudTh Style="text-align: right;">Status</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.Name</MudTd>
                                    <MudTd Style="text-align: right;">@context.IssueCount</MudTd>
                                    <MudTd Style="text-align: right;">
                                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)" Variant="Variant.Filled">@context.Status</MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    </MudItem>
                </MudGrid>
            }
        </div>
    };

    private class CustomerMetric
    {
        public string Name { get; set; } = "";
        public decimal Revenue { get; set; }
        public decimal Margin { get; set; }
        public string Trend { get; set; } = "";
    }

    private class SupplierMetric
    {
        public string Name { get; set; } = "";
        public decimal Volume { get; set; }
        public decimal OnTimeRate { get; set; }
        public int IssueCount { get; set; }
        public string Status { get; set; } = "";
    }

    private List<CustomerMetric> GetBestCustomers()
    {
        return new List<CustomerMetric>
        {
            new() { Name = "ABC Corp", Revenue = 125000, Margin = 32.5m, Trend = "up" },
            new() { Name = "XYZ Industries", Revenue = 98000, Margin = 28.3m, Trend = "up" },
            new() { Name = "Tech Solutions", Revenue = 87500, Margin = 35.1m, Trend = "up" },
            new() { Name = "Global Services", Revenue = 72000, Margin = 29.8m, Trend = "stable" },
            new() { Name = "Prime Contractors", Revenue = 65000, Margin = 31.2m, Trend = "up" }
        };
    }

    private List<CustomerMetric> GetAtRiskCustomers()
    {
        return new List<CustomerMetric>
        {
            new() { Name = "Delta Corp", Revenue = 45000, Margin = 18.5m, Trend = "down" },
            new() { Name = "Omega Systems", Revenue = 32000, Margin = 22.1m, Trend = "down" },
            new() { Name = "Beta Tech", Revenue = 28000, Margin = 19.8m, Trend = "down" },
            new() { Name = "Alpha Services", Revenue = 15000, Margin = 15.2m, Trend = "stable" }
        };
    }

    private List<SupplierMetric> GetBestSuppliers()
    {
        return new List<SupplierMetric>
        {
            new() { Name = "ElectroSupply Co", Volume = 185000, OnTimeRate = 98.5m, IssueCount = 0, Status = "Excellent" },
            new() { Name = "Lighting Pro", Volume = 142000, OnTimeRate = 96.2m, IssueCount = 1, Status = "Good" },
            new() { Name = "PowerParts Inc", Volume = 98000, OnTimeRate = 94.8m, IssueCount = 2, Status = "Good" },
            new() { Name = "TechComponents", Volume = 87000, OnTimeRate = 93.5m, IssueCount = 2, Status = "Good" },
            new() { Name = "Global Lighting", Volume = 65000, OnTimeRate = 92.1m, IssueCount = 3, Status = "Fair" }
        };
    }

    private List<SupplierMetric> GetProblemSuppliers()
    {
        return new List<SupplierMetric>
        {
            new() { Name = "QuickSupply", Volume = 32000, OnTimeRate = 78.5m, IssueCount = 8, Status = "Poor" },
            new() { Name = "BudgetParts", Volume = 28000, OnTimeRate = 82.1m, IssueCount = 6, Status = "Poor" },
            new() { Name = "ExpressDeliver", Volume = 22000, OnTimeRate = 85.3m, IssueCount = 5, Status = "Fair" }
        };
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Excellent" => Color.Success,
        "Good" => Color.Primary,
        "Fair" => Color.Warning,
        "Poor" => Color.Error,
        _ => Color.Default
    };
}

