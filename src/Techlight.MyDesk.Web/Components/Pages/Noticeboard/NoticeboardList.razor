@page "/noticeboard"
@attribute [Authorize]
@inject NoticeboardService Svc
@inject ISnackbar Snackbar

<PageTitle>Noticeboard - Techlight MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb"><a href="/">Techlight MyDesk</a><span class="sep">/</span><span style="color:var(--gray-700); font-weight:500;">Noticeboard</span></div>
        <h1>Noticeboard</h1>
        <p class="tl-subtitle">Company notices and announcements.</p>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="@(() => OpenEdit(new Notice()))">Post notice</MudButton>
</div>

@if (_items == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_items.Count == 0)
{
    <MudPaper Class="pa-10 text-center" Elevation="0">
        <MudIcon Icon="@Icons.Material.Rounded.Campaign" Color="Color.Default" Style="font-size:3rem; opacity:.3;" />
        <MudText Typo="Typo.h6" Class="mt-4" Style="color:var(--gray-500);">No notices posted yet.</MudText>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var n in _items)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="1" Style="@CardStyle(n)">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@n.Title</MudText>
                            <MudText Typo="Typo.caption" Style="color:var(--gray-500);">
                                @(n.DatePosted?.ToString("dd MMM yyyy") ?? "")
                                @if (n.PostedBy is { Length: > 0 })
                                {
                                    <text> · @n.PostedBy</text>
                                }
                                @if (n.ExpiryDate.HasValue)
                                {
                                    <text> · expires @n.ExpiryDate.Value.ToString("dd MMM yyyy")</text>
                                }
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEdit(n))" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => Delete(n))" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    @if (!string.IsNullOrWhiteSpace(n.Body))
                    {
                        <MudCardContent>
                            <MudText Typo="Typo.body2" Style="white-space:pre-line;">@n.Body</MudText>
                        </MudCardContent>
                    }
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@* Inline edit panel *@
@if (_editOpen && _editing != null)
{
    <MudPaper Class="pa-6 mt-4" Style="max-width:540px; border-left:4px solid var(--mud-palette-primary);" Elevation="2">
        <MudText Typo="Typo.h6" Class="mb-4" Style="font-weight:600;">
            @(_editing.NoticeboardId == 0 ? "Post Notice" : "Edit Notice")
        </MudText>
        <MudTextField @bind-Value="_editing.Title" Label="Title" Variant="Variant.Outlined" Required="true" Class="mb-3" />
        <MudTextField @bind-Value="_editing.Body" Label="Body" Variant="Variant.Outlined" Lines="5" Class="mb-3" />
        <MudDatePicker @bind-Date="_expiryDate" Label="Expiry date (optional)" Variant="Variant.Outlined" Class="mb-4" />
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Save"
                       OnClick="Save">Save</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="@(() => _editOpen = false)">Cancel</MudButton>
        </div>
    </MudPaper>
}

@code {
    private List<Notice>? _items;
    private bool _editOpen;
    private Notice? _editing;
    private DateTime? _expiryDate;

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Svc.GetAllAsync();

    private void OpenEdit(Notice n)
    {
        _editing = new Notice
        {
            NoticeboardId = n.NoticeboardId,
            Title = n.Title,
            Body = n.Body,
            PostedBy = n.PostedBy,
            ExpiryDate = n.ExpiryDate,
        };
        _expiryDate = n.ExpiryDate;
        _editOpen = true;
    }

    private async Task Save()
    {
        if (_editing == null) return;
        _editing.ExpiryDate = _expiryDate;
        try
        {
            await Svc.SaveAsync(_editing);
            Snackbar.Add(_editing.NoticeboardId == 0 ? "Notice posted." : "Notice updated.", Severity.Success);
            _editOpen = false;
            await Reload();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private async Task Delete(Notice n)
    {
        try
        {
            await Svc.DeleteAsync(n.NoticeboardId);
            Snackbar.Add("Notice deleted.", Severity.Info);
            await Reload();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private static string CardStyle(Notice n)
    {
        if (n.ExpiryDate.HasValue && n.ExpiryDate.Value < DateTime.Today)
            return "border-left:4px solid var(--mud-palette-error); opacity:.65;";
        return "border-left:4px solid var(--mud-palette-primary);";
    }
}
