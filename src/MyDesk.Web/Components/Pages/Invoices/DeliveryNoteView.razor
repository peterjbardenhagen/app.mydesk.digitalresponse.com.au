@page "/invoices/{Id:int}/delivery-note"
@attribute [Authorize]
@inject InvoiceService InvoiceService
@inject NavigationManager Nav
@inject PlatformSettingsService PlatformSettings

<PageTitle>Delivery Note @Id - MyDesk</PageTitle>

@if (_inv == null)
{
    <MudProgressCircular Indeterminate="true" Class="mx-auto my-8 d-block" />
}
else
{
    <div class="tl-page-header">
        <div>
            <div class="tl-breadcrumb">
                <a href="/">MyDesk</a><span class="sep">/</span>
                <a href="/invoices">Invoices</a><span class="sep">/</span>
                <a href="@($"/invoices/{Id}")">Invoice @_inv.InvoiceNum</a><span class="sep">/</span>
                <span>Delivery Note</span>
            </div>
            <h1>Delivery Note</h1>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.ArrowBack"
                       Href="@($"/invoices/{Id}")">Back</MudButton>
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.LocalShipping"
                       Href="@($"/invoices/{Id}/despatch")" Color="Color.Secondary">Enter Despatch</MudButton>
        </div>
    </div>

    @* Delivery note — no pricing *@
    <div style="max-width:800px;" class="mx-auto">
        <MudPaper Class="pa-8" Elevation="2">
            <div class="d-flex justify-space-between mb-6">
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">DELIVERY NOTE</MudText>
                    <MudText Typo="Typo.body2" Style="color:var(--gray-500);">Invoice Ref: @_inv.InvoiceNum</MudText>
                    <MudText Typo="Typo.body2" Style="color:var(--gray-500);">Date: @_inv.InvoiceDate.ToString("dd MMM yyyy")</MudText>
                </div>
                <div style="text-align:right;">
                    <MudText Typo="Typo.body1" Class="font-weight-bold">@PlatformSettings.Current.CompanyName</MudText>
                </div>
            </div>

            <MudGrid Spacing="4" Class="mb-6">
                <MudItem xs="6">
                    <MudText Typo="Typo.subtitle2" Class="mb-1" Style="color:var(--gray-500);text-transform:uppercase;">Deliver To</MudText>
                    <div style="white-space:pre-line;">@_inv.DelCompany<br/>@_inv.DelAddress</div>
                </MudItem>
                @if (!string.IsNullOrEmpty(_inv.Attention))
                {
                    <MudItem xs="6">
                        <MudText Typo="Typo.subtitle2" Class="mb-1" Style="color:var(--gray-500);text-transform:uppercase;">Attention</MudText>
                        <div>@_inv.Attention</div>
                    </MudItem>
                }
            </MudGrid>

            @* Items — no price column *@
            <table style="width:100%;border-collapse:collapse;font-size:.9rem;">
                <thead>
                    <tr style="background:#f5f5f5;">
                        <th style="text-align:left;padding:8px;">Description</th>
                        <th style="text-align:right;padding:8px;width:80px;">Qty</th>
                        <th style="text-align:right;padding:8px;width:80px;">Ordered</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var l in _lines)
                    {
                        <tr style="border-bottom:1px solid #eee;">
                            <td style="padding:8px;">
                                @if (!string.IsNullOrEmpty(l.ProductCode))
                                {
                                    <span style="color:var(--gray-400);font-size:.8rem;margin-right:6px;">@l.ProductCode</span>
                                }
                                @l.Description
                            </td>
                            <td style="text-align:right;padding:8px;">@l.Quantity.ToString("N0")</td>
                            <td style="text-align:right;padding:8px;"></td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!string.IsNullOrEmpty(_inv.CustomerNotes))
            {
                <div class="mt-6">
                    <MudText Typo="Typo.subtitle2" Style="color:var(--gray-500);text-transform:uppercase;">Notes</MudText>
                    <div style="white-space:pre-line;margin-top:4px;">@_inv.CustomerNotes</div>
                </div>
            }

            @if (_despatch != null)
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color:var(--gray-500);text-transform:uppercase;">Despatch Details</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="4"><span style="color:var(--gray-500);">Date:</span> @_despatch.DespatchDate.ToString("dd MMM yyyy")</MudItem>
                    <MudItem xs="4"><span style="color:var(--gray-500);">Carrier:</span> @(_despatch.Carrier ?? "—")</MudItem>
                    <MudItem xs="4"><span style="color:var(--gray-500);">Ref:</span> @(_despatch.CarrierRef ?? "—")</MudItem>
                    @if (!string.IsNullOrEmpty(_despatch.PackageDetails))
                    {
                        <MudItem xs="12"><span style="color:var(--gray-500);">Packages:</span> @_despatch.PackageDetails</MudItem>
                    }
                </MudGrid>
            }
        </MudPaper>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Invoice?              _inv;
    private List<InvoiceLineItem> _lines   = new();
    private DespatchDetail?       _despatch;

    protected override async Task OnInitializedAsync()
    {
        _inv      = await InvoiceService.GetInvoiceAsync(Id);
        _lines    = await InvoiceService.GetLineItemsAsync(Id);
        _despatch = await InvoiceService.GetDespatchAsync(Id);
    }
}

