@page "/admin/users/new"
@page "/admin/users/{UserId:int}/edit"
@attribute [Authorize]
@inject UserService UserSvc
@inject SystemService SystemSvc
@inject PermissionService PermSvc
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>@(IsNew ? "New User" : $"Edit {_model.Name}") - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/admin/setup">Admin</a>
            <span class="sep">/</span>
            <a href="/admin/users">Users</a>
            <span class="sep">/</span>
            <span style="color:var(--gray-700); font-weight:500;">@(IsNew ? "New" : "Edit")</span>
        </div>
        <h1>@(IsNew ? "Create user" : $"Edit user")</h1>
    </div>
    <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo("/admin/users"))">Cancel</MudButton>
</div>

<MudPaper Class="pa-6" Style="max-width: 640px;">
    <MudForm @ref="_form" Model="_model">
        <MudGrid Spacing="3">
            <MudItem xs="6">
                <MudTextField @bind-Value="_model.Code" Label="User code" Required="true" Variant="Variant.Outlined"
                              HelperText="Short code used for login (e.g. MD0229)" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="_model.Name" Label="Full name" Required="true" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" InputType="InputType.Email" />
            </MudItem>
            <MudItem xs="6">
                <MudSelect @bind-Value="_model.UserTypeId" Label="Role" Variant="Variant.Outlined">
                    @foreach (var t in _userTypes)
                    {
                        <MudSelectItem Value="t.UserTypeId">@t.TypeName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6">
                <MudSelect T="int?" @bind-Value="_model.DivisionId" Label="Division" Variant="Variant.Outlined" Clearable="true">
                    @foreach (var d in _divisions)
                    {
                        <MudSelectItem T="int?" Value="d.DivisionId">@d.DivisionName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_password" Label="@PasswordLabel" Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              HelperText="@(IsNew ? "Required for new users" : "Leave blank to keep existing password")"
                              Required="@IsNew" />
            </MudItem>
            <MudItem xs="12">
                <div class="d-flex tl-gap-sm justify-end">
                    @if (!IsNew)
                    {
                        <MudButton Color="Color.Error" Variant="Variant.Text" StartIcon="@Icons.Material.Rounded.Delete"
                                   OnClick="Delete">Delete</MudButton>
                    }
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Rounded.Save"
                               OnClick="Save">Save</MudButton>
                </div>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

@code {
    [Parameter] public int? UserId { get; set; }
    private bool IsNew => UserId is null or 0;
    private string PasswordLabel => IsNew ? "Password" : "New password";

    private MudForm _form = default!;
    private User _model = new();
    private string _password = "";
    private List<UserType> _userTypes = new();
    private List<Division> _divisions = new();
    private int _currentUserTypeId;

    protected override async Task OnParametersSetAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext?.User?.Identity?.IsAuthenticated == true)
        {
            var userTypeClaim = httpContext.User.FindFirst("UserTypeId")?.Value;
            if (int.TryParse(userTypeClaim, out var utid))
                _currentUserTypeId = utid;
        }

        _userTypes = await UserSvc.GetUserTypesAsync();
        
        // Directors cannot see Administrator role in dropdown
        if (_currentUserTypeId == 1)
        {
            _userTypes = _userTypes.Where(t => t.UserTypeId != 2).ToList();
        }
        
        _divisions = await SystemSvc.GetDivisionsAsync();

        if (!IsNew)
        {
            _model = await UserSvc.GetAsync(UserId!.Value) ?? new User();
            
            // Check if Director is trying to edit an Administrator
            if (_currentUserTypeId == 1 && _model.UserTypeId == 2)
            {
                Snackbar.Add("Directors cannot manage Administrator users", Severity.Error);
                Nav.NavigateTo("/admin/users");
                return;
            }
        }
    }

    private async Task Save()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        try
        {
            if (IsNew)
            {
                if (string.IsNullOrWhiteSpace(_password))
                {
                    Snackbar.Add("Password is required for new users", Severity.Warning);
                    return;
                }
                var id = await UserSvc.CreateAsync(_model, _password);
                Snackbar.Add($"Created user {_model.Code}", Severity.Success);
                Nav.NavigateTo($"/admin/users/{id}/edit");
            }
            else
            {
                await UserSvc.UpdateAsync(_model, string.IsNullOrWhiteSpace(_password) ? null : _password);
                Snackbar.Add($"Saved {_model.Name}", Severity.Success);
                Nav.NavigateTo("/admin/users");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task Delete()
    {
        try
        {
            await UserSvc.SoftDeleteAsync(_model.UserId);
            Snackbar.Add($"Deleted {_model.Name}", Severity.Success);
            Nav.NavigateTo("/admin/users");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }
}



