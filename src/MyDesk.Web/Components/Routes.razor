<MudThemeProvider Theme="_theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)">
                <NotAuthorized>
                    <RedirectToLogin />
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
        <NotFound>
            <RedirectToLogin />
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    // Techlight brand palette, tuned for an Untitled UI-inspired light theme.
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#00a8b0",             // tl-primary-600 (WCAG AA on white)
            PrimaryDarken = "#008b8b",
            PrimaryLighten = "#4ddddd",
            Secondary = "#cca05a",           // Techlight gold
            SecondaryDarken = "#b98745",
            SecondaryLighten = "#e0b870",
            Tertiary = "#6941c6",
            Info = "#2e90fa",
            Success = "#12b76a",
            Warning = "#f79009",
            Error = "#f04438",
            AppbarBackground = "#ffffff",
            AppbarText = "#101828",
            Background = "#f9fafb",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "#344054",
            DrawerIcon = "#667085",
            TextPrimary = "#101828",
            TextSecondary = "#475467",
            TextDisabled = "#98a2b3",
            ActionDefault = "#475467",
            ActionDisabled = "#d0d5dd",
            Divider = "#eaecf0",
            DividerLight = "#f2f4f7",
            TableLines = "#eaecf0",
            LinesDefault = "#eaecf0",
            LinesInputs = "#d0d5dd",
            GrayDefault = "#667085",
            GrayLight = "#98a2b3",
            GrayLighter = "#d0d5dd",
            OverlayLight = "rgba(16,24,40,0.5)",
        },
        Typography = new Typography
        {
            // Only override font family; finer sizing is handled in app.css
            Default = new Default
