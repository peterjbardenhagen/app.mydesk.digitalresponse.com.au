@page "/Error"
@layout EmptyLayout
@using System.Diagnostics
@inject PlatformSettingsService PlatformSettings

<PageTitle>Error - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="tl-error-root">
    <div class="tl-error-container">
        <div class="tl-error-card">
            <div class="tl-error-icon">
                <MudIcon Icon="@Icons.Material.Rounded.ErrorOutline" Size="Size.Large" />
            </div>
            
            <h1>Something went wrong</h1>
            <p class="tl-error-subtitle">We're sorry, but an unexpected error occurred. Our team has been notified.</p>
            
            @if (!string.IsNullOrEmpty(RequestId))
            {
                <div class="tl-error-details">
                    <MudText Typo="Typo.caption" Class="tl-request-id">
                        <MudIcon Icon="@Icons.Material.Rounded.Fingerprint" Size="Size.Small" />
                        Request ID: <code>@RequestId</code>
                    </MudText>
                </div>
            }

            <div class="tl-error-actions">
                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Class="rounded-xl">
                    <MudIcon Icon="@Icons.Material.Rounded.Home" Size="Size.Small" />
                    Return to Dashboard
                </MudButton>
                <MudButton Href="mailto:support@digitalresponse.com.au" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" Class="rounded-xl">
                    <MudIcon Icon="@Icons.Material.Rounded.Support" Size="Size.Small" />
                    Contact Support
                </MudButton>
            </div>
        </div>

        <div class="tl-error-footer">
            @if (isDevelopment)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Class="mt-6">
                    <MudText Typo="Typo.body2" Class="mb-2">
                        <strong>Development Mode Active</strong>
                    </MudText>
                    <MudText Typo="Typo.caption">
                        Detailed error information is being logged to the database. Check the Admin > Setup > Error Logs section for details.
                    </MudText>
                </MudAlert>
            }
            
            <div class="tl-help-tips">
                <MudText Typo="Typo.subtitle2" Class="mb-3">Helpful Tips</MudText>
                <ul>
                    <li>Try refreshing the page</li>
                    <li>Clear your browser cache and cookies</li>
                    <li>Check your internet connection</li>
                    <li>If the problem persists, contact support with the Request ID above</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .tl-error-root {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        padding: 40px 20px;
        font-family: 'Outfit', 'Inter', sans-serif;
    }

    body.mud-dark-mode .tl-error-root {
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    }

    .tl-error-container {
        max-width: 600px;
        width: 100%;
    }

    .tl-error-card {
        background: white;
        border-radius: 24px;
        padding: 48px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.02);
        text-align: center;
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    body.mud-dark-mode .tl-error-card {
        background: #1e293b;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.2);
    }

    .tl-error-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        color: #dc2626;
    }

    body.mud-dark-mode .tl-error-icon {
        background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);
    }

    .tl-error-card h1 {
        font-size: 32px;
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 12px;
    }

    body.mud-dark-mode .tl-error-card h1 {
        color: #f1f5f9;
    }

    .tl-error-subtitle {
        font-size: 16px;
        color: #64748b;
        margin-bottom: 24px;
    }

    body.mud-dark-mode .tl-error-subtitle {
        color: #94a3b8;
    }

    .tl-error-details {
        background: #f8fafc;
        border-radius: 12px;
        padding: 16px;
        margin: 24px 0;
    }

    body.mud-dark-mode .tl-error-details {
        background: #334155;
    }

    .tl-request-id {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: monospace;
    }

    .tl-request-id code {
        background: white;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
    }

    body.mud-dark-mode .tl-request-id code {
        background: #475569;
        color: #f1f5f9;
    }

    .tl-error-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        margin-top: 32px;
        flex-wrap: wrap;
    }

    .tl-error-footer {
        margin-top: 32px;
        text-align: center;
    }

    .tl-help-tips {
        background: white;
        border-radius: 16px;
        padding: 24px;
        margin-top: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    body.mud-dark-mode .tl-help-tips {
        background: #1e293b;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3);
    }

    .tl-help-tips ul {
        list-style: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }

    .tl-help-tips li {
        padding: 8px 0;
        color: #64748b;
        font-size: 14px;
        position: relative;
        padding-left: 24px;
    }

    body.mud-dark-mode .tl-help-tips li {
        color: #94a3b8;
    }

    .tl-help-tips li:before {
        content: '';
        position: absolute;
        left: 0;
        width: 6px;
        height: 6px;
        background: var(--mud-palette-primary);
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool isDevelopment => Environment.GetEnvironmentVariable("ASPNETCORE_ENVIRONMENT") == "Development";

    protected override void OnInitialized() =>
        RequestId = global::System.Diagnostics.Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
