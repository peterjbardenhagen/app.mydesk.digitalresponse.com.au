@page "/products"
@attribute [Authorize]
@inject ProductService Svc
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Products - Techlight MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb"><a href="/">Techlight MyDesk</a><span class="sep">/</span><span style="color:var(--gray-700); font-weight:500;">Products</span></div>
        <h1>Products</h1>
        <p class="tl-subtitle">Product catalog used in quotes, invoices and purchase orders.</p>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               Href="/products/new">Add product</MudButton>
</div>

@if (_items == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-0">
        <MudDataGrid T="Product" Items="_items" Dense="true" Hover="true" Elevation="0"
                     Filterable="true" QuickFilter="@(p => string.IsNullOrEmpty(_search) || p.ProductName.Contains(_search, StringComparison.OrdinalIgnoreCase))">
            <ToolBarContent>
                <MudTextField T="string" Placeholder="Search products..." @bind-Value="_search" Immediate="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Rounded.Search"
                              Variant="Variant.Outlined" Margin="Margin.Dense" />
            </ToolBarContent>
            <Columns>
                <PropertyColumn Property="x => x.ProductId" Title="#" CellStyle="width:80px;" />
                <PropertyColumn Property="x => x.ProductName" Title="Name" />
                <PropertyColumn Property="x => x.Description" Title="Description" />
                <PropertyColumn Property="x => x.UnitCost" Title="Cost" Format="C2" />
                <PropertyColumn Property="x => x.UnitPrice" Title="Price" Format="C2" />
                <TemplateColumn Title="Actions" CellStyle="width:120px;">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                       Href="@($"/products/{context.Item.ProductId}/edit")" title="Edit" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => Delete(context.Item))" title="Delete" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
            <PagerContent><MudDataGridPager T="Product" /></PagerContent>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<Product>? _items;
    private string _search = "";

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Svc.GetAllAsync();

    private async Task Delete(Product p)
    {
        try
        {
            await Svc.DeleteAsync(p.ProductId);
            Snackbar.Add($"Deleted {p.ProductName}", Severity.Success);
            await Reload();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }
}
