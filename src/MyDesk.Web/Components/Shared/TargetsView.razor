@using MyDesk.Shared.Models
@inject MyDesk.Shared.Services.IntelligenceService Intel

<style>
    .tl-view-content { padding: 24px; }
    .tl-section-title-row { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
    .tl-section-title { font-weight:700; }
    .tl-muted { color:var(--gray-500); }
    .tl-target-list { display:flex; flex-direction:column; }
    .tl-target-card {
        padding: 18px;
        border-radius: 16px;
        border: 1px solid var(--gray-200);
        min-height: 198px;
    }
    .tl-target-card.teal { background: linear-gradient(135deg, rgba(0,168,176,.10) 0%, #f3fbfc 100%); }
    .tl-target-card.gold { background: linear-gradient(135deg, rgba(245,158,11,.12) 0%, #fffaf0 100%); }
    .tl-target-card.dark { background: linear-gradient(135deg, #1f2937 0%, #0f172a 100%); color: white; border-color: #111827; }
    .tl-target-card-header, .tl-target-card-values, .tl-target-card-meta { display:flex; align-items:center; justify-content:space-between; gap:12px; }
    .tl-target-card-header { margin-bottom: 14px; }
    .tl-target-card-period { font-size: 11px; text-transform: uppercase; letter-spacing: .08em; font-weight: 700; color: var(--gray-500); }
    .tl-target-card.dark .tl-target-card-period { color: rgba(255,255,255,.72); }
    .tl-target-card-badge { padding: 4px 8px; border-radius: 999px; font-size: 11px; font-weight: 700; }
    .tl-target-card-badge.on-track { background: rgba(16,185,129,.12); color: #047857; }
    .tl-target-card-badge.at-risk { background: rgba(245,158,11,.14); color: #b45309; }
    .tl-target-card-badge.behind { background: rgba(239,68,68,.12); color: #b91c1c; }
    .tl-target-card-actual { font-size: 24px; font-weight: 800; line-height: 1.1; }
    .tl-target-card-target { color: var(--gray-500); font-size: 13px; }
    .tl-target-card.dark .tl-target-card-target { color: rgba(255,255,255,.72); }
    .tl-target-card-bar { margin: 16px 0 12px; }
    .tl-target-card-bar-track { position: relative; height: 8px; border-radius: 999px; background: rgba(148,163,184,.22); overflow: hidden; }
    .tl-target-card-bar-expected { position: absolute; inset: 0 auto 0 0; background: repeating-linear-gradient(135deg, rgba(15,23,42,.10), rgba(15,23,42,.10) 4px, rgba(15,23,42,0) 4px, rgba(15,23,42,0) 8px); }
    .tl-target-card-bar-actual { position: absolute; inset: 0 auto 0 0; border-radius: 999px; }
    .tl-target-card-bar-actual.on-track { background: linear-gradient(90deg, #16a34a, #22c55e); }
    .tl-target-card-bar-actual.at-risk { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .tl-target-card-bar-actual.behind { background: linear-gradient(90deg, #ef4444, #f87171); }
    .tl-target-card-meta { font-size: 12px; color: var(--gray-600); }
    .tl-target-card.dark .tl-target-card-meta { color: rgba(255,255,255,.75); }
    .tl-target-card-bar-labels { display:flex; justify-content:space-between; font-size:10px; color:var(--gray-400); margin-top:4px; }
    .tl-target-card.dark .tl-target-card-bar-labels { color:rgba(255,255,255,.55); }
    .tl-target-card-card { padding:14px; border-radius:12px; background:var(--gray-50); }
    .tl-target-card-card-title { font-size:11px; text-transform:uppercase; letter-spacing:.06em; font-weight:700; color:var(--gray-500); }
    .tl-target-card-card-value { font-size:16px; font-weight:800; margin-top:2px; }
    .tl-target-card-card-value.positive { color:#047857; }
    .tl-target-card-card-value.negative { color:#b91c1c; }
    body.mud-dark-mode .tl-target-card-card { background:var(--gray-100); }
    body.mud-dark-mode .tl-target-card-card-value.positive { color:#34d399; }
    body.mud-dark-mode .tl-target-card-card-value.negative { color:#f87171; }
    .tl-target-card.dark .tl-target-card-card { background:rgba(255,255,255,.06); }
    .tl-target-card.dark .tl-target-card-card-title { color:rgba(255,255,255,.55); }
    .tl-target-card.dark .tl-target-card-card-value { color:#fff; }
    .tl-targets-leaderboard { padding:18px; border-radius:16px; border:1px solid var(--gray-200); background:var(--gray-50); }
    .tl-targets-leaderboard .tl-target-row { display:flex; align-items:center; gap:12px; padding:8px 0; border-bottom:1px solid var(--gray-200); }
    .tl-targets-leaderboard .tl-target-row:last-child { border-bottom:none; }
    .tl-targets-leaderboard .tl-target-row-name { min-width:140px; font-weight:600; font-size:14px; }
    .tl-targets-leaderboard .tl-target-row-bar { flex:1; }
    .tl-target-row-values { display:flex; gap:8px; align-items:baseline; min-width:180px; justify-content:flex-end; }
    .tl-target-actual { font-weight:700; color:var(--gray-800); }
    .tl-target-target { color:var(--gray-500); font-size:13px; }
    .tl-target-pct { font-size:12px; font-weight:700; min-width:44px; text-align:right; }
    .tl-target-pct.on-track { color:#047857; }
    .tl-target-pct.at-risk { color:#b45309; }
    .tl-target-pct.behind { color:#b91c1c; }
    body.mud-dark-mode .tl-targets-leaderboard { background:var(--gray-100); border-color:var(--gray-300); }
    body.mud-dark-mode .tl-target-actual { color:var(--gray-100); }
    body.mud-dark-mode .tl-target-target { color:var(--gray-400); }
    body.mud-dark-mode .tl-target-pct.on-track { color:#34d399; }
    body.mud-dark-mode .tl-target-pct.at-risk { color:#fbbf24; }
    body.mud-dark-mode .tl-target-pct.behind { color:#fca5a5; }
    body.mud-dark-mode .tl-target-card-badge.at-risk { color:#fde68a; }
    body.mud-dark-mode .tl-target-card-badge.behind { color:#fca5a5; }
    body.mud-dark-mode .tl-target-rank { background: var(--gray-200); color: var(--gray-800); }
    body.mud-dark-mode .tl-target-bar-track, body.mud-dark-mode .tl-target-card-bar-track { background: var(--gray-200); }
    body.mud-dark-mode .tl-target-card-bar-expected { background: repeating-linear-gradient(135deg, rgba(229,229,229,.12), rgba(229,229,229,.12) 4px, rgba(229,229,229,0) 4px, rgba(229,229,229,0) 8px); }
    body.mud-dark-mode .tl-targets-leaderboard { background: var(--gray-100); border-color: var(--gray-300); }
    .tl-target-card-forecast { display:flex; align-items:center; gap:6px; font-size:12px; color:var(--gray-600); margin-top:10px; }
    .tl-target-card.dark .tl-target-card-forecast { color:rgba(255,255,255,.65); }
</style>

@if (_targets == null)
{
    <div class="tl-view-content">
        <MudProgressCircular Indeterminate="true" />
    </div>
}
else
{
    <div class="tl-view-content">
        <MudGrid Spacing="3">
            <MudItem xs="12" md="4">
                @RenderTargetCard("Monthly", _targets.CompanyMonthlyActual, _targets.CompanyMonthlyTarget,
                                  _targets.MonthlyProgress, _targets.ExpectedMonthlyProgress,
                                  _targets.MonthlyForecast,
                                  $"{_targets.DaysIntoMonth} of {_targets.DaysInMonth} days",
                                  "teal")
            </MudItem>
            <MudItem xs="12" md="4">
                @RenderTargetCard("Quarterly", _targets.CompanyQuarterlyActual, _targets.CompanyQuarterlyTarget,
                                  _targets.QuarterlyProgress, _targets.ExpectedQuarterlyProgress,
                                  _targets.QuarterlyForecast,
                                  $"{_targets.DaysIntoQuarter} of {_targets.DaysInQuarter} days",
                                  "gold")
            </MudItem>
            <MudItem xs="12" md="4">
                @RenderTargetCard("Yearly", _targets.CompanyYearlyActual, _targets.CompanyYearlyTarget,
                                  _targets.YearlyProgress, _targets.ExpectedYearlyProgress,
                                  _targets.YearlyForecast,
                                  $"{_targets.DaysIntoYear} of {_targets.DaysInYear} days",
                                  "dark")
            </MudItem>
        </MudGrid>

        @if (_leaderboard != null && _leaderboard.Members.Any())
        {
            <MudPaper Class="pa-4 mt-4" Elevation="0" Style="background:var(--gray-50); border-radius:12px;">
                <div class="tl-section-title-row">
                    <MudText Typo="Typo.subtitle1" Class="tl-section-title">
                        <MudIcon Icon="@Icons.Material.Rounded.Groups" Size="Size.Small" Class="mr-1" />
                        Sales Team Target Tracking
                    </MudText>
                    <MudText Typo="Typo.caption" Class="tl-muted">
                        @_leaderboard.MembersMeetingTarget of @_leaderboard.TotalMembers meeting monthly target
                    </MudText>
                </div>

                <div class="tl-target-list">
                    @foreach (var m in _leaderboard.Members.Take(10))
                    {
                        var pct = Math.Min((double)m.MonthlyProgress, 150);
                        var band = m.PerformanceBand;
                        <div class="tl-target-row">
                            <div class="tl-target-row-name">
                                <span class="tl-target-rank">#@m.Rank</span>
                                <span>@m.UserName</span>
                            </div>
                            <div class="tl-target-row-bar">
                                <div class="tl-target-bar-track">
                                    <div class="tl-target-bar-fill @band" style="width:@(pct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                                </div>
                            </div>
                            <div class="tl-target-row-values">
                                <span class="tl-target-actual">@Fmt(m.InvoiceValueThisMonth)</span>
                                <span class="tl-target-target">/ @Fmt(m.MonthlyTarget)</span>
                                <span class="tl-target-pct @band">@m.MonthlyProgress.ToString("0")%</span>
                            </div>
                        </div>
                    }
                </div>
            </MudPaper>
        }
    </div>
}

@code {
    private PerformanceTargets? _targets;
    private TeamLeaderboard?    _leaderboard;

    protected override async Task OnInitializedAsync()
    {
        _targets     = await Intel.GetPerformanceTargetsAsync();
        _leaderboard = await Intel.GetTeamLeaderboardAsync();
    }

    private RenderFragment RenderTargetCard(
        string period, decimal actual, decimal target,
        decimal actualPct, decimal expectedPct, decimal forecast,
        string periodLabel, string color) => __builder =>
    {
        var band = actualPct >= expectedPct ? "on-track"
                 : actualPct >= expectedPct * 0.9m ? "at-risk"
                 : "behind";

        <div class="tl-target-card @color">
            <div class="tl-target-card-header">
                <span class="tl-target-card-period">@period Target</span>
                <span class="tl-target-card-badge @band">@BandLabel(band)</span>
            </div>
            <div class="tl-target-card-values">
                <div class="tl-target-card-actual">@Fmt(actual)</div>
                <div class="tl-target-card-target">of @Fmt(target)</div>
            </div>
            <div class="tl-target-card-bar">
                <div class="tl-target-card-bar-track">
                    <div class="tl-target-card-bar-expected" style="width:@(((double)expectedPct).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                    <div class="tl-target-card-bar-actual @band" style="width:@(Math.Min((double)actualPct, 150).ToString("0.#", System.Globalization.CultureInfo.InvariantCulture))%"></div>
                </div>
            </div>
            <div class="tl-target-card-meta">
                <span>@periodLabel</span>
                <span class="tl-target-card-pct">@actualPct.ToString("0.#")%</span>
            </div>
            <div class="tl-target-card-forecast">
                <MudIcon Icon="@Icons.Material.Rounded.Insights" Size="Size.Small" />
                Forecast: <strong>@Fmt(forecast)</strong>
                (@((forecast >= target ? "+" : "") + ((target > 0 ? (forecast - target) / target * 100 : 0)).ToString("0.#"))%)
            </div>
        </div>
    };

    private static string BandLabel(string band) => band switch
    {
        "on-track" => "On Track",
        "at-risk"  => "At Risk",
        _          => "Behind"
    };

    private static string Fmt(decimal v) =>
        v >= 1_000_000 ? $"${v / 1_000_000:N2}M" :
        v >= 1_000 ? $"${v / 1_000:N1}K" : $"${v:N0}";
}
