@page "/quotes/create"
@page "/quotes/{Id:int}/edit"
@attribute [Authorize]
@inject QuoteService QuoteService
@inject LookupService LookupService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(IsNew ? "New" : "Edit") Quote - Techlight MyDesk</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4" Class="font-weight-bold">@(IsNew ? "New Quote" : $"Edit Quote #{_quote.Qid}")</MudText>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.ArrowBack"
               OnClick="@(() => Nav.NavigateTo(IsNew ? "/quotes" : $"/quotes/{Id}"))">Cancel</MudButton>
</div>

<MudPaper Elevation="2" Class="pa-6">
    <MudForm @ref="_form" Model="_quote" @bind-IsValid="_isValid">
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_quote.Reference" Label="Reference" Variant="Variant.Outlined" Required="true" RequiredError="Reference is required" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" @bind-Value="_quote.ContactId" Label="Contact" Variant="Variant.Outlined" Required="true">
                    @foreach (var contact in _contacts)
                    {
                        <MudSelectItem T="int" Value="@contact.ContactId">@contact.CompanyName - @contact.FullName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" @bind-Value="_quote.DivisionId" Label="Division" Variant="Variant.Outlined">
                    @foreach (var div in _divisions)
                    {
                        <MudSelectItem T="int" Value="@div.DivisionId">@div.DivisionName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="int" @bind-Value="_quote.QuoteStatusId" Label="Status" Variant="Variant.Outlined">
                    @foreach (var s in _statuses)
                    {
                        <MudSelectItem T="int" Value="@s.QuoteStatusId">@s.StatusName</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_quote.UnitCostTotal" Label="Unit Cost Total" Format="N2" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_quote.NettPriceTotal" Label="Net Price Total" Format="N2" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_quote.Margin" Label="Margin %" Format="N2" Variant="Variant.Outlined" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_quote.CustomerNotes" Label="Customer Notes" Variant="Variant.Outlined" Lines="3" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_quote.InternalNotes" Label="Internal Notes" Variant="Variant.Outlined" Lines="3" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_quote.Terms" Label="Terms" Variant="Variant.Outlined" Lines="2" />
            </MudItem>
        </MudGrid>

        <div class="d-flex justify-end gap-2 mt-4">
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo(IsNew ? "/quotes" : $"/quotes/{Id}"))">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync" Disabled="@_saving" StartIcon="@Icons.Material.Filled.Save">
                @(_saving ? "Saving..." : "Save")
            </MudButton>
        </div>
    </MudForm>
</MudPaper>

@code {
    [Parameter] public int? Id { get; set; }

    private bool IsNew => !Id.HasValue || Id == 0;

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;

    private Quote _quote = new() { QuoteDate = DateTime.Today, QuoteStatusId = 1 };
    private List<Contact> _contacts = new();
    private List<Division> _divisions = new();
    private List<QuoteStatus> _statuses = new();

    protected override async Task OnInitializedAsync()
    {
        _contacts = await LookupService.GetContactLookupsAsync();
        _divisions = await LookupService.GetDivisionsAsync();
        _statuses = await LookupService.GetQuoteStatusesAsync();

        if (!IsNew)
        {
            var existing = await QuoteService.GetQuoteAsync(Id!.Value);
            if (existing != null) _quote = existing;
        }
    }

    private async Task SaveAsync()
    {
        await _form.Validate();
        if (!_isValid) return;

        _saving = true;
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var code = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";

            if (IsNew)
            {
                var newId = await QuoteService.CreateQuoteAsync(_quote, code);
                Snackbar.Add($"Quote #{newId} created successfully", Severity.Success);
                Nav.NavigateTo($"/quotes/{newId}");
            }
            else
            {
                await QuoteService.UpdateQuoteAsync(_quote);
                Snackbar.Add("Quote updated successfully", Severity.Success);
                Nav.NavigateTo($"/quotes/{_quote.Qid}");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving quote: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
