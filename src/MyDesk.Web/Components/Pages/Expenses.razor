@page "/expenses"
@attribute [Authorize]
@using MyDesk.Shared.Models
@using MyDesk.Shared.Services
@using MyDesk.Web.Services
@using MudBlazor
@inject ExpenseService ExpenseService
@inject UserService UserService
@inject CompanyService CompanyService
@inject DocumentExtractionService ExtractionService
@inject WorkflowApprovalService ApprovalSvc
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@inject IDialogService DialogService

<PageTitle>Expense Claims - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb"><a href="/">MyDesk</a><span class="sep">/</span><span>Expense Claims</span></div>
        <h1>Expense Claims</h1>
        <p class="tl-subtitle">Submit and manage expense claims for approval and reimbursement.</p>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="NewClaim" Class="ml-auto mr-0">
        New Claim
    </MudButton>
</div>

@* Stats strip *@
<MudGrid Class="mb-4">
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5">@_allClaims.Count</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Total Claims</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Warning">@_allClaims.Count(c => c.Status == "Submitted")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Awaiting Approval</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Success">@_allClaims.Count(c => c.Status == "Approved")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Approved</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Class="pa-3 text-center" Elevation="1">
            <MudText Typo="Typo.h5" Color="Color.Primary">@_allClaims.Where(c => c.Status == "Approved" || c.Status == "Finalised").Sum(c => c.TotalAmount).ToString("C")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Default">Total Approved</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@* Status tabs *@
<MudTabs @bind-ActivePanelIndex="_tabIndex" Rounded="true" Border="true" PanelClass="pa-0">
    <MudTabPanel Text="All" />
    <MudTabPanel Text="Draft" />
    <MudTabPanel Text="Submitted" />
    <MudTabPanel Text="Approved" />
    <MudTabPanel Text="Rejected" />
    <MudTabPanel Text="Finalised" />
</MudTabs>

<MudPaper Elevation="1" Class="mt-2">
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
    }
    else if (!_filteredClaims.Any())
    {
        <div class="tl-empty-state pa-8">
            <MudIcon Icon="@Icons.Material.Rounded.ReceiptLong" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.h6" Class="mt-4">No @(_currentStatusFilter ?? "") claims</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default" Class="mt-2">
                @if (_tabIndex == 0) { <span>Click <strong>New Claim</strong> to create your first expense claim.</span> }
                else { <span>No claims with status "@_currentStatusFilter".</span> }
            </MudText>
        </div>
    }
    else
    {
        <MudDataGrid T="Expense" Items="_expenses" Dense="true" Hover="true" Bordered="false" Striped="true"
                     Filterable="true" QuickFilter="@QuickFilter" Class="tl-data-grid">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Expense Records</MudText>
            <MudSpacer />
            <MudTextField @bind-Value="_searchString" Placeholder="Search description, supplier, category..."
                          Adornment="Adornment.Start" Immediate="true"
                          AdornmentIcon="@Icons.Material.Rounded.Search" IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.Date" Title="Date" Format="dd MMM yyyy" />
            <PropertyColumn Property="x => x.SupplierName" Title="Supplier" />
            <PropertyColumn Property="x => x.Description" Title="Description" />
            <PropertyColumn Property="x => x.Category" Title="Category" />
            <PropertyColumn Property="x => x.Total" Title="Total" Format="C" />
            <TemplateColumn Title="Status" CellStyle="width:120px;">
                <CellTemplate>
                    <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Item.Status)" Variant="Variant.Text">
                        @context.Item.Status
                    </MudChip>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn Title="Receipt" CellStyle="width:80px;">
                <CellTemplate>
                    @if (!string.IsNullOrEmpty(context.Item.FilePath))
                    {
                        <MudIconButton Icon="@Icons.Material.Rounded.PictureAsPdf" Color="Color.Error" Size="Size.Small"
                                       Href="@(context.Item.FilePath)" Target="_blank" />
                    }
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn CellStyle="width:150px;" Sortable="false">
                <CellTemplate>
                    <div class="d-flex gap-1">
                        <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" OnClick="@(() => OnEditExpense(context.Item))" Title="Edit" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Send" Size="Size.Small" Color="Color.Info" OnClick="@(() => OnSubmitForApprovalAsync(context.Item))" Title="Submit for Approval" />
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => OnDeleteExpense(context.Item))" Title="Delete" />
                    </div>
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <PagerContent>
            <MudDataGridPager T="Expense" />
        </PagerContent>
        </MudDataGrid>
    }
</MudPaper>

@code {
    private List<ExpenseClaim> _allClaims = new();
    private bool _loading = true;
    private int _tabIndex = 0;
    private bool _isManagerOrAccounts = false;
    private string? _currentUserName;

    private static readonly string?[] TabStatuses = { null, "Draft", "Submitted", "Approved", "Rejected", "Finalised" };

    private string? _currentStatusFilter => TabStatuses[_tabIndex];

    private List<ExpenseClaim> _filteredClaims => _currentStatusFilter == null
        ? _allClaims
        : _allClaims.Where(c => c.Status == _currentStatusFilter).ToList();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserName = auth.User.Identity?.Name ?? auth.User.FindFirst("name")?.Value;
        _isManagerOrAccounts =
            auth.User.IsInRole("Director") ||
            auth.User.IsInRole("Administrator") ||
            auth.User.IsInRole("Accounts") ||
            auth.User.FindFirst("IsAdmin")?.Value == "True" ||
            auth.User.FindFirst("IsAccounts")?.Value == "True";

        await LoadClaimsAsync();
    }

    private async Task LoadClaimsAsync()
    {
        _loading = true;
        try
        {
            // Managers/Accounts see all claims; regular users see only their own.
            _allClaims = _isManagerOrAccounts
                ? await ExpenseService.GetClaimsAsync()
                : await ExpenseService.GetClaimsAsync(submittedBy: _currentUserName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading claims: {ex.Message}", Severity.Error);
        }
        finally { _loading = false; }
    }

    private async Task NewClaim()
    {
        var claim = new ExpenseClaim
        {
            SubmittedBy = _currentUserName ?? "",
            ClaimPeriod = DateTime.Today.ToString("MMMM yyyy"),
        };
        try
        {
            var id = await ExpenseService.SaveClaimAsync(claim);
            Nav.NavigateTo($"/expenses/claim/{id}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating claim: {ex.Message}", Severity.Error);
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "Approved"  => Color.Success,
        "Submitted" => Color.Warning,
        "Rejected"  => Color.Error,
        "Finalised" => Color.Info,
        "Draft"     => Color.Default,
        _           => Color.Default
    };

    private async Task OnSubmitForApprovalAsync(Expense expense)
    {
        var parameters = new DialogParameters<Shared.SubmitForApprovalDialog>
        {
            { x => x.ModuleType, "Expense" },
            { x => x.ModuleId, expense.ExpenseId }
        };

        var dialog = await DialogService.ShowAsync<Shared.SubmitForApprovalDialog>(
            "Submit Expense for Approval",
            parameters,
            new DialogOptions { CloseButton = true, CloseOnEscapeKey = true, BackdropClick = true, MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await LoadClaimsAsync();
        }
    }
}
