@page "/admin/user-roles"
@attribute [Authorize]
@inject SystemService Svc
@inject ISnackbar Snackbar

<PageTitle>User Roles - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/admin/setup">Admin</a><span class="sep">/</span>
            <span style="color:var(--gray-700);font-weight:500;">User Roles</span>
        </div>
        <h1>User Roles</h1>
        <p class="tl-subtitle">Manage user role definitions.</p>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
               OnClick="AddNew">Add Role</MudButton>
</div>

@if (_items == null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudPaper Class="pa-0" Style="max-width:540px;">
        <MudDataGrid T="UserRole" Items="_items" Dense="true" Hover="true" Elevation="0">
            <Columns>
                <PropertyColumn Property="x => x.UserRoleId" Title="#" CellStyle="width:70px;" />
                <TemplateColumn Title="Role Name">
                    <CellTemplate>
                        @if (_editingId == context.Item.UserRoleId)
                        {
                            <MudTextField @bind-Value="_editingName" Immediate="true" Margin="Margin.Dense"
                                          Variant="Variant.Outlined" AutoFocus="true" />
                        }
                        else { @context.Item.RoleName }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Actions" CellStyle="width:120px;">
                    <CellTemplate>
                        @if (_editingId == context.Item.UserRoleId)
                        {
                            <MudIconButton Icon="@Icons.Material.Rounded.Check" Color="Color.Success" Size="Size.Small"
                                           OnClick="@(() => Save(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Close" Size="Size.Small" OnClick="Cancel" />
                        }
                        else
                        {
                            <MudIconButton Icon="@Icons.Material.Rounded.Edit" Size="Size.Small" Color="Color.Primary"
                                           OnClick="@(() => BeginEdit(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => Delete(context.Item))" />
                        }
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </MudPaper>
}

@code {
    private List<UserRole>? _items;
    private int? _editingId;
    private string _editingName = "";

    protected override async Task OnInitializedAsync() => await Reload();
    private async Task Reload() => _items = await Svc.GetUserRolesAsync();

    private void BeginEdit(UserRole r) { _editingId = r.UserRoleId; _editingName = r.RoleName; }
    private void Cancel() { _editingId = null; _editingName = ""; }

    private async Task Save(UserRole r)
    {
        try
        {
            r.RoleName = _editingName;
            await Svc.SaveUserRoleAsync(r);
            Snackbar.Add("Saved", Severity.Success);
            Cancel(); await Reload();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private async Task AddNew()
    {
        try
        {
            await Svc.SaveUserRoleAsync(new UserRole { RoleName = "New Role" });
            await Reload();
            var newest = _items!.OrderByDescending(x => x.UserRoleId).First();
            BeginEdit(newest);
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }

    private async Task Delete(UserRole r)
    {
        try
        {
            await Svc.DeleteUserRoleAsync(r.UserRoleId);
            Snackbar.Add("Deleted", Severity.Info);
            await Reload();
        }
        catch (Exception ex) { Snackbar.Add($"Failed: {ex.Message}", Severity.Error); }
    }
}

