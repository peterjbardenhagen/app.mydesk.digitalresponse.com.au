    {
        ChartPalette = new[] { "#00a8b0", "#94a3b8" },
        YAxisLines = true,
        XAxisLines = false,
        YAxisFormat = "$#,##0",
    };

    private List<ChartSeries> GetRevenueSeries()
    {
        if (Metrics == null) return new();
        return new List<ChartSeries>
        {
            new() { Name = "Quotes", Data = Metrics.MonthlyQuotesThisYear.Select(v => (double)v).ToArray() },
            new() { Name = "Invoices", Data = Metrics.MonthlyInvoicesThisYear.Select(v => (double)v).ToArray() },
            new() { Name = "POs", Data = Metrics.MonthlyPOsThisYear.Select(v => (double)v).ToArray() },
        };
    }

    private List<ChartSeries> GetComparisonSeries()
    {
        if (Metrics == null) return new();
        return new List<ChartSeries>
        {
            new() { Name = "This Year", Data = Metrics.MonthlyInvoicesThisYear.Select(v => (double)v).ToArray() },
            new() { Name = "Last Year", Data = Metrics.LastYearMonthlyRevenue.Select(v => (double)v).ToArray() },
        };
    }

    private string[] GetMonthLabels()
    {
        return new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec" };
    }

    private static string Fmt(decimal v) => "$" + v.ToString("#,##0");

    private string GetDeltaClass(decimal percent) => percent >= 0 ? "positive" : "negative";

    private double GetCircleCircumference() => 2.0 * Math.PI * 45.0;

    private double GetCircleOffset(decimal grossProfitMargin)
    {
        var circumference = GetCircleCircumference();
        var marginDouble = (double)grossProfitMargin;
        return circumference * (1.0 - marginDouble / 100.0);
    }

    private string GetInitials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return string.Concat(parts.Take(2).Select(p => p[0])).ToUpper();
    }

    private string GetTrendIcon(string trend) => trend switch
    {
        "up" => Icons.Material.Rounded.TrendingUp,
        "down" => Icons.Material.Rounded.TrendingDown,
        _ => Icons.Material.Rounded.TrendingFlat
    };

    private Color GetTrendColor(string trend) => trend switch
    {
        "up" => Color.Success,
        "down" => Color.Error,
        _ => Color.Default
    };

    private string GetHealthScoreClass(int score) => score switch
    {
        >= 90 => "excellent",
        >= 70 => "good",
        >= 50 => "warning",
        _ => "critical"
    };

    private string GetHealthStatus(int score) => score switch
    {
        >= 90 => "Excellent",
        >= 70 => "Good",
        >= 50 => "Needs Attention",
        _ => "Critical"
    };

    private string GetHealthIcon(int score) => score switch
    {
        >= 90 => Icons.Material.Rounded.CheckCircle,
        >= 70 => Icons.Material.Rounded.ThumbUp,
        >= 50 => Icons.Material.Rounded.NotificationImportant,
        _ => Icons.Material.Rounded.Warning
    };

    private double GetGaugeOffset(int score)
    {
        // Arc circumference is ~251.2 (π * 80)
        var maxOffset = 251.2;
        return maxOffset * (1.0 - score / 100.0);
    }

    private string GetHealthMetricClass(decimal value, decimal warningThreshold, decimal successThreshold)
    {
        if (value >= successThreshold) return "success";
        if (value >= warningThreshold) return "primary";
        if (value >= warningThreshold * 0.5m) return "warning";
        return "error";
    }

    private string GetCashFlowBarClass(int overdueCount)
    {
        if (overdueCount == 0) return "";
        if (overdueCount <= 5) return "warning";
        return "error";
    }

    private string GetRecommendationIcon(string category) => category.ToLower() switch
    {
        "sales" => Icons.Material.Rounded.TrendingUp,
        "revenue" => Icons.Material.Rounded.AttachMoney,
        "operations" => Icons.Material.Rounded.Settings,
        "cash flow" => Icons.Material.Rounded.AccountBalance,
        "profitability" => Icons.Material.Rounded.ShowChart,
        _ => Icons.Material.Rounded.Lightbulb
    };
