@page "/project-management/{ProjectId:int}"
@attribute [Authorize]
@using MyDesk.Shared.Models
@using MyDesk.Shared.Services
@using System.Security.Claims
@inject ProjectService ProjectSvc
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>@(_project?.Name ?? "Project") — Project Management</PageTitle>

@if (_loading)
{
    <div class="d-flex justify-center pa-12"><MudProgressCircular Indeterminate="true" Size="Size.Large" Color="Color.Primary" /></div>
}
else if (_project is null)
{
    <MudAlert Severity="Severity.Error">Project not found.</MudAlert>
}
else
{
    <!-- Header -->
    <div class="tl-page-header">
        <div>
            <div class="tl-breadcrumb">
                <a href="/">Dashboard</a><span class="sep">/</span>
                <a href="/project-management">Projects</a><span class="sep">/</span>
                <span>@_project.Name</span>
            </div>
            <h1 class="d-flex align-center gap-2">
                @_project.Name
                @if (!string.IsNullOrWhiteSpace(_project.ProjectCode))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@_project.ProjectCode</MudChip>
                }
                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_project.Status)">@_project.Status</MudChip>
            </h1>
            <p class="tl-subtitle">@_project.CommercialModel · @_project.OwnerName</p>
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.Edit" OnClick="EditProject">Edit</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add" OnClick="() => _addTaskOpen = true">Add Task</MudButton>
        </div>
    </div>

    <!-- Health Summary Bar -->
    @if (_health is not null)
    {
        <MudGrid Class="mb-3" Spacing="2">
            <MudItem xs="6" sm="3">
                <MudPaper Outlined="true" Class="pa-3 text-center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">% Complete</MudText>
                    <MudProgressLinear Value="@_health.PercentComplete" Color="@HealthColor(_health.ScheduleHealth)" Class="my-1" />
                    <MudText Typo="Typo.h6">@_health.PercentComplete%</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Outlined="true" Class="pa-3 text-center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Budget</MudText>
                    <MudText Typo="Typo.h6" Color="@HealthColor(_health.BudgetHealth)">@_health.ActualCost.ToString("C0")</MudText>
                    <MudText Typo="Typo.caption">of @_health.BudgetAmount.ToString("C0")</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Outlined="true" Class="pa-3 text-center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Predicted End</MudText>
                    <MudText Typo="Typo.h6" Color="@HealthColor(_health.ScheduleHealth)">
                        @(_health.PredictedEndDate?.ToString("dd MMM yy") ?? "—")
                    </MudText>
                    @if (_health.DaysVariance.HasValue)
                    {
                        <MudText Typo="Typo.caption" Color="@(_health.DaysVariance > 0 ? Color.Error : Color.Success)">
                            @(Math.Abs(_health.DaysVariance.Value)) days @(_health.DaysVariance > 0 ? "late" : "early")
                        </MudText>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudPaper Outlined="true" Class="pa-3 text-center">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Open Risks / Issues</MudText>
                    <MudText Typo="Typo.h6" Color="@(_health.OpenRisks + _health.OpenIssues > 0 ? Color.Warning : Color.Success)">
                        @_health.OpenRisks R · @_health.OpenIssues I
                    </MudText>
                    @if (_health.PendingChangeRequests > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning">@_health.PendingChangeRequests CR pending</MudText>
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    <!-- Main Tabs -->
    <MudTabs Elevation="0" Rounded="true" PanelClass="pt-3" Color="Color.Primary" Outlined="true" @bind-ActivePanelIndex="_activeTab">

        <!-- ── OVERVIEW ── -->
        <MudTabPanel Text="Overview" Icon="@Icons.Material.Rounded.Dashboard">
            <MudGrid Spacing="3">
                <!-- Members -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Project Members</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIconButton Icon="@Icons.Material.Rounded.PersonAdd" Size="Size.Small" OnClick="() => _addMemberOpen = true" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent Class="pa-0">
                            <MudList T="ProjectMember" Dense="true">
                                @foreach (var m in _members)
                                {
                                    <MudListItem T="ProjectMember">
                                        <div class="d-flex align-center gap-2">
                                            <MudAvatar Size="Size.Small" Color="@RoleColor(m.Role)">@m.Name[0]</MudAvatar>
                                            <div style="flex:1">
                                                <MudText Typo="Typo.body2">@m.Name</MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@m.Role @(m.PortalAccess ? "· Portal" : "")</MudText>
                                            </div>
                                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                                           OnClick="() => RemoveMember(m.MemberId)" />
                                        </div>
                                    </MudListItem>
                                }
                                @if (!_members.Any())
                                {
                                    <MudListItem T="string"><MudText Typo="Typo.caption" Color="Color.Secondary">No members added yet.</MudText></MudListItem>
                                }
                            </MudList>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Milestones -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.subtitle1">Milestones @(_project.CommercialModel == "FixedPrice" ? "/ UAT" : "")</MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudIconButton Icon="@Icons.Material.Rounded.Add" Size="Size.Small" OnClick="() => _addMilestoneOpen = true" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        <MudCardContent Class="pa-0">
                            @foreach (var ms in _milestones.OrderBy(m => m.DueDate))
                            {
                                <div class="pa-3 d-flex align-center gap-2" style="border-bottom:1px solid var(--mud-palette-divider)">
                                    <MudIcon Icon="@(ms.Status == "Complete" ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.RadioButtonUnchecked)"
                                             Color="@(ms.Status == "Complete" ? Color.Success : ms.DueDate < DateTime.Today ? Color.Error : Color.Default)"
                                             Size="Size.Small" />
                                    <div style="flex:1">
                                        <MudText Typo="Typo.body2">@ms.Title @(ms.IsUAT ? "(UAT)" : "")</MudText>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Due @ms.DueDate.ToString("dd MMM yyyy")
                                            @if (ms.SignOffRequired && ms.SignOffDate.HasValue)
                                            {
                                                <text> · Signed off @ms.SignOffDate.Value.ToString("dd MMM")</text>
                                            }
                                            else if (ms.SignOffRequired)
                                            {
                                                <text> · Sign-off required</text>
                                            }
                                        </MudText>
                                    </div>
                                    @if (ms.SignOffRequired && ms.Status != "Complete")
                                    {
                                        <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Success"
                                                   OnClick="() => SignOffMilestone(ms)">Sign Off</MudButton>
                                    }
                                </div>
                            }
                            @if (!_milestones.Any())
                            {
                                <div class="pa-4 text-center"><MudText Typo="Typo.caption" Color="Color.Secondary">No milestones yet.</MudText></div>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <!-- Project Links -->
                <MudItem xs="12" md="6">
                    <MudCard Elevation="1">
                        <MudCardContent>
                            <MudText Typo="Typo.subtitle1" Class="mb-2">Project Details</MudText>
                            <MudGrid Spacing="1">
                                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Commercial Model</MudText><MudText Typo="Typo.body2">@_project.CommercialModel</MudText></MudItem>
                                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Budget</MudText><MudText Typo="Typo.body2">@(_project.BudgetAmount?.ToString("C0") ?? "—")</MudText></MudItem>
                                @if (_project.LinkedQuoteId.HasValue)
                                {
                                    <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Linked Quote</MudText><MudLink Href="@($"/quotes/{_project.LinkedQuoteId}")">Q-@_project.LinkedQuoteId</MudLink></MudItem>
                                }
                                @if (_project.LinkedInvoiceId.HasValue)
                                {
                                    <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Linked Invoice</MudText><MudLink Href="@($"/invoices/{_project.LinkedInvoiceId}")">INV-@_project.LinkedInvoiceId</MudLink></MudItem>
                                }
                                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Start Date</MudText><MudText Typo="Typo.body2">@(_project.StartDate?.ToString("dd MMM yyyy") ?? "—")</MudText></MudItem>
                                <MudItem xs="6"><MudText Typo="Typo.caption" Color="Color.Secondary">Target End</MudText><MudText Typo="Typo.body2">@(_project.EndDate?.ToString("dd MMM yyyy") ?? "—")</MudText></MudItem>
                            </MudGrid>
                            @if (!string.IsNullOrWhiteSpace(_project.PortalToken))
                            {
                                <MudDivider Class="my-2" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Client/Supplier Portal Link</MudText>
                                <MudTextField Value="@($"{Nav.BaseUri}portal/project/{_project.PortalToken}")" ReadOnly="true"
                                              Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Rounded.ContentCopy"
                                              OnAdornmentClick="CopyPortalLink" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            }
                            else
                            {
                                <MudButton Size="Size.Small" StartIcon="@Icons.Material.Rounded.Link" OnClick="GeneratePortalLink" Class="mt-2">
                                    Generate Portal Link
                                </MudButton>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <!-- ── TASKS WORKSPACE (Gallery / Grid / Kanban / Gantt) ── -->
        <MudTabPanel Text="Tasks" Icon="@Icons.Material.Rounded.Task">
            <!-- Toolbar: view switcher + filters + team presets -->
            <div class="d-flex flex-wrap gap-2 align-center mb-3">
                <MudPaper Outlined="true" Class="d-flex" Style="border-radius:8px;overflow:hidden;">
                    @foreach (var (icon, view, tip) in new[]{
                        (Icons.Material.Rounded.GridView,    "gallery", "Gallery"),
                        (Icons.Material.Rounded.TableChart,  "grid",    "Grid"),
                        (Icons.Material.Rounded.ViewKanban,  "kanban",  "Kanban"),
                        (Icons.Material.Rounded.Timeline,    "gantt",   "Gantt")})
                    {
                        <MudTooltip Text="@tip">
                            <MudIconButton Icon="@icon" Size="Size.Small"
                                           Color="@(_taskView == view ? Color.Primary : Color.Default)"
                                           Style="@(_taskView == view ? "background:var(--mud-palette-primary);color:white;border-radius:0;" : "border-radius:0;")"
                                           OnClick="() => _taskView = view" />
                        </MudTooltip>
                    }
                </MudPaper>
                <MudSelect T="string" @bind-Value="_taskFilter" Label="Status" Variant="Variant.Outlined"
                           Dense="true" Margin="Margin.Dense" Style="min-width:120px;max-width:150px;">
                    <MudSelectItem Value="@("All")">All</MudSelectItem>
                    @foreach (var s in _taskStatuses) { <MudSelectItem Value="@s">@s</MudSelectItem> }
                </MudSelect>
                <MudSelect T="string" @bind-Value="_filterPriority" Label="Priority" Variant="Variant.Outlined"
                           Dense="true" Margin="Margin.Dense" Style="min-width:115px;max-width:145px;">
                    <MudSelectItem Value="@("all")">All</MudSelectItem>
                    @foreach (var p in new[]{"Critical","High","Medium","Low"}) { <MudSelectItem Value="@p">@p</MudSelectItem> }
                </MudSelect>
                @if (_taskView is "gallery" or "grid")
                {
                    <MudSelect T="string" @bind-Value="_groupBy" Label="Group by" Variant="Variant.Outlined"
                               Dense="true" Margin="Margin.Dense" Style="min-width:130px;max-width:160px;">
                        <MudSelectItem Value="@("none")">No grouping</MudSelectItem>
                        <MudSelectItem Value="@("status")">Status</MudSelectItem>
                        <MudSelectItem Value="@("milestone")">Milestone</MudSelectItem>
                        <MudSelectItem Value="@("priority")">Priority</MudSelectItem>
                        <MudSelectItem Value="@("assignee")">Assignee</MudSelectItem>
                    </MudSelect>
                }
                <MudSpacer />
                <MudMenu Label="Team Views" StartIcon="@Icons.Material.Rounded.Groups" Variant="Variant.Outlined" Size="Size.Small">
                    @foreach (var preset in _teamPresets)
                    {
                        <MudMenuItem OnClick="() => ApplyPreset(preset)">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@preset.Icon" Size="Size.Small" />
                                <div>
                                    <MudText Typo="Typo.body2">@preset.Name</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@preset.Description</MudText>
                                </div>
                            </div>
                        </MudMenuItem>
                    }
                </MudMenu>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add"
                           Size="Size.Small" OnClick="() => _addTaskOpen = true">Add Task</MudButton>
            </div>
            @{
                var viewTasks = FilteredTasks.ToList();
                IEnumerable<IGrouping<string, TaskItem>> grouped = _groupBy switch
                {
                    "status"    => viewTasks.GroupBy(t => t.Status),
                    "milestone" => viewTasks.GroupBy(t => t.MilestoneName ?? "General"),
                    "priority"  => viewTasks.GroupBy(t => t.Priority),
                    "assignee"  => viewTasks.GroupBy(t => t.AssigneeName ?? "Unassigned"),
                    _           => viewTasks.GroupBy(_ => ""),
                };
            }

            <!-- ── GALLERY ── -->
            @if (_taskView == "gallery")
            {
                @if (!viewTasks.Any())
                {
                    <MudPaper Outlined="true" Class="pa-12 text-center">
                        <MudIcon Icon="@Icons.Material.Rounded.GridView" Size="Size.Large" Class="mb-2" Style="opacity:.3" />
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No tasks match the current filters.</MudText>
                    </MudPaper>
                }
                @foreach (var grp in grouped)
                {
                    @if (_groupBy != "none" && !string.IsNullOrEmpty(grp.Key))
                    {
                        <div class="d-flex align-center gap-2 mb-2 mt-3">
                            <div style="width:4px;height:20px;border-radius:2px;background:var(--mud-palette-primary);"></div>
                            <MudText Typo="Typo.subtitle2">@grp.Key</MudText>
                            <MudChip T="string" Size="Size.Small">@grp.Count()</MudChip>
                        </div>
                    }
                    <MudGrid Spacing="3">
                        @foreach (var task in grp.OrderBy(t => t.OrderIndex).ThenBy(t => t.DueDate))
                        {
                            var isOverdue = task.DueDate < DateTime.Today && task.Status != "Done";
                            <MudItem xs="12" sm="6" md="4" lg="3">
                                <MudCard Elevation="1" @onclick="() => OpenTaskEdit(task)"
                                         Style="@($"cursor:pointer;border-radius:10px;border-left:4px solid {PriorityHex(task.Priority)};")">
                                    <MudCardContent Class="pa-3">
                                        <div class="d-flex gap-1 mb-1 flex-wrap">
                                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)" Style="height:20px;font-size:10px;">@task.Priority</MudChip>
                                            <MudChip T="string" Size="Size.Small" Color="@GetTaskStatusColor(task.Status)" Style="height:20px;font-size:10px;">@task.Status</MudChip>
                                            @if (task.StoryPoints.HasValue)
                                            {
                                                <MudChip T="string" Size="Size.Small" Style="height:20px;font-size:10px;margin-left:auto;">@task.StoryPoints pts</MudChip>
                                            }
                                        </div>
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:600;line-height:1.3;">@task.Title</MudText>
                                        @if (!string.IsNullOrWhiteSpace(task.Description))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                     Style="font-size:11px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                                                @task.Description
                                            </MudText>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(task.MilestoneName))
                                        {
                                            <div class="d-flex align-center gap-1 mt-1">
                                                <MudIcon Icon="@Icons.Material.Rounded.Flag" Size="Size.Small" Color="Color.Warning" Style="font-size:12px;" />
                                                <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:11px;">@task.MilestoneName</MudText>
                                            </div>
                                        }
                                        <MudDivider Class="my-1" />
                                        <div class="d-flex align-center gap-1">
                                            @if (!string.IsNullOrWhiteSpace(task.AssigneeName))
                                            {
                                                <MudAvatar Size="Size.Small" Color="Color.Primary" Style="width:20px;height:20px;font-size:10px;">@task.AssigneeName[0]</MudAvatar>
                                                <MudText Typo="Typo.caption" Style="font-size:11px;flex:1;">@task.AssigneeName</MudText>
                                            }
                                            else { <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size:11px;flex:1;">Unassigned</MudText> }
                                            @if (task.DueDate.HasValue)
                                            {
                                                <MudText Typo="Typo.caption" Color="@(isOverdue ? Color.Error : Color.Secondary)" Style="font-size:10px;">
                                                    @task.DueDate.Value.ToString("dd MMM")
                                                </MudText>
                                            }
                                        </div>
                                        <MudProgressLinear Value="@task.PercentComplete"
                                                           Color="@(task.Status == "Done" ? Color.Success : isOverdue ? Color.Error : Color.Primary)"
                                                           Size="Size.Small" Class="mt-1" Style="border-radius:4px;" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size:10px;text-align:right;">@task.PercentComplete%</MudText>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        }
                    </MudGrid>
                }
            }

            <!-- ── GRID ── -->
            @if (_taskView == "grid")
            {
                @if (!viewTasks.Any())
                {
                    <MudPaper Outlined="true" Class="pa-8 text-center">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">No tasks match the current filters.</MudText>
                    </MudPaper>
                }
                @foreach (var grp in grouped)
                {
                    @if (_groupBy != "none" && !string.IsNullOrEmpty(grp.Key))
                    {
                        <div class="d-flex align-center gap-2 mb-1 mt-3">
                            <div style="width:4px;height:20px;border-radius:2px;background:var(--mud-palette-primary);"></div>
                            <MudText Typo="Typo.subtitle2">@grp.Key</MudText>
                            <MudChip T="string" Size="Size.Small">@grp.Count()</MudChip>
                        </div>
                    }
                    <MudTable Items="@grp" Dense="true" Hover="true" Striped="true" Elevation="0" Outlined="true" Class="mb-3">
                        <HeaderContent>
                            <MudTh Style="width:38%">Task</MudTh>
                            <MudTh>Assignee</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Due</MudTh>
                            <MudTh Style="min-width:140px">Progress</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <div style="cursor:pointer;" @onclick="() => OpenTaskEdit(context)">
                                    <MudText Typo="Typo.body2" Style="font-weight:500">@context.Title</MudText>
                                    @if (!string.IsNullOrWhiteSpace(context.MilestoneName))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:11px;">⬦ @context.MilestoneName</MudText>
                                    }
                                </div>
                            </MudTd>
                            <MudTd>
                                @if (!string.IsNullOrWhiteSpace(context.AssigneeName))
                                {
                                    <div class="d-flex align-center gap-1">
                                        <MudAvatar Size="Size.Small" Color="Color.Primary" Style="width:22px;height:22px;font-size:10px;">@context.AssigneeName[0]</MudAvatar>
                                        <MudText Typo="Typo.caption">@context.AssigneeName</MudText>
                                    </div>
                                }
                                else { <MudText Typo="Typo.caption" Color="Color.Secondary">—</MudText> }
                            </MudTd>
                            <MudTd><MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip></MudTd>
                            <MudTd>
                                <MudText Typo="Typo.caption" Color="@(context.DueDate < DateTime.Today && context.Status != "Done" ? Color.Error : Color.Default)">
                                    @(context.DueDate?.ToString("dd MMM") ?? "—")
                                </MudText>
                            </MudTd>
                            <MudTd>
                                <div class="d-flex align-center gap-1">
                                    <MudSlider T="int" Value="@context.PercentComplete" Min="0" Max="100" Step="5"
                                               ValueChanged="@(v => UpdatePercent(context, v))"
                                               Style="flex:1" Color="Color.Primary" />
                                    <MudText Typo="Typo.caption" Style="min-width:32px;font-size:10px;">@context.PercentComplete%</MudText>
                                </div>
                            </MudTd>
                            <MudTd>
                                <MudSelect T="string" Value="@context.Status" ValueChanged="@(s => UpdateTaskStatus(context, s))"
                                           Dense="true" Variant="Variant.Text" Style="min-width:110px;">
                                    @foreach (var s in _taskStatuses) { <MudSelectItem Value="@s">@s</MudSelectItem> }
                                </MudSelect>
                            </MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="() => DeleteTask(context.TaskId)" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            }

            <!-- ── KANBAN (drag-drop) ── -->
            @if (_taskView == "kanban")
            {
                <MudGrid Spacing="2">
                    @foreach (var col in _kanbanColumns)
                    {
                        var colTasks = viewTasks.Where(t => t.Status == col.Status).OrderBy(t => t.OrderIndex).ToList();
                        <MudItem xs="12" sm="6" md="@(12 / _kanbanColumns.Length)">
                            <div @ondragover:preventDefault @ondragenter:preventDefault
                                 @ondragenter="() => _dropTarget = col.Status"
                                 @ondragleave="() => { if (_dropTarget == col.Status) _dropTarget = string.Empty; }"
                                 @ondrop="() => OnDropAsync(col.Status)"
                                 style="@($"min-height:320px;padding:8px;border-radius:8px;border:2px dashed {(_dropTarget == col.Status ? "var(--mud-palette-primary)" : "var(--mud-palette-divider)")};background:{(_dropTarget == col.Status ? "rgba(var(--mud-palette-primary-rgb,25,118,210),0.05)" : "var(--mud-palette-surface)")};transition:all .15s;")">
                                <div class="d-flex align-center gap-1 mb-2 px-1">
                                    <MudIcon Icon="@col.Icon" Size="Size.Small" Color="@col.Color" />
                                    <MudText Typo="Typo.subtitle2">@col.Label</MudText>
                                    <MudChip T="string" Size="Size.Small" Style="margin-left:auto;height:18px;font-size:10px;">@colTasks.Count</MudChip>
                                </div>
                                @foreach (var task in colTasks)
                                {
                                    var isOverdue = task.DueDate < DateTime.Today && task.Status != "Done";
                                    <div draggable="true"
                                         @ondragstart="() => _draggingTask = task"
                                         @ondragend="() => { _draggingTask = null; _dropTarget = string.Empty; }"
                                         @onclick="() => OpenTaskEdit(task)"
                                         style="@($"margin-bottom:8px;border-radius:8px;padding:10px;cursor:grab;background:var(--mud-palette-background);border:1px solid var(--mud-palette-divider);border-left:4px solid {PriorityHex(task.Priority)};opacity:{(_draggingTask?.TaskId == task.TaskId ? ".4" : "1")};transition:opacity .1s;")">
                                        <div class="d-flex gap-1 mb-1">
                                            <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)" Style="height:18px;font-size:10px;">@task.Priority</MudChip>
                                            @if (task.StoryPoints.HasValue) { <MudText Typo="Typo.caption" Style="margin-left:auto;font-size:10px;">@task.StoryPoints sp</MudText> }
                                        </div>
                                        <MudText Typo="Typo.body2" Style="font-weight:600;font-size:13px;line-height:1.3;">@task.Title</MudText>
                                        @if (!string.IsNullOrWhiteSpace(task.MilestoneName))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Warning" Style="font-size:10px;">⬦ @task.MilestoneName</MudText>
                                        }
                                        <div class="d-flex align-center gap-1 mt-1">
                                            @if (!string.IsNullOrWhiteSpace(task.AssigneeName))
                                            {
                                                <MudAvatar Size="Size.Small" Color="Color.Primary" Style="width:18px;height:18px;font-size:9px;">@task.AssigneeName[0]</MudAvatar>
                                                <MudText Typo="Typo.caption" Style="font-size:10px;flex:1;">@task.AssigneeName</MudText>
                                            }
                                            @if (task.DueDate.HasValue)
                                            {
                                                <MudText Typo="Typo.caption" Color="@(isOverdue ? Color.Error : Color.Secondary)" Style="font-size:10px;">@task.DueDate.Value.ToString("dd MMM")</MudText>
                                            }
                                        </div>
                                        <MudProgressLinear Value="@task.PercentComplete" Color="@col.Color" Size="Size.Small" Class="mt-1" Style="border-radius:4px;" />
                                    </div>
                                }
                                @if (!colTasks.Any())
                                {
                                    <div style="text-align:center;padding:24px 0;font-size:12px;color:var(--mud-palette-text-secondary);">Drop tasks here</div>
                                }
                            </div>
                        </MudItem>
                    }
                </MudGrid>
            }

            <!-- ── GANTT ── -->
            @if (_taskView == "gantt")
            {
                @{
                    var ganttTasks = viewTasks;
                    var ganttStart = ganttTasks.Where(t => t.TaskStartDate.HasValue).Select(t => t.TaskStartDate!.Value)
                                     .Concat(new[]{ _project!.StartDate ?? DateTime.Today }).Min();
                    var ganttEnd   = ganttTasks.Where(t => t.TaskEndDate.HasValue).Select(t => t.TaskEndDate!.Value)
                                     .Concat(new[]{ _project!.EndDate ?? DateTime.Today.AddDays(30) }).Max();
                    if (ganttEnd < ganttStart.AddDays(7)) ganttEnd = ganttStart.AddDays(30);
                    var totalDays  = Math.Max(1, (ganttEnd - ganttStart).Days + 1);
                    var todayOffset = Math.Clamp((DateTime.Today - ganttStart).Days * 100.0 / totalDays, 0, 100);
                }
                <div style="overflow-x:auto;">
                    <div style="min-width:900px;">
                        <div class="d-flex" style="margin-left:220px;border-bottom:2px solid var(--mud-palette-divider);background:var(--mud-palette-background-grey);">
                            @{ var wk = ganttStart.AddDays(-(int)ganttStart.DayOfWeek); }
                            @while (wk <= ganttEnd)
                            {
                                var wdays = Math.Max(0, Math.Min((ganttEnd - wk).Days + 1, 7));
                                var wpct  = wdays * 100.0 / totalDays;
                                if (wpct > 0)
                                {
                                    <div style="width:@($"{wpct:F2}%");text-align:center;font-size:10px;color:var(--mud-palette-text-secondary);border-right:1px solid var(--mud-palette-divider);padding:3px 0;white-space:nowrap;overflow:hidden;">@wk.ToString("dd MMM")</div>
                                }
                                wk = wk.AddDays(7);
                            }
                        </div>
                        @foreach (var grp in ganttTasks.GroupBy(t => t.MilestoneName ?? "General"))
                        {
                            <div style="padding:2px 8px;background:var(--mud-palette-background-grey);font-size:11px;font-weight:600;color:var(--mud-palette-primary-text);border-bottom:1px solid var(--mud-palette-divider);">@grp.Key</div>
                            @foreach (var task in grp.OrderBy(t => t.TaskStartDate ?? ganttStart))
                            {
                                var ts    = task.TaskStartDate ?? ganttStart;
                                var te    = task.TaskEndDate   ?? ts.AddDays(Math.Max(1, (int)((task.EstimatedHours ?? 8) / 8)));
                                var left  = Math.Max(0, (ts - ganttStart).Days * 100.0 / totalDays);
                                var width = Math.Max(0.3, (te - ts).Days * 100.0 / totalDays);
                                var late  = te < DateTime.Today && task.PercentComplete < 100;
                                var bar   = late ? "var(--mud-palette-error)" : task.Status == "Done" ? "var(--mud-palette-success)" : "var(--mud-palette-primary)";
                                <div class="d-flex align-center" style="height:34px;border-bottom:1px solid var(--mud-palette-divider);cursor:pointer;" @onclick="() => OpenTaskEdit(task)">
                                    <div style="width:220px;min-width:220px;padding:0 8px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;">
                                        <div style="font-size:12px;font-weight:500;">@task.Title</div>
                                        <div style="font-size:10px;color:var(--mud-palette-text-secondary);">@(task.AssigneeName ?? "")</div>
                                    </div>
                                    <div style="flex:1;position:relative;height:100%;">
                                        <div style="position:absolute;left:@($"{todayOffset:F2}%");top:0;bottom:0;width:2px;background:var(--mud-palette-error);opacity:.4;z-index:2;" />
                                        <div style="position:absolute;left:@($"{left:F2}%");width:@($"{width:F2}%");top:6px;bottom:6px;background:@bar;border-radius:4px;overflow:hidden;display:flex;align-items:center;padding:0 4px;" title="@task.Title — @task.PercentComplete%">
                                            <div style="position:absolute;left:0;top:0;bottom:0;width:@(task.PercentComplete)%;background:rgba(255,255,255,.3);" />
                                            <span style="color:white;font-size:9px;white-space:nowrap;position:relative;z-index:1;">@task.PercentComplete%</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        @foreach (var ms in _milestones.OrderBy(m => m.DueDate))
                        {
                            var msOff = Math.Clamp((ms.DueDate - ganttStart).Days * 100.0 / totalDays, 0, 100);
                            <div style="display:flex;align-items:center;height:22px;border-bottom:1px solid var(--mud-palette-divider);">
                                <div style="width:220px;min-width:220px;padding:0 8px;overflow:hidden;white-space:nowrap;font-size:10px;color:@(ms.Status=="Complete"?"var(--mud-palette-success)":"var(--mud-palette-warning)");">⬦ @ms.Title</div>
                                <div style="flex:1;position:relative;height:100%;">
                                    <div style="position:absolute;left:@($"{msOff:F2}%");top:50%;transform:translate(-50%,-50%) rotate(45deg);width:10px;height:10px;background:@(ms.Status=="Complete"?"var(--mud-palette-success)":"var(--mud-palette-warning)");" title="@ms.Title" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="d-flex gap-3 mt-2" style="font-size:11px;color:var(--mud-palette-text-secondary);">
                    <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:var(--mud-palette-primary);margin-right:3px;vertical-align:middle;"></span>In Progress
                    <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:var(--mud-palette-success);margin-right:3px;vertical-align:middle;"></span>Done
                    <span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:var(--mud-palette-error);margin-right:3px;vertical-align:middle;"></span>Overdue
                </div>
            }
            <MudTable Items="FilteredTasks" Dense="true" Hover="true" Striped="true" Elevation="0" Outlined="true">
                <HeaderContent>
                    <MudTh>Task</MudTh>
                    <MudTh>Assignee</MudTh>
                    <MudTh>Priority</MudTh>
                    <MudTh>Due</MudTh>
                    <MudTh Style="min-width:160px">% Complete</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Typo="Typo.body2" Style="font-weight:500">@context.Title</MudText>
                        @if (!string.IsNullOrWhiteSpace(context.MilestoneName))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@context.MilestoneName</MudText>
                        }
                    </MudTd>
                    <MudTd><MudText Typo="Typo.caption">@(context.AssigneeName ?? "—")</MudText></MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(context.Priority)">@context.Priority</MudChip></MudTd>
                    <MudTd><MudText Typo="Typo.caption" Color="@(context.DueDate < DateTime.Today && context.Status != "Done" ? Color.Error : Color.Default)">@(context.DueDate?.ToString("dd MMM") ?? "—")</MudText></MudTd>
                    <MudTd>
                        <div class="d-flex align-center gap-2">
                            <MudSlider T="int" Value="@context.PercentComplete" Min="0" Max="100" Step="5"
                                       ValueChanged="@(v => UpdatePercent(context, v))"
                                       Style="flex:1" Color="Color.Primary" />
                            <MudText Typo="Typo.caption" Style="min-width:32px">@context.PercentComplete%</MudText>
                        </div>
                    </MudTd>
                    <MudTd>
                        <MudSelect T="string" Value="@context.Status" ValueChanged="@(s => UpdateTaskStatus(context, s))"
                                   Dense="true" Variant="Variant.Text" Style="min-width:110px;">
                            @foreach (var s in _taskStatuses)
                            {
                                <MudSelectItem Value="@s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="() => DeleteTask(context.TaskId)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudTabPanel>

        <!-- ── KANBAN ── -->
        <MudTabPanel Text="Kanban" Icon="@Icons.Material.Rounded.ViewKanban">
            <MudGrid Spacing="2">
                @foreach (var col in _kanbanColumns)
                {
                    <MudItem xs="12" sm="6" md="3">
                        <MudPaper Outlined="true" Class="pa-2" Style="min-height:300px;">
                            <div class="d-flex align-center gap-1 mb-2 px-1">
                                <MudIcon Icon="@col.Icon" Size="Size.Small" Color="@col.Color" />
                                <MudText Typo="Typo.subtitle2">@col.Label</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-auto">(@_tasks.Count(t => t.Status == col.Status))</MudText>
                            </div>
                            @foreach (var task in _tasks.Where(t => t.Status == col.Status).OrderBy(t => t.OrderIndex))
                            {
                                <MudPaper Outlined="true" Class="pa-2 mb-2" Style="cursor:pointer;" @onclick="() => OpenTaskEdit(task)">
                                    <div class="d-flex align-center gap-1 mb-1">
                                        <MudChip T="string" Size="Size.Small" Color="@GetPriorityColor(task.Priority)">@task.Priority</MudChip>
                                        <MudSpacer />
                                        <MudText Typo="Typo.caption">@task.PercentComplete%</MudText>
                                    </div>
                                    <MudText Typo="Typo.body2" Style="font-weight:500">@task.Title</MudText>
                                    @if (!string.IsNullOrWhiteSpace(task.AssigneeName))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@task.AssigneeName</MudText>
                                    }
                                    @if (task.DueDate.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Color="@(task.DueDate < DateTime.Today && task.Status != "Done" ? Color.Error : Color.Secondary)">
                                            Due @task.DueDate.Value.ToString("dd MMM")
                                        </MudText>
                                    }
                                    <MudProgressLinear Value="@task.PercentComplete" Color="@col.Color" Class="mt-1" Size="Size.Small" />
                                    <div class="d-flex gap-1 mt-1">
                                        @foreach (var dest in _kanbanColumns.Where(c => c.Status != col.Status).Take(2))
                                        {
                                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="@dest.Color"
                                                       OnClick="() => MoveTask(task, dest.Status)" Style="font-size:10px;padding:2px 4px;min-width:0;">
                                                → @dest.Label
                                            </MudButton>
                                        }
                                    </div>
                                </MudPaper>
                            }
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        </MudTabPanel>

        <!-- ── GANTT ── -->
        <MudTabPanel Text="Gantt" Icon="@Icons.Material.Rounded.Timeline">
            @{
                var ganttStart = _tasks.Where(t => t.TaskStartDate.HasValue).Min(t => (DateTime?)t.TaskStartDate)
                              ?? _project.StartDate ?? DateTime.Today;
                var ganttEnd   = _tasks.Where(t => t.TaskEndDate.HasValue).Max(t => (DateTime?)t.TaskEndDate)
                              ?? _project.EndDate ?? DateTime.Today.AddDays(30);
                var totalDays  = Math.Max(1, (ganttEnd - ganttStart).Days + 1);
            }
            <div style="overflow-x:auto;">
                <div style="min-width:900px;">
                    <!-- Timeline header: weeks -->
                    <div class="d-flex" style="margin-left:240px; border-bottom:2px solid var(--mud-palette-divider);">
                        @{
                            var wk = ganttStart;
                            while (wk <= ganttEnd)
                            {
                                var wkWidth = Math.Max(1, Math.Min((ganttEnd - wk).Days + 1, 7)) * 100.0 / totalDays;
                                <div style="width:@($"{wkWidth:F1}%"); text-align:center; font-size:10px; color:var(--mud-palette-text-secondary); border-right:1px solid var(--mud-palette-divider); padding:2px 0;">
                                    @wk.ToString("dd MMM")
                                </div>
                                wk = wk.AddDays(7);
                            }
                        }
                    </div>

                    <!-- Today marker position -->
                    @{
                        var todayOffset = Math.Clamp((DateTime.Today - ganttStart).Days * 100.0 / totalDays, 0, 100);
                    }

                    <!-- Task rows -->
                    @foreach (var grp in _tasks.GroupBy(t => t.MilestoneName ?? "General"))
                    {
                        <div class="px-1 py-1" style="background:var(--mud-palette-background-grey); font-size:11px; font-weight:600; color:var(--mud-palette-primary);">
                            @grp.Key
                        </div>
                        @foreach (var task in grp.OrderBy(t => t.TaskStartDate ?? ganttStart))
                        {
                            var tStart  = task.TaskStartDate ?? ganttStart;
                            var tEnd    = task.TaskEndDate   ?? tStart.AddDays(3);
                            var left    = Math.Max(0, (tStart - ganttStart).Days * 100.0 / totalDays);
                            var width   = Math.Max(0.5, (tEnd - tStart).Days * 100.0 / totalDays);
                            var isLate  = tEnd < DateTime.Today && task.PercentComplete < 100;

                            <div class="d-flex align-center" style="height:36px; border-bottom:1px solid var(--mud-palette-divider);">
                                <div style="width:240px; min-width:240px; padding:0 8px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">
                                    <MudText Typo="Typo.caption" Style="font-weight:500">@task.Title</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size:10px"> @(task.AssigneeName ?? "")</MudText>
                                </div>
                                <div style="flex:1; position:relative; height:100%;">
                                    <!-- today line -->
                                    <div style="position:absolute; left:@($"{todayOffset:F1}%"); top:0; bottom:0; width:2px; background:var(--mud-palette-error); opacity:0.5; z-index:1;" />
                                    <!-- task bar -->
                                    <div style="position:absolute; left:@($"{left:F1}%"); width:@($"{width:F1}%"); top:8px; bottom:8px;
                                                background:@(isLate ? "var(--mud-palette-error)" : task.Status == "Done" ? "var(--mud-palette-success)" : "var(--mud-palette-primary)");
                                                border-radius:4px; opacity:0.8; overflow:hidden; display:flex; align-items:center; padding:0 4px;">
                                        <div style="height:100%; width:@(task.PercentComplete)%; background:rgba(255,255,255,0.35); position:absolute; left:0; top:0;" />
                                        <MudText Typo="Typo.caption" Style="color:white; font-size:10px; white-space:nowrap; overflow:hidden; position:relative; z-index:1;">@task.PercentComplete%</MudText>
                                    </div>
                                </div>
                            </div>
                        }
                    }

                    <!-- Milestone markers -->
                    @foreach (var ms in _milestones)
                    {
                        var msOffset = Math.Clamp((ms.DueDate - ganttStart).Days * 100.0 / totalDays, 0, 100);
                        <div style="position:relative; height:24px; border-bottom:1px solid var(--mud-palette-divider);">
                            <div style="width:240px; min-width:240px; padding:0 8px;">
                                <MudText Typo="Typo.caption" Color="@(ms.Status == "Complete" ? Color.Success : Color.Warning)" Style="font-size:10px;">⬦ @ms.Title</MudText>
                            </div>
                            <div style="position:absolute; left:calc(240px + @($"{msOffset:F1}%")); top:2px;
                                        width:0; height:0; border-left:7px solid transparent; border-right:7px solid transparent;
                                        border-top:12px solid @(ms.Status == "Complete" ? "var(--mud-palette-success)" : "var(--mud-palette-warning)");" />
                        </div>
                    }
                </div>
            </div>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                <MudIcon Icon="@Icons.Material.Rounded.FiberManualRecord" Size="Size.Small" Style="color:var(--mud-palette-error);vertical-align:middle;" /> Today
                <MudIcon Icon="@Icons.Material.Rounded.FiberManualRecord" Size="Size.Small" Color="Color.Primary" Style="vertical-align:middle;" Class="ml-2" /> In Progress
                <MudIcon Icon="@Icons.Material.Rounded.FiberManualRecord" Size="Size.Small" Color="Color.Success" Style="vertical-align:middle;" Class="ml-2" /> Done
            </MudText>
        </MudTabPanel>

        <!-- ── BUDGET ── -->
        <MudTabPanel Text="Budget" Icon="@Icons.Material.Rounded.AccountBalance">
            <!-- Summary -->
            <MudGrid Spacing="2" Class="mb-3">
                <MudItem xs="6" sm="3">
                    <MudPaper Outlined="true" Class="pa-3 text-center">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Budget</MudText>
                        <MudText Typo="Typo.h6">@(_project.BudgetAmount?.ToString("C0") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Outlined="true" Class="pa-3 text-center">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Actual Cost</MudText>
                        <MudText Typo="Typo.h6" Color="@(_costTotal > (_project.BudgetAmount ?? decimal.MaxValue) ? Color.Error : Color.Success)">@_costTotal.ToString("C0")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Outlined="true" Class="pa-3 text-center">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Variance</MudText>
                        @{var variance = (_project.BudgetAmount ?? 0) - _costTotal;}
                        <MudText Typo="Typo.h6" Color="@(variance >= 0 ? Color.Success : Color.Error)">@variance.ToString("C0")</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudPaper Outlined="true" Class="pa-3 text-center">
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Predicted Final</MudText>
                        <MudText Typo="Typo.h6">@(_project.PredictedFinalCost?.ToString("C0") ?? "—")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <div class="d-flex justify-end mb-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add" Size="Size.Small" OnClick="() => _addCostOpen = true">Log Cost</MudButton>
            </div>

            <MudTable Items="_costEntries" Dense="true" Hover="true" Striped="true" Elevation="0" Outlined="true">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Description</MudTh>
                    <MudTh>Entered By</MudTh>
                    <MudTh Style="text-align:right">Qty</MudTh>
                    <MudTh Style="text-align:right">Rate</MudTh>
                    <MudTh Style="text-align:right">Amount</MudTh>
                    <MudTh>Billable</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.EntryDate.ToString("dd/MM/yy")</MudTd>
                    <MudTd><MudChip T="string" Size="Size.Small">@context.EntryType</MudChip></MudTd>
                    <MudTd>@context.Description</MudTd>
                    <MudTd>@(context.EnteredBy ?? "")</MudTd>
                    <MudTd Style="text-align:right">@context.Quantity</MudTd>
                    <MudTd Style="text-align:right">@context.UnitRate.ToString("C2")</MudTd>
                    <MudTd Style="text-align:right"><b>@context.Amount.ToString("C2")</b></MudTd>
                    <MudTd><MudIcon Icon="@(context.IsBillable ? Icons.Material.Rounded.CheckCircle : Icons.Material.Rounded.Cancel)" Color="@(context.IsBillable ? Color.Success : Color.Default)" Size="Size.Small" /></MudTd>
                    <MudTd><MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteCostEntry(context.CostEntryId)" /></MudTd>
                </RowTemplate>
                <FooterContent>
                    <MudTd colspan="6" Style="text-align:right; font-weight:bold;">TOTAL</MudTd>
                    <MudTd Style="text-align:right; font-weight:bold;">@_costTotal.ToString("C2")</MudTd>
                    <MudTd colspan="2" />
                </FooterContent>
            </MudTable>
        </MudTabPanel>

        <!-- ── RISKS & ISSUES ── -->
        <MudTabPanel Text="Risks & Issues" Icon="@Icons.Material.Rounded.Warning">
            <div class="d-flex gap-2 mb-3">
                <MudButton Variant="Variant.Filled" Color="Color.Warning" StartIcon="@Icons.Material.Rounded.Add" Size="Size.Small" OnClick="() => AddRiskIssue("Risk")">Add Risk</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Error" StartIcon="@Icons.Material.Rounded.Add" Size="Size.Small" OnClick="() => AddRiskIssue("Issue")">Log Issue</MudButton>
            </div>

            @foreach (var type in new[]{"Risk","Issue"})
            {
                var items = _risksIssues.Where(r => r.ItemType == type).ToList();
                if (!items.Any()) continue;
                <MudText Typo="Typo.subtitle2" Class="mb-1 mt-3">@type&#x73; (@items.Count open)</MudText>
                <MudTable Items="items" Dense="true" Hover="true" Striped="true" Elevation="0" Outlined="true" Class="mb-4">
                    <HeaderContent>
                        <MudTh>Title</MudTh>
                        <MudTh>@(type == "Risk" ? "Likelihood" : "Type")</MudTh>
                        <MudTh>Impact</MudTh>
                        <MudTh>Priority</MudTh>
                        <MudTh>Owner</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Due</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudText Typo="Typo.body2" Style="font-weight:500">@context.Title</MudText>
                            @if (!string.IsNullOrWhiteSpace(context.MitigationPlan))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.MitigationPlan.Length > 80 ? context.MitigationPlan[..80] + "…" : context.MitigationPlan)</MudText>
                            }
                        </MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="@ImpactColor(context.Likelihood)">@context.Likelihood</MudChip></MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="@ImpactColor(context.Impact)">@context.Impact</MudChip></MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="@ImpactColor(context.Priority)">@context.Priority</MudChip></MudTd>
                        <MudTd>@(context.OwnedBy ?? "—")</MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small">@context.Status</MudChip></MudTd>
                        <MudTd><MudText Typo="Typo.caption">@(context.DueDate?.ToString("dd/MM") ?? "—")</MudText></MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Rounded.CheckCircle" Size="Size.Small" Color="Color.Success"
                                           OnClick="() => CloseRiskIssue(context.RiskIssueId)" Title="Close" />
                            <MudIconButton Icon="@Icons.Material.Rounded.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="() => DeleteRiskIssue(context.RiskIssueId)" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

        <!-- ── CHANGE REQUESTS ── -->
        <MudTabPanel Text="Change Requests" Icon="@Icons.Material.Rounded.ChangeCircle">
            <div class="d-flex justify-end mb-3">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.Add" Size="Size.Small" OnClick="() => _addCrOpen = true">New Change Request</MudButton>
            </div>
            @if (!_changeRequests.Any())
            {
                <MudPaper Outlined="true" Class="pa-8 text-center">
                    <MudIcon Icon="@Icons.Material.Rounded.ChangeCircle" Size="Size.Large" Class="mb-2 opacity-60" />
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No change requests yet.</MudText>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_changeRequests" Dense="true" Hover="true" Striped="true" Elevation="0" Outlined="true">
                    <HeaderContent>
                        <MudTh>CR #</MudTh>
                        <MudTh>Title</MudTh>
                        <MudTh>Impact</MudTh>
                        <MudTh>Cost Impact</MudTh>
                        <MudTh>Raised By</MudTh>
                        <MudTh>Raised</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><b>@context.ChangeNumber</b></MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2" Style="font-weight:500">@context.Title</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@(context.Description.Length > 60 ? context.Description[..60] + "…" : context.Description)</MudText>
                        </MudTd>
                        <MudTd><MudText Typo="Typo.caption">@(context.ImpactDays.HasValue ? $"+{context.ImpactDays} days" : "—")</MudText></MudTd>
                        <MudTd><MudText Typo="Typo.caption">@(context.ImpactCost?.ToString("C0") ?? "—")</MudText></MudTd>
                        <MudTd>@context.RaisedBy</MudTd>
                        <MudTd>@context.RaisedAt.ToString("dd/MM/yy")</MudTd>
                        <MudTd><MudChip T="string" Size="Size.Small" Color="@CrStatusColor(context.Status)">@context.Status</MudChip></MudTd>
                        <MudTd>
                            @if (context.Status == "PendingApproval")
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.CheckCircle" Size="Size.Small" Color="Color.Success"
                                               OnClick="() => ApproveCr(context.ChangeRequestId)" Title="Approve" />
                                <MudIconButton Icon="@Icons.Material.Rounded.Cancel" Size="Size.Small" Color="Color.Error"
                                               OnClick="() => RejectCr(context.ChangeRequestId)" Title="Reject" />
                            }
                            @if (context.Status == "Draft")
                            {
                                <MudIconButton Icon="@Icons.Material.Rounded.Send" Size="Size.Small" Color="Color.Primary"
                                               OnClick="() => SubmitCr(context.ChangeRequestId)" Title="Submit for Approval" />
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudTabPanel>

    </MudTabs>
}

