@page "/invoices/myob-export"
@attribute [Authorize]
@inject InvoiceService InvoiceService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@using System.Security.Claims

<PageTitle>MYOB Export - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <a href="/invoices">Invoices</a><span class="sep">/</span>
            <span>MYOB Export</span>
        </div>
        <h1>MYOB Invoice Export</h1>
    </div>
    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Rounded.ArrowBack"
               Href="/invoices">Back to Invoices</MudButton>
</div>

<div style="max-width:640px;">
    <MudPaper Class="pa-6 mb-4" Elevation="1">
        <MudText Typo="Typo.body1" Class="mb-4">
            Exports all <strong>Issued</strong> invoices within the selected date range to a CSV
            compatible with MYOB AccountRight. Invoices will be marked as exported.
        </MudText>

        <MudGrid Spacing="3">
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_dateFrom" Label="From Date *" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_dateTo" Label="To Date *" Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        @if (_hasResult)
        {
            <MudAlert Severity="@(_exportCount > 0 ? Severity.Success : Severity.Info)" Class="mt-4">
                @if (_exportCount > 0)
                {
                    <span>@_exportCount invoice(s) exported. The CSV download should begin automatically.</span>
                }
                else
                {
                    <span>No issued invoices found in the selected date range.</span>
                }
            </MudAlert>
        }

        <div class="d-flex gap-2 mt-4">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Rounded.Output"
                       OnClick="ExportAsync" Disabled="@(_exporting || !_dateFrom.HasValue || !_dateTo.HasValue)">
                @(_exporting ? "Exporting…" : "Export to CSV")
            </MudButton>
        </div>
    </MudPaper>
</div>

@code {
    private DateTime? _dateFrom = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _dateTo   = DateTime.Today;
    private bool      _exporting;
    private bool      _hasResult;
    private int       _exportCount;
    private string    _userCode = "";

    protected override async Task OnInitializedAsync()
    {
        var auth  = await AuthStateProvider.GetAuthenticationStateAsync();
        _userCode = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
    }

    private async Task ExportAsync()
    {
        if (!_dateFrom.HasValue || !_dateTo.HasValue) return;
        _exporting   = true;
        _hasResult   = false;
        _exportCount = 0;
        try
        {
            var (bytes, count) = await InvoiceService.ExportToMYOBAsync(
                _dateFrom.Value, _dateTo.Value, _userCode);

            _hasResult   = true;
            _exportCount = count;

            if (count > 0)
            {
                var b64  = Convert.ToBase64String(bytes);
                var name = $"myob-export-{_dateFrom.Value:yyyyMMdd}-{_dateTo.Value:yyyyMMdd}.csv";
                await JS.InvokeVoidAsync("downloadBase64File", b64, "text/csv", name);
            }
        }
        catch (Exception ex) { Snackbar.Add($"Export failed: {ex.Message}", Severity.Error); }
        finally { _exporting = false; }
    }
}

