@using MyDesk.Shared.Models
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form">
            <MudTextField T="string" @bind-Value="_expense.SupplierName" Label="Supplier" Required="true" RequiredError="Supplier is required" Variant="Variant.Outlined" FullWidth="true" Class="mb-4" />
            <MudTextField T="string" @bind-Value="_expense.Description" Label="Description" Required="true" RequiredError="Description is required" Variant="Variant.Outlined" FullWidth="true" Class="mb-4" />
            <MudTextField T="decimal" @bind-Value="_expense.Amount" Label="Amount (ex GST)" Variant="Variant.Outlined" FullWidth="true" Class="mb-4" Adornment="Adornment.Start" AdornmentText="$" />
            <MudTextField T="decimal" @bind-Value="_expense.GST" Label="GST" Variant="Variant.Outlined" FullWidth="true" Class="mb-4" Adornment="Adornment.Start" AdornmentText="$" />
            <MudSelect T="string" @bind-Value="_expense.Category" Label="Category" Variant="Variant.Outlined" FullWidth="true" Class="mb-4">
                @foreach (var cat in _categories)
                {
                    <MudSelectItem Value="@cat">@cat</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="string" @bind-Value="_expense.Status" Label="Status" Variant="Variant.Outlined" FullWidth="true" Class="mb-4">
                @foreach (var status in _statuses)
                {
                    <MudSelectItem Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
            <MudTextField T="DateTime" @bind-Value="_expense.Date" Label="Date" Variant="Variant.Outlined" FullWidth="true" Class="mb-4" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Expense? Expense { get; set; }

    private MudForm? _form;
    private Expense _expense = new();
    private readonly string[] _categories = { "General", "Software", "Hardware", "Office Supplies", "Travel", "Marketing", "Utilities", "Rent" };
    private readonly string[] _statuses = { "Pending", "Approved", "Paid", "Rejected" };

    protected override void OnInitialized()
    {
        _expense = Expense ?? new Expense();
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        _expense.Total = _expense.Amount + _expense.GST;
        MudDialog.Close(DialogResult.Ok(_expense));
    }
}
