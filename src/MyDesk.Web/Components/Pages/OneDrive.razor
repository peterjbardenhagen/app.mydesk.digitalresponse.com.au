@page "/onedrive"
@attribute [Authorize]
@inject PlatformSettingsService PlatformSettings
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>OneDrive - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">Dashboard</a><span class="sep">/</span>
            <span>OneDrive</span>
        </div>
        <h1>OneDrive Files</h1>
        <p class="tl-subtitle">Access your OneDrive documents and files</p>
    </div>
</div>

@if (!_oneDriveConnected)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-4">
        OneDrive is not connected. Please configure your OneDrive integration in 
        <MudLink Href="/integrations">Settings → Integrations</MudLink>
    </MudAlert>
}
else
{
    <MudPaper Elevation="1" Class="pa-6 mt-4">
        <MudText Typo="Typo.h6" Class="mb-4">Your OneDrive Files</MudText>
        
        @if (_loading)
        {
            <div class="d-flex justify-center pa-8">
                <MudProgressCircular Size="Size.Large" Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (_files?.Count > 0)
        {
            <MudTable Items="_files" Hover="true" Dense="true" Striped="true">
                <HeaderContent>
                    <MudTh>File Name</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Size</MudTh>
                    <MudTh>Modified</MudTh>
                    <MudTh>Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@GetFileIcon(context.Name)" Size="Size.Small" />
                            @context.Name
                        </div>
                    </MudTd>
                    <MudTd>@GetFileType(context.Name)</MudTd>
                    <MudTd>@FormatFileSize(context.Size)</MudTd>
                    <MudTd>@context.ModifiedTime?.ToString("MMM dd, yyyy HH:mm")</MudTd>
                    <MudTd>
                        <MudLink Href="@context.WebUrl" Target="_blank">
                            <MudIcon Icon="@Icons.Material.Rounded.OpenInNew" Size="Size.Small" />
                        </MudLink>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                No files found in your OneDrive. Your OneDrive files will appear here once they are synced.
            </MudAlert>
        }
    </MudPaper>

    <MudPaper Elevation="0" Class="pa-4 mt-4">
        <MudText Typo="Typo.caption" Class="text-muted">
            💡 <strong>Tip:</strong> OneDrive files are automatically synced. You can also manage your OneDrive integration in 
            <MudLink Href="/integrations">Settings</MudLink> to control sync frequency and file types.
        </MudText>
    </MudPaper>
}

@code {
    private bool _oneDriveConnected = false;
    private bool _loading = false;
    private List<OneDriveFile>? _files;

    private class OneDriveFile
    {
        public string Name { get; set; } = "";
        public string? Type { get; set; }
        public long Size { get; set; }
        public DateTime? ModifiedTime { get; set; }
        public string? WebUrl { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var settings = PlatformSettings.Current;
            
            if (settings?.MyOutlookUserConnections != null)
            {
                var userCodeClaim = auth.User.FindFirst("user_code")?.Value;
                if (!string.IsNullOrWhiteSpace(userCodeClaim) && 
                    settings.MyOutlookUserConnections.TryGetValue(userCodeClaim, out var conn))
                {
                    _oneDriveConnected = conn.Enabled && conn.SyncDrive;
                    
                    if (_oneDriveConnected)
                    {
                        await LoadOneDriveFilesAsync();
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking OneDrive connection: {ex.Message}");
        }
    }

    private async Task LoadOneDriveFilesAsync()
    {
        _loading = true;
        try
        {
            // TODO: Implement actual OneDrive API integration
            // For now, return empty list with placeholder structure
            _files = new List<OneDriveFile>();
            
            // This would normally call Microsoft Graph API to fetch OneDrive files
            // Example implementation would use:
            // - HttpClient with Bearer token from Microsoft Identity
            // - Microsoft.Graph SDK
            // - Endpoint: https://graph.microsoft.com/v1.0/me/drive/root/children
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading OneDrive files: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetFileIcon(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName).ToLower();
        return ext switch
        {
            ".pdf" => Icons.Material.Rounded.PictureAsPdf,
            ".doc" or ".docx" or ".txt" => Icons.Material.Rounded.Description,
            ".xls" or ".xlsx" or ".csv" => Icons.Material.Rounded.TableChart,
            ".ppt" or ".pptx" => Icons.Material.Rounded.Slideshow,
            ".jpg" or ".jpeg" or ".png" or ".gif" or ".bmp" => Icons.Material.Rounded.Image,
            ".zip" or ".rar" or ".7z" => Icons.Material.Rounded.FolderZip,
            ".mp4" or ".avi" or ".mov" or ".mkv" => Icons.Material.Rounded.VideoLibrary,
            ".mp3" or ".wav" or ".flac" => Icons.Material.Rounded.AudioFile,
            _ => Icons.Material.Rounded.InsertDriveFile
        };
    }

    private string GetFileType(string fileName)
    {
        var ext = System.IO.Path.GetExtension(fileName).ToLower();
        return ext.TrimStart('.').ToUpper();
    }

    private string FormatFileSize(long bytes)
    {
        string[] sizes = { "B", "KB", "MB", "GB" };
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len = len / 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }
}
