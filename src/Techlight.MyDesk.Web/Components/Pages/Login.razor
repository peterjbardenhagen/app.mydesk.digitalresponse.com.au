@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]

<div class="tl-login-root">
    <!-- LEFT: brand hero -->
    <aside class="tl-login-hero">
        <div class="tl-login-hero-brand">
            <img src="/images/techlight-logo.svg" alt="Techlight" />
        </div>

        <div class="tl-login-quote">
            <div class="q">Your complete sales & operations platform — quotes, invoices, purchase orders, and insights, all in one place.</div>
            <div class="by">Techlight MyDesk &middot; Powered by Digital Response</div>
        </div>

        <div style="position:relative; z-index:1; font-size:12px; color:var(--gray-400);">
            &copy; @DateTime.Now.Year Techlight. All rights reserved.
        </div>
    </aside>

    <!-- RIGHT: form -->
    <section class="tl-login-form">
        <div class="tl-login-form-inner">
            <img src="/images/techlight-mark.svg" alt="" class="tl-mark" />
            <h1>Welcome back</h1>
            <p class="sub">Sign in to your Techlight MyDesk account</p>

            @if (ShowError)
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" Variant="Variant.Outlined">
                    Invalid login credentials. Please try again.
                </MudAlert>
            }

            <form method="post" action="/api/auth/login">
                <AntiforgeryToken />

                <MudTextField T="string" name="login" Label="Username"
                              Variant="Variant.Outlined" Margin="Margin.Normal"
                              HelperText="Your full name or user code"
                              Required="true" FullWidth="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Rounded.PersonOutline" />

                <MudTextField T="string" name="password" Label="Password" InputType="InputType.Password"
                              Variant="Variant.Outlined" Margin="Margin.Normal"
                              Required="true" FullWidth="true" Class="mb-4"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Rounded.Lock" />

                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                           Size="Size.Large" FullWidth="true">
                    Sign in
                </MudButton>
            </form>

            <div class="tl-login-footer">
                Need help? Contact your administrator.
            </div>
        </div>
    </section>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private bool ShowError => Error == "1";
}
