@page "/supplier-quotes"
@attribute [Authorize]

<PageTitle>Supplier Quote AI Automation - MyDesk</PageTitle>

<div class="tl-page-header">
    <div>
        <div class="tl-breadcrumb">
            <a href="/">MyDesk</a><span class="sep">/</span>
            <span style="color:var(--gray-700);font-weight:500;">Supplier Quote Automation</span>
        </div>
        <h1>Supplier Quote AI Automation</h1>
        <MudText Typo="Typo.body1" Class="mt-1" Style="color:var(--gray-500);">Upload supplier quotes for automatic parsing into MyDesk line items</MudText>
    </div>
</div>

<MudPaper Class="pa-6 mb-4" Elevation="1">
    <MudText Typo="Typo.subtitle2" Class="mb-4" Style="color:var(--gray-500);text-transform:uppercase;letter-spacing:.05em;">How It Works</MudText>
    
    <MudTimeline>
        <MudTimelineItem Color="Color.Primary" Size="Size.Medium">
            <MudText><strong>1. Upload</strong> — Drag & drop supplier PDF quotes or images (JPG/PNG)</MudText>
        </MudTimelineItem>
        <MudTimelineItem Color="Color.Secondary" Size="Size.Medium">
            <MudText><strong>2. Extract</strong> — Azure Document Intelligence extracts text and tables</MudText>
        </MudTimelineItem>
        <MudTimelineItem Color="Color.Tertiary" Size="Size.Medium">
            <MudText><strong>3. Parse</strong> — AI identifies line items, costs, and descriptions</MudText>
        </MudTimelineItem>
        <MudTimelineItem Color="Color.Info" Size="Size.Medium">
            <MudText><strong>4. Create Quote</strong> — Pre-populated quote with GP margin applied</MudText>
        </MudTimelineItem>
        <MudTimelineItem Color="Color.Success" Size="Size.Medium">
            <MudText><strong>5. Review & Send</strong> — Validate pricing with AI assistant</MudText>
        </MudTimelineItem>
    </MudTimeline>
</MudPaper>

<MudPaper Class="pa-6 mb-4" Elevation="1">
    <MudText Typo="Typo.subtitle2" Class="mb-4" Style="color:var(--gray-500);text-transform:uppercase;letter-spacing:.05em;">Key Features</MudText>
    
    <MudGrid Spacing="3">
        <MudItem xs="12" md="6">
            <MudList Dense="true">
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" Class="mr-2" /> Automatic cost extraction from supplier quotes</MudListItem>
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.Margin" Class="mr-2" /> GP margin auto-applied (30% default)</MudListItem>
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.Bolt" Class="mr-2" /> Supports PDF, JPG, PNG, TIFF formats</MudListItem>
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.Verified" Class="mr-2" /> AI pricing validation before sending</MudListItem>
            </MudList>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudList Dense="true">
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.Source" Class="mr-2" /> Extracts supplier name, ABN, contact details</MudListItem>
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.TableView" Class="mr-2" /> Table-aware parsing preserves structure</MudDivider>
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.Edit" Class="mr-2" /> Manual line-item editing before save</MudListItem>
                <MudListItem><MudIcon Icon="@Icons.Material.Rounded.Sync" Class="mr-2" /> Integrates with QuickBooks via Composio</MudListItem>
            </MudList>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-6" Elevation="1">
    <MudText Typo="Typo.subtitle2" Class="mb-3" Style="color:var(--gray-500);text-transform:uppercase;letter-spacing:.05em;">Demo Screenshot</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">
        The AI extracted these line items from a Clipsal supplier quote in under 10 seconds:
    </MudText>
    
    <MudTable T="SupplierQuoteDemo" Items="_demoLines" Dense="true" Hover="true">
        <HeaderContent>
            <MudTh>Type</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Qty</MudTh>
            <MudTh>Supplier Cost</MudTh>
            <MudTh>MyDesk Price</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.Type</MudChip></MudTd>
            <MudTd>@context.Description</MudTd>
            <MudTd>@context.Quantity.ToString("N2")</MudTd>
            <MudTd>$@context.UnitCost.ToString("N2")</MudTd>
            <MudTd Style="font-weight:600;">$@context.NettPrice.ToString("N2")</MudTd>
        </RowTemplate>
    </MudTable>
    
    <MudDivider Class="my-4" />
    
    <MudText Typo="Typo.body2">
        <strong>Benefits:</strong> 90% reduction in quote creation time, automatic GP margin enforcement, 
        instant validation against market pricing.
    </MudText>
</MudPaper>

@code {
    private List<SupplierQuoteDemo> _demoLines = new()
    {
        new() { Type = "Supply", Description = "Clipsal Saturn 2 Gang Switch Plate", Quantity = 4, UnitCost = 24.95m, NettPrice = 35.64m },
        new() { Type = "Supply", Description = "Clipsal Saturn Single Switch Mechanism", Quantity = 4, UnitCost = 18.50m, NettPrice = 25.71m },
        new() { Type = "Labour", Description = "Switch installation (licensed electrician)", Quantity = 2, UnitCost = 85.00m, NettPrice = 123.81m },
        new() { Type = "Delivery", Description = "Metro delivery", Quantity = 1, UnitCost = 35.00m, NettPrice = 50.00m }
    };

    public class SupplierQuoteDemo
    {
        public string Type { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Quantity { get; set; }
        public decimal UnitCost { get; set; }
        public decimal NettPrice { get; set; }
    }
}