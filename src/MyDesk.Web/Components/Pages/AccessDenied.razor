@page "/access-denied"
@inject NavigationManager Navigation

<PageTitle>Access Denied - MyDesk</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16 text-center">
    <MudIcon Icon="@Icons.Material.Rounded.Security" Color="Color.Error" Style="font-size: 64px;" Class="mb-4" />
    <MudText Typo="Typo.h4" Class="mb-4">Access Denied</MudText>
    <MudText Typo="Typo.body1" Class="text-muted mb-8">
        You do not have permission to view this page. If you believe you should have access, please contact your administrator.
    </MudText>
    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="@(() => Navigation.NavigateTo("/"))">
        Return to Dashboard
    </MudButton>
</MudContainer>


