@page "/login"
@layout EmptyLayout
@attribute [AllowAnonymous]
@inject PlatformSettingsService PlatformSettings
@inject IJSRuntime JS
@inject IHttpContextAccessor HttpContextAccessor
@inject PlatformSettingsService PlatformSvc

<PageTitle>Login - @PlatformSettings.GetBrandingName()</PageTitle>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    public string? Username { get; set; }
    public string? Password { get; set; }
    public bool RememberMe { get; set; } = true;

    private bool ShowError => Error == "1";
    private bool _isDarkMode;
    private PlatformSettingsService.LoginColorScheme? _colorScheme;

    protected override async Task OnInitializedAsync()
    {
        var host = HttpContextAccessor.HttpContext?.Request?.Host.Host;
        if (!string.IsNullOrWhiteSpace(host))
            await PlatformSettings.LoadForHostAsync(host);

        _colorScheme = await PlatformSvc.GetLoginColorSchemeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var darkPref = await JS.InvokeAsync<string?>("localStorage.getItem", "mydesk_dark_mode");
                _isDarkMode = darkPref == "1";
                if (_isDarkMode)
                {
                    await JS.InvokeVoidAsync("eval", "document.body.classList.add('mud-dark-mode');");
                    StateHasChanged();
                }
            }
            catch { /* localStorage may not be available during pre-render */ }
        }
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        if (_isDarkMode)
        {
            await JS.InvokeVoidAsync("eval", "document.body.classList.add('mud-dark-mode'); localStorage.setItem('mydesk_dark_mode','1');");
        }
        else
        {
            await JS.InvokeVoidAsync("eval", "document.body.classList.remove('mud-dark-mode'); localStorage.removeItem('mydesk_dark_mode');");
        }
    }

    private async Task LoadSavedCredentialsAsync()
    {
        try
        {
            var savedUsername = await JS.InvokeAsync<string>("localStorage.getItem", "mydesk_username");
            var savedRemember = await JS.InvokeAsync<string>("localStorage.getItem", "mydesk_remember");
            
            if (!string.IsNullOrEmpty(savedUsername) && savedRemember == "true")
            {
                Username = savedUsername;
                RememberMe = true;
            }
        }
        catch
        {
            // Ignore errors - localStorage may not be available
        }
    }
}

<div class="tl-login-root @(_isDarkMode ? "dark-mode" : "")">
    <!-- LEFT: Brand Hero -->
    <aside class="tl-login-hero" style="background: linear-gradient(135deg, @(_colorScheme?.PrimaryColor ?? PlatformSettings.Current.LoginPrimaryColor ?? "#1e40af") 0%, @(_colorScheme?.AccentColor ?? PlatformSettings.Current.LoginAccentColor ?? "#0ea5e9") 100%);">
        <div class="tl-login-hero-inner">
            <div class="tl-login-hero-brand">
                <a href="@PlatformSettings.Current.CompanyWebsite" target="_blank" rel="noreferrer">
                    <img src="@PlatformSettings.Current.LoginLogoUrl" alt="@PlatformSettings.Current.PlatformName" class="hero-logo" onerror="this.onerror=null;this.src='/images/mydesk-logo-white-text.svg';" />
                </a>
            </div>

            <div class="tl-login-quote-wrap">
                <div class="tl-quote-icon">
                    <MudIcon Icon="@Icons.Material.Rounded.FormatQuote" Size="Size.Large" Color="Color.Inherit" />
                </div>
                @if (!string.IsNullOrEmpty(PlatformSettings.Current.LoginQuote))
                {
                    <h2 class="tl-login-quote-text">
                        "@PlatformSettings.Current.LoginQuote"
                    </h2>
                    <div class="tl-login-quote-author">
                        <span>@PlatformSettings.Current.LoginQuoteAuthor &middot; <span class="accent-text">@PlatformSettings.Current.LoginQuoteLabel</span></span>
                    </div>
                }
                else
                {
                    <h2 class="tl-login-quote-text">
                        "Simplicity is the ultimate sophistication."
                    </h2>
                    <div class="tl-login-quote-author">
                        <span>Leonardo da Vinci &middot; <span class="accent-text">Design Philosophy</span></span>
                    </div>
                }
            </div>

            <div class="tl-login-hero-footer">
                <div class="legal-links-white">
                    <MudLink Href="https://mydesk.digitalresponse.com.au/privacy.html" Target="_blank" Typo="Typo.caption">Privacy Policy</MudLink>
                    <span class="mx-2 opacity-30">|</span>
                    <MudLink Href="https://mydesk.digitalresponse.com.au/terms.html" Target="_blank" Typo="Typo.caption">Terms & Conditions</MudLink>
                </div>
                    <div class="copyright-text">
                        &copy; @DateTime.Now.Year @(_colorScheme?.CopyrightText ?? "Digital Response. All rights reserved.")
                    </div>
            </div>
        </div>
        
        <!-- Decorative Elements -->
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
        <div class="hero-grid-pattern"></div>
    </aside>

    <!-- RIGHT: Login Form -->
    <section class="tl-login-form-area">
        <div class="tl-login-form-container">
            <div class="tl-form-card">
                <div class="d-flex justify-end">
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Rounded.LightMode : Icons.Material.Rounded.DarkMode)" 
                                   OnClick="ToggleDarkMode" />
                </div>
                <div class="tl-form-header">
                    <div class="tl-mark-container">
                        <img src="@PlatformSettings.Current.LoginMarkUrl" alt="" class="tl-form-mark" onerror="this.onerror=null;this.src='/images/techlight-mark.svg';" />
                    </div>
                    <h1>@(_colorScheme?.Heading ?? PlatformSettings.Current.LoginHeading)</h1>
                    <p class="sub-text">@(_colorScheme?.Subheading ?? PlatformSettings.Current.LoginSubheading)</p>
                </div>

                @if (ShowError)
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-6 rounded-lg" Variant="Variant.Filled">
                        Invalid login credentials. Please try again.
                    </MudAlert>
                }

                <form method="post" action="/api/auth/login" class="login-auth-form">
                    <AntiforgeryToken />

                    <div class="field-wrap">
                        <label>Username</label>
                        <MudTextField @bind-Value="Username" name="login" 
                                       Placeholder="e.g. john.doe"
                                       Variant="Variant.Outlined" 
                                       Margin="Margin.Normal"
                                       Required="true" FullWidth="true"
                                       Adornment="Adornment.Start"
                                       AdornmentIcon="@Icons.Material.Rounded.AlternateEmail"
                                       AdornmentColor="Color.Primary" />
                    </div>

                    <div class="field-wrap mt-4">
                        <div class="d-flex justify-space-between align-center">
                            <label>Password</label>
                            <MudLink Href="/forgot-password" Typo="Typo.caption" Color="Color.Primary" Class="fw-600">Forgot password?</MudLink>
                        </div>
                        <MudTextField @bind-Value="Password" name="password" 
                                       InputType="InputType.Password"
                                       Placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;"
                                       Variant="Variant.Outlined" 
                                       Margin="Margin.Normal"
                                       Required="true" FullWidth="true"
                                       Adornment="Adornment.Start"
                                       AdornmentIcon="@Icons.Material.Rounded.LockPerson"
                                       AdornmentColor="Color.Primary" />
                    </div>

                    <MudCheckBox @bind-Value="RememberMe" Label="Remember for 30 days" Color="Color.Primary" Dense="true" Class="mt-2 mb-6" />
                    <input type="hidden" name="rememberMe" value="@(RememberMe ? "on" : "off")" />

                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                                Size="Size.Large" FullWidth="true" Class="py-3 rounded-xl submit-btn"
                                id="submit-btn">
                        Sign in to MyDesk
                    </MudButton>
                </form>

                <div class="tl-form-footer">
                    @{
                        var supportEmail = _colorScheme?.SupportEmail ?? "support@digitalresponse.com.au";
                        var mailtoLink = "mailto:" + supportEmail;
                    }
                    <p>Having trouble? <MudLink Href="@mailtoLink" Color="Color.Primary" Underline="Underline.Hover">Contact Support</MudLink></p>
                </div>

                <div class="portal-links-section mt-6">
                    <MudDivider Class="mb-4" />
                    <MudText Typo="Typo.caption" Color="Color.Default" Align="Align.Center">
                        Are you a customer or supplier?
                    </MudText>
                    <div class="d-flex justify-center gap-3 mt-2">
                        <MudLink Href="/customer-login" Color="Color.Primary" Underline="Underline.Hover">
                            Customer Portal
                        </MudLink>
                        <MudText Typo="Typo.caption" Color="Color.Default">|</MudText>
                        <MudLink Href="/supplier-login" Color="Color.Primary" Underline="Underline.Hover">
                            Supplier Portal
                        </MudLink>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>

@* Fix IIS login issue: ensure cookies work properly *@
<script>
    document.querySelector('.login-auth-form')?.addEventListener('submit', function(e) {
        const username = document.querySelector('input[name="login"]')?.value;
        const remember = document.querySelector('input[name="rememberMe"]')?.checked;
        if (remember && username) {
            localStorage.setItem('mydesk_username', username);
            localStorage.setItem('mydesk_remember', 'true');
        } else {
            localStorage.removeItem('mydesk_username');
            localStorage.removeItem('mydesk_remember');
        }
    });
</script>
