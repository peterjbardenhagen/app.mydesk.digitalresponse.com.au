@using MyDesk.Shared.Models
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent><MudText Typo="Typo.h6">Credential</MudText></TitleContent>
    <DialogContent><MudText>Credential dialog stub</MudText></DialogContent>
    <DialogActions><MudButton OnClick="Cancel">Close</MudButton></DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public SystemCredential? Credential { get; set; }
    private void Cancel() => MudDialog.Cancel();
}
