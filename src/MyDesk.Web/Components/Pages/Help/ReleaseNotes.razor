@page "/release-notes"
@inject PlatformSettingsService PlatformSettings

<PageTitle>Release Notes - @PlatformSettings.GetBrandingName()</PageTitle>

<div class="release-notes-page">
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-6">
        <div class="mb-6">
            <div class="d-flex align-center gap-3 mb-2">
                <MudIcon Icon="@Icons.Material.Rounded.NewReleases" Size="Size.Large" Color="Color.Primary" />
                <MudText Typo="Typo.h3">Release Notes</MudText>
            </div>
            <MudText Typo="Typo.body1" Class="mud-text-secondary">
                Track what's new in @PlatformSettings.Current.PlatformName. We ship updates regularly to bring you the best business management experience.
            </MudText>
        </div>

        @* ── v3.2 – Current ── *@
        <MudPaper Elevation="0" Class="release-card current-release mb-6">
            <div class="release-header">
                <div class="d-flex align-center gap-3">
                    <MudChip T="string" Color="Color.Primary"  Size="Size.Small" Variant="Variant.Filled">v3.2</MudChip>
                    <MudChip T="string" Color="Color.Success"  Size="Size.Small" Variant="Variant.Text">Current</MudChip>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Released May 2026</MudText>
                </div>
                <MudText Typo="Typo.h4" Class="mt-3">🏢 MyDesk 3.2 – Multi-Tenancy, Super Admin & Login Overhaul</MudText>
                <MudText Typo="Typo.body1" Class="mt-2 mud-text-secondary">
                    Full multi-tenant architecture goes live for all users. Introduces the Super Administrator role, Tenant Settings management, a fully working login flow, dark-mode support, keyboard-navigable carousels, and a comprehensive round of database migration hardening.
                </MudText>
            </div>

            <div class="release-body">
                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.Domain" Color="Color.Primary" /> Multi-Tenancy — Live
                    </MudText>
                    <ul class="release-list">
                        <li><strong>Tenants table live:</strong> Every organisation is now a first-class tenant with its own isolated workspace (TenantId, Name, Slug, Plan, MaxUsers).</li>
                        <li><strong>Platform Settings per tenant:</strong> Branding (logo, colours, heading, tagline) is stored in <code>PlatformSettingsEntities</code> per tenant — no more shared config.</li>
                        <li><strong>Tenant selection at login:</strong> Users who belong to multiple workspaces see a clean "Select your workspace" screen before entering the platform.</li>
                        <li><strong>Seeded tenants:</strong> Techlight (<code>11111111...</code>) and Techlight UAT (<code>22222222...</code>) are seeded on first run.</li>
                        <li><strong>DB schema migration:</strong> Legacy <code>INT</code> TenantId automatically migrated to <code>UNIQUEIDENTIFIER</code>; missing columns back-filled; legacy unique constraints dropped.</li>
                        <li><strong>UserTenants:</strong> All existing users auto-assigned to the Techlight tenant on startup.</li>
                    </ul>
                </div>

                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.AdminPanelSettings" Color="Color.Primary" /> Super Administrator Role
                    </MudText>
                    <ul class="release-list">
                        <li><strong>New UserType:</strong> "Super Administrator" (UserTypeId = 5) added — superset of Administrator with Tenant management capability.</li>
                        <li><strong>Claims issued:</strong> Super Admins receive <code>SuperAdministrator</code>, <code>Administrator</code>, and <code>Director</code> role claims — full access to everything plus the new Tenant Settings page.</li>
                        <li><strong>Tenant Settings page:</strong> <code>/admin/tenants</code> — list, create and edit tenants. Gated exclusively to SuperAdministrator role.</li>
                        <li><strong>Quick Nav shortcut:</strong> "Tenant Settings" appears in Quick Access (with divider and amber highlight) only for Super Admins.</li>
                        <li><strong>Admin nav:</strong> Tenant Settings also appears in the Admin section nav above Platform Settings for Super Admins.</li>
                    </ul>
                </div>

                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.Login" Color="Color.Primary" /> Login Page Overhaul
                    </MudText>
                    <ul class="release-list">
                        <li><strong>Correct Techlight logo:</strong> Hero panel now displays the real Techlight SVG logo downloaded directly from <code>techlight.com.au</code>.</li>
                        <li><strong>Dark mode toggle:</strong> The moon/sun icon button now actually works — switches a full set of dark-mode CSS variables covering the card, inputs, labels, MudBlazor components and icon colours.</li>
                        <li><strong>Dark mode persisted:</strong> Preference stored in <code>localStorage</code> under <code>mydesk_dark_mode</code> and restored on next page load via <code>OnAfterRenderAsync</code>.</li>
                        <li><strong>Login fixed end-to-end:</strong> Resolved tenant JOIN returning empty (Tenants rows missing), unique-constraint violations on nullable columns, and wrong UserTypeId mappings in AuthService.</li>
                        <li><strong>UserType mapping corrected:</strong> AuthService now maps DB values correctly (3=Director, 4=Administrator, 5=SuperAdministrator) instead of the legacy 1/2 hardcode.</li>
                        <li><strong>UserTypeId claim:</strong> Raw <code>UserTypeId</code> is now included as a claim for downstream use.</li>
                    </ul>
                </div>

                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.Keyboard" Color="Color.Primary" /> Keyboard Navigation & UX
                    </MudText>
                    <ul class="release-list">
                        <li><strong>Arrow key carousel:</strong> Project detail popups on <code>/projects</code> now respond to <kbd>←</kbd> and <kbd>→</kbd> keys to navigate the image carousel — in addition to existing click buttons.</li>
                        <li><strong>Keyboard hint shown:</strong> A subtle <kbd>←</kbd> <kbd>→</kbd> "keyboard to browse images" hint appears in the dialog panel when a carousel has more than one image.</li>
                        <li><strong>Index reset on open:</strong> Each time a project dialog opens the carousel resets to image 0.</li>
                    </ul>
                </div>

                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.BugReport" Color="Color.Primary" /> Stability & Migration Fixes
                    </MudText>
                    <ul class="release-list">
                        <li><strong>PermissionService DI fixed:</strong> Singleton consuming a scoped <code>DatabaseService</code> caused a fatal startup crash — resolved by injecting <code>IServiceScopeFactory</code> and creating scopes on demand.</li>
                        <li><strong>018_MultiTenant.sql hardened:</strong> <code>Slug</code>, <code>IsAdmin</code>, <code>UserRole</code> column errors and duplicate-cursor errors fixed; user-role assignment now uses <code>UserTypeId</code> (correct column) via dynamic SQL.</li>
                        <li><strong>Tenants schema back-fill:</strong> <code>AddMissingColumnsAsync</code> adds <code>Country</code>, <code>MaxUsers</code>, <code>StorageLimitMB</code>, <code>SubscriptionPlan</code>, <code>Slug</code>, <code>Name</code> etc. idempotently to legacy tables.</li>
                        <li><strong>FK constraint resilience:</strong> PlatformSettingsEntities foreign key creation wrapped in <code>BEGIN TRY / END CATCH</code> so startup never fails on type mismatch.</li>
                        <li><strong>Port-in-use errors:</strong> Run.bat option 4 kills any process already on port 5237 before launching Kestrel.</li>
                        <li><strong>Zero build warnings:</strong> All compiler and MudBlazor analyzer warnings resolved.</li>
                    </ul>
                </div>

                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.Book" Color="Color.Primary" /> Documentation & Developer Experience
                    </MudText>
                    <ul class="release-list">
                        <li><strong>AGENTS.md rewritten:</strong> Comprehensive autonomous developer guide — login credentials, tenant GUIDs, DB fix scripts, Kestrel startup procedure, common error→fix lookup table, and file location reference all in one place.</li>
                        <li><strong>Run.bat option [0]:</strong> Opens AGENTS.md directly from the launcher menu.</li>
                        <li><strong>Self-healing upgraded to Gemini 2.5 Flash:</strong> AI-powered error fixing in <code>Run.ps1 -SelfHealing</code> now uses Google's latest model.</li>
                        <li><strong>Release Notes &amp; Help Centre refreshed:</strong> This document, plus the Help Centre quick-start cards and FAQs, updated to reflect v3.2 features.</li>
                    </ul>
                </div>
            </div>
        </MudPaper>

        @* ── v3.1 ── *@
        <MudPaper Elevation="0" Class="release-card mb-6">
            <div class="release-header">
                <div class="d-flex align-center gap-3">
                    <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">v3.1</MudChip>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Released 3 May 2026</MudText>
                </div>
                <MudText Typo="Typo.h4" Class="mt-3">✨ MyDesk 3.1 – Subscriptions, Stability & Coverage</MudText>
                <MudText Typo="Typo.body1" Class="mt-2 mud-text-secondary">
                    Focused release closing long-standing usability bugs, adding a proper recurring-revenue module, and ensuring every page in the platform is reachable from the side navigation.
                </MudText>
            </div>
            <div class="release-body">
                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.Subscriptions" Color="Color.Primary" /> Subscription Management
                    </MudText>
                    <ul class="release-list">
                        <li><strong>Renamed from DRM:</strong> "DRM" → "Subscriptions" – recurring services like hosting, Office 365, domains, support contracts.</li>
                        <li><strong>One-click invoice raising:</strong> Raise Invoice instantly creates a customer invoice and rolls the renewal date forward.</li>
                        <li><strong>Multiple cadences:</strong> Weekly, fortnightly, monthly, quarterly, half-yearly, annual and biennial schedules.</li>
                        <li><strong>Upcoming renewals widget:</strong> Dashboard surfaces subscriptions due in the next 30 days.</li>
                    </ul>
                </div>
                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.BugReport" Color="Color.Primary" /> Stability Fixes
                    </MudText>
                    <ul class="release-list">
                        <li><strong>Dialog close fixed:</strong> Duplicated <code>MudDialogProvider</code> in layout removed — X, Close and click-outside now reliably close every popup.</li>
                        <li><strong>Build clean:</strong> All CS0246, CS4033, CS0105 warnings resolved.</li>
                        <li><strong>SQL migration 015 fixed:</strong> Duplicate <code>ExportedDate</code> column no longer breaks fresh deployments.</li>
                    </ul>
                </div>
                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.Menu" Color="Color.Primary" /> Navigation
                    </MudText>
                    <ul class="release-list">
                        <li><strong>Comprehensive Quick Nav:</strong> Timesheets, Staff Whereabouts, Projects, Subscriptions, Calendar, Call Reports, Help Centre, Release Notes and Roadmap all added.</li>
                        <li><strong>Sitemap page:</strong> <code>/sitemap</code> lists every route in the platform.</li>
                        <li><strong>Accounts hub:</strong> <code>/accounts</code> links Reconciliation, Aged Payables, MYOB Sync and Banking.</li>
                    </ul>
                </div>
                <div class="release-section">
                    <MudText Typo="Typo.h6" Class="release-category">
                        <MudIcon Icon="@Icons.Material.Rounded.Lock" Color="Color.Primary" /> Security & Permissions
                    </MudText>
                    <ul class="release-list">
                        <li><strong>Granular permission system:</strong> 80+ permissions across all modules, role-based defaults, UI-configurable permission matrix.</li>
                        <li><strong>Director restriction:</strong> Directors cannot view or edit Administrator accounts.</li>
                        <li><strong>robots.txt + X-Robots-Tag:</strong> All crawlers blocked across the entire platform.</li>
                    </ul>
                </div>
            </div>
        </MudPaper>

        @* ── v3.0 ── *@
        <MudPaper Elevation="0" Class="release-card mb-6">
            <div class="release-header">
                <div class="d-flex align-center gap-3">
                    <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">v3.0</MudChip>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Released 28 April 2026</MudText>
                </div>
                <MudText Typo="Typo.h4" Class="mt-3">🚀 MyDesk 3.0 – Complete Platform Transformation</MudText>
                <MudText Typo="Typo.body1" Class="mt-2 mud-text-secondary">
                    Re-platformed as a modern SaaS solution: new Techlight brand, AI-powered insights, multi-tenant architecture, .NET 10, and 72+ automated tests.
                </MudText>
            </div>
            <div class="release-body">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <div class="release-section">
                            <MudText Typo="Typo.h6" Class="release-category"><MudIcon Icon="@Icons.Material.Rounded.Palette" Color="Color.Primary" /> Brand &amp; Design</MudText>
                            <ul class="release-list">
                                <li>New Techlight brand — teal (#00c8c8) &amp; dark navy (#08121a)</li>
                                <li>Modern UI: dashboard, login, all major screens redesigned</li>
                                <li>Responsive across desktop, tablet and mobile</li>
                            </ul>
                        </div>
                        <div class="release-section">
                            <MudText Typo="Typo.h6" Class="release-category"><MudIcon Icon="@Icons.Material.Rounded.SmartToy" Color="Color.Primary" /> Ask AI Assistant</MudText>
                            <ul class="release-list">
                                <li>Natural language queries against live business data</li>
                                <li>Context-aware: respects division, permissions, history</li>
                                <li>Powered by Azure OpenAI GPT</li>
                            </ul>
                        </div>
                        <div class="release-section">
                            <MudText Typo="Typo.h6" Class="release-category"><MudIcon Icon="@Icons.Material.Rounded.ContentCopy" Color="Color.Primary" /> Copy Supplier Quote</MudText>
                            <ul class="release-list">
                                <li>AI extracts line items from supplier PDF/image</li>
                                <li>30% gross profit margin applied automatically</li>
                                <li>Draft quote ready for review in one step</li>
                            </ul>
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <div class="release-section">
                            <MudText Typo="Typo.h6" Class="release-category"><MudIcon Icon="@Icons.Material.Rounded.Business" Color="Color.Primary" /> Customer &amp; Supplier Portals</MudText>
                            <ul class="release-list">
                                <li>Self-service portals for customers and suppliers</li>
                                <li>Per-contact portal enablement with expiry dates</li>
                            </ul>
                        </div>
                        <div class="release-section">
                            <MudText Typo="Typo.h6" Class="release-category"><MudIcon Icon="@Icons.Material.Rounded.AccountTree" Color="Color.Primary" /> Accounting Integration</MudText>
                            <ul class="release-list">
                                <li>MYOB bi-directional sync for invoices &amp; payments</li>
                                <li>Reconciliation dashboard with conflict resolution</li>
                            </ul>
                        </div>
                        <div class="release-section">
                            <MudText Typo="Typo.h6" Class="release-category"><MudIcon Icon="@Icons.Material.Rounded.Speed" Color="Color.Primary" /> Platform</MudText>
                            <ul class="release-list">
                                <li>.NET 10 + MudBlazor 7.x — latest, fastest stack</li>
                                <li>Serilog structured logging to rolling daily files</li>
                                <li>72+ Playwright E2E tests, CI/CD pipeline</li>
                            </ul>
                        </div>
                    </MudItem>
                </MudGrid>
            </div>
        </MudPaper>

        @* ── Previous releases ── *@
        <MudGrid>
            @foreach (var rel in _previousReleases)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudPaper Elevation="0" Class="release-card mb-4" Style="height:100%;">
                        <div class="release-header-compact">
                            <div class="d-flex align-center gap-2">
                                <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">@rel.Version</MudChip>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">@rel.Date</MudText>
                            </div>
                            <MudText Typo="Typo.h6" Class="mt-2">@rel.Title</MudText>
                        </div>
                        <div class="release-body" Style="padding: 16px 20px;">
                            <ul class="release-list">
                                @foreach (var item in rel.Items)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        @* ── Coming Soon ── *@
        <MudPaper Elevation="0" Class="release-card upcoming-card mt-6">
            <div class="release-header-compact">
                <div class="d-flex align-center gap-3">
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">Coming Soon</MudChip>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">v3.3 – Q3 2026</MudText>
                </div>
                <MudText Typo="Typo.h5" Class="mt-2">🔮 What's Next</MudText>
            </div>
            <div class="release-body">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <ul class="release-list">
                            <li><strong>Mobile App:</strong> Native iOS &amp; Android for field sales</li>
                            <li><strong>Xero Integration:</strong> Add Xero alongside MYOB</li>
                            <li><strong>SSO:</strong> Microsoft Entra ID &amp; Google Workspace</li>
                            <li><strong>API Platform:</strong> Public REST API for integrations</li>
                        </ul>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <ul class="release-list">
                            <li><strong>STP Phase 2:</strong> Single Touch Payroll payroll integration</li>
                            <li><strong>BAS / GST:</strong> Automated BAS preparation</li>
                            <li><strong>Advanced Analytics:</strong> ML-powered revenue forecasting</li>
                            <li><strong>Telegram Bot:</strong> Quote approvals via Telegram</li>
                        </ul>
                    </MudItem>
                </MudGrid>
            </div>
        </MudPaper>

        <MudText Typo="Typo.body2" Align="Align.Center" Class="mt-6 mud-text-secondary">
            Have feedback or feature requests? Email us at
            <MudLink Href="@($"mailto:{PlatformSettings.Current.SupportEmail}")">@PlatformSettings.Current.SupportEmail</MudLink>
        </MudText>
    </MudContainer>
</div>

<style>
    .release-notes-page { min-height: calc(100vh - 120px); }
    .release-card { background: white; border-radius: 12px; overflow: hidden; border: 1px solid rgba(0,0,0,0.06); }
    .current-release { border: 2px solid var(--tl-primary, #00c8c8); box-shadow: 0 8px 32px rgba(0,200,200,0.15); }
    .upcoming-card { background: linear-gradient(135deg, #fff9e6 0%, #ffffff 100%); border: 1px dashed #f59e0b; }
    .release-header { padding: 24px 32px; background: linear-gradient(135deg, #f0fdfa 0%, #ffffff 100%); border-bottom: 1px solid rgba(0,0,0,0.06); }
    .release-header-compact { padding: 20px 24px; border-bottom: 1px solid rgba(0,0,0,0.04); }
    .release-body { padding: 24px 32px; }
    .release-section { margin-bottom: 24px; }
    .release-section:last-child { margin-bottom: 0; }
    .release-category { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; color: var(--tl-dark, #08121a); }
    .release-list { margin: 0; padding-left: 20px; }
    .release-list li { margin-bottom: 8px; line-height: 1.6; color: #4b5563; }
    .release-list li strong { color: #111827; }
    code { background: #f3f4f6; padding: 2px 6px; border-radius: 4px; font-size: 0.85em; font-family: 'Consolas', 'Monaco', monospace; }
    kbd { display: inline-flex; align-items: center; border: 1px solid #d1d5db; border-radius: 4px; padding: 1px 6px; font-size: 0.8em; font-family: monospace; background: #f9fafb; color: #374151; }

    /* Dark mode */
    body.mud-dark-mode .release-card,
    .mud-dark-mode .release-card { background: var(--gray-100); border-color: var(--gray-300); }
    body.mud-dark-mode .upcoming-card,
    .mud-dark-mode .upcoming-card { background: linear-gradient(135deg, rgba(245,158,11,0.12) 0%, var(--gray-100) 100%); border-color: rgba(245,158,11,0.50); }
    body.mud-dark-mode .release-header,
    .mud-dark-mode .release-header { background: linear-gradient(135deg, rgba(20,184,166,0.10) 0%, var(--gray-100) 100%); border-bottom-color: var(--gray-300); }
    body.mud-dark-mode .release-list li,
    .mud-dark-mode .release-list li { color: var(--gray-700); }
    body.mud-dark-mode .release-list li strong,
    .mud-dark-mode .release-list li strong { color: var(--gray-900); }
    body.mud-dark-mode code,
    .mud-dark-mode code { background: var(--gray-200); color: var(--gray-900); }
    body.mud-dark-mode kbd,
    .mud-dark-mode kbd { background: var(--gray-200); color: var(--gray-900); border-color: var(--gray-400); }
</style>

