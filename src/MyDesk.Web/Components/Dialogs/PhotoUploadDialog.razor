@using MudBlazor
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_uploadStep == UploadStep.SelectFile)
        {
            <MudText Typo="Typo.h6" Class="mb-4">Select a Photo</MudText>
            
            <MudFileUpload T="IBrowserFile" OnFilesChanged="HandleFileSelected" Accept=".jpg,.jpeg,.png,.gif">
                <ButtonTemplate>
                    <MudButton HtmlTag="label" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Rounded.CloudUpload" FullWidth="true">
                        Choose File
                    </MudButton>
                </ButtonTemplate>
            </MudFileUpload>

            @if (!string.IsNullOrEmpty(_previewUrl))
            {
                <div class="mt-4">
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Preview</MudText>
                    <img src="@_previewUrl" alt="Preview" style="max-width: 100%; max-height: 300px;" />
                </div>
            }
        }
        else if (_uploadStep == UploadStep.Crop)
        {
            <MudText Typo="Typo.h6" Class="mb-4">Crop Your Photo</MudText>
            <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-3">
                Adjust the crop to show your face centered. The photo will be automatically made square.
            </MudText>

            @if (!string.IsNullOrEmpty(_previewUrl))
            {
                <div class="crop-container mb-4">
                    <img src="@_previewUrl" alt="Crop Preview" style="max-width: 100%; max-height: 400px;" />
                </div>
            }

            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                The photo will be converted to a square and displayed as a circular avatar in your profile.
            </MudAlert>
        }
        else if (_uploadStep == UploadStep.Uploading)
        {
            <div class="text-center">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mt-4">Uploading and processing your photo...</MudText>
            </div>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="CancelAsync">Cancel</MudButton>
        
        @if (_uploadStep == UploadStep.SelectFile)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="() => _uploadStep = UploadStep.Crop" Disabled="string.IsNullOrEmpty(_previewUrl)">
                Next
            </MudButton>
        }
        else if (_uploadStep == UploadStep.Crop)
        {
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="UploadPhotoAsync">
                Upload Photo
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance? MudDialog { get; set; }

    private enum UploadStep { SelectFile, Crop, Uploading }
    private UploadStep _uploadStep = UploadStep.SelectFile;
    private string? _previewUrl;
    private IBrowserFile? _selectedFile;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;

        try
        {
            var stream = _selectedFile.OpenReadStream(maxAllowedSize: 5242880);
            var bytes = new byte[_selectedFile.Size];
            await stream.ReadAsync(bytes);
            
            _previewUrl = $"data:{_selectedFile.ContentType};base64,{Convert.ToBase64String(bytes)}";
            await stream.DisposeAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading file: {ex.Message}", Severity.Error);
            _selectedFile = null;
            _previewUrl = null;
        }
    }

    private async Task UploadPhotoAsync()
    {
        if (_selectedFile == null)
        {
            Snackbar.Add("Please select a photo", Severity.Warning);
            return;
        }

        _uploadStep = UploadStep.Uploading;

        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = _selectedFile.OpenReadStream(maxAllowedSize: 5242880);
            using var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(_selectedFile.ContentType);
            content.Add(streamContent, "photo", _selectedFile.Name);

            var response = await Http.PostAsync("/api/user/profile/photo/upload", content);

            if (response.IsSuccessStatusCode)
            {
                MudDialog?.Close(DialogResult.Ok(true));
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Upload failed: {error}", Severity.Error);
                _uploadStep = UploadStep.Crop;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error uploading photo: {ex.Message}", Severity.Error);
            _uploadStep = UploadStep.Crop;
        }
    }

    private async Task CancelAsync()
    {
        await MudDialog?.CancelAsync() ?? Task.CompletedTask;
    }
}

<style>
.crop-container {
    border: 2px dashed var(--mud-palette-primary);
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 300px;
    background-color: rgba(25, 118, 210, 0.05);
}
</style>
